@using OperationalWorkspaceApplication.DTOs
@using Microsoft.FluentUI.AspNetCore.Components
@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons
@using FluentOrientation = Microsoft.FluentUI.AspNetCore.Components.Orientation

@inject IJSRuntime JS

<FluentCard Style="margin-bottom: 10px;">
    <FluentStack Orientation="FluentOrientation.Horizontal" Justify="JustifyContent.SpaceBetween">
        @* FIX: Using 'Header' which is universally available in the Enum *@
        <FluentLabel Typo="Typography.Header">Linked Documents</FluentLabel>
        <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.ArrowUpload())">
            Upload
        </FluentButton>
    </FluentStack>

    <FluentDivider Style="margin: 10px 0;" />

    @if (_documents == null || !_documents.Any())
    {
        <FluentLabel Typo="Typography.Body">No documents found.</FluentLabel>
    }
    else
    {
        <div style="max-height: 200px; overflow-y: auto;">
            @foreach (var doc in _documents)
            {
                <div style="display: flex; align-items: center; padding: 8px 0; border-bottom: 1px solid #fafafa;">
                    <FluentIcon Value="@GetIcon(doc.Extension)" Color="Color.Accent" />
                    <div style="margin-left: 10px; flex-grow: 1;">
                        <FluentLabel Typo="Typography.Body" Style="font-weight: 600; display: block;">
                            @doc.Name
                        </FluentLabel>
                        @* FIX: Using Body with smaller font-size to mimic a 'Caption' *@
                        <FluentLabel Typo="Typography.Body" Style="font-size: 0.75rem; color: gray; display: block;">
                            @doc.CreatedDate.ToShortDateString() • @doc.Size
                        </FluentLabel>
                    </div>
                    <FluentButton Appearance="Appearance.Stealth"
                                  IconStart="@(new Icons.Regular.Size16.ArrowDownload())"
                                  OnClick="@(() => DownloadFile(doc.Name))" />
                </div>
            }
        </div>
    }
</FluentCard>

@code {
    private List<DocumentDto> _documents = new()
    {
        new DocumentDto { Name = "Invoice_INV001.pdf", Extension = "pdf", Size = "145 KB", CreatedDate = DateTime.Now.AddDays(-2) },
        new DocumentDto { Name = "Quote_QTE99.pdf", Extension = "pdf", Size = "210 KB", CreatedDate = DateTime.Now.AddDays(-5) },
        new DocumentDto { Name = "CustomerContract.docx", Extension = "docx", Size = "1.2 MB", CreatedDate = DateTime.Now.AddMonths(-1) }
    };

    private Icon GetIcon(string ext) => ext.ToLower() switch
    {
        "pdf" => new Icons.Regular.Size24.DocumentPdf(),
        "docx" => new Icons.Regular.Size24.DocumentEdit(),
        _ => new Icons.Regular.Size24.Document()
    };

    private void DownloadFile(string fileName) => Console.WriteLine($"Downloading: {fileName}");
}
