@page "/workspace/businesspartners"
@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceUI.Components.Pages.Forms.FormComponents
@using OperationalWorkspaceUI.Components.Pages.Workspace.WorkspaceComponents
@using OperationalWorkspaceUI.UIServices.System
@using OperationalWorkspaceUI.UIServices.Workspace

@inject BusinessPartnerUIService BPService
@inject WorkspaceState WorkspaceState
@inject NavigationService NavigationService
@inject NotificationService NotificationService

<h3>Business Partners</h3>

<WorkspaceHeader Title="Business Partners" Subtitle="Manage clients and contacts" />

<WorkspaceToolbar>
    <button class="btn btn-primary" @onclick="Create">+ New Client</button>
    <button class="btn btn-outline-secondary" @onclick="Refresh">Refresh</button>
</WorkspaceToolbar>

<WorkspaceFilters>
    <FormField Label="Search" @bind-Value="SearchQuery" />
</WorkspaceFilters>

<BpGrid TItem="ClientDTO"
        Items="FilteredClients"
        IsLoading="IsLoading"
        OnRowClick="@(client => Open(client))">
    <HeaderContent>
        <th>Code</th>
        <th>Name</th>
        <th>Email</th>
        <th>Status</th>
        <th class="text-end">Revenue</th>
    </HeaderContent>
    <RowTemplate Context="client">
        <td><span class="badge bg-light text-dark">@client.ClientCode</span></td>
        <td><strong>@client.Name</strong></td>
        <td>@client.Email</td>
        <td>
            <span class="badge @(client.Status == "Active" ? "bg-success" : "bg-secondary")">
                @client.Status
            </span>
        </td>
        <td class="text-end">@client.TotalRevenue.ToString("C")</td>
    </RowTemplate>
</BpGrid>

@code {
    private string SearchQuery = string.Empty;
    private bool IsLoading = true;

    private IEnumerable<ClientDTO> FilteredClients =>
        (WorkspaceState.Clients ?? Enumerable.Empty<ClientDTO>())
            .Where(c => string.IsNullOrWhiteSpace(SearchQuery)
                     || c.Name.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
                     || c.ClientCode.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        IsLoading = true;
        await BPService.LoadClientsAsync();
        IsLoading = false;
    }

    private async Task Refresh()
    {
        await LoadData();
        await NotificationService.Success("Clients refreshed");
    }

    private void Create() => NavigationService.NavigateTo("/forms/create-client");

    private void Open(ClientDTO client) =>
        NavigationService.NavigateTo($"/workspace/businesspartners/{client.Id}");
}
