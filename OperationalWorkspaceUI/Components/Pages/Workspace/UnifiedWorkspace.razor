<!-- ========================================================= -->

@page "/workspace"

@using OperationalWorkspaceUI.Components.Email
@using OperationalWorkspaceUI.Components.Pages.Dashboard
@using OperationalWorkspaceUI.Components.Pages.Workspace
@using OperationalWorkspaceUI.Components.Pages.Forms
@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceUI.Components.Pages.Workspace.WorkspaceComponents

@inject OperationalWorkspaceUI.State.UIState
@inject WorkspaceState WorkspaceState
@inject NotificationService NotificationService
@inject OperationalWorkspaceUI.State.UIState UIState

<div class="workspace-container @(UIState.CurrentTheme)">

    <!-- ================= LEFT PANEL ================= -->
    <aside class="context-panel">

        <!-- EMAIL CONTEXT -->
        <section class="panel-section">
            <h3>Email Context</h3>
            <EmailContextPanel />
        </section>

        <!-- CRM SNAPSHOT -->
        <section class="panel-section">
            <h3>Customer</h3>
            <CrmPanel />
        </section>

        <!-- QUICK ACTIONS -->
        <section class="panel-section">
            <h3>Quick Actions</h3>
            <QuickActionsPanel />
        </section>

        <!-- TASKS -->
        <section class="panel-section">
            <h3>Tasks</h3>
            <TasksPanel />
        </section>

        <!-- ACTIVITY -->
        <section class="panel-section">
            <h3>Activity</h3>
            <RecentActivityPanel />
        </section>

    </aside>


    <!-- ================= RIGHT PANEL ================= -->
    <main class="main-dashboard">

        <!-- KPI STRIP -->
        <section class="kpi-row">
            <KpiWidget Title="Revenue" Value="@DashboardData.Revenue" />
            <KpiWidget Title="Open Orders" Value="@DashboardData.OpenOrders" />
            <KpiWidget Title="Invoices Due" Value="@DashboardData.InvoicesDue" />
        </section>

        <!-- CORE DASHBOARD GRID -->
        <section class="dashboard-grid">

            <!-- SALES ORDERS -->
            <div class="dashboard-card">
                <h4>Sales Orders</h4>
                <SalesOrders />
            </div>

            <!-- QUOTES -->
            <div class="dashboard-card">
                <h4>Quotes</h4>
                <Quotes />
            </div>

            <!-- DOCUMENTS -->
            <div class="dashboard-card">
                <h4>Documents</h4>
                <DocumentsPanel />
            </div>

            <!-- TASKS & APPROVALS -->
            <div class="dashboard-card">
                <h4>Tasks & Approvals</h4>
                <TasksPanel />
            </div>

        </section>

    </main>

</div>


@code {

    /* =========================================================
       PRODUCTION NOTE:
       Replace with API-driven data via Application layer
    ========================================================= */

    private DashboardDto DashboardData = new()
    {
        Revenue = 125000,
        OpenOrders = 42,
        InvoicesDue = 18
    };

}

