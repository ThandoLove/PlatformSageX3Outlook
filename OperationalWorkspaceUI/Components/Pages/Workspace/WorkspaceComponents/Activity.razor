@page "/workspace/activities"
@rendermode InteractiveServer

@using OperationalWorkspaceUI.Components.Pages.Workspace.WorkspaceComponents
@using OperationalWorkspaceUI.State
@using Microsoft.FluentUI.AspNetCore.Components
@inject DashboardState DashboardState
@inject OperationalWorkspaceUI.UIServices.Workspace.ActivityUIService ActivityService

<div class="workspace-container" style="padding: 20px; background-color: #f4f7f9; min-height: 100vh;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <div>
            <h2 style="margin: 0; color: #003366; font-weight: 600;">Activity Log</h2>
            <p style="margin: 0; color: #64748b; font-size: 0.9rem;">System-wide activity tracking</p>
        </div>
        <FluentButton Appearance="Appearance.Outline"
                      @* FIX: Use ArrowClockwise which is the standard Size20 Refresh icon *@
                      IconStart="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.ArrowClockwise())"
                      OnClick="Reload">
            Refresh
        </FluentButton>
    </div>

    @if (DashboardState.RecentActivities == null)
    {
        <div style="display: flex; justify-content: center; padding: 50px;">
            <FluentProgressRing />
        </div>
    }
    else if (!DashboardState.RecentActivities.Any())
    {
        <div style="text-align:center; padding: 40px;">
            <p>No activity found.</p>
        </div>
    }
    else
    {
        <ActivityGrid Data="DashboardState.RecentActivities" />
    }
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        await Reload();
    }

    private async Task Reload()
    {
        var logs = await ActivityService.GetActivitiesAsync();
        DashboardState.RecentActivities = logs;
        StateHasChanged();
    }
}
