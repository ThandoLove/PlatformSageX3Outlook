@page "/activities"
@rendermode InteractiveServer

@using OperationalWorkspaceUI.State
@inject DashboardState DashboardState
@inject OperationalWorkspaceUI.UIServices.Workspace.ActivityUIService ActivityService

@* REMOVED: workspace-container and 100vh styles to prevent layout clashing *@
<div style="padding: 24px;">
    
    @* HEADER SECTION *@
    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 24px;">
        <div>
            <h2 style="margin: 0; color: #1e293b; font-size: 1.75rem; font-weight: 700;">Activity Log</h2>
            <p style="margin: 4px 0 0 0; color: #64748b;">System-wide activity tracking</p>
        </div>
        <FluentButton Appearance="Appearance.Outline"
                      IconStart="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.ArrowClockwise())"
                      OnClick="Reload">
            Refresh
        </FluentButton>
    </div>

    @* DATA LOADING LOGIC *@
    @if (DashboardState.RecentActivities == null)
    {
        <div style="display: flex; justify-content: center; padding: 100px;">
            <FluentProgressRing />
        </div>
    }
    else if (!DashboardState.RecentActivities.Any())
    {
        <FluentCard Style="padding: 40px; text-align: center;">
            <p style="color: #64748b;">No activities found in the system log.</p>
        </FluentCard>
    }
    else
    {
        <ActivityGrid Data="DashboardState.RecentActivities" />
    }
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        // Load data on start
        await Reload();
    }

    private async Task Reload()
    {
        DashboardState.RecentActivities = await ActivityService.GetActivitiesAsync();
        StateHasChanged();
    }
}
