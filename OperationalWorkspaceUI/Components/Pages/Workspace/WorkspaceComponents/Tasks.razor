@page "/tasks"
@rendermode InteractiveServer
@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceApplication.Mappers
@using OperationalWorkspaceUI.State
@inject WorkspaceState State

<div class="sage-app">
    <!-- 1. TOP HEADER: ALEX TURNER SECTION -->
    <header class="sage-header">
        <div class="user-block">
            <div class="avatar-ring">
                <img src="images/alex_turner.png" alt="Alex Turner" />
                <span class="online-dot"></span>
            </div>
            <div class="u-text">
                <span class="u-name">Alex Turner</span>
                <span class="u-role">UX Designer | UX Design</span>
            </div>
        </div>

        <!-- INTEGRATED SEARCH COMPONENT -->
        <div class="search-pill">
            <i class="oi oi-magnifying-glass search-icon"></i>
            <input type="text"
                   value="@SearchQuery"
                   @oninput="OnSearch"
                   placeholder="Search across Outlook & Sage X3..." />
            <i class="oi oi-chevron-bottom dropdown-icon"></i>
        </div>
    </header>

    <main class="sage-body">
        <!-- 2. LEFT COLUMN: THE TASKS HUB -->
        <section class="hub-main-container">
            @* TaskGrid handles Hub Title, Tabs, and the 4-column cards *@
            <TaskGrid Tasks="FilteredTasks"
                      OnTaskSelected="HandleTaskSelection" />
        </section>

        <!-- 3. RIGHT COLUMN: THE SIDEBAR -->
        <aside class="details-sidebar">
            @* TaskDetailsPanel handles Aging Charts, Delegate, and Workload *@
            <TaskDetailsPanel Task="SelectedTask" />
        </aside>
    </main>
</div>

@code {
    private string SearchQuery = "";
    private TaskDto? SelectedTask;

    // REACTIVE FILTERING LOGIC
    private List<TaskDto> FilteredTasks => State.Tasks
        .Where(t => string.IsNullOrWhiteSpace(SearchQuery) ||
                    t.Title.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) ||
                    t.CompanyName?.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) == true)
        .ToList();

    private void OnSearch(ChangeEventArgs e) => SearchQuery = e.Value?.ToString() ?? "";

    private void HandleTaskSelection(TaskDto task) => SelectedTask = task;

    protected override async Task OnInitializedAsync()
    {
        // Load the 5 image-specific dummy tasks if list is empty
        if (State.Tasks == null || State.Tasks.Count == 0)
        {
            await State.LoadTasksAsync();
        }
        
        // Auto-select the first task (Inquiry about Product XYZ) to fill sidebar
        SelectedTask = State.Tasks?.FirstOrDefault();
    }
}
