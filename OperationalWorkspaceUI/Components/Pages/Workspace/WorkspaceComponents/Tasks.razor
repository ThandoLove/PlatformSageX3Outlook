@page "/tasks"
@rendermode InteractiveServer
@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceApplication.Mappers
@using OperationalWorkspaceUI.State
@inject WorkspaceState State

<div class="sage-app">
    <!-- TOP HEADER -->
    <header class="sage-header">
        <div class="user-block">
            <div class="avatar-ring">
                <img src="images/alex_turner.png" alt="Alex Turner" />
                <span class="online-dot"></span>
            </div>
            <div class="u-text">
                <span class="u-name">Alex Turner</span>
                <span class="u-role">UX Designer | UX Design</span>
            </div>
        </div>
        <div class="search-pill">
            <i class="oi oi-magnifying-glass search-icon"></i>
            <input type="text" @bind="SearchQuery" @bind:event="oninput" placeholder="Search..." />
        </div>
    </header>

    <main class="sage-body">
        <section class="hub-main-container">
            <!-- 🔥 THE CONNECTION FIX: ActiveTab + OnTabChanged -->
            <TaskGrid Tasks="FilteredTasks"
                      ActiveTab="@CurrentTab"
                      OnTabChanged="HandleTabChange"
                      OnTaskSelected="t => SelectedTask = t" />
        </section>

        <aside class="details-sidebar">
            <TaskDetailsPanel Task="SelectedTask" />
        </aside>
    </main>
</div>

@code {
    private string SearchQuery = "";
    private string CurrentTab = "Today (6)";
    private TaskDto? SelectedTask;

    // 🔥 DYNAMIC FILTER: Re-runs every time CurrentTab or SearchQuery changes
    private List<TaskDto> FilteredTasks => State.Tasks
        .Where(t =>
        {
            if (CurrentTab == "All") return true;
            if (CurrentTab.Contains("Today")) return t.DueDate?.Date == DateTime.Today && !t.Completed;
            if (CurrentTab == "Overdue") return TaskRulesEngine.IsOverdue(t);
            if (CurrentTab == "Upcoming") return t.DueDate?.Date > DateTime.Today && !t.Completed;
            if (CurrentTab == "Completed") return t.Completed;
            return true;
        })
        .Where(t => string.IsNullOrWhiteSpace(SearchQuery) || t.Title.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase))
        .ToList();

    // 🔥 THE BRIDGE: Receives the click from the grid and wakes up the UI
    private void HandleTabChange(string newTab)
    {
        CurrentTab = newTab;
        StateHasChanged(); // Forces the UI to push the new 'FilteredTasks' to the Grid
    }

    protected override async Task OnInitializedAsync()
    {
        if (State.Tasks.Count == 0) await State.LoadTasksAsync();
        SelectedTask = State.Tasks.FirstOrDefault();
    }
}
