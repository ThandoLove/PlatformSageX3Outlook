@page "/tasks"
@rendermode InteractiveServer
@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceApplication.Mappers
@using OperationalWorkspaceUI.State
@inject WorkspaceState State

<div class="sage-app">
    <!-- 1. TOP HEADER: ALEX TURNER SECTION -->
    <header class="sage-header">
        <div class="user-block">
            <div class="avatar-ring">
                <img src="images/alex_turner.png" alt="Alex Turner" />
                <span class="online-dot"></span>
            </div>
            <div class="u-text">
                <span class="u-name">Alex Turner</span>
                <span class="u-role">UX Designer | UX Design</span>
            </div>
        </div>

        <!-- INTEGRATED SEARCH COMPONENT -->
        <div class="search-pill">
            <i class="oi oi-magnifying-glass search-icon"></i>
            <input type="text"
                   @bind="SearchQuery"
                   @bind:event="oninput"
                   placeholder="Search across Outlook & Sage X3..." />
            <i class="oi oi-chevron-bottom dropdown-icon"></i>
        </div>
    </header>

    <main class="sage-body">
        <!-- 2. LEFT COLUMN: THE TASKS HUB -->
        <section class="hub-main-container">
            @* FIX: Removed Tasks="State.Tasks" because TaskGrid now gets data from State internally *@
            <TaskGrid SearchQuery="@SearchQuery"
                      OnTaskSelected="HandleTaskSelection" />
        </section>

        <!-- 3. RIGHT COLUMN: THE SIDEBAR -->
        <aside class="details-sidebar">
            <TaskDetailsPanel Task="SelectedTask" />
        </aside>
    </main>
</div>

@code {
    private string SearchQuery = "";
    private TaskDto? SelectedTask;

    private void HandleTaskSelection(TaskDto task)
    {
        SelectedTask = task;
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        if (State.Tasks == null || State.Tasks.Count == 0)
        {
            await State.LoadTasksAsync();
        }
        
        // Match the initial tab filter
        SelectedTask = State.Tasks?.FirstOrDefault(t => t.DueDate?.Date == DateTime.Today);
    }
}
