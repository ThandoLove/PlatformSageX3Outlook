@page "/attachments"
@rendermode InteractiveServer

@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceUI.State
@using OperationalWorkspaceUI.Components.Shared
@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons

@inject WorkspaceState State
@inject NavigationManager Nav
@inject HttpClient Http
@inject IJSRuntime JSRuntime

<div class="attach-container">
    @* HEADER *@
    <div class="page-title-header">
        <h1 class="page-title">Documents</h1>
    </div>

    @* TOP BAR *@
    <div class="top-bar">
        <div class="header-left-actions">
            <div class="search-box">
                <FluentIcon Value="@(new Icons.Regular.Size16.Search())" Color="Color.Neutral" />
                <input type="text" placeholder="Search Documents..." @bind="SearchQuery" @bind:event="oninput" />
            </div>

            <div class="filter-dropdowns">
                <select @bind="SelectedType" class="ui-select">
                    <option value="All">Type</option>
                    <option value="Proposal">Proposal</option>
                    <option value="Invoice">Invoice</option>
                    <option value="Contract">Contract</option>
                </select>
                <select class="ui-select"><option>Date</option></select>
                <select class="ui-select"><option>Category</option></select>
            </div>
        </div>

        <div class="upload-wrapper">
            <InputFile id="fileInput" OnChange="HandleFileUpload" class="hidden-file" disabled="@State.IsUploading" />
            <label for="fileInput" class="btn-upload-primary @(State.IsUploading ? "is-disabled" : "")">
                @if (State.IsUploading)
                {
                    <FluentProgressRing Class="upload-ring" />
                    <span class="upload-text">Uploading...</span>
                }
                else
                {
                    <FluentIcon Value="@(new Icons.Regular.Size16.ArrowUpload())" Color="Color.Fill" />
                    <span>Upload</span>
                }
            </label>
        </div>
    </div>

    <div class="main-layout">
        @* LEFT: DOCUMENT LIST *@
        <div class="document-list-pane">
            <div class="pane-header">
                <span class="title">Document List</span>
            </div>

            <div class="table-wrapper">
                <table class="ui-table">
                    <thead>
                        <tr>
                            <th><input type="checkbox" /></th>
                            <th>Name</th>
                            <th>Type</th>
                            <th>Size</th>
                            <th>Related To</th>
                            <th class="text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var doc in PaginatedDocs)
                        {
                            <tr class="@(SelectedDoc?.Id == doc.Id ? "is-selected" : "")" @onclick="() => SelectedDoc = doc">
                                <td><input type="checkbox" @onclick:stopPropagation /></td>
                                <td>
                                    <div class="file-name-cell">
                                        <FluentIcon Value="@GetIcon(doc.FileName)" Color="Color.Error" />
                                        <span>@doc.FileName</span>
                                    </div>
                                </td>
                                <td>@doc.ContentType</td>
                                <td>@FormatSize(doc.FileSize)</td>
                                <td><span class="related-pill">@doc.RelatedEntity</span></td>
                                <td class="text-right">
                                    <div class="action-row">
                                        <button class="btn-preview-ghost" @onclick:stopPropagation @onclick="() => SelectedDoc = doc">Preview</button>
                                        <button class="btn-attach-teal" @onclick:stopPropagation @onclick="() => HandleAttachDocument(doc)">Attach</button>
                                        <button class="btn-delete-ghost" @onclick:stopPropagation @onclick="() => DeleteDocument(doc)">
                                            <FluentIcon Value="@(new Icons.Regular.Size16.Delete())" Color="Color.Error" />
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="list-footer">
                <button class="btn-sage-browse" @onclick="BrowseSageX3">Browse Sage X3 →</button>
                <div class="pagination">
                    <button class="ui-select" disabled="@(CurrentPage == 1)" @onclick="() => CurrentPage--">Prev</button>
                    <span class="pagination-info">@CurrentPage of @TotalPages</span>
                    <button class="ui-select" disabled="@(CurrentPage == TotalPages)" @onclick="() => CurrentPage++">Next</button>
                </div>
            </div>
        </div>
        @* RIGHT: PREVIEW PANE *@
        <div class="document-preview-pane" style="box-shadow: none; border-left: 1px solid #f1f5f9;">
            <div class="pane-header">
                <span class="title">Document Preview</span>
                @if (SelectedDoc != null)
                {
                    <FluentIcon Value="@(new Icons.Regular.Size16.Dismiss())" @onclick="() => SelectedDoc = null" Class="dismiss-icon" />
                }
            </div>

            @if (SelectedDoc != null)
            {
                <div class="preview-info" style="box-shadow: none;">
                    <div class="preview-hero">
                        <FluentIcon Value="@GetIcon(SelectedDoc.FileName)" Class="preview-icon" Color="Color.Error" />
                        <span class="hero-filename">@SelectedDoc.FileName</span>
                    </div>
                    <div class="preview-meta">Version 1.0 — @FormatSize(SelectedDoc.FileSize)</div>

                    <div class="detail-grid">
                        <div class="detail-row"><label>Type</label><span>@SelectedDoc.ContentType</span></div>
                        <div class="detail-row"><label>Source</label><span>Local</span></div>
                        <div class="detail-row"><label>Date</label><span>@SelectedDoc.UploadedAtUtc.ToShortDateString()</span></div>
                    </div>

                    @if (SelectedDoc.FileName.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
                    {
                        <div class="pdf-preview-container" style="margin-top: 15px; width: 100%; border: none; border-radius: 4px; overflow: hidden; background: #ffffff; box-shadow: none;">
                            <iframe src="@GetPdfUrl(SelectedDoc)"
                                    style="width: 100%; height: 680px; border: none; overflow: hidden; display: block;"
                                    scrolling="no">
                            </iframe>
                        </div>
                    }

                    @* RELATED RECORDS SECTION *@
                    <div class="related-records" style="margin-top: 15px;">
                        <RelatedRecordsPanel Title="Linked Order"
                                             Records="@(new List<string> { SelectedDoc.RelatedEntity })"
                                             OnRecordClicked="@((n) => OpenPdfPreviewAsync())" />

                        <RelatedRecordsPanel Title="Linked Tasks"
                                             Records="@State.Tasks.Where(t => t.Title.Contains(SelectedDoc.FileName)).Select(t => t.Title).ToList()"
                                             OnRecordClicked="@((n) => Nav.NavigateTo("/activities"))" />
                    </div>

                    <button class="btn-attach-full" @onclick="() => HandleAttachDocument(SelectedDoc)" style="margin-top: 15px;">Attach to Record</button>
                    <button class="btn-delete-full" @onclick="() => DeleteDocument(SelectedDoc)">Delete</button>
                </div>
            }
            else
            {
                <div class="preview-empty">
                    <FluentIcon Value="@(new Icons.Regular.Size32.DocumentSearch())" />
                    <p>Select a file to preview</p>
                </div>
            }
        </div>
    </div>
</div>
@code {
    private string SearchQuery = "";
    private string SelectedType = "All";
    private int CurrentPage = 1;
    private int PageSize = 10;
    private AttachmentDto? SelectedDoc;

    private IEnumerable<AttachmentDto> FilteredData => State.Attachments
        .Where(d => (SelectedType == "All" || d.ContentType == SelectedType) &&
                    (string.IsNullOrWhiteSpace(SearchQuery) || d.FileName.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)));

    private IEnumerable<AttachmentDto> PaginatedDocs => FilteredData.Skip((CurrentPage - 1) * PageSize).Take(PageSize);
    private int TotalPages => (int)Math.Ceiling((double)FilteredData.Count() / PageSize);

    // 1. HORIZONTAL ARROW ROUTE LINK (Maps to Pic 4 Stream)
    private void OpenPdfPreviewAsync()
    {
        if (SelectedDoc == null)
            return;

        // Redirects directly to your standalone streaming route layout
        Nav.NavigateTo($"/attachments/{SelectedDoc.Id}");
    }

    private string GetPdfUrl(AttachmentDto doc)
    {
        if (doc == null)
            return string.Empty;

        string webOptions = "#toolbar=0&navpanes=0&statusbar=0&messages=0&scrollbar=0";

        // TOGGLE SWITCH: Set to true once backend handles live production ERP routing tasks
        bool isProductionStreamingServiceLive = false;

        if (isProductionStreamingServiceLive)
        {
            // Matches your 4th Swagger picture path exactly
            return $"/api/v1/Attachment/stream/{doc.Id}{webOptions}";
        }

        return $"/mock-documents/{doc.FileName}{webOptions}";
    }

    // 2. FILE INPUT UPLOAD ACTION (Maps to Pic 1 upload-file multipart form-data)
    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        State.SetUploading(true);

        try
        {
            using var content = new MultipartFormDataContent();
            var fileStream = file.OpenReadStream(10 * 1024 * 1024);
            var streamContent = new StreamContent(fileStream);
            streamContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);

            // Name must match the Swagger form field name "file" exactly
            content.Add(streamContent, "file", file.Name);

            // Calls your Pic 1 endpoint route
            var response = await Http.PostAsync($"api/v1/Attachment/upload-file?ownerId=Tia&ownerType=DocumentList", content);

            if (response.IsSuccessStatusCode)
            {
                var newDoc = new AttachmentDto(Guid.NewGuid(), file.Name, file.ContentType, file.Size, "#", "Unlinked", DateTime.UtcNow);
                State.Attachments.Insert(0, newDoc);
                SelectedDoc = newDoc;

                State.LogActivity(file.Name, "Uploaded Document", "Tia");
                State.Notify();
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Upload network failure: {ex.Message}");
        }
        finally
        {
            State.SetUploading(false);
        }
    }

    // 3. ATTACH TO RECORD JSON ACTION (Maps to Pic 2 /upload endpoint application/json)
    private async Task HandleAttachDocument(AttachmentDto? doc)
    {
        if (doc == null) return;

        try
        {
            // Builds the exact JSON request body structure seen in your 2nd Swagger picture
            var requestBody = new
            {
                ownerType = "SageX3OrderContext",
                ownerId = doc.RelatedEntity,
                fileName = doc.FileName,
                contentType = doc.ContentType,
                fileSize = doc.FileSize,
                storagePath = $"/mock-documents/{doc.FileName}"
            };

            // Posts clean JSON data directly to your Pic 2 upload endpoint
            var response = await Http.PostAsJsonAsync("api/v1/Attachment/upload", requestBody);

            if (response.IsSuccessStatusCode)
            {
                State.LogActivity(doc.FileName, $"Attached to ERP ({doc.RelatedEntity})", "Tia");
                State.Notify();
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"ERP link configuration fault: {ex.Message}");
        }
    }

    // 4. BROWSE SAGE INDEX ACTION (Maps to Pic 3 /list GET route query parameters)
    private async Task BrowseSageX3()
    {
        try
        {
            // Calls your Pic 3 endpoint passing required parameters via the query string
            var response = await Http.GetAsync("api/v1/Attachment/list?ownerType=SageGlobalIndex&ownerId=All");

            if (response.IsSuccessStatusCode)
            {
                // Instantly pushes a clean record entry onto your Activity tracking page log
                State.LogActivity("Sage Server Repository", "Queried ERP Document Index", "Tia");
                State.Notify();
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Sage browsing lookup error: {ex.Message}");
        }
    }

    private async Task DeleteDocument(AttachmentDto? doc)
    {
        if (doc == null) return;

        State.Attachments.Remove(doc);
        if (SelectedDoc?.Id == doc.Id) SelectedDoc = null;

        State.LogActivity(doc.FileName, "Deleted Document", "Tia");
        State.Notify();
    }

    private string FormatSize(long bytes) => bytes < 1048576 ? $"{(bytes / 1024.0):F1} KB" : $"{(bytes / 1048576.0):F1} MB";

    private Icon GetIcon(string filename)
    {
        if (filename.EndsWith(".pdf")) return new Icons.Regular.Size20.DocumentPdf();
        return new Icons.Regular.Size20.Document();
    }
}

