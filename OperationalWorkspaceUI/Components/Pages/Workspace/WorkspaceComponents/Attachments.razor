@page "/attachments"
@rendermode InteractiveServer

@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceUI.State
@using OperationalWorkspaceUI.Components.Shared
@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons

@inject WorkspaceState State
@inject NavigationManager Nav
@inject HttpClient Http

<div class="attach-container">
    @* HEADER *@
    <div class="page-title-header">
        <h1 style="font-weight: 800; color: #002d5a; border-bottom: 3px solid #002d5a; padding-bottom: 8px;">Documents</h1>
    </div>

    @* TOP BAR *@
    <div class="top-bar">
        <div class="header-left-actions">
            <div class="search-box">
                <FluentIcon Value="@(new Icons.Regular.Size16.Search())" Color="Color.Neutral" />
                <input type="text" placeholder="Search Documents..." @bind="SearchQuery" @bind:event="oninput" />
            </div>
            
            <div class="filter-dropdowns">
                <select @bind="SelectedType" class="ui-select">
                    <option value="All">Type</option>
                    <option value="Proposal">Proposal</option>
                    <option value="Invoice">Invoice</option>
                    <option value="Contract">Contract</option>
                </select>
                <select class="ui-select"><option>Date</option></select>
                <select class="ui-select"><option>Category</option></select>
            </div>
        </div>

        <div class="upload-wrapper">
            <InputFile id="fileInput" OnChange="HandleFileUpload" style="display:none" disabled="@State.IsUploading" />
            <label for="fileInput" class="btn-upload-primary" style="cursor: @(State.IsUploading ? "not-allowed" : "pointer"); opacity: @(State.IsUploading ? "0.6" : "1")">
                @if (State.IsUploading)
                {
                    <FluentProgressRing Style="width: 16px; height: 16px; margin-right: 8px;" />
                    <span>Uploading...</span>
                }
                else
                {
                    <FluentIcon Value="@(new Icons.Regular.Size16.ArrowUpload())" Color="Color.Fill" />
                    <span>Upload</span>
                }
            </label>
        </div>
    </div>

    <div class="main-layout">
        @* LEFT: DOCUMENT LIST *@
        <div class="document-list-pane">
            <div class="pane-header">
                <span class="title">Document List</span>
            </div>

            <div class="table-wrapper">
                <table class="ui-table">
                    <thead>
                        <tr>
                            <th><input type="checkbox" /></th>
                            <th>Name</th>
                            <th>Type</th>
                            <th>Size</th>
                            <th>Related To</th>
                            <th class="text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var doc in PaginatedDocs)
                        {
                            <tr class="@(SelectedDoc?.Id == doc.Id ? "is-selected" : "")" @onclick="() => SelectedDoc = doc">
                                <td><input type="checkbox" @onclick:stopPropagation /></td>
                                <td>
                                    <div class="file-name-cell">
                                        <FluentIcon Value="@GetIcon(doc.FileName)" Color="Color.Error" />
                                        <span>@doc.FileName</span>
                                    </div>
                                </td>
                                <td>@doc.ContentType</td>
                                <td>@FormatSize(doc.FileSize)</td>
                                <td><span class="related-pill">@doc.RelatedEntity</span></td>
                                <td class="text-right">
                                    <div class="action-row">
                                        <button class="btn-preview-ghost" @onclick:stopPropagation @onclick="() => SelectedDoc = doc">Preview</button>
                                        <button class="btn-attach-teal" @onclick:stopPropagation>Attach</button>
                                        <button class="btn-delete-ghost" @onclick:stopPropagation @onclick="() => DeleteDocument(doc)">
                                            <FluentIcon Value="@(new Icons.Regular.Size16.Delete())" Color="Color.Error" />
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="list-footer">
                <button class="btn-sage-browse" @onclick="BrowseSageX3">Browse Sage X3 →</button>
                <div class="pagination">
                    <button class="ui-select" disabled="@(CurrentPage == 1)" @onclick="() => CurrentPage--">Prev</button>
                    <span style="margin: 0 10px; font-size: 12px;">@CurrentPage of @TotalPages</span>
                    <button class="ui-select" disabled="@(CurrentPage == TotalPages)" @onclick="() => CurrentPage++">Next</button>
                </div>
            </div>
        </div>

        @* RIGHT: PREVIEW PANE *@
        <div class="document-preview-pane">
            <div class="pane-header">
                <span class="title">Document Preview</span>
                @if (SelectedDoc != null)
                {
                    <FluentIcon Value="@(new Icons.Regular.Size16.Dismiss())" @onclick="() => SelectedDoc = null" Style="cursor:pointer" />
                }
            </div>

            @if (SelectedDoc != null)
            {
                <div class="preview-info">
                    <div class="preview-hero">
                        <FluentIcon Value="@GetIcon(SelectedDoc.FileName)" Style="width:32px; height:32px;" Color="Color.Error" />
                        <span class="hero-filename">@SelectedDoc.FileName</span>
                    </div>
                    <div class="preview-meta">Version 1.0 — @FormatSize(SelectedDoc.FileSize)</div>
                    <div class="detail-grid">
                        <div class="detail-row"><label>Type</label><span>@SelectedDoc.ContentType</span></div>
                        <div class="detail-row"><label>Source</label><span>Local</span></div>
                        <div class="detail-row"><label>Date</label><span>@SelectedDoc.UploadedAtUtc.ToShortDateString()</span></div>
                    </div>

                    @* RELATED RECORDS SECTION *@
                    <div style="margin: 20px 0; display: flex; flex-direction: column; gap: 15px;">
                        <RelatedRecordsPanel Title="Linked Order"
                                             Records="@(new List<string> { SelectedDoc.RelatedEntity })"
                                             OnRecordClicked="@((n) => Nav.NavigateTo("/orders"))" />
                        
                        <RelatedRecordsPanel Title="Linked Tasks"
                                             Records="@State.Tasks.Where(t => t.Title.Contains(SelectedDoc.FileName)).Select(t => t.Title).ToList()"
                                             OnRecordClicked="@((n) => Nav.NavigateTo("/activities"))" />
                    </div>

                    <button class="btn-attach-full">Attach to Record</button>
                    <button class="btn-delete-full" @onclick="() => DeleteDocument(SelectedDoc)">Delete</button>
                </div>
            }
            else
            {
                <div style="display:flex; flex-direction:column; align-items:center; justify-content:center; height:100%; color:#94a3b8;">
                    <FluentIcon Value="@(new Icons.Regular.Size32.DocumentSearch())" />
                    <p>Select a file to preview</p>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private string SearchQuery = "";
    private string SelectedType = "All";
    private int CurrentPage = 1;
    private int PageSize = 10;
    private AttachmentDto? SelectedDoc;

    protected override void OnInitialized()
    {
        // Populate global state if empty
        if (State.Attachments == null || !State.Attachments.Any())
        {
            State.Attachments = new List<AttachmentDto> {
                new(Guid.NewGuid(), "QTE-7789_Proposal.pdf", "Proposal", 1240000, "#", "Quote - QTE-7789", DateTime.Now),
                new(Guid.NewGuid(), "INV-2024-00567_Invoice.pdf", "Invoice", 960000, "#", "Invoice - INV-2024-00567", DateTime.Now)
            };
        }
    }

    private IEnumerable<AttachmentDto> FilteredData => State.Attachments
        .Where(d => (SelectedType == "All" || d.ContentType == SelectedType) &&
                    (string.IsNullOrWhiteSpace(SearchQuery) || d.FileName.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)));

    private IEnumerable<AttachmentDto> PaginatedDocs => FilteredData.Skip((CurrentPage - 1) * PageSize).Take(PageSize);
    private int TotalPages => (int)Math.Ceiling((double)FilteredData.Count() / PageSize);

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        // START GLOBAL STATUS
        State.SetUploading(true);

        try
        {
            // Simulate processing time
            await Task.Delay(1500);

            var newDoc = new AttachmentDto(Guid.NewGuid(), file.Name, file.ContentType, file.Size, "#", "Unlinked", DateTime.UtcNow);
            
            State.Attachments.Insert(0, newDoc);
            SelectedDoc = newDoc;

            State.LogActivity(file.Name, "Uploaded Document", "Tia");
            State.Notify();
        }
        finally
        {
            // END GLOBAL STATUS
            State.SetUploading(false);
        }
    }

    private async Task DeleteDocument(AttachmentDto? doc)
    {
        if (doc == null) return;
        
        State.Attachments.Remove(doc);
        if (SelectedDoc?.Id == doc.Id) SelectedDoc = null;

        State.LogActivity(doc.FileName, "Deleted Document", "Tia");
        State.Notify();
    }

    private async Task BrowseSageX3()
    {
        var newDoc = new AttachmentDto(Guid.NewGuid(), "Sage_Manual.pdf", "PDF", 1048576, "sage", "Sage X3", DateTime.UtcNow);
        State.Attachments.Insert(0, newDoc);
        State.LogActivity("Sage_Manual.pdf", "Browsed Sage X3", "Tia");
        State.Notify();
    }

    private string FormatSize(long bytes) => bytes < 1048576 ? $"{(bytes / 1024.0):F1} KB" : $"{(bytes / 1048576.0):F1} MB";

    private Icon GetIcon(string filename)
    {
        if (filename.EndsWith(".pdf")) return new Icons.Regular.Size20.DocumentPdf();
        return new Icons.Regular.Size20.Document();
    }
}
