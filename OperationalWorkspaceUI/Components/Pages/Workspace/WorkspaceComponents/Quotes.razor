@page "/quotes"
@rendermode InteractiveServer

@using OperationalWorkspaceApplication.DTOs

@using OperationalWorkspaceUI.UIServices.Workspace
@using Microsoft.JSInterop

@inject OrdersUIService OrdersService
@inject WorkspaceState WorkspaceState
@inject DashboardState DashboardState
@inject NavigationManager NavManager
@inject Radzen.NotificationService NotificationService
@inject IJSRuntime JS

<div class="workspace-container quotes-root">
    <WorkspaceHeader Title="Quotes" Subtitle="Quotations reference layer synced directly with Sage X3" />
    <div class="page-container quotes-page">
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="dashboard-card p-3 text-center card-radius">
                    <div class="kpi-label">Total Quotes</div>
                    <div class="kpi-value">@TotalQuotes</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="dashboard-card p-3 text-center card-radius">
                    <div class="kpi-label label-draft">Draft</div>
                    <div class="kpi-value">@DraftCount</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="dashboard-card p-3 text-center card-radius">
                    <div class="kpi-label label-approved">Approved</div>
                    <div class="kpi-value">@ApprovedCount</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="dashboard-card p-3 text-center card-radius">
                    <div class="kpi-label label-value">Total Value</div>
                    <div class="kpi-value">@TotalValue.ToString("C0")</div>
                </div>
            </div>
        </div>
        <div class="dashboard-card shadow-sm quotes-main-card">
            <div class="d-flex justify-content-between align-items-start mb-4 quotes-header">
                <div>
                    <h2 class="quotes-title">Quotations List</h2>
                    <div class="d-flex flex-column gap-3 mt-4">
                        <div class="d-flex gap-2">
                            <div class="search-wrapper">
                                <span class="search-icon">🔍</span>
                                <input type="text" class="form-control ps-5 quotes-search-input" placeholder="Search Sage X3 Quotes..." @bind="SearchQuery" @bind:event="oninput" />
                            </div>
                            <button class="btn btn-light border d-flex align-items-center gap-2 filter-btn" @onclick="() => IsFilterOpen = !IsFilterOpen">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon>
                                </svg>
                                Filter
                            </button>
                        </div>
                        @if (IsFilterOpen)
                        {
                            <div class="filter-tray d-flex gap-3 p-3 mb-2 filter-tray-custom">
                                <div class="filter-item">
                                    <label class="filter-label">STATUS</label>
                                    <select class="form-select form-select-sm" @bind="SelectedStatus">
                                        <option value="All">All Statuses</option>
                                        <option value="Draft">Draft</option>
                                        <option value="Approved">Approved</option>
                                        <option value="Rejected">Rejected</option>
                                    </select>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div class="d-flex gap-2 header-actions">
                    <button class="btn btn-outline-secondary px-3 py-2 btn-refresh" @onclick="Refresh">Refresh</button>
                </div>
            </div>
            <div class="table-responsive mt-4">
                @if (IsLoading)
                {
                    <div class="text-center p-5"><LoadingSpinner /></div>
                }
                else
                {
                    <table class="table table-hover quote-table">
                        <thead>
                            <tr class="quote-table-head">
                                <th class="pb-3 border-0">Quote #</th>
                                <th class="pb-3 border-0">Client</th>
                                <th class="pb-3 border-0">Date</th>
                                <th class="pb-3 border-0">Amount</th>
                                <th class="pb-3 border-0">Status</th>
                                <th class="pb-3 border-0 text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var q in FilteredQuotes)
                            {
                                <tr @onclick="() => HandleRowClick(q)" class="sage-row">
                                    <td class="py-4 border-0 fw-bold order-number">@q.OrderNumber</td>
                                    <td class="py-4 border-0 client-name">@q.ClientName</td>
                                    <td class="py-4 border-0 text-muted">@(q.OrderDate?.ToString("MMM dd, yyyy") ?? "N/A")</td>
                                    <td class="py-4 border-0 fw-bold amount-col">@q.TotalAmount.ToString("C0")</td>
                                    <td class="py-4 border-0">
                                        <span class="status-pill @q.Status.ToLower()">@q.Status</span>
                                    </td>
                                    <td class="py-4 border-0 text-center">
                                        <a class="btn btn-sm btn-outline-secondary deep-link-btn" href="https://company.internal" target="_blank" @onclick:stopPropagation="true">Open in Sage X3 ↗</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>
@code {
    private bool IsLoading = true;
    private string SearchQuery = "";
    private string SelectedStatus = "All";
    private bool IsFilterOpen = false;

    private List<OpenOrderDto> QuoteList => WorkspaceState.Quotes ?? new();

    private IEnumerable<OpenOrderDto> FilteredQuotes =>
        QuoteList.Where(q =>
            (SelectedStatus == "All" || q.Status == SelectedStatus) &&
            (string.IsNullOrWhiteSpace(SearchQuery) || q.OrderNumber.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) || q.ClientName.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase))
        );

    private int TotalQuotes => QuoteList.Count;
    private int DraftCount => QuoteList.Count(q => q.Status == "Draft");
    private int ApprovedCount => QuoteList.Count(q => q.Status == "Approved");
    private decimal TotalValue => QuoteList.Sum(q => q.TotalAmount);

    protected override async Task OnInitializedAsync() => await LoadQuotes();

    private async Task LoadQuotes()
    {
        try
        {
            IsLoading = true;
            await OrdersService.LoadQuotesAsync();
            if (!QuoteList.Any())
            {
                WorkspaceState.Quotes = new List<OpenOrderDto> {
                    new() { Id = Guid.NewGuid(), OrderNumber = "SQ-7789", ClientName = "Global Solutions", OrderDate = DateTime.Now, Status = "Draft", TotalAmount = 4500m },
                    new() { Id = Guid.NewGuid(), OrderNumber = "SQ-7790", ClientName = "Tech Innovations", OrderDate = DateTime.Now.AddDays(-1), Status = "Approved", TotalAmount = 12000m }
                };
            }
        }
        finally { IsLoading = false; }
    }

    private async Task HandleRowClick(OpenOrderDto q)
    {
        await DashboardState.LoadOrderDetailsAsync(q.OrderNumber);
        NavManager.NavigateTo($"/workspace/orders/{q.Id}");
    }

    private async Task Refresh() => await LoadQuotes();
}
