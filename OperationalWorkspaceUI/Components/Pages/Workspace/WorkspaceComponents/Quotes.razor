@page "/workspace/quotes"
@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceUI.Components.Pages.Forms.FormComponents
@using OperationalWorkspaceUI.Components.Pages.Workspace.WorkspaceComponents
@using OperationalWorkspaceUI.UIServices.System
@using OperationalWorkspaceUI.UIServices.Workspace
@inject OrdersUIService OrdersService
@inject WorkspaceState WorkspaceState
@inject NavigationService NavigationService
@inject Radzen.NotificationService NotificationService

<h3>Quotes</h3>

<WorkspaceHeader Title="Quotes" Subtitle="Manage quotations lifecycle" />

<WorkspaceSummaryPanel Title="Quote Overview">
    <div class="d-flex gap-4">
        <div><strong>Total:</strong> @TotalQuotes</div>
        <div><strong>Draft:</strong> @DraftCount</div>
        <div><strong>Approved:</strong> @ApprovedCount</div>
        <div><strong>Value:</strong> @TotalValue.ToString("C")</div>
    </div>
</WorkspaceSummaryPanel>

<WorkspaceToolbar>
    <button class="btn btn-primary" @onclick="CreateQuote">+ New Quote</button>
    <button class="btn btn-outline-secondary" @onclick="Refresh">Refresh</button>
</WorkspaceToolbar>

<WorkspaceFilters>
    @* FIX: Ensure bind-value is lowercase if your component expects it *@
    <FormField Label="Search" @bind-value="SearchQuery" />
    <FormField Label="Status" Type="select" Options="StatusOptions" @bind-value="SelectedStatus" />
</WorkspaceFilters>

@if (IsLoading)
{
    <LoadingSpinner />
}
else
{
    <QuoteGrid Items="FilteredQuotes" OnView="OpenQuote" OnApprove="ApproveQuote" OnConvert="ConvertQuote" />
}

@code {
    private bool IsLoading = true;
    private string SearchQuery = "";
    private string SelectedStatus = "All";

    private List<KeyValuePair<string, string>> StatusOptions = new()
    {
        new("All", "All"), new("Draft", "Draft"), new("Approved", "Approved"), new("Rejected", "Rejected")
    };

    private List<OpenOrderDto> QuoteList => WorkspaceState.Quotes ?? new();

    private IEnumerable<OpenOrderDto> FilteredQuotes =>
        QuoteList.Where(q =>
            (string.IsNullOrWhiteSpace(SearchQuery) || q.OrderNumber.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase))
            && (SelectedStatus == "All" || q.Status == SelectedStatus)
        );

    private int TotalQuotes => QuoteList.Count;
    private int DraftCount => QuoteList.Count(q => q.Status == "Draft");
    private int ApprovedCount => QuoteList.Count(q => q.Status == "Approved");
    private decimal TotalValue => QuoteList.Sum(q => q.TotalAmount);

    protected override async Task OnInitializedAsync() => await LoadQuotes();

    private async Task LoadQuotes()
    {
        try
        {
            IsLoading = true;
            await OrdersService.LoadQuotesAsync();
        }
        catch
        {
            NotificationService.Notify(new Radzen.NotificationMessage
            {
                Severity = Radzen.NotificationSeverity.Error,
                Summary = "Error",
                Detail = "Failed to load quotes"
            });
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task Refresh()
    {
        await LoadQuotes();
        NotificationService.Notify(new Radzen.NotificationMessage
        {
            Severity = Radzen.NotificationSeverity.Success,
            Summary = "Success",
            Detail = "Quotes refreshed"
        });
    }

    private void CreateQuote() => NavigationService.NavigateTo("/forms/create-quote");
    private void OpenQuote(OpenOrderDto quote) => NavigationService.NavigateTo($"/workspace/orders/{quote.Id}");

    private async Task ApproveQuote(OpenOrderDto quote)
    {
        try
        {
            await OrdersService.ApproveQuoteAsync(quote.Id);
            NotificationService.Notify(new Radzen.NotificationMessage
            {
                Severity = Radzen.NotificationSeverity.Success,
                Summary = "Success",
                Detail = "Quote approved"
            });
            await LoadQuotes();
        }
        catch
        {
            NotificationService.Notify(new Radzen.NotificationMessage
            {
                Severity = Radzen.NotificationSeverity.Error,
                Summary = "Error",
                Detail = "Failed to approve quote"
            });
        }
    }

    private async Task ConvertQuote(OpenOrderDto quote)
    {
        try
        {
            await OrdersService.ConvertToOrderAsync(quote.Id);
            NotificationService.Notify(new Radzen.NotificationMessage
            {
                Severity = Radzen.NotificationSeverity.Success,
                Summary = "Success",
                Detail = "Converted to order"
            });
            await LoadQuotes();
        }
        catch
        {
            NotificationService.Notify(new Radzen.NotificationMessage
            {
                Severity = Radzen.NotificationSeverity.Error,
                Summary = "Error",
                Detail = "Conversion failed"
            });
        }
    }
}
