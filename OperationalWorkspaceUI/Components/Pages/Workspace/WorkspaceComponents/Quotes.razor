@page "/quotes"
@rendermode InteractiveServer

@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceUI.UIServices.System
@using OperationalWorkspaceUI.UIServices.Workspace
@using Microsoft.JSInterop

@inject OrdersUIService OrdersService
@inject WorkspaceState WorkspaceState
@inject DashboardState DashboardState
@inject NavigationManager NavManager
@inject Radzen.NotificationService NotificationService
@inject IJSRuntime JS

<div class="workspace-container" style="flex-direction: column; background: #f3f4f6; min-height: 100vh;">
    
    <WorkspaceHeader Title="Quotes" Subtitle="Manage quotations lifecycle synced with Sage X3" />

    <div class="page-container" style="padding: 24px;">
        
        @* OVERVIEW KPIS *@
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="dashboard-card p-3 text-center" style="border-radius: 10px;">
                    <div style="font-size: 0.75rem; font-weight: 800; color: #64748b; text-transform: uppercase;">Total Quotes</div>
                    <div style="font-size: 1.5rem; font-weight: 700; color: #1e293b;">@TotalQuotes</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="dashboard-card p-3 text-center" style="border-radius: 10px;">
                    <div style="font-size: 0.75rem; font-weight: 800; color: #f59e0b; text-transform: uppercase;">Draft</div>
                    <div style="font-size: 1.5rem; font-weight: 700; color: #1e293b;">@DraftCount</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="dashboard-card p-3 text-center" style="border-radius: 10px;">
                    <div style="font-size: 0.75rem; font-weight: 800; color: #10b981; text-transform: uppercase;">Approved</div>
                    <div style="font-size: 1.5rem; font-weight: 700; color: #1e293b;">@ApprovedCount</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="dashboard-card p-3 text-center" style="border-radius: 10px;">
                    <div style="font-size: 0.75rem; font-weight: 800; color: #3b82f6; text-transform: uppercase;">Total Value</div>
                    <div style="font-size: 1.5rem; font-weight: 700; color: #1e293b;">@TotalValue.ToString("C0")</div>
                </div>
            </div>
        </div>

        <div class="dashboard-card shadow-sm" style="background: #ffffff; border-radius: 12px; padding: 32px; border: 1px solid #e5e7eb;">
            
            @* HEADER & ACTIONS *@
            <div class="d-flex justify-content-between align-items-start mb-4">
                <div>
                    <h2 style="font-weight: 700; color: #111827; margin: 0; font-size: 1.5rem;">Quotations List</h2>
                    
                    <div class="d-flex flex-column gap-3 mt-4">
                        <div class="d-flex gap-2">
                            @* SEARCH BAR *@
                            <div style="width: 350px; position: relative;">
                                <span style="position: absolute; left: 16px; top: 12px; color: #94a3b8;">🔍</span>
                                <input type="text" class="form-control ps-5" 
                                       style="height: 45px; border-radius: 8px; border: 1px solid #e2e8f0;" 
                                       placeholder="Search Sage X3 Quotes..." 
                                       @bind="SearchQuery" @bind:event="oninput" />
                            </div>

                            @* FILTER TOGGLE *@
                            <button class="btn btn-light border d-flex align-items-center gap-2" 
                                    style="height: 45px; border-radius: 8px; background: white; color: #475569; font-weight: 500;"
                                    @onclick="() => IsFilterOpen = !IsFilterOpen">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon>
                                </svg>
                                Filter
                            </button>
                        </div>

                        @* WORKING FILTER TRAY *@
                        @if (IsFilterOpen)
                        {
                            <div class="filter-tray d-flex gap-3 p-3 mb-2" style="background: #f8fafc; border-radius: 8px; border: 1px solid #e2e8f0;">
                                <div class="filter-item">
                                    <label style="font-size: 0.75rem; font-weight: 700; color: #64748b; display: block; margin-bottom: 4px;">STATUS</label>
                                    <select class="form-select form-select-sm" @bind="SelectedStatus">
                                        <option value="All">All Statuses</option>
                                        <option value="Draft">Draft</option>
                                        <option value="Approved">Approved</option>
                                        <option value="Rejected">Rejected</option>
                                    </select>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button class="btn btn-outline-secondary px-3 py-2" style="border-radius: 6px; font-weight: 600;" @onclick="Refresh">
                        Refresh
                    </button>
                    <button class="btn btn-primary px-4 py-2" style="background-color: #0061d5; border: none; border-radius: 6px; font-weight: 600;" @onclick="CreateQuote">
                        + New Quote
                    </button>
                </div>
            </div>

            @* HIGH DENSITY TABLE *@
            <div class="table-responsive mt-4">
                @if (IsLoading)
                {
                    <div class="text-center p-5"><LoadingSpinner /></div>
                }
                else
                {
                    <table class="table table-hover" style="border: none;">
                        <thead>
                            <tr style="color: #94a3b8; font-size: 0.75rem; text-transform: uppercase; font-weight: 700; border-bottom: 1px solid #f1f5f9;">
                                <th class="pb-3 border-0">Quote #</th>
                                <th class="pb-3 border-0">Client</th>
                                <th class="pb-3 border-0">Date</th>
                                <th class="pb-3 border-0">Amount</th>
                                <th class="pb-3 border-0">Status</th>
                                <th class="pb-3 border-0 text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var q in FilteredQuotes)
                            {
                                <tr @onclick="() => HandleRowClick(q)" style="cursor: pointer; border-bottom: 1px solid #f8fafc;" class="sage-row">
                                    <td class="py-4 border-0 fw-bold" style="color: #2563eb;">@q.OrderNumber</td>
                                    <td class="py-4 border-0" style="color: #374151;">@q.ClientName</td>
                                    <td class="py-4 border-0 text-muted">@(q.OrderDate?.ToString("MMM dd, yyyy") ?? "N/A")</td>
                                    <td class="py-4 border-0 fw-bold" style="color: #1e293b;">@q.TotalAmount.ToString("C0")</td>
                                    <td class="py-4 border-0">
                                        <span class="status-pill @q.Status.ToLower()">@q.Status</span>
                                    </td>
                                    <td class="py-4 border-0 text-center">
                                        <div class="d-flex justify-content-center gap-2">
                                            @if (q.Status == "Draft")
                                            {
                                                <button class="btn btn-sm btn-light border" title="Approve" @onclick:stopPropagation="true" @onclick="() => ApproveQuote(q)">✅</button>
                                            }
                                            <button class="btn btn-sm btn-light border" title="Convert to Order" @onclick:stopPropagation="true" @onclick="() => ConvertQuote(q)">🛒</button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .sage-row:hover { background-color: #f9fafb !important; }
    .status-pill { padding: 6px 14px; border-radius: 6px; font-size: 0.8rem; font-weight: 700; display: inline-block; min-width: 90px; text-align: center; }
    .status-pill.draft { background-color: #f3f4f6; color: #4b5563; }
    .status-pill.approved { background-color: #dcfce7; color: #16a34a; }
    .status-pill.rejected { background-color: #fee2e2; color: #b91c1c; }
</style>

@code {
    private bool IsLoading = true;
    private string SearchQuery = "";
    private string SelectedStatus = "All";
    private bool IsFilterOpen = false;

    private List<OpenOrderDto> QuoteList => WorkspaceState.Quotes ?? new();

    // FIXED: The working filter pattern from Knowledge Base applied here
    private IEnumerable<OpenOrderDto> FilteredQuotes =>
        QuoteList.Where(q =>
            (SelectedStatus == "All" || q.Status == SelectedStatus) &&
            (string.IsNullOrWhiteSpace(SearchQuery) || q.OrderNumber.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) || q.ClientName.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase))
        );

    private int TotalQuotes => QuoteList.Count;
    private int DraftCount => QuoteList.Count(q => q.Status == "Draft");
    private int ApprovedCount => QuoteList.Count(q => q.Status == "Approved");
    private decimal TotalValue => QuoteList.Sum(q => q.TotalAmount);

    protected override async Task OnInitializedAsync() => await LoadQuotes();

    private async Task LoadQuotes()
    {
        try {
            IsLoading = true;
            await OrdersService.LoadQuotesAsync();
            
            // Seed Dummy if Service is empty for visual testing
            if (!QuoteList.Any())
            {
                WorkspaceState.Quotes = new List<OpenOrderDto> {
                    new() { Id = Guid.NewGuid(), OrderNumber = "SQ-7789", ClientName = "Global Solutions", OrderDate = DateTime.Now, Status = "Draft", TotalAmount = 4500m },
                    new() { Id = Guid.NewGuid(), OrderNumber = "SQ-7790", ClientName = "Tech Innovations", OrderDate = DateTime.Now.AddDays(-1), Status = "Approved", TotalAmount = 12000m }
                };
            }
        }
        finally { IsLoading = false; }
    }

    private async Task HandleRowClick(OpenOrderDto q)
    {
        await DashboardState.LoadOrderDetailsAsync(q.OrderNumber);
        NavManager.NavigateTo($"/workspace/orders/{q.Id}");
    }

    private async Task Refresh() => await LoadQuotes();
    private void CreateQuote() => NavManager.NavigateTo("/forms/create-quote");

    private async Task ApproveQuote(OpenOrderDto q) {
        await OrdersService.ApproveQuoteAsync(q.Id);
        NotificationService.Notify(new Radzen.NotificationMessage { Severity = Radzen.NotificationSeverity.Success, Summary = "Approved" });
        await LoadQuotes();
    }

    private async Task ConvertQuote(OpenOrderDto q) {
        await OrdersService.ConvertToOrderAsync(q.Id);
        NotificationService.Notify(new Radzen.NotificationMessage { Severity = Radzen.NotificationSeverity.Success, Summary = "Converted" });
        await LoadQuotes();
    }
}
