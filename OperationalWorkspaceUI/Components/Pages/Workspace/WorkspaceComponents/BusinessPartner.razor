@page "/contacts"
@rendermode InteractiveServer

@using OperationalWorkspaceApplication.DTOs
@inject NavigationManager NavigationService

<div class="sage-container">
    <div class="sage-tabs">
        <div class="tab @(activeTab == "list" ? "active" : "")" @onclick='() => activeTab = "list"'>Contacts</div>
        <div class="tab @(activeTab == "recent" ? "active" : "")" @onclick='() => activeTab = "recent"'>Recent Activity</div>
    </div>

    @if (activeTab == "list")
    {
        <div class="sage-content animate-fade-in">
            <div class="sage-header-row">
                <div class="title-group">
                    <h2 class="title">Contacts</h2>
                    <p class="subtitle">Manage Sage X3 contact records</p>
                </div>
                <div class="action-group">
                    <button class="btn-sage-blue" @onclick="Create">+ New Contact</button>
                    @* FIXED: Associated spinner icon utility modifier classes to track asynchronous execution state variables *@
                    <button class="btn-sage-white" @onclick="RefreshContactsAsync" disabled="@isRefreshing">
                        <i class="oi oi-reload @(isRefreshing ? "animate-spin" : "")" style="margin-right: 4px;"></i>
                        <span>@(isRefreshing ? "Syncing..." : "Refresh")</span>
                    </button>
                </div>
            </div>

            <div class="sage-toolbar">
                <div class="search-box">
                    <span class="icon">🔍</span>
                    <input type="text" placeholder="Search contacts..." @bind="SearchQuery" @bind:event="oninput" />
                </div>
                <button class="btn-filter" @onclick="() => IsFilterOpen = !IsFilterOpen">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon></svg>
                    Filter
                </button>
            </div>

            @if (IsFilterOpen)
            {
                <div class="filter-tray animate-fade-in">
                    <div class="filter-item">
                        <label>STATUS</label>
                        <select @bind="StatusFilter" class="sage-select">
                            <option value="All">All Contacts</option>
                            <option value="Active">Active Only</option>
                            <option value="Inactive">Inactive Only</option>
                        </select>
                    </div>
                </div>
            }

            <table class="sage-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Company</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var contact in FilteredContacts)
                    {
                        <tr>
                            <td class="name-link" @onclick="() => Open(contact)">@contact.FullName</td>
                            <td>@contact.Company</td>
                            <td class="email-text">@contact.Email</td>
                            <td>@contact.Phone</td>
                            <td>
                                <span class="badge @(contact.Category == "Active" ? "active" : "inactive")">
                                    @(contact.Category == "Active" ? "Active" : "Inactive")
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (activeTab == "recent")
    {
        <div class="sage-content animate-fade-in">
            <p style="padding: 20px; color: #605e5c;">No recent activity logs available.</p>
        </div>
    }
</div>

@code {
    private string activeTab = "list";
    private bool IsFilterOpen = true;
    private string SearchQuery = string.Empty;
    private string StatusFilter = "All";
    private bool isRefreshing = false;

    private List<ContactCreateDto> ContactsList = new();

    protected override void OnInitialized()
    {
        LoadMockContacts();
    }

    private void LoadMockContacts()
    {
        ContactsList = new List<ContactCreateDto>
        {
            new() { FullName = "Sarah Johnson", Company = "Tech Innovations Inc.", Email = "sarah.j@tech.com", Phone = "(555) 123-4567", Category = "Active" },
            new() { FullName = "David Wilson", Company = "NextGen Tech", Email = "david.w@nextgen.com", Phone = "(555) 456-7890", Category = "Inactive" }
        };
    }

    private IEnumerable<ContactCreateDto> FilteredContacts =>
        ContactsList.Where(c =>
            (StatusFilter == "All" || (StatusFilter == "Active" && c.Category == "Active") || (StatusFilter == "Inactive" && c.Category != "Active")) &&
            (string.IsNullOrWhiteSpace(SearchQuery) || (c.FullName != null && c.FullName.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase))));

    private void Create() => NavigationService.NavigateTo("/forms/add-contact");

    private async Task RefreshContactsAsync()
    {
        if (isRefreshing) return;

        // FIXED: Dispatched asynchronously to simulate data network sync requests while forcing a complete UI layout refresh step
        await InvokeAsync(async () =>
        {
            isRefreshing = true;
            StateHasChanged();

            try
            {
                await Task.Delay(1000); // Simulated API transaction latency delay
                LoadMockContacts(); // Explicitly re-read reference listings matrices back to memory variables
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Contacts async reload pipeline encountered an issue: {ex.Message}");
            }
            finally
            {
                isRefreshing = false;
                StateHasChanged(); // Hyper-lock thread push flushes new variables array directly onto the screen layout
            }
        });
    }

    private void Open(ContactCreateDto contact) => NavigationService.NavigateTo($"/workspace/contacts/{contact.Email}");
}
