@page "/contacts"
@rendermode InteractiveServer

@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceUI.State
@inject NavigationManager NavigationService
@inject WorkspaceState WState

@implements IDisposable

<div class="enterprise-page-layout">

    <!-- COHESIVE GLASS NAVIGATION TABS -->
    <div class="sage-tabs" style="margin-top: 0; margin-bottom: 8px;">
        <div class="tab @(activeTab == "list" ? "active" : "")" @onclick='() => activeTab = "list"'>Contacts</div>
        <div class="tab @(activeTab == "recent" ? "active" : "")" @onclick='() => activeTab = "recent"'>Recent Activity</div>
    </div>

    @if (activeTab == "list")
    {
        <div class="sage-content animate-fade-in">

            <!-- HIGH-DENSITY HEADER BAR ACTIONS CONTROL -->
            <div class="sage-header-row">
                <div>
                    <h2 class="title">Contacts</h2>
                    <p class="subtitle">Manage Sage X3 contact records</p>
                </div>

                <div class="action-group">
                    <button class="btn-sage-blue" @onclick="Create">+ New Contact</button>
                    <button class="btn-sage-white" @onclick="RefreshContactsAsync" disabled="@isRefreshing">
                        <i class="oi oi-reload @(isRefreshing ? "animate-spin" : "")"></i>
                        <span style="margin-left:8px">@(isRefreshing ? "Syncing..." : "Refresh")</span>
                    </button>
                </div>
            </div>

            <!-- COMPACT FILTER FILTER ROW TOOLBAR -->
            <div class="toolbar-row">
                <div class="search-container">
                    <span class="search-icon">🔍</span>
                    <input type="text" placeholder="Search contacts..." @bind="SearchQuery" @bind:event="oninput" class="search-input" />
                </div>
                <button class="btn-ghost filter-toggle" @onclick="() => IsFilterOpen = !IsFilterOpen">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon></svg>
                    <span>Filter</span>
                </button>
            </div>

            @if (IsFilterOpen)
            {
                <div class="filter-tray-box animate-fade-in">
                    <label class="filter-label">Status Filter</label>
                    <select @bind="StatusFilter" class="sage-select">
                        <option value="All">All Contacts</option>
                        <option value="Active">Active Only</option>
                        <option value="Inactive">Inactive Only</option>
                    </select>
                </div>
            }

            <!-- PRIMARY RESPONSIVE LIQUID DATA TABLES CANVAS -->
            <div class="responsive-table-wrapper">
                <table class="sage-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Company</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var contact in FilteredContacts)
                        {
                            <tr class="contact-row" @onclick="() => Open(contact)">
                                <td class="td-name">@contact.FullName</td>
                                <td class="td-company">@contact.Company</td>
                                <td class="td-email">@contact.Email</td>
                                <td class="td-phone">@partnerPhoneFallback(contact.Phone)</td>
                                <td class="td-status">
                                    <span class="status-pill @(contact.Category == "Active" ? "status-online" : "status-offline")">
                                        @(contact.Category == "Active" ? "Active" : "Inactive")
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @if (activeTab == "recent")
    {
        <div class="recent-activity-container animate-fade-in">
            @if (FilteredActivityLogs == null || !FilteredActivityLogs.Any())
            {
                <div class="recent-activity-placeholder">
                    <p>No recent contact activity logs recorded in this session.</p>
                </div>
            }
            else
            {
                <!-- DYNAMIC HIGH-DENSITY MODERN GLASSMORPHIC RECENT ACTIVITY AUDIT TABLE -->
                <div class="responsive-table-wrapper">
                    <table class="sage-activity-table">
                        <thead>
                            <tr>
                                <th style="width: 40px; text-align: center;">Trace</th>
                                <th style="width: 100px;">Timestamp</th>
                                <th style="width: 100px;">Subsystem</th>
                                <th>Operational Description Audit Log</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in FilteredActivityLogs)
                            {
                                <tr class="activity-row-line">
                                    <td class="td-icon-cell">
                                        <span class="activity-badge-dot @log.ImpactClass">@log.Icon</span>
                                    </td>
                                    <td class="td-time-cell">@log.Timestamp.ToString("hh:mm:ss tt")</td>
                                    <td class="td-tag-cell">
                                        <span class="subsystem-pill">@log.Category</span>
                                    </td>
                                    <td class="td-description-cell">@log.Description</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }
</div>

@code {
    private string activeTab = "list";
    private bool IsFilterOpen = false;
    private string SearchQuery = string.Empty;
    private string StatusFilter = "All";
    private bool isRefreshing = false;

    private List<ContactCreateDto> ContactsList = new();

    private string partnerPhoneFallback(string? phone) => !string.IsNullOrEmpty(phone) ? phone : "N/A";

    protected override void OnInitialized()
    {
        LoadMockContacts();
        WState.OnChange += Refresh;

        // Push initial page setup telemetry down to central state logger
        WState.LogGlobalAction("Contact", "User loaded the contacts workspace dashboard registry grid tracking array view.", "💡", "tint-info");
    }

    private void LoadMockContacts()
    {
        ContactsList = new List<ContactCreateDto>
        {
            new() { FullName = "Sarah Johnson", Company = "Tech Innovations Inc.", Email = "sarah.j@tech.com", Phone = "(555) 123-4567", Category = "Active" },
            new() { FullName = "David Wilson", Company = "NextGen Tech", Email = "david.w@nextgen.com", Phone = "(555) 456-7890", Category = "Inactive" }
        };
    }

    // THE CENTRAL FILTER: Pulls only logs tagged to our specific operational category
    private IEnumerable<GlobalActivityItem> FilteredActivityLogs =>
        WState.SharedSystemLogs.Where(log => log.Category.Equals("Contact", StringComparison.OrdinalIgnoreCase));

    private IEnumerable<ContactCreateDto> FilteredContacts =>
        ContactsList.Where(c =>
            (StatusFilter == "All" || (StatusFilter == "Active" && c.Category == "Active") || (StatusFilter == "Inactive" && c.Category != "Active")) &&
            (string.IsNullOrWhiteSpace(SearchQuery) || (c.FullName != null && c.FullName.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase))));

    private void Create()
    {
        WState.LogGlobalAction("Contact", "Redirected workspace down to '/forms/add-contact' client creation panel view layer path entries.", "➕", "tint-success");
        NavigationService.NavigateTo("/forms/add-contact");
    }

    private async Task RefreshContactsAsync()
    {
        if (isRefreshing) return;

        await InvokeAsync(async () =>
        {
            isRefreshing = true;
            StateHasChanged();

            try
            {
                await Task.Delay(1000);
                LoadMockContacts();
                WState.LogGlobalAction("Contact", $"Triggered manual refresh. Successfully updated internal context memory buffers with {ContactsList.Count} active profiles data rows.", "🔄", "tint-primary");
            }
            catch (Exception ex)
            {
                WState.LogGlobalAction("Contact", $"Synchronization channel pass unexpected execution error generated: {ex.Message}", "❌", "tint-danger");
            }
            finally
            {
                isRefreshing = false;
                StateHasChanged();
            }
        });
    }

    private void Open(ContactCreateDto contact)
    {
        WState.LogGlobalAction("Contact", $"Inspected active corporate operational registry records files context parameters for partner profile: {contact.FullName}", "👤", "tint-info");
        NavigationService.NavigateTo($"/workspace/contacts/{contact.Email}");
    }

    private void Refresh() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        WState.OnChange -= Refresh;
    }
}
