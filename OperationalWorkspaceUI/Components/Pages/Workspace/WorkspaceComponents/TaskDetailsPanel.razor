@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceUI.UIServices.Workspace
@inject TasksUIService TasksUIService
@inject IJSRuntime JS

<div class="sidebar-root">
    <!-- 1. TASK DETAILS HEADER (IMAGE MATCH) -->
    <div class="sidebar-header-main">
        <span>Task Details</span>
        <i class="oi oi-chevron-bottom"></i>
    </div>

    @if (Task != null)
    {
        <!-- 2. TASK AGING CARD (IMAGE MATCH: RING + STATS) -->
        <div class="side-card aging-card">
            <div class="card-label">
                <i class="oi oi-layers red-txt"></i> TASK AGING
            </div>
            
            <div class="aging-grid">
                <div class="stat-unit">
                    <span class="stat-num red-txt">2</span>
                    <span class="stat-lbl">OVERDUE</span>
                </div>
                <div class="stat-unit">
                    <span class="stat-num blue-txt">1</span>
                    <span class="stat-lbl">DUE SOON</span>
                </div>
                <div class="ring-unit">
                    <div class="green-ring">78%</div>
                </div>
            </div>

            <div class="histo-divider">COMPLETED</div>

            <!-- 3. HISTOGRAM (IMAGE MATCH: POWERED BY CANVAS/CHARTS.JS) -->
            <div class="histogram-viewport">
                <canvas id="agingHistogramCanvas"></canvas>
            </div>
        </div>

        <!-- 4. RESPONSE TIME (IMAGE MATCH: 2.3h RED TIMER) -->
        <div class="side-card response-row">
            <div class="timer-red-ring">2.3h</div>
            <div class="response-text">
                <span class="lbl-bold">Avg. Response Time</span>
                <div class="spark-box">
                    @for (int i = 0; i < 6; i++)
                    {
                        <div class="spark"></div>
                    }
                </div>
            </div>
        </div>

        <!-- 5. DELEGATE BUTTON (IMAGE MATCH: FULL WIDTH BLUE) -->
        <button class="btn-blue-delegate" @onclick="HandleDelegate">
            <span>Delegate Task</span>
            <i class="oi oi-chevron-bottom"></i>
        </button>

        <!-- 6. WORKLOAD (IMAGE MATCH: PEOPLE ICONS) -->
        <div class="sidebar-header-main no-border">
            <span>Workload</span>
            <i class="oi oi-chevron-bottom"></i>
        </div>
        
        <div class="workload-stats">
            <div class="task-count">6 Active Tasks</div>
            <div class="icon-row">
                @for (int i = 0; i < 5; i++)
                {
                    <i class="oi oi-person blue-p"></i>
                }
                <i class="oi oi-person grey-p"></i>
            </div>
            <div class="footer-msg">
                <i class="oi oi-info"></i> Active Tasks
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public TaskDto? Task { get; set; }

    private async Task HandleDelegate()
    {
        if (Task != null)
        {
            await TasksUIService.DelegateTaskAsync(Task.Id, "user@test.com");
        }
    }

    // TRIGGER THE CHARTS.JS LOGIC
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Task != null)
        {
            // Data order: [Overdue, Soon, Upcoming, Completed]
            var chartData = new[] { 2, 1, 0, 3 };
            
            // This calls the renderAgingHistogram function in your charts.js file
            await JS.InvokeVoidAsync("renderAgingHistogram", "agingHistogramCanvas", chartData);
        }
    }
}
