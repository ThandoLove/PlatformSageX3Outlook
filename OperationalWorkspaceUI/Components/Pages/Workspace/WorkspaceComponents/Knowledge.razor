@page "/workspace/knowledge"
@rendermode InteractiveServer

@using OperationalWorkspaceUI.Components.Pages.Workspace.WorkspaceComponents
@using OperationalWorkspaceUI.UIServices.System
@using OperationalWorkspaceUI.State
@using OperationalWorkspaceApplication.DTOs
@using Microsoft.FluentUI.AspNetCore.Components
@implements IDisposable

@inject DashboardState DashboardState
@inject NavigationService NavigationService
@inject OperationalWorkspaceUI.UIServices.Workspace.KnowledgeUIService KBService

<div class="workspace-container" style="padding: 20px; background-color: #f4f7f9; min-height: 100vh;">
    
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <div>
            <h2 style="margin: 0; color: #003366; font-weight: 600;">Knowledge Base</h2>
            <p style="margin: 0; color: #64748b; font-size: 0.9rem;">Sage X3 Central Documentation & Articles</p>
        </div>
        <FluentButton Appearance="Appearance.Accent"
                      IconStart="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.Add())"
                      OnClick="Create">
            New Article
        </FluentButton>
    </div>

    @if (DashboardState.KnowledgeBase == null)
    {
        <div style="display: flex; justify-content: center; padding: 50px;">
            <FluentProgressRing />
        </div>
    }
    else if (!DashboardState.KnowledgeBase.Any())
    {
        <FluentCard Style="padding: 40px; text-align: center;">
            <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size32.DocumentSearch())"
                        Color="@Microsoft.FluentUI.AspNetCore.Components.Color.Neutral" />
            <p>No knowledge articles found in Sage X3.</p>
        </FluentCard>
    }
    else
    {
        @* Passing the mapped DTO list to the grid component *@
        <KnowledgeGrid Data="DashboardState.KnowledgeBase" />
    }
</div>

@code {
    private void Create() => NavigationService.NavigateTo("/forms/send-knowledge");

    protected override async Task OnInitializedAsync()
    {
        // 1. Subscribe to state changes
        DashboardState.OnChange += StateHasChanged;
        
        // 2. Fetch the raw strings from the Sage service
        var result = await KBService.GetArticlesAsync();
        
        // 3. Map strings to the Positional Record KnowledgeDto
        // Since KnowledgeDto is a record(Guid, string, string, string, string, string)
        // we must pass all arguments in order.
        DashboardState.KnowledgeBase = result.Select(title => new KnowledgeDto(
            Guid.NewGuid(),      // Id
            title,               // Title
            "",                  // Content
            "General",           // Category
            "Sage X3 Article",   // Summary
            ""                   // Url
        )).ToList();
    }

    public void Dispose()
    {
        // Unsubscribe to avoid memory leaks
        DashboardState.OnChange -= StateHasChanged;
    }
}
