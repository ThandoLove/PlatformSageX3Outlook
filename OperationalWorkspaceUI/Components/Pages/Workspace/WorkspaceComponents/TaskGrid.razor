@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceApplication.Mappers
@using OperationalWorkspaceUI.State
@using OperationalWorkspace.Domain.Enums
@implements IDisposable
@inject WorkspaceState State
@inject DashboardState AdminState  
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

@* Added to track Admin context *@

<div class="hub-container force-interactive" style="position: relative;">

    @* --- LIVE SYNC OVERLAY --- *@
    @if (State.IsLoadingTasks)
    {
        <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(255,255,255,0.7); z-index: 100; display: flex; flex-direction: column; align-items: center; justify-content: center; border-radius: 8px;">
            <FluentProgressRing Style="width: 32px; height: 32px;" />
            <span style="margin-top: 10px; font-weight: 600; color: #003366; font-size: 0.8rem;">Syncing Tasks...</span>
        </div>
    }

    <header class="hub-header">
        <div class="hub-title-group @(ActiveTab == "All" ? "active" : "")" @onclick='() => SelectFilter("All")'>
            <i class="oi oi-list-rich"></i><span>Tasks Grid</span>
        </div>
        
        <nav class="hub-tabs">
            @* DYNAMIC TABS: Uses 'SourceTasks' to reflect Admin or Employee context *@
            <div class="tab-item @(ActiveTab == "Today" ? "active" : "")" @onclick='() => SelectFilter("Today")'>
                Today (@SourceTasks.Count(t => t.DueDate?.Date == DateTime.Today && !t.Completed))
            </div>
            <div class="tab-item @(ActiveTab == "Overdue" ? "active" : "")" @onclick='() => SelectFilter("Overdue")'>
                Overdue (@SourceTasks.Count(t => t.DueDate?.Date < DateTime.Today && !t.Completed))
            </div>
            <div class="tab-item @(ActiveTab == "Upcoming" ? "active" : "")" @onclick='() => SelectFilter("Upcoming")'>
                Upcoming (@SourceTasks.Count(t => t.DueDate?.Date > DateTime.Today && !t.Completed))
            </div>
            <div class="tab-item @(ActiveTab == "Completed" ? "active" : "")" @onclick='() => SelectFilter("Completed")'>
                Completed (@SourceTasks.Count(t => t.Completed))
            </div>
        </nav>
    </header>

    <div class="sub-header-bar">
        <div class="sub-header-left">
            <div class="pill-dropdown">
                <i class="oi oi-calendar"></i>
                <span>@ActiveTab (@GetFilteredTasks().Count())</span>
                <i class="oi oi-chevron-bottom"></i>
            </div>

            <button class="btn-filter-action" @onclick="ToggleFilter">
                <i class="oi oi-list"></i> Filter
            </button>
        </div>
        <button class="btn-source-top-bold" @onclick="OpenTopEmail">Open Source Email</button>
    </div>

    @if (IsFilterOpen)
    {
        <div class="filter-tray-mini animate-fade-in">
            <label>Priority:</label>
            <select @bind="PriorityFilter">
                <option value="All">All Levels</option>
                <option value="Urgent">Urgent</option>
                <option value="High">High</option>
                <option value="Medium">Medium</option>
                <option value="Low">Low</option>
            </select>
        </div>
    }

    <div class="task-list-scroller">
        @foreach (var task in GetFilteredTasks())
        {
            <TaskItem Task="task" OnSelect="OnTaskSelected" />
        }
    </div>
</div>

@code {
    // FIX: This parameter stops the 'InvalidOperationException' in the Admin page
    [Parameter] public IEnumerable<TaskDto>? Tasks { get; set; }

    [Parameter] public string SearchQuery { get; set; } = "";
    [Parameter] public EventCallback<TaskDto> OnTaskSelected { get; set; }

    private string ActiveTab = "Today";
    private bool IsFilterOpen = false;
    private string PriorityFilter = "All";

    private string CurrentUserEmail = "alex.turner@company.com";

    // UPDATED LOGIC:
    // If Admin passes 'Tasks', use those. 
    // Otherwise, filter 'State.Tasks' for Alex Turner (Standard Employee Dashboard).
    private IEnumerable<TaskDto> SourceTasks => Tasks ?? State.Tasks
        .Where(t => t.AssignedTo == CurrentUserEmail || string.IsNullOrEmpty(t.AssignedTo));

    protected override void OnInitialized()
    {
        State.OnChange += Refresh;
        AdminState.OnChange += Refresh;// Listen to Admin state too
    }

    private void Refresh()
    {
        InvokeAsync(StateHasChanged);
    }

    private void ToggleFilter() => IsFilterOpen = !IsFilterOpen;

    private async Task OpenTopEmail()
    {
        var firstTask = GetFilteredTasks().FirstOrDefault();
        if (firstTask != null && !string.IsNullOrEmpty(firstTask.OutlookItemId))
            await JSRuntime.InvokeVoidAsync("openOutlookItem", firstTask.OutlookItemId);
    }

    private IEnumerable<TaskDto> GetFilteredTasks()
    {
        // Start with the correctly contextualized source
        var q = SourceTasks;
        
        // 2. Apply Tab Filter
        q = ActiveTab switch
        {
            "Overdue" => q.Where(t => t.DueDate?.Date < DateTime.Today && !t.Completed),
            "Upcoming" => q.Where(t => t.DueDate?.Date > DateTime.Today && !t.Completed),
            "Completed" => q.Where(t => t.Completed),
            "All" => q,
            _ => q.Where(t => t.DueDate?.Date == DateTime.Today && !t.Completed)
        };

        // 3. Apply Dropdown & Search Filters
        if (PriorityFilter != "All") q = q.Where(x => x.Priority.ToString() == PriorityFilter);
        if (!string.IsNullOrWhiteSpace(SearchQuery)) q = q.Where(t => t.Title.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase));

        return q;
    }

    private void SelectFilter(string tabName) => ActiveTab = tabName;

    public void Dispose()
    {
        State.OnChange -= Refresh;
        AdminState.OnChange -= Refresh;
    }
}
