@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceApplication.Mappers
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<div class="hub-container force-interactive">
    <header class="hub-header">
        <div class="hub-title-group @(ActiveTab == "All" ? "active" : "")" @onclick='() => SelectFilter("All")'>
            <i class="oi oi-list-rich"></i><span>Tasks Hub</span>
        </div>
        
        <nav class="hub-tabs">
            @* DYNAMIC TABS WITH LIVE COUNTS *@
            <div class="tab-item @(ActiveTab == "Today" ? "active" : "")" @onclick='() => SelectFilter("Today")'>
                Today (@Tasks.Count(t => t.DueDate?.Date == DateTime.Today && !t.Completed))
            </div>
            <div class="tab-item @(ActiveTab == "Overdue" ? "active" : "")" @onclick='() => SelectFilter("Overdue")'>
                Overdue (@Tasks.Count(t => TaskRulesEngine.IsOverdue(t)))
            </div>
            <div class="tab-item @(ActiveTab == "Upcoming" ? "active" : "")" @onclick='() => SelectFilter("Upcoming")'>
                Upcoming (@Tasks.Count(t => t.DueDate?.Date > DateTime.Today && !t.Completed))
            </div>
            <div class="tab-item @(ActiveTab == "Completed" ? "active" : "")" @onclick='() => SelectFilter("Completed")'>
                Completed (@Tasks.Count(t => t.Completed))
            </div>
        </nav>
    </header>

    <div class="sub-header-bar">
        <div class="sub-header-left">
            <div class="pill-dropdown">
                <i class="oi oi-calendar"></i>
                @* DYNAMIC PILL TEXT *@
                <span>@ActiveTab (@GetFilteredTasks().Count())</span>
                <i class="oi oi-chevron-bottom"></i>
            </div>

            <button class="btn-filter-action" @onclick="ToggleFilter">
                <i class="oi oi-list"></i> Filter
            </button>
        </div>
        <button class="btn-source-top-bold" @onclick="OpenTopEmail">Open Source Email</button>
    </div>

    @if (IsFilterOpen)
    {
        <div class="filter-tray-mini animate-fade-in">
            <label>Priority:</label>
            <select @bind="PriorityFilter">
                <option value="All">All Levels</option>
                <option value="Urgent">Urgent (Warnings)</option>
                <option value="High">High Priority</option>
                <option value="Normal">Normal</option>
                <option value="Low">Low Priority</option>
                <option value="Medium">Medium</option>
            </select>
        </div>
    }

    <div class="task-list-scroller">
        @foreach (var task in GetFilteredTasks())
        {
            <TaskItem Task="task" OnSelect="OnTaskSelected" />
        }
    </div>
</div>

@code {
    [Parameter] public List<TaskDto> Tasks { get; set; } = new();
    [Parameter] public string SearchQuery { get; set; } = "";
    [Parameter] public EventCallback<TaskDto> OnTaskSelected { get; set; }

    private string ActiveTab = "Today";
    private bool IsFilterOpen = false;
    private string PriorityFilter = "All";

    private void ToggleFilter() => IsFilterOpen = !IsFilterOpen;

    private async Task OpenTopEmail()
    {
        var firstTask = GetFilteredTasks().FirstOrDefault();
        if (firstTask != null && !string.IsNullOrEmpty(firstTask.OutlookItemId))
            await JSRuntime.InvokeVoidAsync("openOutlookItem", firstTask.OutlookItemId);
    }

    private IEnumerable<TaskDto> GetFilteredTasks()
    {
        var q = Tasks.AsEnumerable();
        
        q = ActiveTab switch
        {
            "Overdue" => q.Where(t => TaskRulesEngine.IsOverdue(t)),
            "Upcoming" => q.Where(t => t.DueDate?.Date > DateTime.Today && !t.Completed),
            "Completed" => q.Where(t => t.Completed),
            "All" => q,
            _ => q.Where(t => t.DueDate?.Date == DateTime.Today && !t.Completed)
        };

        if (PriorityFilter != "All") q = q.Where(x => x.Priority.ToString() == PriorityFilter);

        if (!string.IsNullOrWhiteSpace(SearchQuery))
            q = q.Where(t => t.Title.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase));

        return q;
    }

    private void SelectFilter(string tabName)
    {
        ActiveTab = tabName;
        StateHasChanged();
    }
}
