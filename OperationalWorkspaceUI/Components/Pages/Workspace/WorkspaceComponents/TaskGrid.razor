@using OperationalWorkspaceApplication.DTOs

<div class="hub-container">
    <header class="hub-header">
        <!-- TITLE CLICK (RESET) -->
        <div class="hub-title-group @(ActiveTab == "All" ? "active" : "")"
             @onclick='() => OnTabChanged.InvokeAsync("All")' style="cursor:pointer">
            <i class="oi oi-list-rich"></i><span>Tasks Hub</span>
        </div>
        
        <nav class="hub-tabs">
            @foreach (var tab in FilterTabs)
            {
                var tabName = tab; // 🔥 CRITICAL FIX: Locks the variable for the click event
                <div class="tab-item @(ActiveTab == tabName ? "active" : "")"
                     @onclick="() => OnTabChanged.InvokeAsync(tabName)">
                    @tabName
                </div>
            }
        </nav>
    </header>

    <div class="sub-header-bar">
        <div class="pill-dropdown">
            <i class="oi oi-calendar"></i>
            <span>@(ActiveTab == "All" ? "All Tasks" : ActiveTab)</span>
            <i class="oi oi-chevron-bottom"></i>
        </div>
        <button class="btn-source-top">Open Source Email</button>
    </div>

    <div class="task-list-scroller">
        @foreach (var task in Tasks)
        {
            <TaskItem Task="task" OnSelect="OnTaskSelected" />
        }
    </div>
</div>

@code {
    [Parameter] public List<TaskDto> Tasks { get; set; } = new();
    [Parameter] public string ActiveTab { get; set; } = "";
    [Parameter] public EventCallback<string> OnTabChanged { get; set; }
    [Parameter] public EventCallback<TaskDto> OnTaskSelected { get; set; }
    
    private string[] FilterTabs = { "Today (6)", "Overdue", "Upcoming", "Completed" };
}
