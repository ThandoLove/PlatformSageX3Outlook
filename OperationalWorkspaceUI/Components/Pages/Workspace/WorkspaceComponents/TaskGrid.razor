@using OperationalWorkspaceApplication.DTOs
@using Microsoft.FluentUI.AspNetCore.Components

<div class="tasks-root">

    <!-- HEADER -->
    <div class="tasks-header">
        <div class="user">
            <div class="avatar"></div>
            <div>
                <div class="name">Alex Turner</div>
                <div class="role">UX Designer | UX Design</div>
            </div>
        </div>

        <FluentTextField Placeholder="Search across Outlook & Sage X3..."
                         Class="search-box"
                         @bind-Value="SearchQuery" />
    </div>

    <!-- BODY -->
    <div class="tasks-body">

        <!-- LEFT -->
        <div class="tasks-left">

            <!-- TABS -->
            <div class="tabs">
                @foreach (var tab in Tabs)
                {
                    <div class="tab @(tab == SelectedTab ? "active" : "")"
                         @onclick="() => ChangeTab(tab)">
                        @tab (@GetCount(tab))
                    </div>
                }
            </div>

            <!-- SUB HEADER -->
            <div class="sub-header">
                <span>@SelectedTab (@GetCount(SelectedTab))</span>
                <FluentButton Appearance="Appearance.Lightweight">
                    Open Source Email
                </FluentButton>
            </div>

            <!-- TASK LIST -->
            <div class="task-list">
                @foreach (var task in FilteredTasks)
                {
                    <TaskItem Task="task" OnSelect="SelectTask" />
                }
            </div>

        </div>

        <!-- RIGHT -->
        <div class="tasks-right">
            @if (SelectedTask != null)
            {
                <TaskDetailsPanel Task="SelectedTask" />
            }
            else
            {
                <div class="empty">Select a task</div>
            }
        </div>

    </div>

</div>

@code {
    [Parameter] public List<TaskDto> Tasks { get; set; } = new();

    private string SearchQuery = "";
    private string SelectedTab = "Today";
    private TaskDto? SelectedTask;

    private List<string> Tabs = new() { "Today", "Overdue", "Upcoming", "Completed" };

    private IEnumerable<TaskDto> FilteredTasks =>
        Tasks
        .Where(t =>
            string.IsNullOrWhiteSpace(SearchQuery) ||
            t.Title.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase))
        .Where(t => SelectedTab switch
        {
            "Today" => t.DueDate?.Date == DateTime.Today,
            "Overdue" => t.DueDate?.Date < DateTime.Today && !t.Completed,
            "Upcoming" => t.DueDate?.Date > DateTime.Today,
            "Completed" => t.Completed,
            _ => true
        });

    private int GetCount(string tab) => tab switch
    {
        "Today" => Tasks.Count(t => t.DueDate?.Date == DateTime.Today),
        "Overdue" => Tasks.Count(t => t.DueDate?.Date < DateTime.Today && !t.Completed),
        "Upcoming" => Tasks.Count(t => t.DueDate?.Date > DateTime.Today),
        "Completed" => Tasks.Count(t => t.Completed),
        _ => 0
    };

    private void ChangeTab(string tab) => SelectedTab = tab;

    private void SelectTask(TaskDto task) => SelectedTask = task;
}