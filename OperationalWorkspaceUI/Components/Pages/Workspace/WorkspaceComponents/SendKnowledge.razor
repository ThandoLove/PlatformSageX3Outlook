@page "/knowledge-page"
@rendermode InteractiveServer

@using Microsoft.FluentUI.AspNetCore.Components
@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons
@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceUI.State
@using OperationalWorkspaceUI.UIServices.Workspace
@using System.Text.RegularExpressions

@inject NavigationManager NavManager
@inject KnowledgeUIService KBService
@inject WorkspaceState WState
@inject Radzen.NotificationService Notifications

<div class="kb-page-container">
    
    @* HEADER *@
    <div class="kb-header">
        <h1 class="kb-title">Knowledge Base</h1>
        <FluentButton Appearance="Appearance.Accent" class="kb-new-btn" OnClick="CreateArticle">New Article</FluentButton>
    </div>

    @* FILTERS *@
    <div class="kb-filter-bar">
        <div class="search-wrapper">
            <FluentSearch Placeholder="Search Sage X3 Articles..."
                          @bind-Value="SearchQuery"
                          @bind-Value:event="oninput"
                          Style="width: 100%;" />
        </div>

        <FluentSelect Items="@Categories.Select(c => c.Name)" @bind-Value="SelectedCategory" Label="Category" />
        <FluentSelect Items="@(new[] { "Newest", "Most Viewed" })" @bind-Value="SortOrder" Label="Sort By" />

        <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Filter())">Filter</FluentButton>
    </div>

    @* DATA TABLE *@
    <div class="kb-table-container">
        <table class="kb-table">
            <thead>
                <tr>
                    <th style="width: 40px;"><FluentCheckbox /></th>
                    <th>ARTICLE TITLE</th>
                    <th>CATEGORY</th>
                    <th style="text-align: center;">VIEWS</th>
                    <th style="text-align: right;">ACTIONS</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var article in FilteredArticles)
                {
                    <tr class="kb-row-hover">
                        <td><FluentCheckbox /></td>
                        <td>
                            <FluentButton Appearance="Appearance.Lightweight" class="kb-title-btn" OnClick="@(() => OpenPreview(article))">
                                <FluentIcon Value="@(new Icons.Regular.Size20.Document())" Style="margin-right: 8px; vertical-align: middle;" />
                                @article.Title
                            </FluentButton>
                        </td>
                        <td class="kb-col-category">@article.Category</td>
                        <td class="kb-col-views">@article.Views</td>
                        <td class="kb-actions">
                            <FluentButton Appearance="Appearance.Outline" OnClick="@(() => OpenPreview(article))">Preview</FluentButton>
                            <FluentButton Appearance="Appearance.Accent" class="kb-send-btn" OnClick="@(() => OpenEmailForm(article))">Send</FluentButton>
                            <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => DeleteArticle(article))">
                                <FluentIcon Value="@(new Icons.Regular.Size16.Delete())" Color="Color.Error" />
                            </FluentButton>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* MODAL OVERLAY *@
    @if (SelectedArticle != null)
    {
        <div class="kb-modal-backdrop">
            <div class="kb-modal-content">
                
                @if (!IsSuccessMode)
                {
                    <div class="modal-header">
                        <h2>@(IsEmailMode ? "Send Article" : SelectedArticle.Title)</h2>
                        <FluentButton Appearance="Appearance.Stealth" OnClick="CloseModal" Disabled="IsSending"><FluentIcon Value="@(new Icons.Regular.Size24.Dismiss())" /></FluentButton>
                    </div>
                    <hr class="modal-divider" />

                    @if (IsEmailMode)
                    {
                        <div class="email-form-box">
                            <FluentTextField @bind-Value="RecipientEmail"
                                             Placeholder="recipient@company.com"
                                             Label="Recipient Email"
                                             @oninput="@(e => RecipientEmail = e.Value?.ToString() ?? "")"
                                             Style="width: 100%;" />
                            
                            @if (!string.IsNullOrEmpty(RecipientEmail) && !IsEmailValid)
                            {
                                <span class="validation-error">Please enter a valid email address.</span>
                            }

                            <div class="modal-footer-actions">
                                <FluentButton Appearance="Appearance.Stealth" OnClick="CloseModal" Disabled="IsSending">Cancel</FluentButton>
                                <FluentButton Appearance="Appearance.Accent" class="kb-send-confirm-btn"
                                              OnClick="SendAsAttachment"
                                              Disabled="@(!IsEmailValid || IsSending)">
                                    @if (IsSending)
                                    {
                                        <FluentProgressRing Style="width:16px; height:16px; margin-right:8px;" />
                                    }
                                    @(IsSending ? "Sending..." : "Confirm Send")
                                </FluentButton>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="preview-text">@SelectedArticle.Content</div>
                        <div class="modal-footer-actions">
                            <FluentButton Appearance="Appearance.Accent" OnClick="CloseModal">Close</FluentButton>
                        </div>
                    }
                }
                else
                {
                    <div class="success-state">
                        <FluentIcon Value="@(new Icons.Filled.Size32.CheckmarkCircle())" Color="Color.Success" Style="width: 64px; height: 64px;" />
                        <h2>Sent Successfully!</h2>
                        <p>The dashboard has been updated.</p>
                    </div>
                }
            </div>
        </div>
    }

    @* FOOTER *@
    <div class="kb-footer">
        <FluentAnchor Appearance="Appearance.Stealth" Href="https://your-sage-url.com" Target="_blank" class="kb-browse-link">
            Browse Sage X3 →
        </FluentAnchor>
        <div class="kb-pagination">
            <span>1 of 1</span>
            <FluentButton Appearance="Appearance.Stealth">Prev</FluentButton>
            <FluentButton Appearance="Appearance.Stealth">Next</FluentButton>
        </div>
    </div>
</div>

@code {
    private KbArticle? SelectedArticle;
    private bool IsEmailMode, IsSuccessMode, IsSending;
    private string RecipientEmail = "", SearchQuery = "", SelectedCategory = "All Categories", SortOrder = "Newest";

    private void OpenPreview(KbArticle article) { SelectedArticle = article; IsEmailMode = false; }
    private void OpenEmailForm(KbArticle article) { SelectedArticle = article; IsEmailMode = true; }
    private void CloseModal() { SelectedArticle = null; IsEmailMode = false; IsSuccessMode = false; IsSending = false; RecipientEmail = ""; }
    private void CreateArticle() => NavManager.NavigateTo("/forms/send-knowledge");

    private async Task SendAsAttachment()
    {
        if (SelectedArticle == null) return;
        
        // 1. BROADCAST START TO DASHBOARD
        WState.SetSendingKnowledge(true);

        try
        {
            IsSending = true;
            await Task.Delay(1500); // Simulate network
            
            await KBService.SendKnowledgeAsync(new SendKnowledgeModel
            {
                SearchQuery = SelectedArticle.Title,
                Message = RecipientEmail
            });
            
            IsSuccessMode = true;
            IsSending = false;
            StateHasChanged();
            
            await Task.Delay(2000);
            CloseModal();
        }
        finally
        {
            // 2. BROADCAST END TO DASHBOARD
            WState.SetSendingKnowledge(false);
        }
    }

    private void DeleteArticle(KbArticle article)
    {
        MasterArticles.Remove(article);
        WState.LogActivity(article.Title, "Deleted Article", "Tia");
        Notifications.Notify(new Radzen.NotificationMessage { Severity = Radzen.NotificationSeverity.Info, Summary = "Deleted", Detail = "Article removed." });
    }

    private bool IsEmailValid => Regex.IsMatch(RecipientEmail ?? "", @"^[^@\s]+@[^@\s]+\.[^@\s]+$");

    private List<CategoryItem> Categories = new() {
        new("All Categories", 24), new("Pricing Guidelines", 4), new("Product Documentation", 5),
        new("Case Studies", 3), new("FAQ", 6), new("How To Guides", 4)
    };

    private List<KbArticle> MasterArticles = new() {
        new("Pricing Guidelines 2024", "Pricing Guidelines", DateTime.Now, 120, "Sage X3 pricing tiered structure for 2024."),
        new("How to Create a Sales Order", "How To Guides", DateTime.Now, 153, "Full O-WS interface instructions...")
    };

    private IEnumerable<KbArticle> FilteredArticles => MasterArticles
        .Where(a => (SelectedCategory == "All Categories" || a.Category == SelectedCategory) &&
                    (string.IsNullOrWhiteSpace(SearchQuery) || a.Title.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)));

    public record KbArticle(string Title, string Category, DateTime LastUpdated, int Views, string Content);
    public record CategoryItem(string Name, int Count);
}
