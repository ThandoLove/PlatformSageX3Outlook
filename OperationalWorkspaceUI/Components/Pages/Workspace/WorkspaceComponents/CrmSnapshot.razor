@page "/crm-snapshot"
@rendermode InteractiveServer

@using OperationalWorkspaceUI.State
@using Microsoft.FluentUI.AspNetCore.Components
@implements IDisposable
@inject DashboardState State

<FluentCard Style="width: 100%; padding: 16px; border-radius: 12px; border-left: 4px solid #005A9E;">
    @* Fix 1: Fully qualified Orientation to resolve conflict with Radzen *@
    <FluentStack Orientation="@Microsoft.FluentUI.AspNetCore.Components.Orientation.Vertical" Spacing="3">
        
        @* Header Section *@
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <FluentLabel Typo="Typography.Header" Style="font-size: 1.1rem; font-weight: 600;">CRM Snapshot</FluentLabel>
            @* Fix 2: Fully qualified Icon path *@
            <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.ChevronDown())"
                        Color="@Microsoft.FluentUI.AspNetCore.Components.Color.Neutral" />
        </div>

        <FluentLabel Typo="Typography.Body"><strong>Tech Innovations Inc.</strong></FluentLabel>

        <FluentDivider Role="DividerRole.Presentation" />

        <FluentLabel Typo="Typography.Body">
            <strong>@State.CurrentTickets.Count(t => t.Status != "Resolved") Active</strong>
        </FluentLabel>

        <FluentGrid Spacing="3">
            <FluentGridItem xs="6">
                <FluentLabel Typo="Typography.Body" Style="font-size: 0.8rem; color: #64748b;">Open Tickets</FluentLabel>
                <FluentLabel Typo="Typography.Body"><strong>@State.CurrentTickets.Count Active</strong></FluentLabel>
            </FluentGridItem>

            <FluentGridItem xs="6">
                <FluentLabel Typo="Typography.Body" Style="font-size: 0.8rem; color: #d83b01;">Overdue Invoices</FluentLabel>
                <FluentLabel Typo="Typography.Body" Style="color: #d83b01;">
                    <strong>$ @GetOverdueAmount()</strong>
                </FluentLabel>
            </FluentGridItem>

            <FluentGridItem xs="6">
                <FluentLabel Typo="Typography.Body" Style="font-size: 0.8rem; color: #64748b;">Credit Limit</FluentLabel>
                <FluentLabel Typo="Typography.Body" Style="color: #107c10; margin-bottom: 4px;"><strong>$50,000</strong></FluentLabel>
                @* Note: Ensure FluentProgress uses valid hex or DesignToken *@
                <FluentProgress Min="0" Max="50000" Value="37500" Style="height: 4px;" />
            </FluentGridItem>

            <FluentGridItem xs="6">
                <FluentLabel Typo="Typography.Body" Style="font-size: 0.8rem; color: #64748b;">Last Contact</FluentLabel>
                <FluentLabel Typo="Typography.Body"><strong>3 days ago</strong></FluentLabel>
            </FluentGridItem>
        </FluentGrid>
    </FluentStack>
</FluentCard>

@code {
    protected override void OnInitialized()
    {
        State.OnChange += StateHasChanged;
    }

    private string GetOverdueAmount()
    {
        if (State.IsAdminEnvironment && State.AdminFinance != null)
        {
            @* Fix 3: Updated property name. Ensure this matches your Finance DTO (e.g., TotalOverdue) *@
            return State.AdminFinance.TotalOverdue.ToString("N0");
        }
        
        return "12,500";
    }

    public void Dispose()
    {
        State.OnChange -= StateHasChanged;
    }
}
