@using OperationalWorkspace.Domain.Enums
@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceApplication.Mappers
@using OperationalWorkspaceUI.State
@using TaskStatus = OperationalWorkspace.Domain.Enums.TaskStatus
@inject IJSRuntime JSRuntime
@inject WorkspaceState State

<div class="task-card @GetCssClass(Task)" @onclick="() => OnSelect.InvokeAsync(Task)">

    <!-- COL 1: IDENTITY -->
    <div class="card-col info-group">
        <div class="card-t">@Task.Title</div>
        <div class="card-c">@Task.CompanyName</div>
    </div>

    <!-- COL 2: STATUS -->
    <div class="card-col status-group">
        <span class="p-chip @Task.Priority.ToString().ToLower()">
            <i class="oi oi-layers"></i> @Task.Priority
        </span>
        <div class="due-text @(TaskRulesEngine.IsOverdue(Task) ? "red-alert" : "")">
            <i class="oi oi-clock"></i> @TaskRulesEngine.DueLabel(Task)
        </div>
    </div>

    <!-- COL 3: SOURCE -->
    <div class="card-col source-group">
        <button class="btn-ghost-link" @onclick="OpenEmail" @onclick:stopPropagation="true">
            <i class="oi oi-circle-check"></i>
            <span>Open Source Email</span>
            <span class="sage-s-box">S</span>
        </button>
    </div>

    <!-- COL 4: MAIN ACTION -->
    <div class="card-col action-group">
        @if (!Task.Completed && Task.Status != TaskStatus.Completed)
        {
            <button class="btn-outline-complete" @onclick="HandleComplete" @onclick:stopPropagation="true">
                <i class="oi oi-envelope-closed"></i>
                <span>Complete</span>
            </button>
        }
        else
        {
            <span class="completed-label"><i class="oi oi-check"></i> Done</span>
        }
    </div>

    <!-- COL 5: SAGE ACTION (FIXED: Triggers OpenSageX3Context onClick safely) -->
    <div class="card-col sage-link-group">
        <button class="btn-blue-square-icon" title="View in Sage X3" @onclick="OpenSageX3Context" @onclick:stopPropagation="true">
            <i class="oi oi-external-link"></i>
        </button>
    </div>
</div>

@code {
    [Parameter] public TaskDto Task { get; set; } = default!;
    [Parameter] public EventCallback<TaskDto> OnSelect { get; set; }

    private string GetCssClass(TaskDto t) => TaskRulesEngine.GetDueState(t) switch
    {
        TaskDueState.Overdue => "border-red-alert",
        TaskDueState.DueToday => "bg-light-blue",
        TaskDueState.Completed => "is-completed-faded",
        _ => ""
    };

    private async Task OpenEmail()
    {
        if (!string.IsNullOrEmpty(Task.OutlookItemId))
        {
            await JSRuntime.InvokeVoidAsync("openOutlookItem", Task.OutlookItemId);
        }
    }

    private async Task OpenSageX3Context()
    {
        // Triggers the JavaScript context lookup pass to fetch ERP row references instantly
        if (!string.IsNullOrEmpty(Task.CompanyName))
        {
            await JSRuntime.InvokeVoidAsync("openSageX3CustomerContext", Task.CompanyName);
        }
    }

    private void HandleComplete()
    {
        Task.Completed = true;
        Task.Status = TaskStatus.Completed;
        Task.UpdatedDate = DateTime.UtcNow;

        State.LogActivity(Task.Title, "Completed Task", "Current User");
        State.Notify();
    }
}
