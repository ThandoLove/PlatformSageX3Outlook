@page "/workspace/orders"
@rendermode InteractiveServer

@using OperationalWorkspaceUI.Components.Pages.Workspace.WorkspaceComponents
@using OperationalWorkspaceUI.UIServices.System
@using OperationalWorkspaceUI.UIServices.Workspace
@using OperationalWorkspaceApplication.DTOs

@inject OrdersUIService OrderService
@inject WorkspaceState WorkspaceState
@inject NavigationService NavigationService
@inject Radzen.NotificationService NotificationService

<h3>Sales Orders</h3>

<WorkspaceHeader Title="Orders" Subtitle="Manage all sales orders" />

<WorkspaceToolbar>
    <button class="btn btn-primary" @onclick="Create">+ New Order</button>
    <button class="btn btn-outline-secondary" @onclick="Refresh">Refresh</button>
</WorkspaceToolbar>

<WorkspaceFilters>
    <FormField Label="Search" @bind-Value="SearchQuery" />
</WorkspaceFilters>

@if (FilteredOrders == null)
{
    <LoadingSpinner />
}
else if (!FilteredOrders.Any())
{
    <EmptyState Message="No orders found." />
}
else
{
    @* FIXED: Passing the method reference 'Open' directly prevents lambda conversion issues *@
    <BpGrid TItem="OpenOrderDto" Items="FilteredOrders.ToList()" OnRowClick="Open">
        <HeaderContent>
            <th>Order #</th>
            <th>Date</th>
            <th>Total</th>
            <th>Status</th>
        </HeaderContent>
        <RowTemplate Context="order">
            <td>@order.OrderNumber</td>
            @* Safe display for nullable date values *@
            <td>@(order.OrderDate?.ToShortDateString() ?? "N/A")</td>
            <td>@order.TotalAmount.ToString("C")</td>
            <td>
                <span class="badge @(order.Status == "Completed" ? "bg-success" : "bg-warning")">
                    @order.Status
                </span>
            </td>
        </RowTemplate>
    </BpGrid>
}

@code {
    private string SearchQuery = string.Empty;

    // FIXED: The Select logic now includes a null-coalescing operator (??)
    // to bridge the gap between nullable DateTime? and non-nullable DateTime.
    private IEnumerable<OpenOrderDto>? FilteredOrders =>
        WorkspaceState.Orders?
            .Select(o => new OpenOrderDto
            {
                Id = o.Id,
                OrderNumber = o.OrderNumber,
                OrderDate = o.OrderDate,
                TotalAmount = o.TotalAmount,
                Status = "Open"
            })
            .Where(o => string.IsNullOrWhiteSpace(SearchQuery)
                     || (o.OrderNumber != null && o.OrderNumber.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)));

    protected override async Task OnInitializedAsync()
    {
        await OrderService.GetOrdersAsync();
    }

    private async Task Refresh()
    {
        await OrderService.GetOrdersAsync();
        
        NotificationService.Notify(new Radzen.NotificationMessage
        {
            Severity = Radzen.NotificationSeverity.Success,
            Summary = "Success",
            Detail = "Orders refreshed",
            Duration = 4000
        });
    }

    private void Create() => NavigationService.NavigateTo("/forms/create-order");

    private void Open(OpenOrderDto order) =>
        NavigationService.NavigateTo($"/workspace/orders/{order.Id}");
}
