@page "/welcome"
@layout EmptyLayout
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop

@implements IAsyncDisposable

@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>Initializing Workspace</PageTitle>

<div class="bootstrap-shell">

    <div class="bootstrap-card">

        <img src="/images/sage-x3-logo.png"
             class="bootstrap-logo" />

        <h2>Connecting Outlook Workspace</h2>

        <p>
            Preparing contextual operational environment...
        </p>

        <div class="bootstrap-status">

            <div class="status-row">
                <span>Office.js</span>
                <span>@OfficeStatus</span>
            </div>

            <div class="status-row">
                <span>Outlook Context</span>
                <span>@ContextStatus</span>
            </div>

            <div class="status-row">
                <span>Email Detection</span>
                <span>@EmailStatus</span>
            </div>

        </div>

        @if (!string.IsNullOrWhiteSpace(CurrentSubject))
        {
            <div class="email-preview">

                <label>Detected Email</label>

                <div class="preview-box">
                    @CurrentSubject
                </div>

            </div>
        }

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="bootstrap-error">
                @ErrorMessage
            </div>
        }

    </div>

</div>

@code {

    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private DotNetObjectReference<Welcome>? _reference;

    private bool _disposed;
    private bool _initialized;

    private string OfficeStatus = "Initializing...";
    private string ContextStatus = "Waiting...";
    private string EmailStatus = "Waiting...";

    private string CurrentSubject = string.Empty;

    private string? ErrorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _initialized || _disposed)
            return;

        _initialized = true;

        try
        {
            OfficeStatus = "Connecting...";

            await SafeRefresh();

            // ============================================
            // CREATE JS CALLBACK REFERENCE
            // ============================================

            _reference =
                DotNetObjectReference.Create(this);

            // ============================================
            // INITIALIZE OFFICE BRIDGE
            // ============================================

            await JS.InvokeVoidAsync(
                "officeBridge.initialize",
                _reference);

            if (_disposed)
                return;

            OfficeStatus = "Connected";

            ContextStatus = "Listening";

            await SafeRefresh();

            // ============================================
            // SMALL BOOTSTRAP DELAY
            // ============================================

            await Task.Delay(1500);

            if (_disposed)
                return;

            // ============================================
            // AUTHENTICATION FLOW
            // ============================================

            if (AuthenticationStateTask is not null)
            {
                var authState =
                    await AuthenticationStateTask;

                if (_disposed)
                    return;

                if (authState.User.Identity?.IsAuthenticated == true)
                {
                    Nav.NavigateTo("/dashboard");
                }
                else
                {
                    Nav.NavigateTo("/");
                }
            }
        }
        catch (JSDisconnectedException)
        {
            // Blazor circuit disconnected safely
        }
        catch (ObjectDisposedException)
        {
            // Component disposed safely
        }
        catch (TaskCanceledException)
        {
            // Navigation interrupted safely
        }
        catch (Exception ex)
        {
            if (_disposed)
                return;

            OfficeStatus = "Failed";

            ErrorMessage =
                $"Bootstrap failed: {ex.Message}";

            await SafeRefresh();
        }
    }

    [JSInvokable]
    public async Task OnEmailReceived(EmailContext context)
    {
        if (_disposed)
            return;

        if (context == null)
            return;

        try
        {
            CurrentSubject = context.Subject;

            EmailStatus = "Connected";

            await SafeRefresh();
        }
        catch (Exception ex)
        {
            Console.WriteLine(
                $"OnEmailReceived failed: {ex.Message}");
        }
    }

    private async Task SafeRefresh()
    {
        if (_disposed)
            return;

        try
        {
            await InvokeAsync(() =>
            {
                if (!_disposed)
                {
                    StateHasChanged();
                }
            });
        }
        catch
        {
            // Ignore disposed renderer errors
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_disposed)
            return;

        _disposed = true;

        try
        {
            _reference?.Dispose();
            _reference = null;
        }
        catch
        {
            // Ignore disposal exceptions safely
        }

        await Task.CompletedTask;
    }

    public class EmailContext
    {
        public string SenderEmail { get; set; } = string.Empty;

        public string SenderName { get; set; } = string.Empty;

        public string Subject { get; set; } = string.Empty;
    }
}