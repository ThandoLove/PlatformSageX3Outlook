@page "/welcome"
@layout EmptyLayout
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Components.Authorization
@implements IAsyncDisposable

@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>Initializing Workspace</PageTitle>

<div class="bootstrap-shell">

    <div class="bootstrap-card">

        <img src="/images/sage-x3-logo.png"
             class="bootstrap-logo" />

        <h2>Connecting Outlook Workspace</h2>

        <p>
            Preparing contextual operational environment...
        </p>

        <div class="bootstrap-status">

            <div class="status-row">
                <span>Office.js</span>
                <span>@OfficeStatus</span>
            </div>

            <div class="status-row">
                <span>Outlook Context</span>
                <span>@ContextStatus</span>
            </div>

            <div class="status-row">
                <span>Email Detection</span>
                <span>@EmailStatus</span>
            </div>

        </div>

        @if (!string.IsNullOrWhiteSpace(CurrentSubject))
        {
            <div class="email-preview">

                <label>Detected Email</label>

                <div class="preview-box">
                    @CurrentSubject
                </div>

            </div>
        }

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="bootstrap-error">
                @ErrorMessage
            </div>
        }

    </div>

</div>

@code {

    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private DotNetObjectReference<Welcome>? _reference;

    private string OfficeStatus = "Initializing...";
    private string ContextStatus = "Waiting...";
    private string EmailStatus = "Waiting...";

    private string CurrentSubject = string.Empty;

    private string? ErrorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        try
        {
            OfficeStatus = "Connecting...";

            _reference =
                DotNetObjectReference.Create(this);

            await JS.InvokeVoidAsync(
                "officeBridge.initialize",
                _reference);

            OfficeStatus = "Connected";

            ContextStatus = "Listening";

            StateHasChanged();

            await Task.Delay(1500);

            if (AuthenticationStateTask is not null)
            {
                var authState =
                    await AuthenticationStateTask;

                if (authState.User.Identity?.IsAuthenticated == true)
                {
                    Nav.NavigateTo("/dashboard");
                }
                else
                {
                    Nav.NavigateTo("/");
                }
            }
        }
        catch (Exception ex)
        {
            OfficeStatus = "Failed";

            ErrorMessage =
                $"Bootstrap failed: {ex.Message}";
        }

        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnEmailReceived(EmailContext context)
    {
        CurrentSubject = context.Subject;

        EmailStatus = "Connected";

        await InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        _reference?.Dispose();

        await Task.CompletedTask;
    }

    public class EmailContext
    {
        public string SenderEmail { get; set; } = string.Empty;

        public string SenderName { get; set; } = string.Empty;

        public string Subject { get; set; } = string.Empty;
    }
}