@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceUI.State
@using Microsoft.FluentUI.AspNetCore.Components
@inject EmailContextState EmailState
@inject WorkspaceState WorkspaceState
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<div class="dashboard-card quick-actions-panel">
    <div class="panel-header">
        <h4>Quick Actions</h4>
    </div>

    <div class="actions-grid">
        <!-- ADD PARTNER / CREATE CONTACT -->
        <button class="action-item" @onclick="CreatePartner">
            <div class="action-icon icon-blue">
                <i class="ms-Icon ms-Icon--AddFriend"></i>
            </div>
            <span>Add Partner</span>
        </button>

        <!-- CREATE QUOTE -->
        <button class="action-item" @onclick="CreateQuote">
            <div class="action-icon icon-orange">
                <i class="ms-Icon ms-Icon--PageAdd"></i>
            </div>
            <span>Create Quote</span>
        </button>

        <!-- ADD SALES ORDER -->
        <button class="action-item" @onclick="CreateOrder">
            <div class="action-icon icon-blue">
                <i class="ms-Icon ms-Icon--ShoppingCart"></i>
            </div>
            <span>Add Sales</span>
        </button>

        <!-- ATTACH EMAIL -->
        <button class="action-item" @onclick="AttachEmail">
            <div class="action-icon icon-green">
                <i class="ms-Icon ms-Icon--Attach"></i>
            </div>
            <span>Attach Email</span>
        </button>

        <!-- ADD TASK -->
        <button class="action-item" @onclick="CreateTask">
            <div class="action-icon icon-blue">
                <i class="ms-Icon ms-Icon--CheckMark"></i>
            </div>
            <span>Add Task</span>
        </button>

        <!-- KNOWLEDGE BASE -->
        <button class="action-item" @onclick="SendKnowledge">
            <div class="action-icon icon-orange">
                <i class="ms-Icon ms-Icon--KnowledgeArticle"></i>
            </div>
            <span>Knowledge</span>
        </button>
    </div>
</div>

@code {
    private async Task CreatePartner() => await ExecuteAction("/forms/create-partner");
    private async Task CreateQuote() => await ExecuteAction("/forms/create-quote");
    private async Task CreateOrder() => await ExecuteAction("/forms/create-order");
    private async Task CreateTask() => await ExecuteAction("/forms/create-task");
    private async Task AttachEmail() => await ExecuteAction("/forms/attach-email");
    private async Task SendKnowledge() => await ExecuteAction("/forms/send-knowledge");

    private async Task ExecuteAction(string route)
    {
        if (EmailState.CurrentEmail != null)
        {
            NavigationManager.NavigateTo(route);
        }
        else
        {
            await JS.InvokeVoidAsync("showToast", "Please select an email first.");
        }
    }
}
