@using Microsoft.FluentUI.AspNetCore.Components
@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons
@using OperationalWorkspaceUI.UIServices.Actions
@using OperationalWorkspaceUI.UIServices.System
@using Radzen
@using FluentOrientation = Microsoft.FluentUI.AspNetCore.Components.Orientation

@* Radzen types are referenced explicitly to avoid enum conflicts with Fluent UI *@

@inject QuickActionUIService ActionService
@inject EmailContextState EmailState
@inject WorkspaceState WorkspaceState
@inject Radzen.NotificationService RadzenNotify
@inject NavigationManager NavigationManager

<FluentCard Style="margin-bottom: 10px; padding: 12px; border-bottom: 4px solid #f2c94c;">
    <FluentStack Orientation="Orientation.Vertical" Spacing="3">
        <FluentLabel Typo="Typography.Header">Quick Actions</FluentLabel>

        <FluentGrid Spacing="2">
            <!-- CREATE ORDER -->
            <FluentGridItem xs="6">
                <FluentButton Appearance="Appearance.Accent"
                              Style="width: 100%;"
                              IconStart="@(new Icons.Regular.Size20.Cart())"
                              OnClick="CreateOrder">
                    Create Order
                </FluentButton>
            </FluentGridItem>

            <!-- CREATE TASK -->
            <FluentGridItem xs="6">
                <FluentButton Appearance="Appearance.Outline"
                              Style="width: 100%;"
                              IconStart="@(new Icons.Regular.Size20.TaskListLtr())"
                              OnClick="CreateTask">
                    Create Task
                </FluentButton>
            </FluentGridItem>

            <!-- ATTACH EMAIL -->
            <FluentGridItem xs="6">
                <FluentButton Appearance="Appearance.Outline"
                              Style="width: 100%;"
                              IconStart="@(new Icons.Regular.Size20.Attach())"
                              OnClick="AttachEmail">
                    Attach Email
                </FluentButton>
            </FluentGridItem>

            <!-- SEND KNOWLEDGE -->
            <FluentGridItem xs="6">
                <FluentButton Appearance="Appearance.Outline"
                              Style="width: 100%;"
                              IconStart="@(new Icons.Regular.Size20.BookInformation())"
                              OnClick="SendKnowledge">
                    Knowledge
                </FluentButton>
            </FluentGridItem>
        </FluentGrid>
    </FluentStack>
</FluentCard>

@code {
    [Parameter] public string? EmailId { get; set; }

    private void CreateOrder()
    {
        if (EmailState.CurrentEmail != null)
        {
            WorkspaceState.PreFillOrderFromEmail(EmailState.CurrentEmail);
            NavigationManager.NavigateTo("/forms/create-order");
        }
        else
        {
            ShowNoEmailError();
        }
    }

    private void CreateTask()
    {
        if (EmailState.CurrentEmail != null)
        {
            WorkspaceState.PreFillTaskFromEmail(EmailState.CurrentEmail);
            NavigationManager.NavigateTo("/forms/create-task");
        }
        else
        {
            ShowNoEmailError();
        }
    }

    private void AttachEmail()
    {
        if (EmailState.CurrentEmail != null)
        {
            NavigationManager.NavigateTo($"/forms/attach-email?emailId={EmailState.CurrentEmail.MessageId}");
        }
        else
        {
            ShowNoEmailError();
        }
    }

    private void SendKnowledge()
    {
        if (EmailState.CurrentEmail != null)
        {
            NavigationManager.NavigateTo($"/forms/send-knowledge?emailId={EmailState.CurrentEmail.MessageId}");
        }
        else
        {
            ShowNoEmailError();
        }
    }

    private void ShowNoEmailError()
    {
        RadzenNotify.Notify(new NotificationMessage
        {
            Style = "position: absolute; z-index: 9999;",
            Severity = NotificationSeverity.Error,
            Summary = "Action Required",
            Detail = "Please select an email in Outlook first.",
            Duration = 4000
        });
    }
}
