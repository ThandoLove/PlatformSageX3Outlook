@using OperationalWorkspaceUI.State
@using OperationalWorkspaceUI.UIServices.System
@using OperationalWorkspaceUI.Components.Pages.Forms
@inject EmailContextState EmailState
@inject ModalService ModalService
@inject IJSRuntime JS

<FluentCard Style="width: 100%; padding: 16px; border-radius: 8px;">
    @* Panel Header *@
    <div class="panel-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <h3 style="margin: 0; font-size: 1.1rem; font-weight: 600; color: #333;">Quick Actions</h3>
        <FluentIcon Value="@(new Icons.Regular.Size16.ChevronDown())" Color="Color.Neutral" />
    </div>

    @* Icons Container (Exactly like the image) *@
    <div class="actions-container" style="display: flex; justify-content: space-around; align-items: flex-start; text-align: center;">
        
        @* Add Partner (Create Contact) *@
        <div class="action-item" style="cursor:pointer;" @onclick='() => OpenModal<NewContactForm>("Add Business Partner")'>
            <div class="icon-circle circle-blue">
                <FluentIcon Value="@(new Icons.Regular.Size24.PersonAdd())" Color="Color.Custom" CustomColor="white" />
            </div>
            <div class="action-label">Add Partner</div>
        </div>

        @* Link to Existing *@
        <div class="action-item" style="cursor:pointer;" @onclick='() => NavigateToSage("GESBPR", "LINK")'>
            <div class="icon-circle circle-teal">
                <FluentIcon Value="@(new Icons.Regular.Size24.Link())" Color="Color.Custom" CustomColor="white" />
            </div>
            <div class="action-label">Link Existing</div>
        </div>

        @* Create Quote (Orange Icon in image) *@
        <div class="action-item" style="cursor:pointer;" @onclick='() => OpenModal<CreateQuoteForm>("Create Sage Quote")'>
            <div class="icon-circle circle-orange">
                <FluentIcon Value="@(new Icons.Regular.Size24.DocumentAdd())" Color="Color.Custom" CustomColor="white" />
            </div>
            <div class="action-label">Create Quote</div>
        </div>

        @* Add Sales (Sales Order) *@
        <div class="action-item" style="cursor:pointer;" @onclick='() => OpenModal<AddSalesOrderForm>("New Sales Order")'>
            <div class="icon-circle circle-indigo">
                <FluentIcon Value="@(new Icons.Regular.Size24.Cart())" Color="Color.Custom" CustomColor="white" />
            </div>
            <div class="action-label">Add Sales</div>
        </div>

        @* Create Invoice *@
        <div class="action-item" style="cursor:pointer;" @onclick='() => NavigateToSage("GESPNH", "NEW")'>
            <div class="icon-circle circle-blue-dark">
                <FluentIcon Value="@(new Icons.Regular.Size24.Document())" Color="Color.Custom" CustomColor="white" />
            </div>
            <div class="action-label">Create Invoice</div>
        </div>

        @* Attach Email (Green Icon matching your workspace logic) *@
        <div class="action-item" style="cursor:pointer;" @onclick='() => OpenModal<AttachEmailForm>("Attach Email to Sage")'>
            <div class="icon-circle circle-green">
                <FluentIcon Value="@(new Icons.Regular.Size24.Attach())" Color="Color.Custom" CustomColor="white" />
            </div>
            <div class="action-label">Attach Email</div>
        </div>

    </div>
</FluentCard>

@code {
    private async Task OpenModal<TComponent>(string title) where TComponent : IComponent
    {
        if (EmailState.CurrentEmail == null)
        {
            await JS.InvokeVoidAsync("showToast", "Please select an email first.");
            return;
        }

        await ModalService.ShowModal(title, builder =>
        {
            builder.OpenComponent<TComponent>(0);
            builder.AddAttribute(1, "Email", EmailState.CurrentEmail.SenderEmail);
            builder.AddAttribute(2, "FullName", EmailState.CurrentEmail.SenderName);
            builder.CloseComponent();
        });
    }

    private async Task NavigateToSage(string functionCode, string action)
    {
        // LOGIC: Direct Sage X3 navigation via your officebridge.js
        await JS.InvokeVoidAsync("officeBridge.openSageRecord", functionCode, action);
    }
}
