@using OperationalWorkspaceUI.State
@using OperationalWorkspaceUI.UIServices.System
@using OperationalWorkspaceUI.Components.Pages.Forms

@inject EmailContextState EmailState
@inject ModalService ModalService
@inject IJSRuntime JS

<div class="dashboard-card quick-actions-panel">
    <div class="panel-header">
        <h4>Quick Actions</h4>
    </div>

    <div class="actions-grid">
        @* ADD PARTNER *@
        <button class="action-item" @onclick='() => OpenModal<NewContactForm>("Add Business Partner")'>
            <div class="action-icon icon-blue">
                <i class="ms-Icon ms-Icon--AddFriend"></i>
            </div>
            <span>Add Partner</span>
        </button>

        @* CREATE QUOTE *@
        <button class="action-item" @onclick='() => OpenModal<CreateQuoteForm>("Create Sage Quote")'>
            <div class="action-icon icon-orange">
                <i class="ms-Icon ms-Icon--PageAdd"></i>
            </div>
            <span>Create Quote</span>
        </button>

        @* ADD SALES *@
        <button class="action-item" @onclick='() => OpenModal<AddSalesOrderForm>("New Sales Order")'>
            <div class="action-icon icon-blue">
                <i class="ms-Icon ms-Icon--ShoppingCart"></i>
            </div>
            <span>Add Sales</span>
        </button>

        @* ATTACH EMAIL *@
        <button class="action-item" @onclick='() => OpenModal<AttachEmailForm>("Attach Email to Sage")'>
            <div class="action-icon icon-green">
                <i class="ms-Icon ms-Icon--Attach"></i>
            </div>
            <span>Attach Email</span>
        </button>

        @* ADD TASK *@
        <button class="action-item" @onclick='() => OpenModal<CreateTaskForm>("Assign New Task")'>
            <div class="action-icon icon-blue">
                <i class="ms-Icon ms-Icon--CheckMark"></i>
            </div>
            <span>Add Task</span>
        </button>

        @* KNOWLEDGE *@
        <button class="action-item" @onclick='() => OpenModal<SendKnowledgeForm>("Sage Knowledge Base")'>
            <div class="action-icon icon-orange">
                <i class="ms-Icon ms-Icon--KnowledgeArticle"></i>
            </div>
            <span>Knowledge</span>
        </button>
    </div>
</div>

@code {
    private async Task OpenModal<TComponent>(string title) where TComponent : IComponent
    {
        if (EmailState.CurrentEmail == null)
        {
            await JS.InvokeVoidAsync("showToast", "Please select an email first.");
            return;
        }

        // Opens the specific form component inside the Modal
        await ModalService.ShowModal(title, builder =>
        {
            builder.OpenComponent<TComponent>(0);
            
            // Passes Outlook context to the form parameters
            builder.AddAttribute(1, "Email", EmailState.CurrentEmail.SenderEmail);
            builder.AddAttribute(2, "FullName", EmailState.CurrentEmail.SenderName);
            
            builder.CloseComponent();
        });
    }
}
