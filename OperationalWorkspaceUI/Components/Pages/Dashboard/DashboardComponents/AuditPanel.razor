@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceUI.State
@using Microsoft.FluentUI.AspNetCore.Components
@implements IDisposable
@inject DashboardState State

<FluentCard Style="width: 100%; padding: 16px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.05);">
    @* Panel Header *@
    <div class="panel-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
        <h3 style="margin: 0; font-size: 1.1rem; font-weight: 600; color: #333;">System Audit Logs</h3>
        @* Fix 1: Full path for Icon and Color *@
        <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size16.ShieldCheckmark())"
                    Color="@Microsoft.FluentUI.AspNetCore.Components.Color.Accent" />
    </div>

    <div class="audit-list" style="display: flex; flex-direction: column; gap: 12px; max-height: 300px; overflow-y: auto;">
        @if (State.CurrentAuditLogs != null && State.CurrentAuditLogs.Any())
        {
            @foreach (var log in State.CurrentAuditLogs.OrderByDescending(l => l.Timestamp))
            {
                <div class="audit-item" style="display: flex; gap: 12px; align-items: flex-start; padding-bottom: 8px; border-bottom: 1px solid #f1f5f9;">
                    <div style="margin-top: 2px;">
                        @* Fix 2: Explicit Color and IconSize *@
                        <FluentIcon Value="@GetAuditIcon(log.Entity)"
                                    Size="@Microsoft.FluentUI.AspNetCore.Components.IconSize.Size16"
                                    Color="@Microsoft.FluentUI.AspNetCore.Components.Color.Neutral" />
                    </div>

                    <div class="audit-details" style="flex-grow: 1;">
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <span style="font-size: 0.9rem; font-weight: 600; color: #1e293b;">@log.Action</span>
                            <span style="font-size: 0.75rem; color: #94a3b8;">@log.Timestamp.ToString("HH:mm")</span>
                        </div>
                        <div style="font-size: 0.8rem; color: #64748b;">
                            <strong>@log.User</strong> affected <strong>@log.Entity</strong>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div style="padding: 20px; text-align: center; color: #94a3b8;">
                <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size24.History())"
                            Color="@Microsoft.FluentUI.AspNetCore.Components.Color.Neutral" />
                <p style="font-size: 0.85rem; margin-top: 8px;">No audit events recorded.</p>
            </div>
        }
    </div>

    <div style="margin-top: 16px; border-top: 1px solid #f1f5f9; padding-top: 12px; text-align: center;">
        <FluentAnchor Appearance="Appearance.Lightweight" Href="#" Style="color: #3b82f6; font-weight: 600;">
            View Full Audit Trail →
        </FluentAnchor>
    </div>
</FluentCard>

@code {
   
    [Parameter] public List<AuditLogDto>? Logs { get; set; } = new();

   

    protected override void OnInitialized()
    {
        State.OnChange += StateHasChanged;
    }

    // Fix 3: Full path for Return Type 'Icon'
    private Microsoft.FluentUI.AspNetCore.Components.Icon GetAuditIcon(string entity) => entity?.ToLower() switch
    {
        "auth" => new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size16.LockClosed(),
        "invoice" => new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size16.Money(),
        "ticket" => new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size16.TicketDiagonal(),
        "report" => new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size16.Poll(),
        _ => new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size16.History()
    };

    public void Dispose()
    {
        State.OnChange -= StateHasChanged;
    }
}
