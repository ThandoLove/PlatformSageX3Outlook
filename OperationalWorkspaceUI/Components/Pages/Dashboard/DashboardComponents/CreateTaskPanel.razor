@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceUI.State
@using OperationalWorkspaceUI.UIServices.DashboardUI
@inject DashboardState State
@inject DashboardUIService DashboardService
@inject IJSRuntime JS

<FluentCard Style="width: 100%; padding: 16px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.05);">
    <div class="panel-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
        <h3 style="margin: 0; font-size: 1.1rem; font-weight: 600; color: #333;">Create Task (Admin)</h3>
        <FluentIcon Value="@(new Icons.Regular.Size16.ChevronDown())" Color="Color.Neutral" />
    </div>

    <div class="task-form" style="display: flex; flex-direction: column; gap: 16px;">
        
        @* Task Title *@
        <FluentTextField @bind-Value="_newTask.Title" Placeholder="Task Title..." Style="width: 100%;" />

        @* Assignee Select *@
        <FluentSelect Label="Assign To" Style="width: 100%;" @bind-Value="_newTask.AssignedTo">
            <FluentIcon Value="@(new Icons.Regular.Size20.Person())" Slot="start" />
            <FluentSelectOption Value="Admin">Admin</FluentSelectOption>
            <FluentSelectOption Value="CurrentUser">Current User</FluentSelectOption>
            <FluentSelectOption Value="Sarah Johnson">Sarah Johnson</FluentSelectOption>
        </FluentSelect>

        @* Due Date Picker *@
        <FluentDatePicker Label="Due Date" @bind-Value="_newTask.DueDate" Style="width: 100%;" />

        @* Priority Selection (Exactly like Image) *@
        <div class="priority-selector" style="display: flex; gap: 4px; background: #f1f5f9; padding: 4px; border-radius: 6px;">
            @foreach (var p in new[] { 1, 3, 5 })
            {
                <button type="button" 
                        class="priority-btn @(GetPriorityClass(p)) @(_newTask.Priority == p ? "active" : "")"
                        @onclick="() => _newTask.Priority = p">
                    @GetPriorityLabel(p)
                </button>
            }
        </div>

        @* Action Button *@
        <FluentButton Appearance="Appearance.Accent" 
                      OnClick="HandleCreateTask"
                      Style="width: 100%; height: 42px; background-color: #005fb8; font-weight: 600;">
            Create Task
        </FluentButton>
    </div>
</FluentCard>

@code {
    private TaskDto _newTask = new() { DueDate = DateTime.Today, Priority = 3, AssignedTo = "Admin" };

    private async Task HandleCreateTask()
    {
        if (string.IsNullOrWhiteSpace(_newTask.Title)) return;

        // 1. Logic: Add to State list so "My Tasks" updates immediately
        State.AllTasks.Add(new TaskDto 
        { 
            Id = Guid.NewGuid(),
            Title = _newTask.Title,
            DueDate = _newTask.DueDate ?? DateTime.Today,
            Priority = _newTask.Priority,
            AssignedTo = _newTask.AssignedTo,
            Status = "Open"
        });

        // 2. Mock API call via Service
        await JS.InvokeVoidAsync("showToast", $"Task assigned to {_newTask.AssignedTo}");

        // 3. Reset Form
        _newTask = new() { DueDate = DateTime.Today, Priority = 3, AssignedTo = "Admin" };
        
        // 4. Refresh Dashboard
        await State.LoadDashboardAsync();
    }

    private string GetPriorityLabel(int p) => p switch { 1 => "Low", 3 => "Medium", 5 => "High", _ => "" };
    
    private string GetPriorityClass(int p) => p switch { 5 => "high-btn", _ => "" };
}
