@using System.Linq
@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspace.Domain.Enums

@using OperationalWorkspaceUI.State
@inject DashboardState State

<div class="dashboard-card tasks-panel">
    <div class="panel-header">
        <div class="header-main">
            <h4>My Tasks</h4>
            <span class="task-count">@Tasks.Count(t => t.Status != "Completed") Pending</span>
        </div>
        <button class="btn-add-task">View All</button>
    </div>

    <div class="task-list">
        @if (Tasks != null && Tasks.Any())
        {
            @foreach (var task in Tasks)
            {
                <div class="task-item @(task.Status.ToLower() == "completed" ? "is-done" : "")">
                    <div class="task-checkbox">
                        @if (task.Status.ToLower() == "completed")
                        {
                            <i class="ms-Icon ms-Icon--CompletedSolid"></i>
                        }
                        else
                        {
                            <i class="ms-Icon ms-Icon--CircleRing"></i>
                        }
                    </div>
                    <div class="task-info">
                        <span class="task-title">@task.Title</span>
                        @if (task.Priority != default(TaskPriority))
                        {
                            <span class="task-priority @(task.Priority.ToString().ToLower())">@task.Priority</span>
                        }
                    </div>
                    <div class="task-actions">
                        <i class="ms-Icon ms-Icon--More"></i>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-task-state">
                <i class="ms-Icon ms-Icon--CheckMark"></i>
                <p>All caught up!</p>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public List<TaskDto> Tasks { get; set; } = new();

    protected override void OnInitialized()
    {
        // Auto-subscribe to state changes if tasks aren't passed as a parameter
        if (Tasks == null || !Tasks.Any())
        {
            Tasks = State.CurrentTasks;
        }
    }
}
