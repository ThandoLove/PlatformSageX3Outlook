@inject DashboardState State

<div class="dashboard-panel tasks-panel">
    <h4>Tasks</h4>
    @* 1. Change State.Tasks to State.AllTasks (or State.MyTasks) *@
    @if (State.AllTasks != null && State.AllTasks.Any())
    {
        <ul>
            @foreach (var task in State.AllTasks)
            {
                @* 2. Ensure TaskDto has Title and Status properties *@
                <li>@task.Title (@task.Status)</li>
            }
        </ul>
    }
    else
    {
        <EmptyState Message="No tasks available." />
    }
</div>
