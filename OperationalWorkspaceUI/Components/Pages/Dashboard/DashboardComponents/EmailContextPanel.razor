@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons
@using Microsoft.FluentUI.AspNetCore.Components
@using OperationalWorkspaceApplication.ApplicationState
@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceUI.State
@using OperationalWorkspaceUI.UIServices.EmailService

@implements IDisposable

@inject EmailContextState State
@inject AppStateContainer AppState
@inject EmailContextUIService EmailService
@inject WorkspaceState WorkspaceState

<FluentCard Class="email-insight-card">

    <!-- PANEL HEADER -->
    <div class="panel-header">

        <h3>Email Insight</h3>

        @if (State.IsLoading)
        {
            <FluentProgressRing Style="width:16px;height:16px;" />
        }

    </div>

    @if (State.IsLoading)
    {
        <div class="loading-overlay">

            <FluentProgressRing />

            <span>
                Sage X3 AI is analyzing...
            </span>

        </div>
    }
    else
    {
        <div class="insight-content">

            <!-- CONTACT ROW -->
            <div class="detail-row">

                <div class="avatar">

                    @(
                        !string.IsNullOrEmpty(
                            AppState.CurrentEmail?.SenderName)
                            ? AppState.CurrentEmail
                                .SenderName
                                .Substring(0, 1)
                            : "?"
                     )

                </div>

                <div class="text-group">

                    <span class="label">
                        CONTACT
                    </span>

                    <div class="value-container">

                        <span class="value link">

                            @(
                                AppState.CurrentEmail
                                    ?.SenderName
                                ?? "Select an Email"
                             )

                        </span>

                        @if (AppState.MatchedClient != null)
                        {
                            <span class="status-badge-linked">
                                Linked
                            </span>
                        }

                    </div>

                </div>

            </div>

            <!-- COMPANY ROW -->
            <div class="detail-row no-avatar">

                <div class="text-group">

                    <span class="label">
                        COMPANY
                    </span>

                    <span class="value">

                        @(
                            AppState.MatchedClient?.FullName
                            ?? "Unknown Entity"
                         )

                    </span>

                </div>

            </div>

            <!-- INTENT ROW -->
            <div class="detail-row no-avatar">

                <div class="text-group">

                    <span class="label">
                        INTENT
                    </span>

                    <div class="intent-value">

                        <FluentIcon Value="@(new Icons.Regular.Size16.Flash())"
                                    Color="@Color.Accent" />

                        <span>

                            @(
                                AppState.CurrentEmail?.Subject
                                ?? "Analyzing Context..."
                             )

                        </span>

                    </div>

                </div>

            </div>

            <!-- AI SUMMARY -->
            <div class="ai-summary-box">

                <span class="ai-label">
                    AI SUMMARY
                </span>

                <p>

                    @(
                        !string.IsNullOrEmpty(
                            AppState.CurrentEmail?.Message)
                            ? AppState.CurrentEmail.Message
                            : "Waiting for email selection..."
                     )

                </p>

            </div>

        </div>
    }

</FluentCard>

@code {
    // ======================================================
    // OPTIONAL EXTERNAL DATA PARAMETER
    // ======================================================
    [Parameter]
    public EmailInsightDto? Data { get; set; }

    // ======================================================
    // INITIALIZATION & DISPOSAL PIPES
    // ======================================================
    protected override void OnInitialized()
    {
        State.OnChange += HandleStateChanged;
        AppState.OnChange += HandleStateChanged;
    }

    private void HandleStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        State.OnChange -= HandleStateChanged;
        AppState.OnChange -= HandleStateChanged;
    }
}
