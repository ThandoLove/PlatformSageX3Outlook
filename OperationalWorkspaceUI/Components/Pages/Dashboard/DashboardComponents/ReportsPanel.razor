@using OperationalWorkspaceUI.State

@using Microsoft.FluentUI.AspNetCore.Components
@inject DashboardState State
@* Fix 3: Explicitly inject YOUR service to avoid FluentUI conflict *@
@inject OperationalWorkspaceUI.UIServices.ToastUIService.ToastService CustomToast

@inject IJSRuntime JS

<FluentCard Class="reports-card">
    <div class="panel-header reports-header">
        <h3 class="reports-title">Sage X3 Reports</h3>
        @* Fix 4: Fully qualified icon path *@
        <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size16.Poll())"
                    Color="@Microsoft.FluentUI.AspNetCore.Components.Color.Accent" />
    </div>

    <div class="report-list">
        @{
            var reportNames = new[] { "Aged Receivables (Invoices)", "Open Tickets Summary", "Daily Sales Order Log" };
        }

        @foreach (var report in reportNames.Take(2))
        {
            <div class="report-card">
                <div class="report-card-title">@report</div>
                <div class="report-card-actions">
                    <FluentButton Appearance="Appearance.Outline"
                                  OnClick="@(() => HandleExport(report, "PDF"))"
                                  Class="report-action-btn">
                        <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size16.DocumentPdf())"
                                    Slot="start"
                                    Color="@Microsoft.FluentUI.AspNetCore.Components.Color.Error" />
                        PDF
                    </FluentButton>
                    
                    <FluentButton Appearance="Appearance.Outline"
                                  OnClick="@(() => HandleExport(report, "XLSX"))"
                                  Class="report-action-btn">
                        <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size16.Table())"
                                    Slot="start"
                                    Color="@Microsoft.FluentUI.AspNetCore.Components.Color.Success" />
                        Excel
                    </FluentButton>
                </div>
            </div>
        }
    </div>
</FluentCard>

@code {
    private async Task HandleExport(string reportName, string format)
    {
        // Fix 5: Use helper methods (ShowInfo/ShowSuccess) to avoid ToastIntent/string errors
        CustomToast.ShowInfo($"Sage X3: Generating {reportName}...");

        await JS.InvokeVoidAsync("officeBridge.exportReport", reportName, format);

        await Task.Delay(2500);

        CustomToast.ShowSuccess($"{format} Download Ready");
    }
}
