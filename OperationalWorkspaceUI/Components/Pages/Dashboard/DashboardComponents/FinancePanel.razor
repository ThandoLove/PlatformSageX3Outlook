@using OperationalWorkspaceApplication.DTOs
@using Microsoft.FluentUI.AspNetCore.Components
@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons

<FluentCard Class="finance-widget-card">
    <div class="panel-header">
        <h3>Financial Overview</h3>
        <FluentIcon Value="@(new Icons.Regular.Size16.Money())" Color="@Color.Neutral" />
    </div>

    <div class="finance-content">
        @if (Data is AdminFinanceDto admin)
        {
            <!-- ADMIN VIEW: Matching your specific DTO names -->
            <div class="finance-stat-grid">
                <div class="stat-item">
                    <span class="stat-label">Total Revenue</span>
                    <span class="stat-value">@admin.TotalRevenue.ToString("C0")</span>
                </div>
                <div class="stat-item">
                    <span class="stat-label">Sales This Month</span>
                    <span class="stat-value">@admin.TotalSalesThisMonth.ToString("C0")</span>
                </div>
                <div class="stat-item warning">
                    <span class="stat-label">Total Overdue</span>
                    <span class="stat-value">@admin.TotalOverdue.ToString("C0")</span>
                </div>
            </div>
        }
        else if (Data is EmployeeFinanceDto employee)
        {
            <!-- EMPLOYEE VIEW: Matching your specific DTO names -->
            <div class="finance-stat-grid">
                <div class="stat-item">
                    <span class="stat-label">Sales This Month</span>
                    <span class="stat-value">@employee.ThisMonthSales.ToString("C0")</span>
                </div>
                <div class="stat-item warning">
                    <span class="stat-label">Outstanding Rec.</span>
                    <span class="stat-value">@employee.OutstandingReceivables.ToString("C0")</span>
                </div>
            </div>
        }
        else
        {
            <div class="finance-empty">
                <FluentProgressRing Style="width:24px; height:24px;" />
                <p>Loading Sage X3 Financials...</p>
            </div>
        }
    </div>
</FluentCard>

@code {
    [Parameter]
    public object? Data { get; set; }
}
