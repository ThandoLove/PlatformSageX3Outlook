@using OperationalWorkspaceUI.State
@using Microsoft.FluentUI.AspNetCore.Components
@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons
@using OperationalWorkspaceApplication.DTOs

@implements IDisposable
@inject DashboardState State

<div class="health-widget-card">

    @* HEADER PANEL *@
    <div class="panel-header">
        <h3>System Health</h3>
        <FluentIcon Value="@(new Icons.Regular.Size16.ChevronDown())" Color="@Color.Neutral" />
    </div>

    @* DATA STATUS LIST *@
    <div class="health-content">

        <!-- Sage X3 ERP Status -->
        <div class="status-item">
            <div class="status-info">
                <span class="status-label">Sage X3 ERP</span>
                <span class="status-pill @(State.AdminHealth?.SageX3Connected == true ? "status-online" : "status-offline")">
                    @if (State.AdminHealth?.SageX3Connected == true)
                    {
                        <span class="pulse-dot"></span>
                    }
                    @(State.AdminHealth?.SageX3Connected == true ? "Connected" : "Disconnected")
                </span>
            </div>
            <div class="status-meta">Primary ERP Endpoint</div>
        </div>

        <!-- API Gateway Health -->
        <div class="status-item">
            <div class="status-info">
                <span class="status-label">API Gateway</span>
                <span class="status-pill @(State.AdminHealth?.APIHealthStatus == "Healthy" ? "status-online" : "status-warning")">
                    @(State.AdminHealth?.APIHealthStatus ?? "Unknown")
                </span>
            </div>
            <div class="status-meta">Gateway Connectivity</div>
        </div>

        <!-- Transaction Sync Status -->
        <div class="status-item">
            <div class="status-info">
                <span class="status-label">Failed Syncs</span>
                <span class="status-pill @(State.AdminHealth?.FailedTransactions > 0 ? "status-warning" : "status-online")">
                    @(State.AdminHealth?.FailedTransactions == -1 ? 0 : State.AdminHealth?.FailedTransactions) Errors
                </span>
            </div>
            <div class="status-meta">Pending Retry Queue</div>
        </div>

    </div>
    @* FOOTER PANEL BAR *@
    <div class="health-footer">
        <span class="refresh-label">Last updated: @_lastUpdated</span>
        <FluentButton Appearance="Appearance.Stealth"
                      Class="fluent-button-stealth-override"
                      IconStart="@(new Icons.Regular.Size16.ArrowClockwise())"
                      OnClick="ManualRefresh"
                      Loading="_isRefreshing"
                      Title="Refresh Now" />
    </div>

</div>

@code {
    [Parameter]
    public AdminSystemHealthDto? Status { get; set; }

    private System.Threading.Timer? _refreshTimer;
    private string _lastUpdated = DateTime.Now.ToString("HH:mm:ss");
    private bool _isRefreshing = false;

    protected override void OnInitialized()
    {
        State.OnChange += Refresh;

        _refreshTimer = new System.Threading.Timer(async _ =>
        {
            await ManualRefresh();
        }, null, TimeSpan.FromSeconds(60), TimeSpan.FromSeconds(60));
    }

    private void Refresh()
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task ManualRefresh()
    {
        await InvokeAsync(async () =>
        {
            _isRefreshing = true;
            StateHasChanged();

            await State.LoadDashboardAsync();

            _lastUpdated = DateTime.Now.ToString("HH:mm:ss");
            _isRefreshing = false;
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        State.OnChange -= Refresh;
        _refreshTimer?.Dispose();
    }
}
