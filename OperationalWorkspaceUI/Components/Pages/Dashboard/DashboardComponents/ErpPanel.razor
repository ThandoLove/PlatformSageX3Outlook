@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceUI.State
@using Microsoft.FluentUI.AspNetCore.Components
@implements IDisposable
@inject DashboardState State

<FluentCard Style="width: 100%; padding: 16px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.05);">
    @* Panel Header *@
    <div class="panel-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
        <h3 style="margin: 0; font-size: 1.1rem; font-weight: 600; color: #333;">ERP Snapshot</h3>
        <div style="background-color: #f0fdf4; color: #16a34a; border: 1px solid #dcfce7; padding: 2px 10px; border-radius: 12px; font-size: 0.75rem; font-weight: 600;">Linked</div>
    </div>

    @* KPI Grid *@
    <div class="kpi-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
        @if (State.IsAdminEnvironment)
        {
            @* Admin View: Focus on Global Production/Stock *@
            <div class="kpi-item">
                <div style="font-size: 0.8rem; color: #64748b; margin-bottom: 4px;">Daily Orders</div>
                <div style="display: flex; align-items: center; gap: 8px;">
                    <div style="font-size: 1.5rem; font-weight: 700; color: #005fb8;">@State.AdminErp.TotalOrdersToday</div>
                    @* Fix: Full path for Icon and Color *@
                    <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.Cart())"
                                Color="@Microsoft.FluentUI.AspNetCore.Components.Color.Accent" />
                </div>
            </div>

            <div class="kpi-item">
                <div style="font-size: 0.8rem; color: #64748b; margin-bottom: 4px;">Stock Alerts</div>
                <div style="display: flex; align-items: center; gap: 8px;">
                    <div style="font-size: 1.5rem; font-weight: 700; color: #ef4444;">@State.AdminErp.StockAlerts</div>
                    <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.Warning())"
                                Color="@Microsoft.FluentUI.AspNetCore.Components.Color.Error" />
                </div>
            </div>
        }
        else
        {
            @* Employee View: Focus on Personal Sales Context *@
            <div class="kpi-item">
                <div style="font-size: 0.8rem; color: #64748b; margin-bottom: 4px;">My Open Orders</div>
                <div style="display: flex; align-items: center; gap: 8px;">
                    <div style="font-size: 1.5rem; font-weight: 700; color: #005fb8;">@State.EmployeeErp.MyOpenOrders</div>
                    <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.DocumentData())"
                                Color="@Microsoft.FluentUI.AspNetCore.Components.Color.Accent" />
                </div>
            </div>

            <div class="kpi-item">
                <div style="font-size: 0.8rem; color: #64748b; margin-bottom: 4px;">Pending Deliveries</div>
                <div style="display: flex; align-items: center; gap: 8px;">
                    <div style="font-size: 1.5rem; font-weight: 700; color: #16a34a;">@State.EmployeeErp.PendingDeliveries</div>
                    <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.VehicleTruck())"
                                Color="@Microsoft.FluentUI.AspNetCore.Components.Color.Success" />
                </div>
            </div>
        }
    </div>

    @* Integration: Footer Action for Sage X3 Entry *@
    <div style="margin-top: 20px; border-top: 1px solid #f1f5f9; padding-top: 12px;">
        <FluentButton Appearance="Appearance.Lightweight"
                      Style="width: 100%; color: #3b82f6; font-weight: 600;"
                      OnClick="@(() => State.LoadDashboardAsync())">
            Refresh ERP Data
        </FluentButton>
    </div>
</FluentCard>

@code {
    protected override void OnInitialized()
    {
        State.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        State.OnChange -= StateHasChanged;
    }
}
