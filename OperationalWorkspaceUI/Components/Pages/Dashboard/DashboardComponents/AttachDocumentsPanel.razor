@rendermode InteractiveServer

@using OperationalWorkspaceUI.State
@using Microsoft.FluentUI.AspNetCore.Components
@using OperationalWorkspaceApplication.DTOs
@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons

@inject WorkspaceState WorkspaceState
@inject OperationalWorkspaceUI.UIServices.Workspace.AttachmentUIService AttachmentService
@inject OperationalWorkspaceUI.UIServices.ToastUIService.ToastService CustomToastService
@inject NavigationManager NavManager
@inject IJSRuntime JS

<FluentCard Class="attach-card">
    
    @* LIVE OVERLAY: Only shows when WorkspaceState.IsUploading is true *@
    @if (WorkspaceState.IsUploading)
    {
        <div class="upload-overlay">
            <FluentProgressRing Class="overlay-ring" />
            <span class="overlay-text">Processing Upload...</span>
        </div>
    }

    @* HEADER *@
    <div class="panel-header">
        <h3 class="panel-title">Documents</h3>
        <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => UploadToEmail())" Class="panel-action">
            <FluentIcon Value="@(new Icons.Regular.Size20.ArrowUpload())" Color="@Color.Accent" />
        </FluentButton>
    </div>

    @* SEARCH *@
    <div class="search-row">
        <FluentSearch Placeholder="Search files..." @bind-Value="_searchQuery" @bind:event="oninput" Class="search-full" />
    </div>

    @* DOCUMENT LIST *@
    <div class="document-list">
        @if (WorkspaceState.Attachments == null)
        {
            <div class="loading-placeholder">
                <FluentProgressRing Class="loading-ring" />
            </div>
        }
        else if (!FilteredAttachments.Any())
        {
            <p class="no-docs">No documents found.</p>
        }
        else
        {
            @* Show only the 2 most recent attachments to keep the card compact; latest first *@
            @foreach (var doc in FilteredAttachments.OrderByDescending(d => d.UploadedAtUtc).Take(2))
            {
                <div class="doc-item">
                    <FluentIcon Value="@GetFileIcon(doc.FileName)" Color="@GetIconColor(doc.FileName)" />
                    <div class="doc-name-cell">
                        <div class="doc-filename">@doc.FileName</div>
                    </div>
                    <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Attach())" OnClick="@(() => Attach(doc.FileName))" />
                </div>
            }
        }
    </div>

    @* FOOTER *@
    <div class="panel-footer">
        <FluentButton Appearance="Appearance.Stealth" Class="panel-footer-btn" OnClick="@(() => NavManager.NavigateTo("/attachments"))">
            Go to Attachments &nbsp; <FluentIcon Value="@(new Icons.Regular.Size16.Open())" />
        </FluentButton>
    </div>
</FluentCard>

@code {
    private string _searchQuery = "";

    private IEnumerable<AttachmentDto> FilteredAttachments =>
        (WorkspaceState.Attachments ?? new List<AttachmentDto>())
            .Where(d => string.IsNullOrWhiteSpace(_searchQuery) || d.FileName.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        // Sync with the global state event so the overlay appears instantly
        WorkspaceState.OnChange += Refresh;

        if (WorkspaceState.Attachments == null)
        {
            var fileNames = await AttachmentService.GetAttachmentsAsync();
            WorkspaceState.Attachments = fileNames.Select(name => new AttachmentDto(
                Guid.NewGuid(), name, "application/octet-stream", 0, $"/files/{name}", "General", DateTime.UtcNow
            )).ToList();
        }
    }

    private void Refresh()
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task Attach(string fileName)
    {
        await JS.InvokeVoidAsync("officeBridge.attachDocument", "GENERAL", fileName);
        CustomToastService.ShowSuccess($"{fileName} attached");
    }

    private async Task UploadToEmail()
    {
        WorkspaceState.SetUploading(true);
        try
        {
            await JS.InvokeVoidAsync("officeBridge.uploadCurrentDocument", "EMAIL_ATTACHMENT");
            CustomToastService.ShowSuccess("Uploading...");
        }
        finally
        {
            WorkspaceState.SetUploading(false);
        }
    }

    // Clean up to prevent memory leaks
    public void Dispose()
    {
        WorkspaceState.OnChange -= Refresh;
    }

    private Microsoft.FluentUI.AspNetCore.Components.Icon GetFileIcon(string name) => name.ToLower().EndsWith(".pdf") ? new Icons.Filled.Size20.DocumentPdf() : new Icons.Filled.Size20.DocumentBulletList();
    private Microsoft.FluentUI.AspNetCore.Components.Color GetIconColor(string name) => name.ToLower().EndsWith(".pdf") ? Color.Error : Color.Accent;
}
