@using OperationalWorkspaceUI.State
@using OperationalWorkspaceApplication.DTOs
@using Microsoft.FluentUI.AspNetCore.Components
@using Microsoft.FluentUI.AspNetCore.Components.Icons
@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons

@implements IDisposable
@inject WorkspaceState WState
@inject NavigationManager NavManager

<FluentCard Class="kb-widget-card" Style="position: relative;">
    
    @* --- LIVE OVERLAY: Dims the tile when an article is being sent --- *@
    @if (WState.IsSendingKnowledge)
    {
        <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(255,255,255,0.7); z-index: 10; display: flex; flex-direction: column; align-items: center; justify-content: center; border-radius: inherit;">
            <FluentProgressRing Style="width: 32px; height: 32px;" />
            <span style="margin-top: 12px; font-size: 0.85rem; color: #008272; font-weight: 600;">Sending Article...</span>
        </div>
    }

    @* Panel Header *@
    <div class="panel-header">
        <h3>Knowledge Base</h3>
        <FluentIcon Value="@(new Icons.Regular.Size16.ChevronUp())" Color="@Color.Neutral" />
    </div>

    @* Search Bar *@
    <div class="kb-search-container">
        <FluentSearch Placeholder="Search articles..."
                      Style="width: 100%;"
                      @bind-Value="@_searchQuery"
                      @bind-Value:event="oninput" />
    </div>

    @* Resource Links *@
    <div class="kb-links-container">
        @if (FilteredArticles != null && FilteredArticles.Any())
        {
            @foreach (var kb in FilteredArticles.Take(4))
            {
                <div class="kb-link-wrapper" style="cursor: pointer;" @onclick="NavigateToKB">
                    <div class="kb-link-item">
                        <FluentIcon Value="@GetIcon(kb.Title)" Color="@GetIconColor(kb.Title)" />
                        
                        <div class="kb-text-group">
                            <span class="kb-title">@kb.Title</span>
                            <span class="kb-meta">Suggested for this context</span>
                        </div>
                        
                        <FluentIcon Value="@(new Icons.Regular.Size16.ArrowRight())"
                                    Color="@Color.Accent"
                                    Class="arrow-icon" />
                    </div>
                </div>
            }
        }
        else
        {
            <div class="kb-empty">
                <FluentIcon Value="@(new Icons.Regular.Size24.Info())" Color="@Color.Neutral" />
                <p>No matching articles found.</p>
            </div>
        }
    </div>

    @* Footer Button *@
    <div class="kb-footer">
        <FluentButton Appearance="Appearance.Lightweight"
                      Class="footer-btn"
                      OnClick="NavigateToKB">
            Open Full Knowledge Base
        </FluentButton>
    </div>
</FluentCard>

@code {
    [Parameter]
    public List<KnowledgeDto>? Data { get; set; }

    private string? _searchQuery = "";

    protected override void OnInitialized()
    {
        // Subscribe to WorkspaceState so the 'Sending' overlay works
        WState.OnChange += HandleStateChanged;

        // Populate initial data if empty
        if (WState.KnowledgeBase == null || !WState.KnowledgeBase.Any())
        {
            WState.KnowledgeBase = new List<KnowledgeDto>
            {
                new KnowledgeDto { Title = "Pricing Guidelines 2024", Url = "#" },
                new KnowledgeDto { Title = "Product Installation Guide", Url = "#" },
                new KnowledgeDto { Title = "Sage X3 FAQ", Url = "#" }
            };
        }
    }

    private void HandleStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    // POINTED TO WState (WorkspaceState)
    private IEnumerable<KnowledgeDto> FilteredArticles =>
        string.IsNullOrWhiteSpace(_searchQuery)
            ? WState.KnowledgeBase
            : WState.KnowledgeBase.Where(a => a.Title.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase));

    private Icon GetIcon(string title) => title.ToLower() switch
    {
        var t when t.Contains("pricing") => new Icons.Filled.Size20.Table(),
        var t when t.Contains("document") => new Icons.Filled.Size20.Document(),
        var t when t.Contains("faq") => new Icons.Filled.Size20.Chat(),
        _ => new Icons.Filled.Size20.Document()
    };

    private Color GetIconColor(string title) => title.ToLower() switch
    {
        var t when t.Contains("pricing") => Color.Success,
        var t when t.Contains("document") => Color.Warning,
        _ => Color.Neutral
    };

    public void Dispose()
    {
        WState.OnChange -= HandleStateChanged;
    }

    private void NavigateToKB()
    {
        NavManager.NavigateTo("/knowledge-page");
    }
}
