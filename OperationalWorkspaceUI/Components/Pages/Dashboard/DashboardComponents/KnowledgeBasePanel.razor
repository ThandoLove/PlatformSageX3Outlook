@using OperationalWorkspaceUI.State
@using OperationalWorkspaceApplication.DTOs
@using Microsoft.FluentUI.AspNetCore.Components

@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons

@implements IDisposable
@inject WorkspaceState WState
@inject NavigationManager NavManager
@inject IJSRuntime JS 

@* Added to handle opening document links *@

<FluentCard Class="kb-widget-card" Style="position: relative; display: flex; flex-direction: column;">
    
    @* --- LIVE OVERLAY --- *@
    @if (WState.IsSendingKnowledge)
    {
        <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(255,255,255,0.7); z-index: 10; display: flex; flex-direction: column; align-items: center; justify-content: center; border-radius: inherit;">
            <FluentProgressRing Style="width: 32px; height: 32px;" />
            <span style="margin-top: 12px; font-size: 0.85rem; color: #008272; font-weight: 600;">Sending Article...</span>
        </div>
    }

    @* Panel Header *@
    <div class="panel-header" style="display: flex; justify-content: space-between; align-items: center; padding: 10px 15px;">
        <h3 style="margin: 0; font-size: 1rem; font-weight: 700; color: #002d5a;">Knowledge Base</h3>
        <FluentIcon Value="@(new Icons.Regular.Size16.ChevronUp())" Color="@Color.Neutral" />
    </div>

    @* Search Bar *@
    <div class="kb-search-container" style="padding: 0 15px 10px 15px;">
        <FluentSearch Placeholder="Search articles..."
                      Style="width: 100%;"
                      @bind-Value="@_searchQuery"
                      @bind-Value:event="oninput" />
    </div>

    @* Resource Links *@
    <div class="kb-links-container" style="flex-grow: 1; overflow-y: auto; padding: 0 15px;">
        @if (FilteredArticles != null && FilteredArticles.Any())
        {
            @foreach (var kb in FilteredArticles.Take(4))
            {
                @* CHANGE: Called OpenDocument(kb) instead of NavigateToKB *@
                <div class="kb-link-wrapper" style="cursor: pointer; padding: 8px 0; border-bottom: 1px solid #f1f5f9;" 
                     @onclick="() => OpenDocument(kb)">
                    <div class="kb-link-item" style="display: flex; align-items: center; gap: 10px;">
                        <FluentIcon Value="@GetIcon(kb.Title)" Color="@GetIconColor(kb.Title)" />
                        
                        <div class="kb-text-group" style="flex-grow: 1;">
                            <div style="font-size: 0.85rem; font-weight: 600; color: #1e293b;">@kb.Title</div>
                            <div style="font-size: 0.75rem; color: #64748b;">@kb.Category</div>
                        </div>
                        
                        <FluentIcon Value="@(new Icons.Regular.Size16.ArrowRight())" Color="@Color.Accent" />
                    </div>
                </div>
            }
        }
        else
        {
            <div style="text-align: center; padding: 20px; color: #94a3b8;">
                <p>No matching articles found.</p>
            </div>
        }
    </div>

    @* Footer Button: Keep this for the Main Page *@
    <div class="kb-footer" style="padding: 12px; border-top: 1px solid #f1f5f9;">
        <FluentButton Appearance="Appearance.Lightweight" 
                      Style="width: 100%; font-size: 0.8rem;"
                      OnClick="@NavigateToKB">
            Open Full Knowledge Base
        </FluentButton>
    </div>
</FluentCard>

@code {
    [Parameter] public List<KnowledgeDto>? Data { get; set; }
    private string? _searchQuery = "";

    protected override void OnInitialized()
    {
        WState.OnChange += HandleStateChanged;

        if (WState.KnowledgeBase == null || !WState.KnowledgeBase.Any())
        {
            WState.KnowledgeBase = new List<KnowledgeDto>
            {
                // Note: The 5th parameter is the URL to the document itself
                new KnowledgeDto(Guid.NewGuid(), "Pricing Guidelines 2024", "Content", "Pricing", "https://your-docs.com", "Sales"),
                new KnowledgeDto(Guid.NewGuid(), "Product Installation Guide", "Content", "Docs", "https://your-docs.com", "IT"),
                new KnowledgeDto(Guid.NewGuid(), "Sage X3 FAQ", "Content", "FAQ", "https://your-docs.com", "Support")
            };
        }
    }

    private void HandleStateChanged() => InvokeAsync(StateHasChanged);

    @* NEW: Logic to open the specific document link *@
    private async Task OpenDocument(KnowledgeDto article)
    {
        if (!string.IsNullOrEmpty(article.Url) && article.Url != "#")
        {
            await JS.InvokeVoidAsync("open", article.Url, "_blank");
        }
        else
        {
            // Fallback: If no URL is provided, show a toast or preview
            Console.WriteLine("No URL defined for this document.");
        }
    }

    private IEnumerable<KnowledgeDto> FilteredArticles =>
        string.IsNullOrWhiteSpace(_searchQuery)
            ? WState.KnowledgeBase
            : WState.KnowledgeBase.Where(a => a.Title.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase));

    private Icon GetIcon(string title) => title.ToLower() switch
    {
        var t when t.Contains("pricing") => new Icons.Filled.Size20.Table(),
        var t when t.Contains("faq") => new Icons.Filled.Size20.Chat(),
        _ => new Icons.Filled.Size20.Document()
    };

    private Color GetIconColor(string title) => title.ToLower() switch
    {
        var t when t.Contains("pricing") => Color.Success,
        _ => Color.Neutral
    };

    public void Dispose() => WState.OnChange -= HandleStateChanged;
    private void NavigateToKB() => NavManager.NavigateTo("/knowledge-page");
}
