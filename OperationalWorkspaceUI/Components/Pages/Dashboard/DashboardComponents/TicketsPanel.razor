@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceUI.State
@using Microsoft.FluentUI.AspNetCore.Components
@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons

@implements IDisposable
@inject WorkspaceState WState
@inject NavigationManager NavManager

<FluentCard Class="tasks-widget-card" Style="display: flex; flex-direction: column; height: 100%; padding: 0;">

    @* HEADER *@
    <div class="panel-header" style="display: flex; justify-content: space-between; align-items: center; padding: 16px; border-bottom: 1px solid #f1f5f9;">
        <div style="display: flex; align-items: center; gap: 8px;">
            <FluentIcon Value="@(new Icons.Regular.Size20.TicketDiagonal())" Color="@Color.Neutral" />
            <h3 style="margin: 0; font-size: 1rem; font-weight: 700; color: #002d5a;">Active Tickets</h3>
        </div>
        <FluentButton Appearance="Appearance.Lightweight"
                      IconStart="@(new Icons.Regular.Size16.Add())"
                      OnClick="@(() => NavManager.NavigateTo("/tickets/new"))">
            New
        </FluentButton>
    </div>

    @* TICKET LIST *@
    <div style="flex-grow: 1; overflow-y: auto; padding: 0 16px;">
        @if (WState.Tickets != null && WState.Tickets.Any())
        {
            @foreach (var ticket in WState.Tickets.OrderByDescending(t => t.CreatedAt))
            {
                <div style="display: flex; align-items: center; padding: 12px 0; border-bottom: 1px solid #f8fafc; gap: 12px;">
                    <div style="flex-grow: 1;">
                        <div style="font-size: 0.85rem; font-weight: 600; color: #1e293b;">@ticket.Title</div>
                        <div style="font-size: 0.75rem; color: #64748b;">@ticket.TicketNumber • @ticket.CustomerName</div>
                    </div>
                    <span class="prio-badge @ticket.Priority.ToLower()" style="font-size: 0.7rem; padding: 2px 6px; border-radius: 4px;">
                        @ticket.Priority
                    </span>
                </div>
            }
        }
        else
        {
            <div style="padding: 40px; text-align: center; color: #94a3b8; font-size: 0.8rem;">
                No active tickets found.
            </div>
        }
    </div>

    @* FOOTER *@
    <div style="padding: 12px; border-top: 1px solid #f1f5f9; text-align: center;">
        <FluentButton Appearance="Appearance.Lightweight"
                      Style="width: 100%; font-size: 0.8rem;"
                      OnClick="@(() => NavManager.NavigateTo("/tickets"))">
            Open Full Ticket Manager
        </FluentButton>
    </div>

</FluentCard>

@code {
    protected override void OnInitialized()
    {
        // LISTEN: Update this tile if tickets are added/deleted on other pages
        WState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        WState.OnChange -= StateHasChanged;
    }
}
