@inject NavigationManager Nav

@using OperationalWorkspaceApplication.DTOs
@using Microsoft.FluentUI.AspNetCore.Components
@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons

<div class="widget-wrapper">
    @* Professional Header matched to Topbar height *@
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; background-color: #f8fafc; height: 40px; padding: 0 12px; border-bottom: 1px solid #e2e8f0;">
        <div style="display: flex; align-items: center; gap: 8px;">
            <FluentIcon Value="@(new Icons.Regular.Size16.TicketDiagonal())" Color="Color.Neutral" />
            <span style="font-size: 0.85rem; font-weight: 700; color: #1e293b;">Support Tickets</span>
        </div>
        @* Small action button like the original image *@
        <FluentButton Appearance="Appearance.Lightweight"
                      IconStart="@(new Icons.Regular.Size16.Add())"
                      Style="height: 24px; font-size: 0.75rem;"
                      @onclick="GoToCreateTicket">
            New
        </FluentButton>
    </div>

    @* The Scrollable List Area *@
    <div class="card-body" style="max-height: 300px; overflow-y: auto; padding: 0;">
        @if (Tickets != null && Tickets.Any())
        {
            @foreach (var item in Tickets.OrderByDescending(t => t.CreatedAt))
            {
                <TicketItem Ticket="item" />
            }
        }
        else
        {
            <div style="padding: 20px; text-align: center; color: #94a3b8; font-size: 0.8rem;">
                No active tickets.
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public List<TicketDto> Tickets { get; set; } = new();

    private void GoToCreateTicket()
    {
        Nav.NavigateTo("/tickets/new"); // adjust route if needed
    }
}