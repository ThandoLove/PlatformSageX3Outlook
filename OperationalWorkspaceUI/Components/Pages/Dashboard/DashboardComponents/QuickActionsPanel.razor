@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons
@using Microsoft.FluentUI.AspNetCore.Components

@using OperationalWorkspaceUI.Components.Pages.Forms
@using OperationalWorkspaceUI.UIServices.System
@using OperationalWorkspaceUI.State

@inject OperationalWorkspaceUI.UIServices.ToastUIService.ToastService CustomToastService
@inject DashboardState DState
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@inject IJSRuntime JS
@inject ModalService ModalService 
@* Instance name injected here *@

<div class="quick-actions-card">
    <div class="quick-actions-grid">
        
        @* 🏢 1. Add Partner (circle-teal -> Form Modal CreateClientForm) *@
        <button class="action-item" @onclick='() => OpenModalAction("Create Sage Client")'>
            <div class="icon-circle circle-teal">
                <FluentIcon Value="@(new Icons.Regular.Size20.Building())" Color="Color.Fill" />
            </div>
            <span class="action-label">Add Partner</span>
        </button>

        @* 👤 2. Add Contact (circle-blue -> Form Modal NewContactForm) *@
        <button class="action-item" @onclick='() => OpenModalAction("Add Business Contact")'>
            <div class="icon-circle circle-blue">
                <FluentIcon Value="@(new Icons.Regular.Size20.PersonAdd())" Color="Color.Fill" />
            </div>
            <span class="action-label">Add Contact</span>
        </button>

        @* 🎫 3. Create Ticket (circle-blue-dark -> Form Modal TicketDetailForm) *@
        <button class="action-item" @onclick='() => OpenModalAction("New Service Request")'>
            <div class="icon-circle circle-blue-dark">
                <FluentIcon Value="@(new Icons.Regular.Size20.Cart())" Color="Color.Fill" />
            </div>
            <span class="action-label">Create Ticket</span>
        </button>

        @* 📝 4. Add Quote (circle-indigo -> Sends to Sage X3 Immutable Vault Query) *@
        <button class="action-item" @onclick='async () => await NavigateToSage("GESQTE", "BROWSE")'>
            <div class="icon-circle circle-indigo">
                <FluentIcon Value="@(new Icons.Regular.Size20.DocumentAdd())" Color="Color.Fill" />
            </div>
            <span class="action-label">Add Quote</span>
        </button>

        @* 🔗 5. Link Existing (circle-orange -> Sends to Sage X3 GESBPR LINK Context) *@
        <button class="action-item" @onclick='async () => await NavigateToSage("GESBPR", "LINK")'>
            <div class="icon-circle circle-orange">
                <FluentIcon Value="@(new Icons.Regular.Size20.Link())" Color="Color.Fill" />
            </div>
            <span class="action-label">Link Existing</span>
        </button>

        @* 📊 6. Add Invoice (circle-green -> Sends to Sage X3 GESPNH NEW Context) *@
        <button class="action-item" @onclick='async () => await NavigateToSage("GESPNH", "NEW")'>
            <div class="icon-circle circle-green">
                <FluentIcon Value="@(new Icons.Regular.Size20.Document())" Color="Color.Fill" />
            </div>
            <span class="action-label">Add Invoice</span>
        </button>

        @* 📎 7. Attach Doc (circle-blue -> Sends directly to Sage X3 to pull immutable info!) *@
        <button class="action-item" @onclick='async () => await NavigateToSage("GESATT", "ATTACH")'>
            <div class="icon-circle circle-blue">
                <FluentIcon Value="@(new Icons.Regular.Size20.Attach())" Color="Color.Fill" />
            </div>
            <span class="action-label">Attach Doc</span>
        </button>

    </div>
</div>

@code {
    private async Task OpenModalAction(string title)
    {
        bool useMock = Configuration.GetValue<bool>("SageX3:UseMockData", true);
        bool isEmailNull = DState.EmailContext == null || string.IsNullOrWhiteSpace(DState.EmailContext.SenderEmail);

        if (!useMock && isEmailNull)
        {
            CustomToastService.ShowError("Please select an email thread first.");
            return;
        }

        string emailParam = DState.EmailContext?.SenderEmail ?? "prospect-demo@testcompany.com";
        string nameParam = DState.EmailContext?.SenderName ?? "Unknown Entity Demo";

        try
        {
            RenderFragment modalContent = title switch
            {
                "Create Sage Client" => builder => { builder.OpenComponent<CreateClientForm>(0); builder.AddAttribute(1, "Email", emailParam); builder.AddAttribute(2, "FullName", nameParam); builder.CloseComponent(); },
                "Add Business Contact" => builder => { builder.OpenComponent<NewContactForm>(0); builder.AddAttribute(1, "Email", emailParam); builder.AddAttribute(2, "FullName", nameParam); builder.CloseComponent(); },
                "New Service Request" => builder => { builder.OpenComponent<TicketDetailForm>(0); builder.CloseComponent(); },
                _ => throw new ArgumentException()
            };

            // 🔥 FIXED: Swapped 'ModalService.ShowModal' (Uppercase Type) to 'ModalService.ShowModal' (Lowercase Property Injection instance)
            await ModalService.ShowModal(title, modalContent);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Modal generation fault: {ex.Message}");
            CustomToastService.ShowError($"Modal generation fault: {ex.Message}");
        }
    }

    private async Task NavigateToSage(string functionCode, string action)
    {
        bool useMock = Configuration.GetValue<bool>("SageX3:UseMockData", true);
        bool isEmailNull = DState.EmailContext == null || string.IsNullOrWhiteSpace(DState.EmailContext.SenderEmail);

        if (!useMock && isEmailNull)
        {
            CustomToastService.ShowError("Please select an email thread first.");
            return;
        }

        if (useMock)
        {
            CustomToastService.ShowSuccess($"[Sage X3 Connection Sandbox Mode] Querying non-mutable ERP files via function: {functionCode} ({action})");
            return;
        }

        try
        {
            bool isBridgeReady = await JS.InvokeAsync<bool>("eval", "typeof window.officeBridge !== 'undefined' && typeof window.officeBridge.openSageRecord === 'function'");

            if (!isBridgeReady)
            {
                CustomToastService.ShowError("Outlook Script Integration engine is initializing. Try again shortly.");
                return;
            }

            await JS.InvokeVoidAsync("officeBridge.openSageRecord", functionCode, action);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"OfficeBridge communication breakdown: {ex.Message}");
            CustomToastService.ShowError($"Bridge connection failure: {ex.Message}");
        }
    }
}
