@using OperationalWorkspaceUI.State
@using OperationalWorkspaceUI.UIServices.System
@using OperationalWorkspaceUI.Components.Pages.Forms
@using Microsoft.FluentUI.AspNetCore.Components
@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons

@inject OperationalWorkspaceUI.State.EmailContextState EmailState
@inject OperationalWorkspaceUI.UIServices.System.ModalService ModalService
@inject IJSRuntime JS
@inject OperationalWorkspaceUI.UIServices.ToastUIService.ToastService ToastService

<div class="quick-actions-container">
    @* 1. Add Partner (Blue) *@
    <button class="action-tile action-blue" @onclick='() => OpenModal<NewContactForm>("Add Business Partner")'>
        <FluentIcon Value="@(new Icons.Regular.Size20.PersonAdd())" Color="Color.Custom" CustomColor="#ffffff" />
        <span>Add Partner</span>
    </button>

    @* 2. Link Existing (Teal) *@
    <button class="action-tile action-teal" @onclick='() => NavigateToSage("GESBPR", "LINK")'>
        <FluentIcon Value="@(new Icons.Regular.Size20.Link())" Color="Color.Custom" CustomColor="#ffffff" />
        <span>Link Existing</span>
    </button>

    @* 3. Create Quote (Orange) *@
    <button class="action-tile action-orange" @onclick='() => OpenModal<CreateQuoteForm>("Create Sage Quote")'>
        <FluentIcon Value="@(new Icons.Regular.Size20.DocumentAdd())" Color="Color.Custom" CustomColor="#ffffff" />
        <span>Create Quote</span>
    </button>

    @* 4. Add Sales (Indigo) *@
    <button class="action-tile action-indigo" @onclick='() => OpenModal<AddSalesOrderForm>("New Sales Order")'>
        <FluentIcon Value="@(new Icons.Regular.Size20.Cart())" Color="Color.Custom" CustomColor="#ffffff" />
        <span>Add Sales</span>
    </button>

    @* 5. Create Invoice (Navy) *@
    <button class="action-tile action-navy" @onclick='() => NavigateToSage("GESPNH", "NEW")'>
        <FluentIcon Value="@(new Icons.Regular.Size20.Document())" Color="Color.Custom" CustomColor="#ffffff" />
        <span>Create Invoice</span>
    </button>

    @* 6. Attach Email (Green) *@
    <button class="action-tile action-green" @onclick='() => OpenModal<AttachEmailForm>("Attach Email to Sage")'>
        <FluentIcon Value="@(new Icons.Regular.Size20.Attach())" Color="Color.Custom" CustomColor="#ffffff" />
        <span>Attach to Email</span>
    </button>
</div>

@code {
    private async Task OpenModal<TComponent>(string title) where TComponent : IComponent
    {
        if (EmailState.CurrentEmail == null)
        {
            ToastService.ShowError("Please select an email first.");
            return;
        }

        await ModalService.ShowModal(title, builder =>
        {
            builder.OpenComponent<TComponent>(0);
            builder.AddAttribute(1, "Email", EmailState.CurrentEmail.SenderEmail);
            builder.AddAttribute(2, "FullName", EmailState.CurrentEmail.SenderName);
            builder.CloseComponent();
        });
    }

    private async Task NavigateToSage(string functionCode, string action)
    {
        await JS.InvokeVoidAsync("officeBridge.openSageRecord", functionCode, action);
    }
}
