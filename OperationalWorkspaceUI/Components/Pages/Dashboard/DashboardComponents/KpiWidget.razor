<!-- CODE START: KpiWidget.razor -->

<div class="kpi-widget @Variant">
    
    <div class="kpi-header">
        <span class="kpi-label">@Label</span>
    </div>

    <div class="kpi-value">
        @Prefix@FormattedValue
    </div>

    @if (!string.IsNullOrEmpty(Trend))
    {
        <div class="kpi-trend">
            @Trend
        </div>
    }

</div>

@code {
    [Parameter] public string? Label { get; set; }
    [Parameter] public object? Value { get; set; }
    [Parameter] public string Prefix { get; set; } = "";
    [Parameter] public string? Trend { get; set; } // e.g. "+12%"
    [Parameter] public string Variant { get; set; } = "default"; // success, warning, etc

    private string FormattedValue => Value switch
    {
        null => "-",
        decimal d => d.ToString("N2"),
        int i => i.ToString("N0"),
        _ => Value?.ToString() ?? "-" // FIX: Added null-safe operator
    };
}

<!-- CODE END -->