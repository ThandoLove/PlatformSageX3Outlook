@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceUI.State
@using Microsoft.FluentUI.AspNetCore.Components
@implements IDisposable
@inject DashboardState State

<FluentCard Style="width: 100%; padding: 16px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.05);">
    @* Panel Header *@
    <div class="panel-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
        <h3 style="margin: 0; font-size: 1.1rem; font-weight: 600; color: #333;">Activity Timeline</h3>
        @* Fix 1: Full path for Header Icon *@
        <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size16.ChevronUp())"
                    Color="@Microsoft.FluentUI.AspNetCore.Components.Color.Neutral" />
    </div>

    <div class="timeline-container" style="display: flex; flex-direction: column; gap: 20px; min-height: 250px;">
        @if (Activities != null && Activities.Any())
        {
            @foreach (var group in Activities.OrderByDescending(a => a.Timestamp).GroupBy(a => a.Timestamp.Date))
            {
                <div class="timeline-group" style="display: flex; flex-direction: column; gap: 8px;">
                    <div class="timeline-date" style="font-size: 0.75rem; font-weight: 600; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.025em;">
                        @GetDateHeader(group.Key)
                    </div>

                    @foreach (var activity in group)
                    {
                        <div class="timeline-item" style="display: flex; align-items: center; gap: 12px;">
                            <div style="width: 28px; height: 28px; border-radius: 6px; display: flex; align-items: center; justify-content: center; background-color: @GetActivityColor(activity.Action);">
                                @* Fix 2: Using Microsoft.FluentUI Color.Custom *@
                                <FluentIcon Value="@GetActivityIcon(activity.Action)"
                                            Color="@Microsoft.FluentUI.AspNetCore.Components.Color.Custom"
                                            CustomColor="white" />
                            </div>
                            
                            <div class="timeline-content">
                                <div class="activity-text" style="font-size: 0.9rem; color: #1e293b; font-weight: 500;">
                                    @activity.Title
                                </div>
                                <div style="font-size: 0.75rem; color: #94a3b8;">
                                    @activity.Action @(string.IsNullOrEmpty(activity.CreatedBy) ? "" : $"by {activity.CreatedBy}")
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        }
        else
        {
            <div style="text-align: center; padding: 40px; color: #94a3b8;">
                <p>No recent interactions found.</p>
            </div>
        }
    </div>

    <div style="margin-top: 20px; border-top: 1px solid #f1f5f9; padding-top: 12px; text-align: center;">
        <FluentAnchor Appearance="Appearance.Lightweight" Href="#" Style="color: #3b82f6; font-weight: 600;">
            View Full Timeline →
        </FluentAnchor>
    </div>
</FluentCard>

@code {
    [Parameter] public List<ActivityDto> Activities { get; set; } = new();

    protected override void OnInitialized()
    {
        State.OnChange += StateHasChanged;
        if (Activities == null || !Activities.Any())
        {
            Activities = State.RecentActivities;
        }
    }

    private string GetDateHeader(DateTime date)
    {
        if (date.Date == DateTime.Today) return "Today";
        if (date.Date == DateTime.Today.AddDays(-1)) return "Yesterday";
        return date.ToString("MMM dd");
    }

    @* Fix 3: Full path for Return Type and Icon constructors *@
    private Microsoft.FluentUI.AspNetCore.Components.Icon GetActivityIcon(string action) => action.ToLower() switch
    {
        "email" or "created" => new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size16.AddSquare(),
        "call" or "contacted" => new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size16.Call(),
        "meeting" or "scheduled" => new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size16.CalendarLtr(),
        _ => new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size16.CheckmarkCircle()
    };

    private string GetActivityColor(string action) => action.ToLower() switch
    {
        "email" or "created" => "#22c55e",
        "call" or "contacted" => "#14b8a6",
        "meeting" or "scheduled" => "#f59e0b",
        _ => "#64748b"
    };

    public void Dispose()
    {
        State.OnChange -= StateHasChanged;
    }
}
