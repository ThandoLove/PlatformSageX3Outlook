@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceUI.State
@inject DashboardState State

<div class="dashboard-card recent-activity-panel">
    <div class="panel-header">
        <div class="header-main">
            <h4>Activity Timeline</h4>
            <span class="activity-subtitle">Last 30 Days</span>
        </div>
        <button class="btn-refresh"><i class="ms-Icon ms-Icon--Refresh"></i></button>
    </div>

    <div class="timeline-container">
        @if (Activities != null && Activities.Any())
        {
            @foreach (var activity in Activities)
            {
                <div class="timeline-item">
                    <div class="timeline-marker @GetActivityColor(activity.Action)">
                        <i class="ms-Icon @GetActivityIcon(activity.Action)"></i>
                    </div>
                    <div class="timeline-content">
                        <div class="timeline-header">
                            <span class="activity-title">@activity.Title</span>
                            <span class="activity-time">@GetTimeAgo(activity.Timestamp)</span>
                        </div>
                        <p class="activity-desc">@activity.Action - @activity.CreatedBy</p>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-timeline">
                <p>No recent interactions found for this contact.</p>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public List<ActivityDto> Activities { get; set; } = new();

    protected override void OnInitialized()
    {
        // Fallback to global state if parameters aren't passed
        if (Activities == null || !Activities.Any())
        {
            Activities = State.RecentActivities;
        }
    }

    private string GetActivityIcon(string action) => action.ToLower() switch
    {
        "email" or "created" => "ms-Icon--Mail",
        "meeting" => "ms-Icon--Calendar",
        "invoice" => "ms-Icon--Money",
        "call" => "ms-Icon--Phone",
        _ => "ms-Icon--CheckMark"
    };

    private string GetActivityColor(string action) => action.ToLower() switch
    {
        "email" or "created" => "icon-blue",
        "invoice" => "icon-green",
        "meeting" => "icon-orange",
        _ => "icon-grey"
    };

    private string GetTimeAgo(DateTime timestamp)
    {
        var diff = DateTime.Now - timestamp;
        if (diff.TotalDays >= 1) return $"{(int)diff.TotalDays}d ago";
        if (diff.TotalHours >= 1) return $"{(int)diff.TotalHours}h ago";
        return "Just now";
    }
}
