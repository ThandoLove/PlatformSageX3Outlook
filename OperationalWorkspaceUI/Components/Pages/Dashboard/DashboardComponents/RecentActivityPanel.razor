@inject DashboardState State

<div class="dashboard-panel recent-activity-panel">
    <h4>Recent Activity</h4>
    @* 1. Change RecentActivity to RecentActivities *@
    @if (State.RecentActivities != null && State.RecentActivities.Any())
    {
        <ul>
            @foreach (var activity in State.RecentActivities)
            {
                @* 2. Change User to CreatedBy and Action to Title (or Action if it exists in your DTO) *@
                <li>@activity.CreatedBy - @activity.Title</li>
            }
        </ul>
    }
    else
    {
        <EmptyState Message="No recent activity." />
    }
</div>
