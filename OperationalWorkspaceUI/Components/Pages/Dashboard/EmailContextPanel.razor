@inject EmailContextUIService EmailService
@inject EmailContextState EmailState
@inject WorkspaceState WorkspaceState
@inject Radzen.NotificationService NotificationService
@inject NavigationService NavigationService
@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceUI.UIServices.EmailService
@using OperationalWorkspaceUI.UIServices.System

<div class="email-context-panel">
    <EmailHeader Email="@EmailState.CurrentEmail" />

    <EmailDetails Email="@EmailState.CurrentEmail" />

    <div class="email-actions">
        <QuickActionsPanel EmailId="@EmailState.CurrentEmail?.Id" />
    </div>

    <EmailClientMatch Email="@EmailState.CurrentEmail" Clients="@WorkspaceState.Clients" />

    <QuickActionsPanel EmailId="@EmailState.CurrentEmail?.MessageId" />
    <EmailTaskSummary Tasks="@EmailState.LinkedTasks" />
</div>

@code {
    protected override async Task OnParametersSetAsync()
    {
        if (EmailState.CurrentEmail != null)
        {
            await EmailService.LoadEmailContextAsync(EmailState.CurrentEmail.MessageId, EmailState, WorkspaceState);
        }
    }
}
