@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceUI.State
@using OperationalWorkspaceUI.UIServices.EmailService
@using Microsoft.FluentUI.AspNetCore.Components
@implements IDisposable
@inject EmailContextState State
@inject EmailContextUIService EmailService

<FluentCard Style="width: 100%; padding: 16px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.05); min-height: 350px;">
    @* Panel Header *@
    <div class="panel-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
        <h3 style="margin: 0; font-size: 1.1rem; font-weight: 600; color: #333;">Email Insight</h3>
        
        @if (State.IsLoading)
        {
            <FluentProgressRing Style="width: 16px; height: 16px;" />
        }
        else if (State.MatchedClient != null)
        {
            <div style="background-color: #f0fdf4; color: #16a34a; border: 1px solid #dcfce7; padding: 2px 10px; border-radius: 12px; font-size: 0.75rem; font-weight: 600;">Linked</div>
        }
        else
        {
            @* Fix: Fully qualified path for Icons and Color *@
            <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size16.ChevronDown())"
                        Color="@Microsoft.FluentUI.AspNetCore.Components.Color.Neutral" />
        }
    </div>

    @if (State.IsLoading)
    {
        <div class="loading-overlay" style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 250px;">
            <FluentProgressRing />
            <span style="margin-top:10px; color:#64748b;">Sage X3 AI is analyzing...</span>
        </div>
    }
    else
    {
        <div class="insight-content" style="display: flex; flex-direction: column; gap: 12px;">
            <div style="display: flex; align-items: center; gap: 12px;">
                <div style="width: 32px; height: 32px; border-radius: 50%; background: #e2e8f0; display: flex; align-items: center; justify-content: center; font-weight: 600; color: #475569; font-size: 0.8rem;">
                    @((!string.IsNullOrEmpty(State.CurrentEmail?.SenderName)) ? State.CurrentEmail.SenderName.Substring(0, 1) : "?")
                </div>
                <div style="display: flex; flex-direction: column;">
                    <span style="font-size: 0.75rem; color: #64748b; text-transform: uppercase;">Contact</span>
                    <span style="font-weight: 600; color: #1e293b;">@(State.CurrentEmail?.SenderName ?? "Select an Email")</span>
                </div>
            </div>

            <div style="display: flex; flex-direction: column; gap: 2px;">
                <span style="font-size: 0.75rem; color: #64748b; text-transform: uppercase;">Company</span>
                @* Fix: Changed .CompanyName to .Name to match your DTO *@
                <span style="font-weight: 500; color: #1e293b;">@(State.MatchedClient?.Name ?? "Unknown Entity")</span>
            </div>

            <div style="display: flex; flex-direction: column; gap: 4px;">
                <span style="font-size: 0.75rem; color: #64748b; text-transform: uppercase;">Intent</span>
                <div style="display: flex; align-items: center; gap: 6px; color: #3b82f6; font-weight: 600;">
                    <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size16.Flash())"
                                Color="@Microsoft.FluentUI.AspNetCore.Components.Color.Accent" />
                    <span>@(State.CurrentEmail?.Subject ?? "Analyzing Context...")</span>
                </div>
            </div>

            <div class="ai-summary-box" style="background-color: #f8fafc; border-left: 4px solid #3b82f6; padding: 12px; margin-top: 8px; border-radius: 0 4px 4px 0;">
                <span style="font-weight: 700; font-size: 0.75rem; color: #334155; display: block; margin-bottom: 4px; letter-spacing: 0.05em;">AI SUMMARY</span>
                <p style="margin: 0; font-size: 0.9rem; color: #475569; line-height: 1.5;">
                    @((!string.IsNullOrEmpty(State.CurrentEmail?.Message)) ? State.CurrentEmail.Message : "Waiting for email selection to generate Sage X3 insights...")
                </p>
            </div>
        </div>
    }
</FluentCard>

@code {
    protected override void OnInitialized() => State.OnChange += HandleStateChanged;
    
    private void HandleStateChanged() => InvokeAsync(StateHasChanged);
    
    public void Dispose() => State.OnChange -= HandleStateChanged;
}
