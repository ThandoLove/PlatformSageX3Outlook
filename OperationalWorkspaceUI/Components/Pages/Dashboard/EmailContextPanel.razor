@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceUI.State
@using OperationalWorkspaceUI.UIServices.EmailService
@implements IDisposable
@inject EmailContextState State
@inject EmailContextUIService EmailService

<div class="dashboard-card email-insight-card">
    <div class="panel-header">
        <h4>Email Insight</h4>
        @* Status badge updates based on whether a Sage X3 client match was found *@
        <span class="status-badge @(State.MatchedClient != null ? "linked" : "unlinked")">
            @(State.MatchedClient != null ? "Linked" : "Unlinked")
        </span>
    </div>

    <div class="insight-content">
        <div class="contact-info">
            <div class="avatar-circle">
                @((!string.IsNullOrEmpty(State.CurrentEmail?.SenderName)) ? State.CurrentEmail.SenderName.Substring(0, 1) : "?")
            </div>
            <div class="text-group">
                <span class="label">Contact</span>
                <span class="contact-name">@(State.CurrentEmail?.SenderName ?? "Select an Email")</span>
            </div>
        </div>

        <div class="intent-section">
            <span class="label">Intent</span>
            <div class="intent-badge">
                <i class="ms-Icon ms-Icon--LightningBolt"></i>
                @* This displays the intent/subject identified in the image *@
                <span>@(State.CurrentEmail?.Subject ?? "Analyzing Context...")</span>
            </div>
        </div>

        <div class="ai-summary-box">
            <span class="summary-label">AI SUMMARY</span>
            <p class="summary-text">
                @if (State.CurrentEmail != null)
                {
                    @((!string.IsNullOrEmpty(State.CurrentEmail.Message)) ? State.CurrentEmail.Message : "Reviewing email for Sage X3 matches...")
                }
                else
                {
                    <span>Waiting for email selection to generate Sage X3 insights...</span>
                }
            </p>
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        // IMPORTANT: Subscribe to the state change event
        // This ensures the panel refreshes when officeBridge.js sends new email data
        State.OnChange += HandleStateChanged;
    }

    private void HandleStateChanged()
    {
        // Trigger a re-render of this specific component
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        // Prevent memory leaks by unsubscribing when the component is destroyed
        State.OnChange -= HandleStateChanged;
    }
}
