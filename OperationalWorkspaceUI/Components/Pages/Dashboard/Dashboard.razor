@page "/dashboard"
@rendermode InteractiveServer

@* 1. COMPONENT NAMESPACES *@
@using OperationalWorkspaceUI.Components.Pages.Dashboard.DashboardComponents
@using OperationalWorkspaceUI.Components.Pages.Workspace.WorkspaceComponents
@using OperationalWorkspaceUI.Components.Email
@using OperationalWorkspaceUI.Components.Shared
@using OperationalWorkspaceUI.State
@using OperationalWorkspaceApplication.DTOs
@using Microsoft.JSInterop

@* 2. SERVICE INJECTIONS *@
@inject DashboardState DState
@inject WorkspaceState WState
@inject UIState AppUIState
@inject IJSRuntime JS

@implements IDisposable

<PageTitle>Sage X3 | Operational Dashboard</PageTitle>

<div class="dashboard-wrapper @(AppUIState.IsDarkMode ? "dark-mode" : "")">

    @* --- ROW 1: DYNAMIC KPI METRICS --- *@
    <div class="metrics-grid">

        @{
            var customer = DState.TopClients?.FirstOrDefault();
            var customerName = customer?.Name ?? "No Customer Linked";
        }

        <!-- OPEN ORDERS -->
        <div class="metric-card">
            <span class="metric-label">Open Orders</span>
            <div class="metric-value">@DState.DashboardData.OpenOrders</div>
            <span class="metric-subtext">@customerName</span>
        </div>

        <!-- TICKETS -->
        <div class="metric-card">
            <span class="metric-label">Open Tickets</span>
            <div class="metric-value">@(DState.CurrentTickets?.Count() ?? 0)</div>
            <span class="metric-subtext">
                @(DState.CurrentTickets?.Any(t => t.Priority == "High") == true ? "Urgent" : "Normal")
            </span>
        </div>

        <!-- ACTIVITIES -->
        <div class="metric-card">
            <span class="metric-label">Recent Activity</span>
            <div class="metric-value">@(DState.CurrentActivities?.Count() ?? 0)</div>
            <span class="metric-subtext">Updated Today</span>
        </div>

        <!-- CUSTOMER STATUS -->
        <div class="metric-card">
            <span class="metric-label">Customer</span>
            <div class="metric-value">@customerName</div>
            <span class="metric-subtext">Active</span>
        </div>
    </div>

    @* --- ROW 2: CONTEXTUAL INSIGHTS --- *@
    <div class="sage-dashboard-row">
        <Card Title="Email Context">
            <EmailContextPanel />
        </Card>
        
        <Card Title="Crm Snapshot">
            <CrmPanel Clients="@DState.TopClients" />
        </Card>
    </div>

    @* --- ROW 3: QUICK ACTIONS --- *@
    <div class="sage-dashboard-row single">
        <Card Title="Quick Actions">
            <QuickActionsPanel />
        </Card>
    </div>

    @* --- ROW 4: OPERATIONAL TOOLS --- *@
    <div class="sage-dashboard-row">
        <Card Title="Knowledge">
            <KnowledgeBasePanel />
        </Card>
        <Card Title="Documents">
            <AttachDocumentsPanel />
        </Card>
    </div>

    @* --- ROW 5: LISTS & ACTIVITY --- *@
    <div class="sage-dashboard-row">
        <Card Title="Tasks & Approvals">
            <TasksPanel />
        </Card>
        <Card Title="Recent Activity">
            <RecentActivityPanel Activities="@DState.CurrentActivities" />
        </Card>
    </div>

    @* --- ROW 6: SYSTEM HEALTH & TICKETS --- *@
    <div class="sage-dashboard-row">
        <Card Title="System Health">
            <SystemHealthPanel Status="@DState.AdminHealth" />
        </Card>
        <Card Title="Active Tickets">
            <TicketsPanel Tickets="@DState.CurrentTickets" />
        </Card>
    </div>

    @* --- THEME TOGGLE --- *@
    <div class="theme-toggle-fixed">
        <FluentSwitch @bind-Value="IsDarkMode"
                      Label="@(AppUIState.IsDarkMode ? "Dark Appearance" : "Light Appearance")" />
    </div>
</div>

@code {
    private bool IsDarkMode
    {
        get => AppUIState.IsDarkMode;
        set
        {
            // Note: Ensure UIState methods are public
            _ = AppUIState.SetTheme(value ? "dark-mode" : "light-mode");
            _ = JS.InvokeVoidAsync("applyTheme", value ? "dark-mode" : "light-mode");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        // 1. Initial Data Load from Dashboard Logic
        await DState.LoadDashboardAsync();
        
        // 2. SUBSCRIBE: Listen to both States for a fully synced experience
        // This ensures updates to Documents or Knowledge reflect on the dashboard tiles
        DState.OnChange += StateHasChanged;
        WState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        // 3. CLEANUP: Prevent memory leaks when navigating away
        DState.OnChange -= StateHasChanged;
        WState.OnChange -= StateHasChanged;
    }
}
