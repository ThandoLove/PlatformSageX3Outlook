@page "/dashboard"
@rendermode InteractiveServer

@* 1. COMPONENT NAMESPACES *@
@using OperationalWorkspaceUI.Components.Pages.Dashboard.DashboardComponents
@using OperationalWorkspaceUI.Components.Pages.Workspace.WorkspaceComponents
@using OperationalWorkspaceUI.Components.Email
@using OperationalWorkspaceUI.Components.Shared
@using OperationalWorkspaceUI.State
@using OperationalWorkspaceApplication.DTOs
@using Microsoft.JSInterop

@* 2. SERVICE INJECTIONS *@
@inject DashboardState DState
@inject WorkspaceState WState
@inject UIState AppUIState
@inject IJSRuntime JS

@implements IDisposable

<PageTitle>Sage X3 | Operational Dashboard</PageTitle>

@* Note: Top div still uses AppUIState.IsDarkMode to react to the Global Toggle *@
<div class="dashboard-wrapper @(AppUIState.IsDarkMode ? "dark-mode" : "")">

    @* --- ROW 1: DYNAMIC KPI CARDS --- *@
    <div class="metrics-grid">

        @{
            var customer = DState.TopClients?.FirstOrDefault();
            var customerName = customer?.Name ?? "No Customer Linked";
        }

        <!-- OPEN ORDERS CARD -->
        <Card Title="Open Orders">
            <div class="metric-value">@(WState.Orders?.Count ?? 0)</div>
            <span class="metric-subtext">@customerName</span>
        </Card>

        <!-- OPEN TICKETS CARD (FILTERED) -->
        <Card Title="Open Tickets">
            <div class="metric-value">
                @(WState.Tickets?.Count(t => t.Status != "Closed" && t.Status != "Resolved") ?? 0)
            </div>
            <span class="metric-subtext">
                @(WState.Tickets?.Any(t => t.Priority == "High" && t.Status != "Closed") == true ? "Urgent Action Required" : "Active work items")
            </span>
        </Card>

        <!-- RECENT ACTIVITY CARD -->
        <Card Title="Recent Activity">
            <div class="metric-value">@(WState.ActivityLogs?.Count ?? 0)</div>
            <span class="metric-subtext">Updated Today</span>
        </Card>

        <!-- CUSTOMER STATUS CARD -->
        <Card Title="Customer">
            <div class="metric-value" style="font-size: 1.2rem;">@customerName</div>
            <span class="metric-subtext">Active Status</span>
        </Card>
    </div>

    @* --- ROW 2: CONTEXTUAL INSIGHTS --- *@
    <div class="sage-dashboard-row">
        <Card Title="Email Context">
            <EmailContextPanel />
        </Card>
        
        <Card Title="Crm Snapshot">
            <CrmPanel Clients="@DState.TopClients" />
        </Card>
    </div>

    @* --- ROW 3: QUICK ACTIONS --- *@
    <div class="sage-dashboard-row single">
        <Card Title="Quick Actions">
            <QuickActionsPanel />
        </Card>
    </div>

    @* --- ROW 4: OPERATIONAL TOOLS --- *@
    <div class="sage-dashboard-row">
        <Card Title="Knowledge">
            <KnowledgeBasePanel />
        </Card>
        <Card Title="Documents">
            <AttachDocumentsPanel />
        </Card>
    </div>

    @* --- ROW 5: LISTS & ACTIVITY --- *@
    <div class="sage-dashboard-row">
        <Card Title="Tasks & Approvals">
            <TasksPanel />
        </Card>
        <Card Title="Recent Activity">
            <RecentActivityPanel />
        </Card>
    </div>

    @* --- ROW 6: SYSTEM HEALTH & TICKETS --- *@
    <div class="sage-dashboard-row">
        <Card Title="System Health">
            <SystemHealthPanel Status="@DState.AdminHealth" />
        </Card>
        <Card Title="Active Tickets">
            <TicketsPanel />
        </Card>
    </div>

</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        // 1. Initial Data Load
        await DState.LoadDashboardAsync();
        
        // 2. SUBSCRIBE: Listen to states so the UI updates when the Global Toggle or data changes
        DState.OnChange += StateHasChanged;
        WState.OnChange += StateHasChanged;
        AppUIState.OnChange += StateHasChanged; // Listen for theme changes specifically
    }

    public void Dispose()
    {
        // 3. CLEANUP
        DState.OnChange -= StateHasChanged;
        WState.OnChange -= StateHasChanged;
        AppUIState.OnChange -= StateHasChanged;
    }
}
