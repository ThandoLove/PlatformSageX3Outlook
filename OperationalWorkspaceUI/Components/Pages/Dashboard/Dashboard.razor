@page "/dashboard"
@rendermode InteractiveServer

@using OperationalWorkspaceUI.Components.Pages.Dashboard.DashboardComponents
@using OperationalWorkspaceUI.State
@inject DashboardState State
@inject IJSRuntime JS
@inject UIState UIState

<div class="dashboard-wrapper @(UIState.IsDarkMode ? "dark-mode" : "")">
    
    <div class="dashboard-grid">
        
        @* COLUMN 1: Context, Knowledge & Admin Health *@
        <div class="grid-column">
            <div class="widget-wrapper">
                <EmailContextPanel Data="@State.EmailContext" />
            </div>
            
            <div class="widget-wrapper">
                <KnowledgeBasePanel Data="@State.KnowledgeBase" />
            </div>

            @if (State.CurrentHealth != null)
            {
                <div class="widget-wrapper">
                    <SystemHealthPanel Status="@State.CurrentHealth" />
                </div>
            }

            <div class="widget-wrapper">
                <ErpPanel Data="@State.CurrentErp" />
            </div>

            @if (State.CurrentFinance != null)
            {
                <div class="widget-wrapper">
                    <FinancePanel Data="@State.CurrentFinance" />
                </div>
            }
        </div>

        @* COLUMN 2: Operations, Tasks & Activity *@
        <div class="grid-column">
            <div class="widget-wrapper">
                @* Exact Image Reference: Tickets-enabled CRM Snapshot *@
                <CrmPanel Clients="@State.TopClients" />
            </div>

            <div class="widget-wrapper">
                @* Custom Create Task Panel (Admin Section in image) *@
                <CreateTaskPanel />
            </div>

            <div class="widget-wrapper">
                <TasksPanel Tasks="@State.CurrentTasks" />
            </div>

            <div class="widget-wrapper">
                <RecentActivityPanel Activities="@State.CurrentActivities" />
            </div>

            <div class="widget-wrapper">
                <AuditPanel Logs="@State.CurrentAuditLogs" />
            </div>
            
            @* THEME TOGGLE *@
            <div class="widget-wrapper theme-toggle-card">
                <FluentSwitch @bind-Value="IsDarkMode" Label="Dark Mode Appearance" />
            </div>
        </div>

        @* MIDDLE ROW: Quick Actions (Full Width across columns) *@
        <div class="full-width-row">
            <QuickActionsPanel />
        </div>
    </div>
</div>

@code {
    private bool IsDarkMode
    {
        get => UIState.IsDarkMode;
        set
        {
            _ = UIState.SetTheme(value ? "dark-mode" : "light-mode");
            _ = JS.InvokeVoidAsync("applyTheme", value ? "dark-mode" : "light-mode");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        // Sage X3 Logic: Detect environment and load relevant workspace data
        string env = await DetectEnvironmentAsync();
        State.SetEnvironment(env);
        await State.LoadDashboardAsync();
    }

    private Task<string> DetectEnvironmentAsync()
    {
        return Task.FromResult("Admin");
    }
}
