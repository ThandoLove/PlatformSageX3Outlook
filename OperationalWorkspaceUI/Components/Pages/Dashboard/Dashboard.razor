@page "/dashboard"
@page "/taskpane/workspace"
@page "/taskpane/compose/template"
@page "/taskpane/compose/ai-response"
@page "/taskpane/compose/attach-documents"
@page "/taskpane/compose/followup"
@rendermode InteractiveServer

@using OperationalWorkspaceUI.Components.Pages.Dashboard.DashboardComponents
@using OperationalWorkspaceUI.Components.Pages.Forms
@using OperationalWorkspaceUI.State
@using Microsoft.JSInterop

@inject DashboardState DState
@inject WorkspaceState WState
@inject UIState AppUIState
@inject IJSRuntime JS
@inject NavigationManager NavManager
@inject OperationalWorkspaceUI.UIServices.System.ModalService DashboardModalService

@implements IDisposable

<PageTitle>Sage X3 | Operational Dashboard</PageTitle>

<div class="dashboard-wrapper @(AppUIState.IsDarkMode ? "dark-mode" : "")">

    @if (_isProcessingOutlookData)
    {
        <div class="alert alert-info py-2 px-3 mb-3 d-flex align-items-center justify-content-between shadow-sm">
            <div class="d-flex align-items-center gap-2">
                <div class="spinner-border spinner-border-sm text-info" role="status"></div>
                <span class="text-sm font-weight-bold">Interrogating Sage X3 Context matrices...</span>
            </div>
            @if (!string.IsNullOrEmpty(_activeManifestActionContext))
            {
                <span class="badge bg-info">@_activeManifestActionContext</span>
            }
        </div>
    }

    @if (DState.ShowAddClientUI)
    {
        <div class="workspace-viewport fade-in-animation">
            <div class="alert alert-warning py-3 px-4 mb-4 shadow-sm d-flex align-items-start gap-3 border-start border-4 border-warning">
                <div class="fs-4">⚠️</div>
                <div>
                    <h5 class="mb-1 font-weight-bold" style="color: #856404;">New Business Prospect Detected</h5>
                    <p class="mb-0 text-sm" style="color: #856404;">
                        The sender email address <code>@DState.EmailContext.SenderEmail</code> does not match any current customer, contact, or business partner accounts inside your Sage X3 ERP infrastructure.
                    </p>
                </div>
            </div>
            <div class="card shadow-sm border-0 mb-4 rounded-lg">
                <div class="card-header bg-light border-bottom-0 py-3">
                    <h3 class="card-title h5 mb-0 font-weight-bold text-dark">Create New Sage X3 Business Partner</h3>
                </div>
                <div class="card-body p-4">
                    <CreateClientForm />
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="metrics-grid">
            @{
                var customerName = !string.IsNullOrWhiteSpace(DState.EmailContext.BusinessPartnerName)
                    ? DState.EmailContext.BusinessPartnerName
                    : (DState.TopClients?.FirstOrDefault()?.Name ?? "No Customer Linked");
            }
            <div class="flat-layout-cell kpi-box orders-box-tint">
                <div class="card-label-tiny">Open Orders</div>
                <div class="metric-value">@(DState.EmailContext.OpenOrderCount > 0 ? DState.EmailContext.OpenOrderCount : (WState.Orders?.Count ?? 0))</div>
                <span class="metric-subtext">@customerName</span>
            </div>
            <div class="flat-layout-cell kpi-box tickets-box-tint clickable-kpi-card" @onclick="OpenTicketsPanelModal">
                <div class="card-label-tiny">Open Tickets ➔</div>
                <div class="metric-value">@(WState.Tickets?.Count(t => t.Status != "Closed" && t.Status != "Resolved") ?? 0)</div>
                <span class="metric-subtext">@(WState.Tickets?.Any(t => t.Priority == "High" && t.Status != "Closed") == true ? "Urgent Action Required" : "Active work items")</span>
            </div>
            <div class="flat-layout-cell kpi-box gateway-box-tint clickable-kpi-card" @onclick="OpenAdminHealthModal">
                <div class="card-label-tiny">System Gateway @(DState.IsAdminEnvironment ? "➔" : "🔒")</div>
                @(DState.IsAdminEnvironment ? "ADMIN LOGGED" : "EMPLOYEE")
            </div>

            <span class="metric-subtext">@(DState.IsAdminEnvironment ? "Diagnostics Available" : "Identity Locked")</span>
        </div>

            <div class="flat-layout-cell kpi-box customer-box-tint">
                <div class="card-label-tiny">Customer</div>
                <div class="metric-value customer-title-lock">@customerName</div>
                <span class="metric-subtext">Account: @DState.EmailContext.AccountStatus</span>
            </div>
    

        <QuickActionsPanel />

        <div class="sage-dashboard-row">
            <div class="flat-layout-cell"><EmailContextPanel /></div>
            <div class="flat-layout-cell"><CrmPanel Clients="@DState.TopClients" /></div>
            <div class="flat-layout-cell"><KnowledgeBasePanel /></div>
        </div>

        <div class="sage-dashboard-row">
            <div class="flat-layout-cell"><AttachDocumentsPanel /></div>
            <div class="flat-layout-cell"><TasksPanel /></div>
            <div class="flat-layout-cell"><RecentActivityPanel /></div>
        </div>
    }

    @if (_isCustomModalOpen)
    {
        <div class="custom-modal-shroud" @onclick="CloseDashboardModal">
            <div class="custom-modal-viewport" @onclick:stopPropagation>
                <div class="custom-modal-header">
                    <h3>@_customModalTitle</h3>
                    <button class="custom-modal-close-btn" @onclick="CloseDashboardModal">✕</button>
                </div>
                <div class="custom-modal-body">
                    @_customModalContent
                </div>
            </div>
        </div>
    }
</div>
@code {
    private bool _isProcessingOutlookData = false;
    private string _activeManifestActionContext = string.Empty;
    private bool _showTicketsModal = false;
    private bool _showHealthModal = false;

    private bool _isCustomModalOpen = false;
    private string _customModalTitle = string.Empty;
    private RenderFragment? _customModalContent;

    protected override void OnInitialized()
    {
        DashboardModalService.OnShow += HandleShowModal;
        DashboardModalService.OnClose += HandleCloseModal;

        _ = InvokeAsync(async () =>
        {
            await DState.LoadDashboardAsync(isAdmin: DState.IsAdminEnvironment);
        });

        DState.OnChange += Refresh;
        WState.OnChange += Refresh;
        AppUIState.OnChange += Refresh;
    }

    private async Task HandleShowModal(string title, RenderFragment content)
    {
        _customModalTitle = title;
        _customModalContent = content;
        _isCustomModalOpen = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleCloseModal()
    {
        _isCustomModalOpen = false;
        _customModalTitle = string.Empty;
        _customModalContent = null;
        await InvokeAsync(StateHasChanged);
    }

    private async Task CloseDashboardModal()
    {
        await DashboardModalService.CloseModal();
    }

    private async Task OpenTicketsPanelModal()
    {
        await DashboardModalService.ShowModal("Contextual Active Tickets", builder =>
        {
            builder.OpenComponent<TicketsPanel>(0);
            builder.CloseComponent();
        });
    }

    private async Task OpenAdminHealthModal()
    {
        if (DState.IsAdminEnvironment)
        {
            await DashboardModalService.ShowModal("System Gateway Health Telemetry", builder =>
            {
                builder.OpenComponent<SystemHealthPanel>(0);
                builder.AddAttribute(1, "Status", DState.AdminHealth);
                builder.CloseComponent();
            });
        }
    }

    private void Refresh() => InvokeAsync(StateHasChanged);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var activeUriPath = NavManager.ToBaseRelativePath(NavManager.Uri).ToLowerInvariant();

                if (activeUriPath.Contains("taskpane"))
                {
                    _isProcessingOutlookData = true;
                    _activeManifestActionContext = activeUriPath switch
                    {
                        var p when p.Contains("template") => "Action: Insert Template",
                        var p when p.Contains("ai-response") => "Action: Copy Assistant",
                        var p when p.Contains("attach-documents") => "Action: Document Sync",
                        var p when p.Contains("followup") => "Action: Follow-up Activity",
                        _ => "Action: Workspace Home"
                    };
                    StateHasChanged();

                    var rawOfficePayload = await JS.InvokeAsync<System.Text.Json.JsonElement?>("eval", "window['initialOfficeItem']");
                    if (rawOfficePayload.HasValue)
                    {
                        _isProcessingOutlookData = false;
                        StateHasChanged();
                    }
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error resolving post-rendering sequence: {ex.Message}");
            }
        }
    }

    public void Dispose()
    {
        DashboardModalService.OnShow -= HandleShowModal;
        DashboardModalService.OnClose -= HandleCloseModal;

        DState.OnChange -= Refresh;
        WState.OnChange -= Refresh;
        AppUIState.OnChange -= Refresh;
    }
}
