@page "/dashboard"
@page "/taskpane/workspace"
@page "/taskpane/compose/template"
@page "/taskpane/compose/ai-response"
@page "/taskpane/compose/attach-documents"
@page "/taskpane/compose/followup"
@rendermode InteractiveServer

@* 1. COMPONENT NAMESPACES *@
@using OperationalWorkspaceUI.Components.Pages.Dashboard.DashboardComponents
@using OperationalWorkspaceUI.State
@using Microsoft.JSInterop

@* 2. SERVICE INJECTIONS *@
@inject DashboardState DState
@inject WorkspaceState WState
@inject UIState AppUIState
@inject IJSRuntime JS
@inject NavigationManager NavManager

@implements IDisposable

<PageTitle>Sage X3 | Operational Dashboard</PageTitle>

<div class="dashboard-wrapper @(AppUIState.IsDarkMode ? "dark-mode" : "")">

    @if (_isProcessingOutlookData)
    {
        <div class="alert alert-info py-2 px-3 mb-3 d-flex align-items-center justify-content-between shadow-sm">
            <div class="d-flex align-items-center gap-2">
                <div class="spinner-border spinner-border-sm text-info" role="status"></div>
                <span class="text-sm font-weight-bold">Interrogating Sage X3 Context matrices...</span>
            </div>
            @if (!string.IsNullOrEmpty(_activeManifestActionContext))
            {
                <span class="badge bg-info">@_activeManifestActionContext</span>
            }
        </div>
    }

    <!-- --- ROW 1: UPDATED HIGH-DENSITY COLORFUL METRICS HEADER STRIP --- -->
    <div class="metrics-grid">
        @{
            var customer = DState.TopClients?.FirstOrDefault();
            var customerName = customer?.Name ?? "No Customer Linked";
        }

        <!-- OPEN ORDERS: BLUE TINT -->
        <div class="flat-layout-cell kpi-box orders-box-tint">
            <div class="card-label-tiny">Open Orders</div>
            <div class="metric-value">@(WState.Orders?.Count ?? 0)</div>
            <span class="metric-subtext">@customerName</span>
        </div>

        <!-- OPEN TICKETS: RED INTERACTIVE JUMP TINT -->
        <div class="flat-layout-cell kpi-box tickets-box-tint clickable-kpi-card"
             @onclick="() => _showTicketsModal = true"
             title="Click to view Active Tickets Panel">
            <div class="card-label-tiny">Open Tickets ➔</div>
            <div class="metric-value">
                @(WState.Tickets?.Count(t => t.Status != "Closed" && t.Status != "Resolved") ?? 0)
            </div>
            <span class="metric-subtext">
                @(WState.Tickets?.Any(t => t.Priority == "High" && t.Status != "Closed") == true ? "Urgent Action Required" : "Active work items")
            </span>
        </div>

        <!-- SYSTEM GATEWAY: ADMIN/EMPLOYEE IDENTITY SECURED TINT -->
        <div class="flat-layout-cell kpi-box gateway-box-tint clickable-kpi-card"
             @onclick="OpenAdminHealthModal"
             title="@(DState.IsAdminEnvironment ? "Click to view System Health Diagnostics" : "Admin Permission Required")">
            <div class="card-label-tiny">System Gateway @(DState.IsAdminEnvironment ? "➔" : "🔒")</div>
            <div class="metric-value" style="font-size: 14px; font-weight: 800; color: @(DState.IsAdminEnvironment ? "#10b981" : "#64748b");">
                @(DState.IsAdminEnvironment ? "ADMIN LOGGED" : "EMPLOYEE")
            </div>
            <span class="metric-subtext">@(DState.IsAdminEnvironment ? "Diagnostics Available" : "Identity Locked")</span>
        </div>

        <!-- CUSTOMER CONTEXT: TEAL TINT -->
        <div class="flat-layout-cell kpi-box customer-box-tint">
            <div class="card-label-tiny">Customer</div>
            <div class="metric-value customer-title-lock">@customerName</div>
            <span class="metric-subtext">Active Status</span>
        </div>
    </div>

    @* --- ROW 2: MODERN COLORFUL ACTION STRIP RIBBON BANNER --- *@
    <div class="modern-action-strip">
        <button class="strip-btn primary-tint">👤 Add Contact</button>
        <button class="strip-btn secondary-tint">🔗 Link Existing</button>
        <button class="strip-btn accent-tint">📝 Add Quote</button>
        <button class="strip-btn success-tint">🎫 Create Ticket</button>
        <button class="strip-btn dark-tint">📊 Add Invoice</button>
        <button class="strip-btn purple-tint">📎 Attach to Email</button>
    </div>

    @* --- ROW 3: FIRST 3-COLUMN COMPACT CARDS ROW --- *@
    <div class="sage-dashboard-row">
        <div class="flat-layout-cell"><EmailContextPanel /></div>
        <div class="flat-layout-cell"><CrmPanel Clients="@DState.TopClients" /></div>
        <div class="flat-layout-cell"><KnowledgeBasePanel /></div>
    </div>

    @* --- ROW 4: SECOND 3-COLUMN COMPACT CARDS ROW --- *@
    <div class="sage-dashboard-row">
        <div class="flat-layout-cell"><AttachDocumentsPanel /></div>
        <div class="flat-layout-cell"><TasksPanel /></div>
        <div class="flat-layout-cell"><RecentActivityPanel /></div>
    </div>

    @* --- HIGH-DENSITY INTERACTIVE DIALOG MODALS --- *@
    @if (_showTicketsModal)
    {
        <div class="modal-overlay" @onclick="() => _showTicketsModal = false">
            <div class="modal-box" @onclick:stopPropagation>
                <div class="modal-header-row">
                    <h4>Contextual Active Tickets</h4>
                    <button class="close-btn" @onclick="() => _showTicketsModal = false">✕</button>
                </div>
                <div class="modal-content-scroller">
                    <TicketsPanel />
                </div>
            </div>
        </div>
    }

    @if (_showHealthModal && DState.IsAdminEnvironment)
    {
        <div class="modal-overlay" @onclick="() => _showHealthModal = false">
            <div class="modal-box success-border" @onclick:stopPropagation>
                <div class="modal-header-row">
                    <h4>System Gateway Health Telemetry</h4>
                    <button class="close-btn" @onclick="() => _showHealthModal = false">✕</button>
                </div>
                <div class="modal-content-scroller">
                    <SystemHealthPanel Status="@DState.AdminHealth" />
                </div>
            </div>
        </div>
    }

</div>

@code {
    private bool _isProcessingOutlookData = false;
    private string _activeManifestActionContext = string.Empty;
    private bool _showTicketsModal = false;
    private bool _showHealthModal = false;

    protected override void OnInitialized()
    {
        _ = InvokeAsync(async () =>
        {
            await DState.LoadDashboardAsync(isAdmin: DState.IsAdminEnvironment);
        });

        DState.OnChange += Refresh;
        WState.OnChange += Refresh;
        AppUIState.OnChange += Refresh;
    }

    private void Refresh() => InvokeAsync(StateHasChanged);

    private void OpenAdminHealthModal()
    {
        if (DState.IsAdminEnvironment) _showHealthModal = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var activeUriPath = NavManager.ToBaseRelativePath(NavManager.Uri).ToLowerInvariant();

                if (activeUriPath.Contains("taskpane"))
                {
                    _isProcessingOutlookData = true;
                    _activeManifestActionContext = activeUriPath switch
                    {
                        var p when p.Contains("template") => "Action: Insert Template",
                        var p when p.Contains("ai-response") => "Action: Copy Assistant",
                        var p when p.Contains("attach-documents") => "Action: Document Sync",
                        var p when p.Contains("followup") => "Action: Follow-up Activity",
                        _ => "Action: Workspace Home"
                    };
                    StateHasChanged();

                    var rawOfficePayload = await JS.InvokeAsync<System.Text.Json.JsonElement?>("eval", "window['initialOfficeItem']");
                    if (rawOfficePayload.HasValue)
                    {
                        _isProcessingOutlookData = false;
                        StateHasChanged();
                    }
                }
            }
            catch (Exception)
            {
                _isProcessingOutlookData = false;
                StateHasChanged();
            }
        }
    }

    public void Dispose()
    {
        DState.OnChange -= Refresh;
        WState.OnChange -= Refresh;
        AppUIState.OnChange -= Refresh;
    }
}
