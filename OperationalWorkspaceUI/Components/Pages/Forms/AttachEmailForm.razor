@page "/forms/attach-email"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.FluentUI.AspNetCore.Components
@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons
@using OperationalWorkspaceUI.Components.Pages.Forms.FormComponents
@using OperationalWorkspaceUI.UIServices.Actions
@using OperationalWorkspaceApplication.ApplicationState

@inject EmailContextState EmailState
@inject AppStateContainer AppState
@inject QuickActionUIService Actions
@inject Radzen.NotificationService Notifications
@inject NavigationManager NavManager

<FormSection Title="Attach Email to Sage Record"
             SubmitLabel="Attach to Sage X3"
             IsPrefilled="@(AppState.CurrentEmail != null)"
             OnSubmit="HandleSubmit"
             OnCancel="HandleCancel">

    @if (AppState.CurrentEmail == null)
    {
        <div class="dashboard-placeholder" style="text-align: center; padding: 40px; color: #64748b;">
            <FluentIcon Value="@(new Icons.Regular.Size48.Mail())" Color="Color.Disabled" />
            <p style="margin: 16px 0; font-size: 0.9rem;">No active email context loaded. Please select an email from the Outlook panel to execute record linkage.</p>
            <FluentButton Appearance="Appearance.Outline" OnClick="HandleCancel">Return to Dashboard</FluentButton>
        </div>
    }
    else
    {
        <EditForm Model="Model" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />

            @* SECTION 1: EMAIL SOURCE INFO *@
            <div class="sage-form-group">
                <FluentLabel Typo="Typography.Body" Style="font-weight: bold; color: #605e5c;">SOURCE EMAIL</FluentLabel>
                <div style="background-color: #f9f9f9; padding: 12px; border-radius: 4px; border: 1px solid #edebe9; margin-top: 8px;">
                    <FluentTextField Label="Subject" Value="@AppState.CurrentEmail.Subject" Readonly="true" FullWidth="true" />
                    <FluentTextField Label="From" Value="@AppState.CurrentEmail.SenderName" Readonly="true" FullWidth="true" Style="margin-top: 8px;" />
                </div>
            </div>

            @* SECTION 2: TARGET RECORD *@
            <div class="sage-form-group" style="margin-top: 24px;">
                <FluentLabel Typo="Typography.Body" Style="font-weight: bold; color: #605e5c;">TARGET RECORD</FluentLabel>
                <div class="form-grid-2-col" style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 8px;">
                    <FluentSelect Label="Entity Type" TOption="string" @bind-Value="Model.EntityType" Style="width: 100%;">
                        <FluentOption TOption="string" Value="Client">Client / Business Partner</FluentOption>
                        <FluentOption TOption="string" Value="Order">Sales Order</FluentOption>
                        <FluentOption TOption="string" Value="Task">Operational Task</FluentOption>
                        <FluentOption TOption="string" Value="Quote">Sales Quote</FluentOption>
                    </FluentSelect>

                    <div>
                        <FluentTextField Label="Record ID / Reference" @bind-Value="Model.RecordId" Placeholder="e.g. SON001234" FullWidth="true" />
                        <ValidationMessage For="@(() => Model.RecordId)" />
                    </div>
                </div>
            </div>

            @* SECTION 3: OPTIONS *@
            <div class="sage-form-group" style="margin-top: 20px;">
                <FluentCheckbox Label="Copy email attachments to Sage" @bind-Value="IncludeAttachments" />
                <FluentCheckbox Label="Mark as 'Sync Complete' in Outlook" @bind-Value="MarkProcessed" />
            </div>
        </EditForm>
    }
</FormSection>

@code {
    private AttachEmailModel Model = new();
    private bool IncludeAttachments = true;
    private bool MarkProcessed = true;

    private async Task HandleSubmit()
    {
        if (AppState.CurrentEmail == null) return;

        try
        {
            await Actions.AttachEmailAsync(Model);

            Notifications.Notify(new Radzen.NotificationMessage
            {
                Severity = Radzen.NotificationSeverity.Success,
                Summary = "Success",
                Detail = "Email successfully linked to Sage X3 record.",
                Duration = 4000
            });

            NavManager.NavigateTo("/dashboard");
        }
        catch (Exception ex)
        {
            Notifications.Notify(new Radzen.NotificationMessage
            {
                Severity = Radzen.NotificationSeverity.Error,
                Summary = "Sync Error",
                Detail = "Failed to attach: " + ex.Message
            });
        }
    }

    private void HandleCancel() => NavManager.NavigateTo("/dashboard");

    public class AttachEmailModel
    {
        public string EntityType { get; set; } = "Client";
        public string RecordId { get; set; } = string.Empty;
    }
}
