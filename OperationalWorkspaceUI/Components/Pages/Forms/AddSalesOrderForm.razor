@page "/forms/add-sales-order"
@namespace OperationalWorkspaceUI.Components.Pages.Forms

@using Microsoft.FluentUI.AspNetCore.Components
@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceApplication.Interfaces.IServices
@using OperationalWorkspaceApplication.Requests
@using OperationalWorkspaceUI.UIServices.System
@using OperationalWorkspaceUI.Components.Pages.Forms.FormComponents

@inject ISalesService SalesService
@inject ModalService ModalService
@inject NavigationManager NavManager
@inject IJSRuntime JS

<FormSection Title="New Sales Order"
             SubmitLabel="Submit to Sage X3"
             OnSubmit="HandleSubmit"
             OnCancel="() => ModalService.CloseModal()">

    <EditForm Model="orderModel" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />

        @* SECTION 1: ORDER HEADER *@
        <div class="sage-form-group">
            <FluentLabel Typo="Typography.Caption" Style="font-weight: bold; color: #605e5c;">ORDER HEADER</FluentLabel>
            <div class="form-grid-2-col">
                <div>
                    <FluentTextField Label="Customer Code" @bind-Value="orderModel.CustomerCode" Placeholder="BPC001" FullWidth="true" />
                    <ValidationMessage For="@(() => orderModel.CustomerCode)" />
                </div>
                <FluentDatePicker Label="Order Date" @bind-Value="orderModel.OrderDate" Style="width: 100%;" />
            </div>
            <div style="margin-top: 12px;">
                <FluentTextField Label="Customer Reference (PO #)" @bind-Value="orderModel.CustomerRef" Placeholder="Required for Sage X3" FullWidth="true" />
            </div>
        </div>

        @* SECTION 2: LINE ITEMS *@
        <div class="sage-form-group" style="margin-top: 24px;">
            <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #edebe9; padding-bottom: 4px; margin-bottom: 12px;">
                <FluentLabel Typo="Typography.Caption" Style="font-weight: bold; color: #605e5c;">LINE ITEMS</FluentLabel>
                <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Add())" OnClick="AddLine" Style="color: #1b5e20;">Add Product</FluentButton>
            </div>

            <div class="items-list">
                @foreach (var line in orderModel.Lines)
                {
                    <div class="item-row">
                        <div style="flex: 2;">
                            <FluentTextField Placeholder="Product Code" @bind-Value="line.ProductCode" FullWidth="true" />
                        </div>
                        <div style="flex: 0.5;">
                            <FluentNumberField Placeholder="Qty" @bind-Value="line.Quantity" FullWidth="true" />
                        </div>
                        <div style="flex: 1;">
                            <FluentNumberField Placeholder="Price" @bind-Value="line.UnitPrice" FullWidth="true">
                                <FluentIcon Value="@(new Icons.Regular.Size16.CurrencyDollar())" Slot="start" />
                            </FluentNumberField>
                        </div>
                        <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Delete())" OnClick="(() => orderModel.Lines.Remove(line))" />
                    </div>
                }
            </div>
        </div>

    </EditForm>
</FormSection>

@code {
    [Parameter] public string Email { get; set; } = "";
    [Parameter] public string FullName { get; set; } = "";

    private SalesOrderCreateDto orderModel = new() { OrderDate = DateTime.Now };

    protected override void OnInitialized()
    {
        if (!orderModel.Lines.Any()) { AddLine(); }
    }

    private void AddLine() => orderModel.Lines.Add(new SalesOrderLineCreateDto());

    private async Task HandleSubmit()
    {
        // Calculate total amount for the request
        decimal totalAmount = orderModel.Lines.Sum(l => l.Quantity * l.UnitPrice);

        var request = new CreateSalesOrderRequest(
            orderModel.CustomerCode,
            orderModel.CustomerRef,
            totalAmount,
            orderModel.Lines.Select(l => new CreateSalesOrderLineRequest(
                l.ProductCode,
                l.Quantity,
                l.UnitPrice
            )).ToList()
        );

        var response = await SalesService.CreateOrderAsync(request, default);
    
        if (response != null && response.OrderId != Guid.Empty)
        {
            await JS.InvokeVoidAsync("showToast", "Success: Sales Order Created");
            await ModalService.CloseModal();
            NavManager.NavigateTo("/workspace/orders");
        }
        else
        {
            await JS.InvokeVoidAsync("showToast", "Error: Failed to create order");
        }
    }
}

