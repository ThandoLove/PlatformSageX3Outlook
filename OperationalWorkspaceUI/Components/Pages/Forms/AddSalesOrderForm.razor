
@namespace OperationalWorkspaceUI.Components.Pages.Forms

@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceApplication.Interfaces.IServices

@using OperationalWorkspaceUI.UIServices.System
@inject ISalesService SalesService
@inject ModalService ModalService
@inject IJSRuntime JS

<div class="add-order-container p-3">
    <div class="form-header d-flex justify-content-between align-items-center mb-4">
        <h5 class="mb-0"><i class="fas fa-cart-plus text-primary me-2"></i>New Sales Order</h5>
        <span class="badge bg-soft-primary">Draft</span>
    </div>

    <EditForm Model="orderModel" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />

        <!-- HEADER SECTION -->
        <div class="form-group-section mb-4 p-3 border rounded bg-light">
            <label class="fw-bold small text-uppercase text-muted mb-2 d-block">Order Header</label>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label small">Customer Code</label>
                    <InputText @bind-Value="orderModel.CustomerCode" class="form-control" placeholder="BPC001" />
                    <ValidationMessage For="@(() => orderModel.CustomerCode)" class="text-danger small" />
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Order Date</label>
                    <InputDate @bind-Value="orderModel.OrderDate" class="form-control" />
                </div>
                <div class="col-12">
                    <label class="form-label small">Customer Reference (PO #)</label>
                    <InputText @bind-Value="orderModel.CustomerRef" class="form-control" placeholder="Required for Sage X3" />
                </div>
            </div>
        </div>

        <!-- ITEMS SECTION -->
        <div class="form-group-section p-3 border rounded bg-light">
            <label class="fw-bold small text-uppercase text-muted mb-2 d-block">Line Items</label>
            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                        <tr class="small text-muted">
                            <th>Product Code</th>
                            <th width="80">Qty</th>
                            <th width="120">Unit Price</th>
                            <th width="40"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in orderModel.Lines)
                        {
                            <tr>
                                <td><InputText @bind-Value="line.ProductCode" class="form-control form-control-sm" placeholder="Search product..." /></td>
                                <td><InputNumber @bind-Value="line.Quantity" class="form-control form-control-sm" /></td>
                                <td><InputNumber @bind-Value="line.UnitPrice" class="form-control form-control-sm" /></td>
                                <td>
                                    <button type="button" class="btn btn-link text-danger btn-sm p-0" @onclick="(() => orderModel.Lines.Remove(line))">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <button type="button" class="btn btn-outline-primary btn-sm mt-2" @onclick="AddLine">
                <i class="fas fa-plus me-1"></i> Add Product Line
            </button>
        </div>

        <div class="form-footer mt-4 d-flex justify-content-end gap-2">
            <button type="button" class="btn btn-light" @onclick="(() => ModalService.CloseModal())">Cancel</button>
            <button type="submit" class="btn btn-primary px-4">
                <i class="fas fa-check-circle me-2"></i> Submit to Sage X3
            </button>
        </div>
    </EditForm>
</div>

@code {
    @code {
    // --- ADD THESE TWO LINES HERE ---
    [Parameter] public string Email { get; set; } = "";
    [Parameter] public string FullName { get; set; } = "";
    // --------------------------------

    private SalesOrderCreateDto orderModel = new();

    protected override void OnInitialized()
    {
        // Optional: Use the passed FullName to search for the CustomerCode automatically
        if (!orderModel.Lines.Any())
        {
            AddLine();
        }
    }

    private void AddLine()
    {
        orderModel.Lines.Add(new OrderLineDto());
    }

    private async Task HandleSubmit()
    {
        var success = await SalesService.CreateOrderAsync(orderModel);
        
        if (success)
        {
            await JS.InvokeVoidAsync("showToast", "Success: Sales Order Created");
            await ModalService.CloseModal();
        }
        else
        {
            await JS.InvokeVoidAsync("showToast", "Error: Failed to create order in Sage X3");
        }
    }
}


}

