@using Microsoft.FluentUI.AspNetCore.Components
@using Microsoft.AspNetCore.Authorization

@* Ensure only authorized users can access the forms *@
@attribute [Authorize]

<div class="sage-stepper-container">
    
    @* SAGE USER IDENTITY BAR (Top of the sidebar) *@
    <div class="sage-user-header">
        <div style="display: flex; align-items: center; gap: 12px;">
            <FluentPersona Name="John Smith"
                           Status="PresenceStatus.Available"
                           Details="Sales Rep"
                           ImageSize="32px" />
        </div>
        <div class="connection-status">
            Connected to Sage X3 <FluentIcon Value="@(new Icons.Regular.Size12.ChevronDown())" />
        </div>
    </div>

    @* FORM NAVIGATION TABS (Replacing your numeric Step 1, 2, 3) *@
    <div class="sage-tab-header">
        <FluentTabs @bind-ActiveTabId="@ActiveFormId" OnTabChange="HandleTabChange">
            <FluentTab Id="contact" Label="Contact" Icon="@(new Icons.Regular.Size20.ContactCard())" />
            <FluentTab Id="order" Label="Order" Icon="@(new Icons.Regular.Size20.Cart())" />
            <FluentTab Id="task" Label="Task" Icon="@(new Icons.Regular.Size20.ClipboardTask())" />
            <FluentTab Id="quote" Label="Quote" Icon="@(new Icons.Regular.Size20.DocumentTarget())" />
            <FluentTab Id="kb" Label="Knowledge" Icon="@(new Icons.Regular.Size20.Book())" />
        </FluentTabs>
    </div>

    @* DYNAMIC CONTENT VIEWPORT *@
    <div class="sage-form-viewport">
        <div class="form-scroll-container">
            @switch (ActiveFormId)
            {
                case "contact":
                    <NewContactForm OnCancel="ResetToDashboard" />
                    break;
                case "order":
                    <AddSalesOrderForm OnCancel="ResetToDashboard" />
                    break;
                case "task":
                    <CreateTaskForm OnCancel="ResetToDashboard" />
                    break;
                case "quote":
                    <CreateQuoteForm OnCancel="ResetToDashboard" />
                    break;
                case "kb":
                    <SendKnowledgeForm OnCancel="ResetToDashboard" />
                    break;
                default:
                    <div class="dashboard-placeholder">
                        <FluentIcon Value="@(new Icons.Regular.Size48.BoxMultiple())" Color="Color.Disabled" />
                        <p>Select a Quick Action to begin.</p>
                    </div>
                    break;
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public string ActiveFormId { get; set; } = "contact";

    // This method allows the Toolbar to switch the form
    public void SetActiveForm(string formId)
    {
        ActiveFormId = formId;
        StateHasChanged();
    }

    private void HandleTabChange(FluentTab tab)
    {
        ActiveFormId = tab.Id ?? "contact";
    }

    private void ResetToDashboard()
    {
        ActiveFormId = "none";
    }
}
