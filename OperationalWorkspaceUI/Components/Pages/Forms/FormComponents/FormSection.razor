@using Microsoft.FluentUI.AspNetCore.Components
@* FIXED: Added Icons alias *@
@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons

<FluentCard Style="padding: 16px; margin: 10px 0; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); background-color: #ffffff;">
    
    @* Header Area with Title and Collapse Icon *@
    <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #eee; padding-bottom: 8px;">
        @* FIXED: Changed Subtitle to Body or Header (Body with weight 600 matches your Sage X3 look) *@
        <FluentLabel Typo="Typography.Body" Style="font-weight: 600; color: #333;">
            @Title
        </FluentLabel>
        <FluentIcon Value="@(new Icons.Regular.Size16.ChevronDown())" Color="Color.Neutral" />
    </div>
    
    @* The "Pre-filled" badge from your first image *@
    @if (IsPrefilled)
    {
        <div style="margin-top: 10px;">
            <FluentBadge Appearance="Appearance.Neutral"
                         Style="background-color: #e6f4ea; color: #1e7e34; border: none; font-weight: bold; font-size: 10px; padding: 4px 8px;">
                PRE-FILLED WITH EMAIL INFO
            </FluentBadge>
        </div>
    }

    @* Main Form Fields Area *@
    <div style="display: flex; flex-direction: column; gap: 16px; margin-top: 20px;">
        @ChildContent
    </div>

    @* Footer Actions (Cancel and the specific Green Submit button) *@
    <div style="display: flex; justify-content: flex-end; gap: 12px; margin-top: 24px; border-top: 1px solid #eee; padding-top: 16px;">
        <FluentButton Appearance="Appearance.Outline"
                      OnClick="OnCancel">
            Cancel
        </FluentButton>
        
        <FluentButton Appearance="Appearance.Accent"
                      OnClick="OnSubmit"
                      Style="background-color: #1b5e20; border-color: #1b5e20; color: white;">
            @SubmitLabel
        </FluentButton>
    </div>
</FluentCard>

@code {
    [Parameter] public string Title { get; set; } = "Form Section";
    [Parameter] public string SubmitLabel { get; set; } = "Submit";
    [Parameter] public bool IsPrefilled { get; set; } = false;
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback OnSubmit { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
}
