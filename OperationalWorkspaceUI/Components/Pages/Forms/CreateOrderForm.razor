@page "/forms/create-order"
@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceUI.Components.Pages.Forms.FormComponents
@using OperationalWorkspaceUI.UIServices.System
@using OperationalWorkspaceUI.UIServices.Workspace

@inject OrdersUIService OrderService
@inject WorkspaceState WorkspaceState
@inject NotificationService NotificationService
@inject NavigationService NavigationService

<h3>Create Order</h3>

<FormStepper Steps="@Steps" OnCompleted="SaveOrderAsync" />

@code {
    private CreateOrderDto NewOrder = new();

    private List<KeyValuePair<string,string>> Clients =>
        WorkspaceState.Clients
            .Select(c => new KeyValuePair<string,string>(c.Id.ToString(), c.Name))
            .ToList();

    private List<FormStepper.FormStep> Steps => new()
    {
        new()
        {
            Title = "Order",
            Content = @<FormSection Title="Order Info">
                            <FormField Label="Order Number" @bind-Value="NewOrder.OrderNumber" />
                            @* Use a wrapper or string-based binding if FormField is not generic *@
                            <FormField Label="Client" Type="select" Options="Clients" 
                                       Value="@NewOrder.ClientId.ToString()" 
                                       ValueChanged="@((string val) => NewOrder.ClientId = Guid.Parse(val))" />
                       </FormSection>,
            Validate = async () => !string.IsNullOrWhiteSpace(NewOrder.OrderNumber)
        },

        new()
        {
            Title = "Financial",
            Content = @<FormSection Title="Financial">
                            <FormField Label="Amount" Type="number" 
                                       Value="@NewOrder.TotalAmount.ToString()" 
                                       ValueChanged="@((string val) => NewOrder.TotalAmount = decimal.Parse(val))" />
                       </FormSection>,
            Validate = async () => NewOrder.TotalAmount > 0
        }
    };

    private async Task SaveOrderAsync()
    {
        // Ensure this method exists in your OrdersUIService
        var success = await OrderService.CreateOrderAsync(NewOrder);

        if (success)
        {
            WorkspaceState.ReloadOrders();
            // FIXED: Using method names from your NotificationService class
            await NotificationService.Success("Order created");
            NavigationService.NavigateTo("/workspace/orders");
        }
        else
        {
            // FIXED: Using method names from your NotificationService class
            await NotificationService.Error("Failed");
        }
    }
}
