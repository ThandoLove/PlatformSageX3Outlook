@page "/forms/create-order"
@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceUI.Components.Pages.Forms.FormComponents
@using OperationalWorkspaceUI.UIServices.System
@using OperationalWorkspaceUI.UIServices.Workspace
@using Microsoft.FluentUI.AspNetCore.Components
@* FIXED: Added Icons alias to resolve namespace error *@
@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons

@inject OrdersUIService OrderService
@inject WorkspaceState WorkspaceState
@inject Radzen.NotificationService NotificationService
@inject NavigationManager NavManager

<FormSection Title="Create Sales Order"
             SubmitLabel="Submit Order to Sage"
             OnSubmit="SaveOrderAsync"
             OnCancel="HandleCancel">

    <EditForm Model="NewOrder" OnValidSubmit="SaveOrderAsync">
        <DataAnnotationsValidator />

        @* SECTION 1: ORDER HEADER *@
        <div class="sage-form-group">
            @* FIXED: Changed Typography.Caption to Typography.Body *@
            <FluentLabel Typo="Typography.Body" Style="font-weight: bold; color: #605e5c;">ORDER INFO</FluentLabel>
            <div class="form-grid-2-col">
                <div>
                    <FluentTextField Label="Order Number" @bind-Value="NewOrder.OrderNumber" FullWidth="true" />
                    <ValidationMessage For="@(() => NewOrder.OrderNumber)" />
                </div>
                
                @* FIXED: Explicitly defined TOption and manual binding to resolve lambda/delegate errors *@
                <FluentSelect Label="Client"
                              TOption="string"
                              Value="@NewOrder.ClientId.ToString()"
                              ValueChanged="@(val => { NewOrder.ClientId = Guid.Parse(val); })"
                              ValueExpression="@(() => NewOrder.ClientId.ToString())"
                              Style="width: 100%;">
                    @foreach (var client in WorkspaceState.Clients)
                    {
                        <FluentOption TOption="string" Value="@client.Id.ToString()">@client.Name</FluentOption>
                    }
                </FluentSelect>
            </div>
        </div>

        @* SECTION 2: FINANCIAL DETAILS *@
        <div class="sage-form-group" style="margin-top: 24px;">
            <FluentLabel Typo="Typography.Body" Style="font-weight: bold; color: #605e5c;">FINANCIALS</FluentLabel>
            <div class="form-grid-2-col">
                <FluentNumberField Label="Total Amount" @bind-Value="NewOrder.TotalAmount" FullWidth="true">
                    @* FIXED: Changed CurrencyDollar to Money for Size16 availability *@
                    <FluentIcon Value="@(new Icons.Regular.Size16.Money())" Slot="start" />
                </FluentNumberField>

                <FluentSelect Label="Order Priority" TOption="string" Style="width: 100%;">
                    <FluentOption TOption="string" Value="Standard">Standard</FluentOption>
                    <FluentOption TOption="string" Value="Urgent">Urgent</FluentOption>
                </FluentSelect>
            </div>
        </div>

        @* SECTION 3: ADDITIONAL INFO *@
        <div class="sage-form-group" style="margin-top: 24px;">
            <FluentLabel Typo="Typography.Body" Style="font-weight: bold; color: #605e5c;">LOGISTICS</FluentLabel>
            <div class="form-grid-2-col">
                @* FIXED: Ensured bind-Value target is nullable if necessary in the DTO *@
                <FluentDatePicker Label="Requested Delivery" @bind-Value="NewOrder.OrderDate" Style="width: 100%;" />
                <FluentTextField Label="Warehouse Code" FullWidth="true" />
            </div>
        </div>

    </EditForm>
</FormSection>

@code {
    private CreateOrderDto NewOrder = new() { OrderDate = DateTime.Today };

    private async Task SaveOrderAsync()
    {
        var success = await OrderService.CreateOrderAsync(NewOrder);

        if (success)
        {
            WorkspaceState.ReloadOrders();
            
            NotificationService.Notify(new Radzen.NotificationMessage
            {
                Severity = Radzen.NotificationSeverity.Success,
                Summary = "Success",
                Detail = "Order created in Sage X3",
                Duration = 4000
            });

            NavManager.NavigateTo("/workspace/orders");
        }
        else
        {
            NotificationService.Notify(new Radzen.NotificationMessage
            {
                Severity = Radzen.NotificationSeverity.Error,
                Summary = "Error",
                Detail = "Failed to create order",
                Duration = 4000
            });
        }
    }

    private void HandleCancel()
    {
        NavManager.NavigateTo("/workspace/orders");
    }
}
