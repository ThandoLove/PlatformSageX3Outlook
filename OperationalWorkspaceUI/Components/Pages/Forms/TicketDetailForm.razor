@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceUI.State
@using OperationalWorkspaceUI.UIServices.System
@using Microsoft.FluentUI.AspNetCore.Components
@inject DashboardState State
@inject ModalService ModalService
@inject IJSRuntime JS
@inject OperationalWorkspaceUI.UIServices.ToastUIService.ToastService ToastService

<div class="sage-form-container" style="padding: 5px;">
    @* Fix 1: Use fully qualified name for Orientation to avoid Radzen conflict *@
    <FluentStack Orientation="@Microsoft.FluentUI.AspNetCore.Components.Orientation.Vertical" Spacing="4">
        
        <div style="background: #f8fafc; padding: 12px; border-radius: 8px; border: 1px solid #e2e8f0;">
            <div style="font-size: 0.8rem; color: #64748b; margin-bottom: 4px;">TICKET #@Ticket.Id</div>
            <div style="font-size: 1.1rem; font-weight: 600; color: #1e293b;">@Ticket.Title</div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
            @* Fix 2: Specify TOption="string" for FluentSelect and FluentOption *@
            <FluentSelect TOption="string" Label="Current Status" @bind-Value="Ticket.Status" Style="width: 100%;">
                <FluentOption TOption="string" Value="@("Open")">Open</FluentOption>
                <FluentOption TOption="string" Value="@("In Progress")">In Progress</FluentOption>
                <FluentOption TOption="string" Value="@("Resolved")">Resolved</FluentOption>
                <FluentOption TOption="string" Value="@("Closed")">Closed</FluentOption>
            </FluentSelect>

            <FluentSelect TOption="string" Label="Priority" @bind-Value="@_priorityString" Style="width: 100%;">
                <FluentOption TOption="string" Value="@("1")">Low</FluentOption>
                <FluentOption TOption="string" Value="@("3")">Medium</FluentOption>
                <FluentOption TOption="string" Value="@("5")">Critical</FluentOption>
            </FluentSelect>
        </div>

        <FluentTextArea Label="Resolution Notes"
                        @bind-Value="Ticket.Description"
                        Rows="5"
                        Placeholder="Enter updates for Sage X3..."
                        Style="width: 100%;" />

        <div style="display: flex; gap: 10px; margin-top: 10px;">
            <FluentButton Appearance="Appearance.Accent"
                          OnClick="HandleUpdate"
                          Style="flex: 1; background-color: #005fb8;">
                Update Sage X3
            </FluentButton>
            <FluentButton Appearance="Appearance.Outline"
                          OnClick="@(() => ModalService.CloseModal())"
                          Style="flex: 1;">
                Cancel
            </FluentButton>
        </div>
    </FluentStack>
</div>

@code {
    [Parameter] public TicketDto Ticket { get; set; } = new();

    private string _priorityString
    {
        get => Ticket.Priority.ToString();
        set => Ticket.Priority = int.Parse(value);
    }

    private async Task HandleUpdate()
    {
        var existing = State.AllTickets.FirstOrDefault(t => t.Id == Ticket.Id);
        if (existing != null)
        {
            existing.Status = Ticket.Status;
            existing.Priority = Ticket.Priority;
            existing.Description = Ticket.Description;
        }

        // Updated to use your new ToastService instead of the JS bridge
        ToastService.ShowSuccess($"Ticket #{Ticket.Id} Updated Successfully");

        await ModalService.CloseModal();
        await State.LoadDashboardAsync();
    }
}
