@page "/tickets/new"
@page "/tickets/edit/{TicketId:guid}"
@rendermode InteractiveServer

@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceUI.State
@using OperationalWorkspaceUI.UIServices.System
@using Microsoft.FluentUI.AspNetCore.Components
@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons

@implements IDisposable
@inject WorkspaceState WState 
@inject NavigationManager NavManager
@inject IJSRuntime JS
@inject OperationalWorkspaceUI.UIServices.ToastUIService.ToastService ToastService
@inject HttpClient Http

<div class="form-container" style="padding: 20px;">
    <div class="page-header" style="display: flex; align-items: center; gap: 15px; margin-bottom: 20px;">
        <FluentButton Appearance="Appearance.Stealth"
                      IconStart="@(new Icons.Regular.Size20.ArrowLeft())"
                      OnClick="@(() => NavManager.NavigateTo("/tickets"))" />
        <h2 style="color: #002d5a; margin: 0;">@(TicketId == null ? "New Service Request" : $"Edit Ticket: {_ticket.TicketNumber}")</h2>
    </div>

    <EditForm Model="@_ticket" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />
        
        <FluentStack Orientation="@Microsoft.FluentUI.AspNetCore.Components.Orientation.Vertical" Spacing="5">
            
            <div class="form-section" style="background: white; padding: 20px; border-radius: 8px; border: 1px solid #e2e8f0;">
                <label style="font-weight: 700; color: #64748b; font-size: 0.75rem; display: block; margin-bottom: 15px;">REQUEST INFORMATION</label>
                <FluentGrid>
                    <FluentGridItem xs="12" sm="8">
                        <FluentTextField Label="Subject" @bind-Value="_ticket.Title" Required="true" Style="width: 100%;" />
                    </FluentGridItem>
                    <FluentGridItem xs="12" sm="4">
                        <FluentSelect TOption="string"
                                      Label="Priority"
                                      @bind-Value="_ticket.Priority"
                                      Style="width: 100%;">
                            <FluentOption TOption="string" Value="Low">Low</FluentOption>
                            <FluentOption TOption="string" Value="Medium">Medium</FluentOption>
                            <FluentOption TOption="string" Value="High">High</FluentOption>
                        </FluentSelect>
                    </FluentGridItem>
                </FluentGrid>
            </div>

            <div class="form-section" style="background: white; padding: 20px; border-radius: 8px; border: 1px solid #e2e8f0;">
                <label style="font-weight: 700; color: #64748b; font-size: 0.75rem; display: block; margin-bottom: 15px;">SAGE X3 CONTEXT</label>
                <FluentGrid>
                    <FluentGridItem xs="12" sm="4">
                        <FluentTextField Label="Customer Name" @bind-Value="_ticket.CustomerName" Placeholder="e.g. Tech Innovations" Style="width: 100%;" />
                    </FluentGridItem>
                    <FluentGridItem xs="12" sm="4">
                        <FluentTextField Label="Site Code" @bind-Value="_ticket.SiteCode" Placeholder="e.g. AO011" Style="width: 100%;" />
                    </FluentGridItem>
                    <FluentGridItem xs="12" sm="4">
                        <FluentTextField Label="Machine Serial" @bind-Value="_ticket.MachineCode" Style="width: 100%;" />
                    </FluentGridItem>
                </FluentGrid>
            </div>

            <div class="form-section" style="background: white; padding: 20px; border-radius: 8px; border: 1px solid #e2e8f0;">
                <label style="font-weight: 700; color: #64748b; font-size: 0.75rem; display: block; margin-bottom: 15px;">PROBLEM DESCRIPTION</label>
                <FluentTextArea Label="Issue Details" @bind-Value="_ticket.Description" Rows="5" Style="width: 100%;" />
            </div>

            <div class="form-footer" style="display: flex; gap: 10px; justify-content: flex-end; margin-top: 20px;">
                <FluentButton OnClick="@(() => NavManager.NavigateTo("/tickets"))">Cancel</FluentButton>
                <FluentButton Type="@Microsoft.FluentUI.AspNetCore.Components.ButtonType.Submit"
                              Appearance="Appearance.Accent"
                              Style="background-color: #005fb8; min-width: 150px;">
                    @(TicketId == null ? "Create in Sage X3" : "Update Sage X3")
                </FluentButton>
            </div>

        </FluentStack>
    </EditForm>
</div>

@code {
    [Parameter] public Guid? TicketId { get; set; }

    private TicketDto _ticket = new();

    protected override void OnInitialized()
    {
        WState.OnChange += StateHasChanged;

        if (TicketId.HasValue)
        {
            // Pull from the same WState list the grid uses
            var existing = WState.Tickets.FirstOrDefault(t => t.Id == TicketId.Value);
            if (existing != null)
            {
                _ticket = existing;
            }
        }
        else
        {
            _ticket = new TicketDto { Status = "Open", CreatedAt = DateTime.Now, Priority = "Medium" };
        }
    }

    private async Task HandleSubmit()
    {
        if (TicketId == null)
        {
            // 1. Finalize DTO Data
            _ticket.Id = Guid.NewGuid();
            _ticket.TicketNumber = $"TKT-{Random.Shared.Next(1000, 9999)}";

            // 2. Simulate API Call (Comment this out if not using a real endpoint yet)
            // var response = await Http.PostAsJsonAsync("api/tickets/create", _ticket);
            
            // 3. INTERNAL UPDATE: Add to the shared list
            WState.Tickets.Add(_ticket);

            // 4. THE SYNC: This forces the grid page and dashboard to refresh
            WState.Notify();

            ToastService.ShowSuccess("New Ticket Created and Synced.");
        }
        else
        {
            // For updates, the object is already in the list (Reference type), 
            // so we just notify the app of the change.
            WState.Notify();
            ToastService.ShowSuccess("Ticket Updated.");
        }
        
        // 5. Go back to the list
        NavManager.NavigateTo("/tickets");
    }

    public void Dispose()
    {
        WState.OnChange -= StateHasChanged;
    }
}
