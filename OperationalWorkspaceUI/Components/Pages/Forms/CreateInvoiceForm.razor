@page "/forms/create-invoice"
@rendermode InteractiveServer

@namespace OperationalWorkspaceUI.Components.Pages.Forms

@using Microsoft.FluentUI.AspNetCore.Components
@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons
@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceApplication.Interfaces.IServices
@using OperationalWorkspaceApplication.Requests
@using OperationalWorkspaceUI.UIServices.System
@using OperationalWorkspaceUI.Components.Pages.Forms.FormComponents

@inject ISalesService SalesService
@inject ModalService ModalService
@inject NavigationManager NavManager
@inject IJSRuntime JS

<FormSection Title="New Sales Invoice" 
             SubmitLabel="Submit Invoice" 
             OnSubmit="HandleSubmit" 
             OnCancel="() => ModalService.CloseModal()">

    <EditForm Model="invoiceModel" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />

        @* SECTION 1: INVOICE HEADER *@
        <div class="sage-form-group">
            <FluentLabel Typo="Typography.Body" Class="label-strong">GENERAL INFORMATION</FluentLabel>
            <div class="form-grid-2-col">
                <div>
                    <FluentTextField Label="Sales Site" @bind-Value="invoiceModel.SalesSite" Placeholder="e.g. AO011" FullWidth="true" />
                    <ValidationMessage For="@(() => invoiceModel.SalesSite)" />
                </div>
                <FluentSelect Label="Invoice Type" TOption="string" @bind-Value="invoiceModel.InvoiceType" Class="full-width-select">
                    <FluentOption TOption="string" Value="DIR">Direct Invoice</FluentOption>
                    <FluentOption TOption="string" Value="NOR">Normal Invoice</FluentOption>
                </FluentSelect>
            </div>
            
            <div class="form-grid-2-col mt-12">
                <div>
                    <FluentTextField Label="Bill-to Customer" @bind-Value="invoiceModel.CustomerCode" Placeholder="BPC001" FullWidth="true" />
                    <ValidationMessage For="@(() => invoiceModel.CustomerCode)" />
                </div>
                    <FluentDatePicker Label="Accounting Date" @bind-Value="invoiceModel.AccountingDate" Class="full-width-select" />
            </div>
        </div>

        @* SECTION 2: INVOICE LINES *@
        <div class="sage-form-group mt-24">
            <div class="invoice-lines-header">
                <FluentLabel Typo="Typography.Body" Class="label-strong">INVOICE LINES</FluentLabel>
                <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Add())" OnClick="AddLine" Class="add-line-btn">Add Line</FluentButton>
            </div>

            <div class="items-list">
                @foreach (var line in invoiceModel.Lines)
                {
                    <div class="item-row">
                        <div class="flex-2">
                            <FluentTextField Placeholder="Product Code" @bind-Value="line.ProductCode" FullWidth="true" />
                        </div>
                        <div class="flex-05">
                            @* FIXED: Added TValue="decimal" *@
                            <FluentNumberField TValue="decimal" Placeholder="Qty" @bind-Value="line.Quantity" FullWidth="true" />
                        </div>
                        <div class="flex-1">
                            @* FIXED: Added TValue="decimal" and swapped to 'Money' icon *@
                            <FluentNumberField TValue="decimal" Placeholder="Price" @bind-Value="line.UnitPrice" FullWidth="true">
                                <FluentIcon Value="@(new Icons.Regular.Size16.Money())" Slot="start" />
                            </FluentNumberField>
                        </div>
                        <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Delete())" OnClick="(() => invoiceModel.Lines.Remove(line))" />
                    </div>
                }
            </div>
        </div>

        @* SECTION 3: SUMMARY *@
        <div class="sage-form-group mt-24 border-top">
            <div class="summary-row">
                <FluentLabel Class="label-strong">Total Invoice Value:</FluentLabel>
                <FluentLabel Class="value-strong">@TotalValue.ToString("C")</FluentLabel>
            </div>
        </div>

    </EditForm>
</FormSection>

@code {
    private InvoiceCreateDto invoiceModel = new() { AccountingDate = DateTime.Now, InvoiceType = "DIR" };

    private decimal TotalValue => invoiceModel.Lines.Sum(l => l.Quantity * l.UnitPrice);

    protected override void OnInitialized()
    {
        if (!invoiceModel.Lines.Any()) { AddLine(); }
    }

    private void AddLine() => invoiceModel.Lines.Add(new InvoiceLineDto());

    private async Task HandleSubmit()
    {
        try 
        {
            await JS.InvokeVoidAsync("showToast", "Success: Invoice Data Processed");
            await ModalService.CloseModal();
            NavManager.NavigateTo("/workspace/invoices");
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", "Error: " + ex.Message);
        }
    }

    public class InvoiceCreateDto
    {
        public string SalesSite { get; set; } = string.Empty;
        public string InvoiceType { get; set; } = string.Empty;
        public string CustomerCode { get; set; } = string.Empty;
        public DateTime? AccountingDate { get; set; } = DateTime.Now;
        public List<InvoiceLineDto> Lines { get; set; } = new();
    }

    public class InvoiceLineDto
    {
        public string ProductCode { get; set; } = string.Empty;
        public decimal Quantity { get; set; } = 1;
        public decimal UnitPrice { get; set; }
    }
}

<style>
    .sage-form-group { display: flex; flex-direction: column; gap: 8px; }
    .form-grid-2-col { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .item-row { display: flex; gap: 10px; align-items: center; margin-bottom: 10px; padding: 8px; background: #fcfcfc; border-radius: 4px; border: 1px solid #f3f2f1; }
    .items-list { max-height: 250px; overflow-y: auto; padding-right: 5px; }
    .label-strong { font-weight:700; color:#605e5c; }
    .full-width-select { width:100%; }
    .mt-12 { margin-top:12px; }
    .mt-24 { margin-top:24px; }
    .invoice-lines-header { display:flex; justify-content:space-between; align-items:center; border-bottom: 1px solid #edebe9; padding-bottom:4px; margin-bottom:12px; }
    .add-line-btn { color:#1b5e20; }
    .flex-2 { flex:2; }
    .flex-05 { flex:0.5; }
    .flex-1 { flex:1; }
    .border-top { border-top:1px solid #edebe9; padding-top:12px; }
    .summary-row { display:flex; justify-content:flex-end; gap:20px; }
    .value-strong { color:#1b5e20; font-weight:700; }
</style>
