@using OperationalWorkspaceUI.Components.Pages.Forms.FormComponents
@using OperationalWorkspaceUI.UIServices.Workspace
@using OperationalWorkspaceUI.UIServices.System

@inject KnowledgeUIService KBService
@inject Radzen.NotificationService Notifications
@inject ModalService ModalService

<div class="sage-form-content">
    @* We remove the H3 header here because the ModalService provides the header *@
    <FormStepper Steps="@Steps" OnCompleted="HandleSubmit" />
</div>

@code {
    // Shared model logic
    private OperationalWorkspaceUI.UIServices.Workspace.SendKnowledgeModel Model = new();

    private List<FormStepper.FormStep> Steps => new()
    {
        new() {
            Title = "Search",
            @* Using Fluent UI for exact visual match with the dashboard *@
            Content = @<div style="display: flex; flex-direction: column; gap: 10px; padding: 5px;">
                            <FluentTextField Label="Search Sage X3 Knowledge" 
                                             @bind-Value="Model.SearchQuery" 
                                             Placeholder="Enter keywords..."
                                             Style="width: 100%;" 
                                             Required="true" />
                       </div>,
            Validate = async () => !string.IsNullOrWhiteSpace(Model.SearchQuery)
        },
        new() {
            Title = "Message",
            Content = @<div style="display: flex; flex-direction: column; gap: 10px; padding: 5px;">
                            <FluentTextArea Label="Note to Recipient" 
                                            @bind-Value="Model.Message" 
                                            Placeholder="Add context for this article..."
                                            Style="width: 100%;" 
                                            Rows="4" />
                       </div>,
            Validate = async () => true
        }
    };

    private async Task HandleSubmit()
    {
        try 
        {
            await KBService.SendKnowledgeAsync(Model);
            
            Notifications.Notify(new Radzen.NotificationMessage
            {
                Severity = Radzen.NotificationSeverity.Success,
                Summary = "Knowledge Sent",
                Detail = "Article transmitted to recipient."
            });
            
            // CRITICAL: Close the dashboard modal on success
            await ModalService.CloseModal();
        }
        catch (Exception ex)
        {
            Notifications.Notify(new Radzen.NotificationMessage
            {
                Severity = Radzen.NotificationSeverity.Error,
                Summary = "Error",
                Detail = "Failed to send: " + ex.Message
            });
        }
    }
}
