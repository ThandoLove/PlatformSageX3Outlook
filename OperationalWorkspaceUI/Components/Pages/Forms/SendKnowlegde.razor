@page "/forms/send-knowledge"
@using OperationalWorkspaceUI.Components.Pages.Forms.FormComponents
@using OperationalWorkspaceUI.UIServices.System
@using OperationalWorkspaceUI.UIServices.Workspace

@inject KnowledgeUIService KBService
@inject NotificationService Notifications
@inject NavigationManager Navigation

<h3>Send Knowledge</h3>

<FormStepper Steps="@Steps" OnCompleted="HandleSubmit" />

@code {
    private SendKnowledgeModel Model = new();

    private List<FormStepper.FormStep> Steps => new()
    {
        new()
        {
            Title = "Search",
            Content = @<FormSection Title="Search">
                            <FormField Label="Search" @bind-Value="Model.SearchQuery" />
                       </FormSection>,
            Validate = async () => !string.IsNullOrWhiteSpace(Model.SearchQuery)
        },
        new()
        {
            Title = "Message",
            Content = @<FormSection Title="Message">
                            <FormField Label="Message" Type="textarea" @bind-Value="Model.Message" />
                       </FormSection>,
            Validate = async () => true
        }
    };

    private async Task HandleSubmit()
    {
        // Call the service we updated above
        await KBService.SendKnowledgeAsync(Model);
        
        // Show success notification
        await Notifications.Success("Knowledge sent successfully");
        
        // Go back to the main knowledge page
        Navigation.NavigateTo("/workspace/knowledge");
    }
}
