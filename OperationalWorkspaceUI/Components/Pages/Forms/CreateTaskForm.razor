@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspace.Domain.Enums
@using Microsoft.FluentUI.AspNetCore.Components

<div class="form">

    <FluentTextField Label="Title"
                     @bind-Value="Model.Title" />

    <FluentTextField Label="Company"
                     @bind-Value="Model.CompanyName" />

    <FluentDatePicker Label="Due Date"
                      @bind-Value="Model.DueDate" />

    <!-- ✅ FIXED ENUM SELECT -->
    <FluentSelect TOption="string"
                  @bind-Value="PriorityString">

        <FluentOption TOption="string" Value="Low">Low</FluentOption>
        <FluentOption TOption="string" Value="Medium">Medium</FluentOption>
        <FluentOption TOption="string" Value="High">High</FluentOption>
        <FluentOption TOption="string" Value="Urgent">Urgent</FluentOption>

    </FluentSelect>

    <FluentButton Appearance="Appearance.Accent"
                  @onclick="Create">
        Create
    </FluentButton>

</div>

@code {
    private TaskDto Model = new();

    private string PriorityString = "Medium";

    [Parameter] public EventCallback<TaskDto> OnCreated { get; set; }

    private async Task Create()
    {
        Model.Priority = PriorityString switch
        {
            "Low" => TaskPriority.Low,
            "Medium" => TaskPriority.Medium,
            "High" => TaskPriority.High,
            "Urgent" => TaskPriority.Urgent,
            _ => TaskPriority.Medium
        };

        await OnCreated.InvokeAsync(Model);

        Model = new TaskDto();
        PriorityString = "Medium";
    }
}