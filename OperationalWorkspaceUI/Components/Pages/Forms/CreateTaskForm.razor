<!-- CODE START: CreateTaskForm.razor -->

@page "/forms/create-task"
@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceUI.Components.Pages.Forms.FormComponents
@using OperationalWorkspaceUI.UIServices.System

@inject OperationalWorkspaceUI.UIServices.Workspace.TasksUIService TaskService
@inject OperationalWorkspaceUI.State.WorkspaceState WorkspaceState
@inject Radzen.NotificationService NotificationService
@inject NavigationService NavigationService



<h3>Create Task</h3>

<FormStepper Steps="@Steps" OnCompleted="SaveTaskAsync" />

@code {

    private TaskDto NewTask = new();

    private List<KeyValuePair<string,string>> Users =>
        WorkspaceState.Users
            .Select(u => new KeyValuePair<string,string>(u.Id.ToString(), u.Name))
            .ToList();

    private List<FormStepper.FormStep> Steps => new()
    {
        new()
        {
            Title = "Basic Info",
            Content = @<FormSection Title="Task Info">
                            <FormField Label="Title" @bind-Value="NewTask.Title" />
                            <FormField Label="Description" Type="textarea"
                                       @bind-Value="NewTask.StatusDescription" />
                       </FormSection>,
            Validate = async () =>
                !string.IsNullOrWhiteSpace(NewTask.Title)
        },

        new()
        {
            Title = "Assignment",
            Content = @<FormSection Title="Assignment">
                            <FormField Label="Assigned To"
                                       Type="select"
                                       Options="Users"
                                       @bind-Value="NewTask.AssignedTo" />
                       </FormSection>,
            Validate = async () =>
                !string.IsNullOrWhiteSpace(NewTask.AssignedTo)
        },

        new()
        {
            Title = "Schedule",
            Content = @<FormSection Title="Schedule">
                            <FormField Label="Due Date"
                                       Type="date"
                                       @bind-Value="DueDateString" />
                       </FormSection>,
            Validate = async () => true
        }
    };

    private string DueDateString
    {
        get => NewTask.DueDate.ToString("yyyy-MM-dd");
        set
        {
            if (DateTime.TryParse(value, out var date))
                NewTask.DueDate = date;
        }
    }

    private async Task SaveTaskAsync()
    {
        var success = await TaskService.CreateTaskAsync(NewTask);

        if (success)
        {
            WorkspaceState.ReloadTasks();
        
            NotificationService.Notify(new Radzen.NotificationMessage
            {
                Severity = Radzen.NotificationSeverity.Success,
                Summary = "Success",
                Detail = "Task created successfully"
            });
        
            NavigationService.NavigateTo("/workspace/tasks");
        }
        else
        {
            NotificationService.Notify(new Radzen.NotificationMessage
            {
                Severity = Radzen.NotificationSeverity.Error,
                Summary = "Error",
                Detail = "Failed to create task"
            });
        }
    }

}

<!-- CODE END -->