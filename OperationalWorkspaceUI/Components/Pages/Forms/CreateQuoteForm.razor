@using OperationalWorkspaceUI.Components.Pages.Forms.FormComponents
@using OperationalWorkspaceUI.UIServices.Actions
@using OperationalWorkspaceUI.UIServices.System

@inject EmailContextState EmailState
@inject QuickActionUIService Actions
@inject NotificationService Notifications

<h3>Create Quote</h3>

<FormStepper Steps="@Steps" OnCompleted="SubmitForm" />

@code {

    private List<FormStepper.FormStep> Steps;
    private CreateQuoteModel Model = new();

    protected override void OnInitialized()
    {
        // Pre-fill from email
        if (EmailState.CurrentEmail != null)
        {
            Model.ClientEmail = EmailState.CurrentEmail.From;
            Model.Description = EmailState.CurrentEmail.Subject;
        }

        Steps = new()
        {
            new FormStepper.FormStep
            {
                Title = "Client",
                Content = builder =>
                {
                    builder.OpenComponent<FormSection>(0);
                    builder.AddAttribute(1, "Title", "Client Info");
                    builder.AddAttribute(2, "ChildContent", (RenderFragment)(b =>
                    {
                        b.OpenComponent<FormField>(0);
                        b.AddAttribute(1, "Label", "Client Email");
                        b.AddAttribute(2, "Value", Model.ClientEmail);
                        b.AddAttribute(3, "ValueChanged", EventCallback.Factory.Create<string>(this, v => Model.ClientEmail = v));
                        b.CloseComponent();
                    }));
                    builder.CloseComponent();
                },
                Validate = async () => !string.IsNullOrWhiteSpace(Model.ClientEmail)
            },

            new FormStepper.FormStep
            {
                Title = "Details",
                Content = builder =>
                {
                    builder.OpenComponent<FormSection>(0);
                    builder.AddAttribute(1, "Title", "Quote Details");
                    builder.AddAttribute(2, "ChildContent", (RenderFragment)(b =>
                    {
                        // Name
                        b.OpenComponent<FormField>(0);
                        b.AddAttribute(1, "Label", "Quote Name");
                        b.AddAttribute(2, "Value", Model.Name);
                        b.AddAttribute(3, "ValueChanged", EventCallback.Factory.Create<string>(this, v => Model.Name = v));
                        b.CloseComponent();

                        // Description
                        b.OpenComponent<FormField>(4);
                        b.AddAttribute(5, "Label", "Description");
                        b.AddAttribute(6, "Type", "textarea");
                        b.AddAttribute(7, "Value", Model.Description);
                        b.AddAttribute(8, "ValueChanged", EventCallback.Factory.Create<string>(this, v => Model.Description = v));
                        b.CloseComponent();

                        // Amount
                        b.OpenComponent<FormField>(9);
                        b.AddAttribute(10, "Label", "Amount");
                        b.AddAttribute(11, "Type", "number");
                        b.AddAttribute(12, "Value", Model.Amount.ToString());
                        b.AddAttribute(13, "ValueChanged", EventCallback.Factory.Create<string>(this, v =>
                        {
                            if (decimal.TryParse(v, out var val))
                                Model.Amount = val;
                        }));
                        b.CloseComponent();
                    }));
                    builder.CloseComponent();
                },
                Validate = async () => 
                    !string.IsNullOrWhiteSpace(Model.Name) && Model.Amount > 0
            }
        };
    }

    private async Task SubmitForm()
    {
        try
        {
            await Actions.CreateQuoteAsync(Model);
            Notifications.Success("Quote created successfully");
        }
        catch
        {
            Notifications.Error("Failed to create quote");
        }
    }

    public class CreateQuoteModel
    {
        public string ClientEmail { get; set; }
        public string Name { get; set; }
        public string Description { get; set; }
        public decimal Amount { get; set; }
    }
}

<!-- CODE END -->