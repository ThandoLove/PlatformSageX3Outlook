@page "/"
@layout EmptyLayout
@rendermode InteractiveServer

@using OperationalWorkspaceUI.Components.Shared
@using OperationalWorkspaceUI.UIServices.System

@inject NavigationManager Nav
@inject IJSRuntime JS
@inject ModalService ModalService

<PageTitle>Sage X3 Workspace</PageTitle>

<div class="landing-page">

    <!-- TOP BAR -->
    <div class="landing-topbar">

        <div class="brand-area">
            <img src="/images/sage-x3-logo.png"
                 class="brand-logo"
                 alt="Sage X3" />

            <div>
                <h1>Sage X3 Workspace</h1>
                <span>Operational Intelligence Platform</span>
            </div>
        </div>

        <button class="theme-toggle-btn"
                @onclick="ToggleTheme">

            <i class="ms-Icon ms-Icon--@(isDark ? "Sunny" : "ClearNight")"></i>

        </button>

    </div>

    <!-- HERO -->
    <section class="hero-section">

        <div class="hero-content">

            <div class="hero-badge">
                Outlook + Sage X3 Integration
            </div>

            <h2>
                Enterprise Workspace
                Built For Operations
            </h2>

            <p>
                Manage CRM, ERP, emails, workflows,
                tickets, approvals and operational activity
                from a single contextual workspace.
            </p>

            <div class="hero-actions">

                <button class="btn-primary"
                        @onclick="ShowLogin">

                    <i class="ms-Icon ms-Icon--Forward"></i>
                    Sign In

                </button>

                <button class="btn-secondary">
                    Learn More
                </button>

            </div> <!-- FIXED: Closed actions container -->

        </div> <!-- FIXED: Closed content container -->

    </section> <!-- FIXED: Closed hero block -->

</div> <!-- FIXED: Closed root layout framework -->
@code {
    private bool isDark = false;

    // 🟢 FIXED: Created missing theme controller to execute light/dark styles
    private async Task ToggleTheme()
    {
        isDark = !isDark;
        
        // Triggers your project's global stylesheet modifier if present
        await JS.InvokeVoidAsync("localStorage.setItem", "theme", isDark ? "dark" : "light");
        StateHasChanged();
    }

    // 🟢 FIXED: Implemented missing handler targeting your Modal Service overlay
    private async Task ShowLogin()
    {
        // Spawns your modal container. If your ModalService takes parameters,
        // update this line to use your exact method signature, e.g., OpenModal<Login>()
        await ModalService.OpenModal();
    }
}
