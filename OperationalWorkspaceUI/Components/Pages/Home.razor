@page "/"
@layout EmptyLayout
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Operational Workspace | Sage X3</PageTitle>

<div class="landing-page">

    <!-- THEME TOGGLE -->
    <button class="btn-outline" @onclick="ToggleTheme">
        Toggle Theme
    </button>

    <!-- HERO -->
    <section class="hero-section">
        <div class="hero-content">
            <div class="brand-logo">
                <img src="https://dummyimage.com/200x80/00c853/ffffff&text=Sage+X3" />
            </div>
            
            <h1 class="hero-title">Operational Workspace</h1>

            <p class="hero-subtitle">
                Contextual ERP insights delivered directly to your Outlook.
            </p>

            <div class="hero-actions">
                <button class="btn-primary" @onclick="GoToLogin">
                    Get Started
                </button>
                <button class="btn-outline">
                    Learn More
                </button>
            </div>
        </div>

        <!-- DASHBOARD PREVIEW -->
        <div class="hero-visual">
            <div class="dashboard-preview">
                <div class="preview-sidebar"></div>
                
                <div class="preview-main">
                    <div class="preview-top"></div>

                    <div class="preview-body">
                        <div class="preview-card"></div>
                        <div class="preview-card"></div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <footer class="landing-footer">
        <div class="footer-item">
            <span>Real-time Sync</span>
        </div>
        <div class="footer-item">
            <span>Secure Access</span>
        </div>
        <div class="footer-item">
            <span>ERP Context</span>
        </div>
    </footer>

</div>

@code {

    private bool isDark = true;

    private void GoToLogin()
    {
        Nav.NavigateTo("/login");
    }

    private async Task ToggleTheme()
    {
        isDark = !isDark;

        if (isDark)
        {
            await JS.InvokeVoidAsync("document.body.classList.remove", "light-mode");
            await JS.InvokeVoidAsync("document.body.classList.add", "dark-mode");
        }
        else
        {
            await JS.InvokeVoidAsync("document.body.classList.remove", "dark-mode");
            await JS.InvokeVoidAsync("document.body.classList.add", "light-mode");
        }
    }
}