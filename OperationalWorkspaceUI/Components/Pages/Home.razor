@page "/"
@layout EmptyLayout
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Operational Workspace | Sage X3</PageTitle>

<div class="landing-page">
    @* --- HERO SECTION --- *@
    <section class="hero-section">
        <div class="hero-content">
            <div class="brand-logo">
                <img src="images/sage-logo.png" alt="Sage X3 Logo" class="sage-logo" />
            </div>
            
            <h1 class="hero-title">Operational Workspace</h1>
            <p class="hero-subtitle">
                Contextual ERP insights delivered directly to your Outlook.
                Enhance your productivity with seamless Sage X3 integration.
            </p>

            <div class="hero-actions">
                <button class="btn-primary" @onclick="GoToLogin">
                    Get Started
                </button>
                <button class="btn-outline">
                    Learn More
                </button>
            </div>
        </div>

        @* --- RIGHT SIDE: DASHBOARD PREVIEW MOCKUP --- *@
        <div class="hero-visual">
            <div class="dashboard-preview">
                @* Miniature Sidebar *@
                <div class="preview-sidebar"></div>
                
                @* Miniature Main Area *@
                <div class="preview-main">
                    <div class="preview-top"></div>
                    <div class="preview-body">
                        <div class="preview-card"></div>
                        <div class="preview-card"></div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* --- QUICK FEATURES (Footer) --- *@
    <footer class="landing-footer">
        <div class="footer-item">
            <i class="ms-Icon ms-Icon--LightningBolt"></i>
            <span>Real-time Sync</span>
        </div>
        <div class="footer-item">
            <i class="ms-Icon ms-Icon--Shield"></i>
            <span>Secure Access</span>
        </div>
        <div class="footer-item">
            <i class="ms-Icon ms-Icon--Insights"></i>
            <span>ERP Context</span>
        </div>
    </footer>
</div>

@code {
    private void GoToLogin()
    {
        // 1. Send user to Login Page
        Nav.NavigateTo("/login");
    }
}
