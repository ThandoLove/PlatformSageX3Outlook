@page "/login"
@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceUI.Security
@using Microsoft.AspNetCore.Components.Authorization
@using Majorsoft.Blazor.Extensions.BrowserStorage
@* FIX 1: Use Accelist instead of Blazored *@
@using Accelist.FluentValidation.Blazor
@inject HttpClient Http
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@inject ILocalStorageService LocalStorage

<div class="login-container d-flex align-items-center justify-content-center" style="min-height: 80vh;">
    <div class="card shadow-lg" style="width: 100%; max-width: 400px;">
        <div class="card-body p-4">
            <h3 class="text-center mb-4">Sage X3 Portal</h3>
            
            <EditForm Model="loginModel" OnValidSubmit="HandleLogin">
                @* FIX 2: This component now works because of the Accelist using above *@
                <FluentValidator />

                <div class="mb-3">
                    <label class="form-label">Username</label>
                    <InputText @bind-Value="loginModel.Username" class="form-control" placeholder="Enter username" />
                    <ValidationMessage For="@(() => loginModel.Username)" class="text-danger small" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <InputText @bind-Value="loginModel.Password" type="password" class="form-control" placeholder="Enter password" />
                    <ValidationMessage For="@(() => loginModel.Password)" class="text-danger small" />
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary w-100" disabled="@isBusy">
                        @if (isBusy)
                        {
                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                            <span> Verifying...</span>
                        }
                        else
                        {
                            <span>Login</span>
                        }
                    </button>
                </div>
            </EditForm>

            @if (!string.IsNullOrEmpty(error))
            {
                <div class="alert alert-danger mt-3 mb-0" role="alert">
                    <i class="bi bi-exclamation-octagon-fill me-2"></i> @error
                </div>
            }
        </div>
    </div>
</div>

@code {
    private LoginRequestDto loginModel = new();
    private string? error;
    private bool isBusy;

    private async Task HandleLogin()
    {
        isBusy = true;
        error = null;

        try
        {
            var response = await Http.PostAsJsonAsync("api/v1/Auth/login", loginModel);
            
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
                
                if (result.TryGetProperty("data", out var data) && data.TryGetProperty("token", out var tokenProp))
                {
                    var token = tokenProp.GetString();
                    if (!string.IsNullOrEmpty(token))
                    {
                        await LocalStorage.SetItemAsync("authToken", token);
                        
                        var customAuthStateProvider = (CustomAuthenticationStateProvider)AuthStateProvider;
                        customAuthStateProvider.NotifyUserAuthentication(token);
                        
                        Nav.NavigateTo("/");
                    }
                }
            }
            else
            {
                error = "Access denied. Please check your credentials.";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Login Error]: {ex.Message}");
            error = "Network error: Could not reach the authentication server.";
        }
        finally
        {
            isBusy = false;
        }
    }
}
