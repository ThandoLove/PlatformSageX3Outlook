@using OperationalWorkspaceUI.State
@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceApplication.Mappers
@inject DashboardState State
@implements IDisposable

<div class="admin-queue-panel">
    <div class="panel-header">
        <h3>Operational Queues</h3>
        <span class="total-count">@State.AllTasks.Count Total</span>
    </div>

    <div class="queue-groups">
        @foreach (var group in GroupedTasks)
        {
            <div class="queue-group @GetGroupClass(group.Key)">
                <div class="group-info" @onclick="() => ToggleGroup(group.Key)">
                    <span class="status-dot"></span>
                    <span class="group-name">@group.Key</span>
                    <span class="group-badge">@group.Value.Count()</span>
                </div>

                @if (ExpandedGroups.Contains(group.Key))
                {
                    <ul class="queue-items">
                        @foreach (var task in group.Value)
                        {
                            <li class="queue-item @(State.SelectedTask?.Id == task.Id ? "active" : "")" 
                                @onclick="() => State.SetSelectedTask(task)">
                                <div class="item-meta">
                                    <span class="task-id">#@task.Id</span>
                                    <span class="assignee">@task.AssignedToName</span>
                                </div>
                                <div class="item-subject">@task.Subject</div>
                                @if (AdminTaskRulesEngine.IsSlaBreached(task.DueDate, task.Status))
                                {
                                    <span class="sla-urgent">OVERDUE</span>
                                }
                            </li>
                        }
                    </ul>
                }
            </div>
        }
    </div>
</div>

@code {
    private HashSet<string> ExpandedGroups = new() { "Critical Priority", "SLA Violations" };

    // Grouping logic driven by the AdminTaskRulesEngine
    private IEnumerable<IGrouping<string, TaskDto>> GroupedTasks => 
        State.AllTasks.GroupBy(AdminTaskRulesEngine.MapToAdminQueue);

    protected override void OnInitialized() => State.OnChange += StateHasChanged;

    private void ToggleGroup(string groupName)
    {
        if (ExpandedGroups.Contains(groupName)) ExpandedGroups.Remove(groupName);
        else ExpandedGroups.Add(groupName);
    }

    private string GetGroupClass(string groupName) => groupName switch
    {
        "Critical Priority" => "status-critical",
        "SLA Violations" => "status-warning",
        _ => "status-normal"
    };

    public void Dispose() => State.OnChange -= StateHasChanged;
}



