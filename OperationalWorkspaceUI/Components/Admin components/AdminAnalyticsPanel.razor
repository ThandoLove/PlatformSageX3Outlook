@using OperationalWorkspaceUI.State
@using OperationalWorkspaceApplication.DTOs
@inject DashboardState State
@implements IDisposable

<div class="analytics-sidebar">
    <div class="analytics-header">
        <h5>Corporate Performance</h5>
        <div class="timeframe-pill">Last 24 Hours</div>
    </div>

    <div class="analytics-scroll-area">
        @* 1. TASK DISTRIBUTION *@
        <div class="chart-card">
            <label>Workload Distribution</label>
            <div class="bar-chart">
                @foreach (var dept in DepartmentStats)
                {
                    <div class="bar-row">
                        <span class="bar-label">@dept.Name</span>
                        <div class="bar-track">
                            <div class="bar-fill" style="width: @(dept.Percentage)%"></div>
                        </div>
                        <span class="bar-value">@dept.Count</span>
                    </div>
                }
            </div>
        </div>

        @* 2. THROUGHPUT METRICS *@
        <div class="metrics-stack">
            <div class="mini-metric">
                <span class="m-label">Avg. Resolution</span>
                <span class="m-value">4.2h</span>
                <span class="m-trend positive">↓ 12%</span>
            </div>
            <div class="mini-metric">
                <span class="m-label">Escalation Rate</span>
                <span class="m-value">@EscalationRate%</span>
                <span class="m-trend negative">↑ 3%</span>
            </div>
        </div>

        @* 3. SYSTEM HEALTH (ADMIN ONLY) *@
        <div class="health-card">
            <label>Integration Status</label>
            <div class="health-item">
                <span>ERP (Sage X3)</span>
                <span class="status-online">Online</span>
            </div>
            <div class="health-item">
                <span>CRM Sync</span>
                <span class="status-online">Active</span>
            </div>
            <div class="health-item">
                <span>Email Listener</span>
                <span class="status-warning">Delayed</span>
            </div>
        </div>
    </div>
</div>

@code {
    private List<(string Name, int Count, int Percentage)> DepartmentStats = new()
    {
        ("Sales", 14, 65),
        ("Support", 8, 40),
        ("Finance", 5, 25)
    };

    private int EscalationRate => State.AllTasks.Any() 
        ? (State.AllTasks.Count(t => t.IsEscalated) * 100) / State.AllTasks.Count 
        : 0;

    protected override void OnInitialized() => State.OnChange += StateHasChanged;

    public void Dispose() => State.OnChange -= StateHasChanged;
}

