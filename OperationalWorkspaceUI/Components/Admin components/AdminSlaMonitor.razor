@using OperationalWorkspaceUI.State
@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceApplication.Mappers
@inject DashboardState State
@implements IDisposable

<div class="sla-monitor-container">
    <div class="sla-header">
        <h4>SLA Compliance Monitor</h4>
        <span class="pulse-indicator">LIVE</span>
    </div>

    <div class="sla-metrics-grid">
        @* BREACHED METRIC (CRITICAL) *@
        <div class="sla-card breached @(BreachedCount > 0 ? "active" : "")">
            <div class="card-body">
                <span class="metric-value">@BreachedCount</span>
                <span class="metric-label">Breached</span>
            </div>
            <div class="card-footer">Needs Immediate Action</div>
        </div>

        @* AT RISK METRIC (WARNING) *@
        <div class="sla-card warning">
            <div class="card-body">
                <span class="metric-value">@AtRiskCount</span>
                <span class="metric-label">At Risk</span>
            </div>
            <div class="card-footer">< 2 Hours Remaining</div>
        </div>

        @* ON TRACK METRIC (HEALTHY) *@
        <div class="sla-card healthy">
            <div class="card-body">
                <span class="metric-value">@OnTrackCount</span>
                <span class="metric-label">Healthy</span>
            </div>
            <div class="card-footer">SLA Standards Met</div>
        </div>
    </div>
</div>

@code {
    // Computed properties for real-time monitoring
    private int BreachedCount => State.AllTasks.Count(t => 
        AdminTaskRulesEngine.IsSlaBreached(t.DueDate, t.Status));

    private int AtRiskCount => State.AllTasks.Count(t => 
        !AdminTaskRulesEngine.IsSlaBreached(t.DueDate, t.Status) && 
        (t.DueDate - DateTime.Now).TotalHours < 2);

    private int OnTrackCount => State.AllTasks.Count(t => 
        !AdminTaskRulesEngine.IsSlaBreached(t.DueDate, t.Status) && 
        (t.DueDate - DateTime.Now).TotalHours >= 2);

    protected override void OnInitialized() => State.OnChange += StateHasChanged;

    public void Dispose() => State.OnChange -= StateHasChanged;
}

