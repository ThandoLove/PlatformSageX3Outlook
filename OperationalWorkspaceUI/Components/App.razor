@using Radzen.Blazor
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    
    <link rel="stylesheet" href="lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="_content/Radzen.Blazor/css/standard-base.css">
    <link rel="stylesheet" href="https://res-1.cdn.office.net/files/fabric-cdn-prod_20230815.002/office-ui-fabric-core/11.0.0/css/fabric.min.css">
    <link rel="stylesheet" href="/OperationalWorkspaceUI.styles.css" />

    <!-- CUSTOM CSS -->
    <link rel="stylesheet" href="css/Landing.css" />
    <link rel="stylesheet" href="css/Forms.css" />
    <link rel="stylesheet" href="css/Workspace.css" />
    <link rel="stylesheet" href="css/Components.css" />
    <link href="css/AdminUsers.css" rel="stylesheet" />
    <link href="css/AdminAudit.css" rel="stylesheet" />
    <link href="css/AdminHealth.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/app.css" /> @* Locked colors live here *@
    
    <link rel="icon" type="image/png" href="/favicon.png" />

    <script type="text/javascript">
            window._historyCache = { replaceState: window.history.replaceState, pushState: window.history.pushState };
    </script>
    <script src="https://appsforoffice.microsoft.com/lib/1/hosted/office.js"></script>
    <script type="text/javascript">
        window.history.replaceState = window._historyCache.replaceState;
        window.history.pushState = window._historyCache.pushState;
    </script>

    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body>
    <RadzenComponents />

    <Routes @rendermode="InteractiveServer" />
    <Modal @rendermode="InteractiveServer" />
    <ReconnectModal />

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="/js/charts.js"></script>
    <script src="/js/officeBridge.js"></script>
    <script src="/js/app.js"></script>

    @* --- THEME ENGINE DELETED --- *@

    <script src="_framework/blazor.web.js"></script>
    <script src="_content/Radzen.Blazor/Radzen.Blazor.js"></script>
    <script src="_content/Microsoft.FluentUI.AspNetCore.Components/Microsoft.FluentUI.AspNetCore.Components.lib.module.js" type="module"></script>

    <script>
        if (window.Office) {
        Office.onReady(function (info) {
        if (info.host !== Office.HostType.Outlook) {
        window.history.pushState = window._historyCache.pushState;
        window.history.replaceState = window._historyCache.replaceState;
        }
        });
        } else {
        window.history.pushState = window._historyCache.pushState;
        window.history.replaceState = window._historyCache.replaceState;
        }
    </script>
</body>
</html>
