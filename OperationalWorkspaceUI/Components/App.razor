@using Radzen.Blazor
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    
    <!-- STYLES -->
    <link rel="stylesheet" href="lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="app.css" />
    <link rel="stylesheet" href="OperationalWorkspaceUI.styles.css" />
    <link rel="stylesheet" href="_content/Radzen.Blazor/css/standard-base.css">
    
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    
    <!-- Office.js - Required for Outlook Context -->
    <script src="https://appsforoffice.microsoft.com/lib/1/hosted/office.js"></script>
    
    <HeadOutlet />
</head>

<body>
    <!-- RADZEN COMPONENTS (Required for Notifications/Dialogs) -->
    <RadzenComponents />

    <!-- FLUENT UI PROVIDER (Required for Icons and Design System) -->
    <FluentDesignTheme />

    <Routes />
    <ReconnectModal />

    <!-- SCRIPTS -->
    <script src="_framework/blazor.web.js"></script>
    <script src="_content/Radzen.Blazor/Radzen.Blazor.js"></script>
    <script src="_content/Microsoft.FluentUI.AspNetCore.Components/Microsoft.FluentUI.AspNetCore.Components.lib.module.js" type="module"></script>
    
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="js/charts.js"></script>
    <script src="js/officeBridge.js"></script> <!-- Your Outlook Bridge -->
    <script src="js/app.js"></script>
</body>

</html>
