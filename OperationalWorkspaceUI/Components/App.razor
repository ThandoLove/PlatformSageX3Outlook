@using Radzen.Blazor
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    
    <!-- 1. EXTERNAL FRAMEWORKS (Lowest Priority) -->
    <link rel="stylesheet" href="lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="_content/Radzen.Blazor/css/standard-base.css">
    <link rel="stylesheet" href="https://res-1.cdn.office.net/files/fabric-cdn-prod_20230815.002/office-ui-fabric-core/11.0.0/css/fabric.min.css">
    
    <!-- 2. INTERNAL BLAZOR STYLES (Includes MainLayout.razor.css) -->
    <link rel="stylesheet" href="/OperationalWorkspaceUI.styles.css" />

    <!-- 3. CUSTOM CSS (HIGHEST PRIORITY - Must be last to override layout) -->
    <link rel="stylesheet" href="/css/app.css" />
    <link rel="stylesheet" href="/css/Dashboard.css" />
    <link rel="stylesheet" href="css/Landing.css" />
    <link rel="stylesheet" href="css/Forms.css" />
    <link rel="stylesheet" href="css/Workspace.css" />
    <link rel="stylesheet" href="css/Components.css" />
    
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- HISTORY CACHE SCRIPTS -->
    <script type="text/javascript">
            window._historyCache = {
                replaceState: window.history.replaceState,
                pushState: window.history.pushState
            };
    </script>
    
    <script src="https://appsforoffice.microsoft.com/lib/1/hosted/office.js"></script>
    
    <script type="text/javascript">
        window.history.replaceState = window._historyCache.replaceState;
        window.history.pushState = window._historyCache.pushState;
    </script>

    <HeadOutlet @rendermode="InteractiveServer" />
</head>

@* 🔥 REMOVED hardcoded dark-mode so your C# ToggleTheme works! *@
<body>
    <RadzenComponents />
    <FluentDesignTheme />

    <Routes @rendermode="InteractiveServer" />
    
    @* 🔥 GLOBAL MODAL PLACEMENT *@
    <Modal @rendermode="InteractiveServer" />
    
    <ReconnectModal />

    <!-- SCRIPTS -->
    <script src="_framework/blazor.web.js"></script>
    <script src="_content/Radzen.Blazor/Radzen.Blazor.js"></script>
    <script src="_content/Microsoft.FluentUI.AspNetCore.Components/Microsoft.FluentUI.AspNetCore.Components.lib.module.js" type="module"></script>
    
    <script src="/js/officeBridge.js"></script>
    <script src="/js/app.js"></script>

    <script>
        if (window.Office) {
        Office.onReady(function (info) {
        if (info.host === Office.HostType.Outlook) {
        console.log("Status: Running inside Outlook.");
        } else {
        console.log("Status: Running in Browser. Restoring navigation...");
        window.history.pushState = window._historyCache.pushState;
        window.history.replaceState = window._historyCache.replaceState;
        }
        });
        } else {
        console.log("Office.js not available (browser mode)");
        window.history.pushState = window._historyCache.pushState;
        window.history.replaceState = window._historyCache.replaceState;
        }
    </script>
</body>
</html>
