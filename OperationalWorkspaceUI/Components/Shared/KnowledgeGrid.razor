<!-- CODE START: KnowledgeGrid.razor -->
@using OperationalWorkspaceApplication.DTOs

@if (IsLoading)
{
    <LoadingSpinner />
}
else if (Data == null || !Data.Any())
{
    <EmptyState Message="No knowledge articles found." />
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Title</th>
                <th>Category</th>
                <th>Summary</th> @* Changed from Created to Summary *@
            </tr>
        </thead>
        <tbody>
            @foreach (var kb in Data)
            {
                <tr @onclick="() => OnRowClick.InvokeAsync(kb)" style="cursor:pointer">
                    <td>@kb.Title</td>
                    <td>@kb.Category</td>
                    <td>@kb.Summary</td> @* Removed .CreatedDate and used .Summary *@
                </tr>
            }
        </tbody>
    </table>
}

@code {
    [Parameter] public List<KnowledgeDto>? Data { get; set; }
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public EventCallback<KnowledgeDto> OnRowClick { get; set; }
}
