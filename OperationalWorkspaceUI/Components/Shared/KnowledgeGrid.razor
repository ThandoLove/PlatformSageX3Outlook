@using OperationalWorkspaceApplication.DTOs
@using Microsoft.FluentUI.AspNetCore.Components

<div class="sage-grid-wrapper" style="background: white; border-radius: 8px; border: 1px solid #e2e8f0; overflow: hidden;">
    <FluentDataGrid Items="@Data.AsQueryable()"
                    ResizableColumns="true"
                    TGridItem="KnowledgeDto"
                    OnRowClick="@((FluentDataGridRow<KnowledgeDto> row) => OnRowClick.InvokeAsync(row.Item))"
                    Style="width: 100%;">
        
        <PropertyColumn Property="@(p => p.Title)" Title="Article Title" Sortable="true" />
        
        <PropertyColumn Property="@(p => p.Category)" Title="Category" Sortable="true">
            <ColumnOptions>
                <div style="padding: 10px; font-weight: 600; color: #003366;">Filter by Category</div>
            </ColumnOptions>
        </PropertyColumn>
        
        <PropertyColumn Property="@(p => p.Summary)" Title="Summary" />

        <TemplateColumn Title="Actions" Align="Align.End">
            <FluentButton Appearance="Appearance.Lightweight"
                          IconStart="@(new Icons.Regular.Size16.Open())"
                          OnClick="@(() => OnRowClick.InvokeAsync(context))" />
        </TemplateColumn>

    </FluentDataGrid>
</div>

@code {
    [Parameter] public List<KnowledgeDto> Data { get; set; } = new();
    [Parameter] public EventCallback<KnowledgeDto> OnRowClick { get; set; }
}
