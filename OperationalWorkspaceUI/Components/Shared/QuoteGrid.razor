@using OperationalWorkspaceApplication.DTOs
@using System.Linq

<div class="dashboard-card quote-container">
    <div class="panel-header">
        <h4>Late Shipments / Open Quotes</h4>
    </div>

    <div class="table-responsive">
        <table class="table sage-table">
            <thead>
                <tr>
                    <th>Quote #</th>
                    <th>BP Code</th>
                    <th>Client</th>
                    <th>Amount</th>
                    <th>Status</th>
                    <th class="text-center">Action</th>
                </tr>
            </thead>

            <tbody>
                @if (Items != null && Items.Any())
                {
                    @foreach (var q in Items)
                    {
                        <tr>
                            <td class="col-bold">@q.OrderNumber</td>
                            <td class="col-muted">@q.Id.ToString().Substring(0, 5).ToUpper()</td>
                            <td>@q.ClientName</td>
                            <td class="col-price">@q.TotalAmount.ToString("C0")</td>
                            <td>
                                <span class="badge-status @q.Status.ToLower()">
                                    @q.Status
                                </span>
                            </td>
                            <td class="text-center">
                                <div class="action-icons">
                                    <i class="ms-Icon ms-Icon--RedEye" @onclick="() => OnView.InvokeAsync(q)"></i>
                                    @if (q.Status == "Draft")
                                    {
                                        <i class="ms-Icon ms-Icon--CheckMark" @onclick="() => OnApprove.InvokeAsync(q)"></i>
                                    }
                                    <i class="ms-Icon ms-Icon--ChevronRight"></i>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="empty-row">No late shipments found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    [Parameter] public IEnumerable<OpenOrderDto>? Items { get; set; } = Enumerable.Empty<OpenOrderDto>();
    [Parameter] public EventCallback<OpenOrderDto> OnView { get; set; }
    [Parameter] public EventCallback<OpenOrderDto> OnApprove { get; set; }
    [Parameter] public EventCallback<OpenOrderDto> OnConvert { get; set; }
}
