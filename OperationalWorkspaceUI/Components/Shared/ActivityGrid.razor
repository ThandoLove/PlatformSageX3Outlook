@using OperationalWorkspaceApplication.DTOs
@using Microsoft.FluentUI.AspNetCore.Components
@* Fix 1: Explicitly include the Icons namespace *@
@using Microsoft.FluentUI.AspNetCore.Components.Icons

<div class="timeline-container">
    @if (Data != null && Data.Any())
    {
        @foreach (var act in Data.OrderByDescending(a => a.Timestamp))
        {
            <div class="timeline-item">
                @* Circle marker with dynamic coloring based on Sage action *@
                <div class="timeline-marker @GetColorClass(act.Action)">
                    @* Fix 2: Explicitly use Microsoft.FluentUI Color enum *@
                    <FluentIcon Value="@GetIcon(act.Action)"
                                Color="@Microsoft.FluentUI.AspNetCore.Components.Color.Custom"
                                CustomColor="currentColor" />
                </div>

                <div class="timeline-content">
                    <div class="timeline-header">
                        <span class="activity-title">@act.Title</span>
                        <span class="activity-time">@act.Timestamp.ToString("MMM dd, HH:mm")</span>
                    </div>
                    <p class="activity-desc" style="margin: 0; font-size: 0.85rem; color: #475569;">
                        <strong style="color: #003366;">@act.Action</strong> by @act.CreatedBy
                    </p>
                </div>
            </div>
        }
    }
    else
    {
        <div style="padding: 20px; color: #94a3b8; text-align: center;">
            No recent activity found.
        </div>
    }
</div>

@code {
    [Parameter] public List<ActivityDto> Data { get; set; } = new();

    private string GetColorClass(string action) => action.ToLower() switch
    {
        "created" or "email" or "new" => "icon-blue",
        "invoice" or "resolved" or "success" => "icon-green",
        "meeting" or "scheduled" or "demo" => "icon-orange",
        _ => "icon-grey"
    };

    @* Fix 3: Full path for Return Type and Icon constructors to stop the "not found" errors *@
    private Microsoft.FluentUI.AspNetCore.Components.Icon GetIcon(string action) => action.ToLower() switch
    {
        "call" => new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size16.Call(),
        "email" => new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size16.Mail(),
        "invoice" => new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size16.Money(),
        "meeting" or "scheduled" => new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size16.CalendarLtr(),
        "created" or "new" => new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size16.AddSquare(),
        _ => new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size16.Circle()
    };
}
