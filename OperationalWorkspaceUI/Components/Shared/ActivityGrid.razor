@using OperationalWorkspaceApplication.DTOs

@if (IsLoading)
{
    <LoadingSpinner />
}
else if (Data == null || !Data.Any())
{
    <EmptyState Message="No activity found." />
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>User</th>
                <th>Action</th>
                <th>Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var act in Data)
            {
                <tr>
                    @* FIX 1: Change UserName to CreatedBy *@
                    <td>@act.CreatedBy</td>
                    <td>@act.Action</td>
                    <td>@act.Timestamp.ToString("yyyy-MM-dd HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    // FIX 2: Initialize with an empty list and use '!' to satisfy the non-nullable warning
    [Parameter] public List<ActivityDto> Data { get; set; } = new();
    [Parameter] public bool IsLoading { get; set; }
}
