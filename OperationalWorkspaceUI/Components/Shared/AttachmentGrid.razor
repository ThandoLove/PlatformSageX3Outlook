@using OperationalWorkspaceApplication.DTOs

@if (IsLoading)
{
    <LoadingSpinner />
}
else if (Data == null || !Data.Any())
{
    <EmptyState Message="No attachments available." />
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>File Name</th>
                <th>Type</th>
                <th>Size</th>
                <th>Uploaded</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var file in Data)
            {
                <tr @onclick="() => OnDownload.InvokeAsync(file)" style="cursor:pointer">
                    <td>@file.FileName</td>
                    @* FIX 1: Changed FileType to ContentType *@
                    <td>@file.ContentType</td>
                    @* FIX 2: Changed Size to FileSize *@
                    <td>@FormatSize(file.FileSize)</td>
                    @* FIX 3: Changed UploadedAt to UploadedAtUtc *@
                    <td>@file.UploadedAtUtc.ToString("yyyy-MM-dd")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    // FIX 4: Added ! to handle the non-nullable warning
    [Parameter] public List<AttachmentDto> Data { get; set; } = new();
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public EventCallback<AttachmentDto> OnDownload { get; set; }

    private string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1048576) return $"{(bytes / 1024.0):F1} KB";
        return $"{(bytes / 1048576.0):F1} MB";
    }
}
