@using OperationalWorkspaceUI.UIServices.System
@implements IDisposable
@inject ModalService ModalService

@if (IsVisible)
{
    @* tabindex and autofocus allow the 'Escape' key logic to function immediately *@
    <div @onkeydown="HandleKeyDown" tabindex="0" autofocus class="modal-wrapper">
        
        @* The backdrop handles closing when clicking outside the window *@
        <div class="modal-backdrop" @onclick="Close"></div>
        
        <div class="modal-window" role="dialog" aria-modal="true">
            @* High-fidelity close button (X) matching the Sage high-fidelity style *@
            <button type="button" class="btn-close-sage" @onclick="Close" aria-label="Close">×</button>
            
            <div class="modal-body">
                @ChildContent
            </div>
        </div>
    </div>
}

@code {
    private bool IsVisible;
    private string Title = "";
    private RenderFragment? ChildContent;

    protected override void OnInitialized()
    {
        // Subscribe to the ModalService events
        ModalService.OnShow += HandleShow;
        ModalService.OnClose += HandleClose;
    }

    private async Task HandleShow(string title, RenderFragment content)
    {
        // Marshalling the state change to the UI thread
        await InvokeAsync(() =>
        {
            Title = title;
            ChildContent = content;
            IsVisible = true;
            StateHasChanged();
        });
    }

    private async Task HandleClose()
    {
        // Ensuring the hide action is reflected on the UI thread
        await InvokeAsync(() =>
        {
            IsVisible = false;
            StateHasChanged();
        });
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        // Close modal on Escape key
        if (e.Key == "Escape") await Close();
    }

    private async Task Close() => await ModalService.CloseModal();

    public void Dispose()
    {
        // Unsubscribe to prevent memory leaks
        ModalService.OnShow -= HandleShow;
        ModalService.OnClose -= HandleClose;
    }
}
