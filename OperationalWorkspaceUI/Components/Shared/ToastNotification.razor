<h3>ToastNotification</h3>

@if (IsVisible)
{
    <div class="toast @Type">
        @Message
    </div>
}

@code {
    [Parameter] public string Message { get; set; } = "This is a toast notification.";
    [Parameter] public string Type { get; set; } = "info"; // info, success, error, warning
    [Parameter] public bool IsVisible { get; set; } = true;
}