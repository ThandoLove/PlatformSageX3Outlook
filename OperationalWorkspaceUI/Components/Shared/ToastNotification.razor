@using OperationalWorkspaceUI.Services
@implements IDisposable
@inject ToastService ToastService

@if (_isVisible)
{
    @* The container class uses the logic-driven level (success, info, etc) *@
    <div class="custom-toast @_levelClass">
        
        @* Icon Section matching Sage system status *@
        <div style="margin-right: 12px; display: flex; align-items: center;">
            @if (_levelClass == "toast-success")
            {
                <FluentIcon Value="@(new Icons.Filled.Size20.CheckmarkCircle())" Color="Color.Success" />
            }
            else if (_levelClass == "toast-error")
            {
                <FluentIcon Value="@(new Icons.Filled.Size20.DismissCircle())" Color="Color.Error" />
            }
            else
            {
                <FluentIcon Value="@(new Icons.Filled.Size20.Info())" Color="Color.Accent" />
            }
        </div>

        <div class="toast-content">
            @_message
        </div>
    </div>
}

@code {
    private bool _isVisible;
    private string _message = "";
    private string _levelClass = "";

    protected override void OnInitialized()
    {
        // Subscribe to the global ToastService events
        ToastService.OnShow += HandleShow;
        ToastService.OnHide += HandleHide;
    }

    private void HandleShow(string message, ToastLevel level)
    {
        _message = message;
        _levelClass = $"toast-{level.ToString().ToLower()}";
        _isVisible = true;
        
        // InvokeAsync is required for Blazor Server thread safety
        InvokeAsync(StateHasChanged);
    }

    private void HandleHide()
    {
        _isVisible = false;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        // Unsubscribe to prevent memory leaks in the background
        ToastService.OnShow -= HandleShow;
        ToastService.OnHide -= HandleHide;
    }
}
