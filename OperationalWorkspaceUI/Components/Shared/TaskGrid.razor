<!-- CODE START: TaskGrid.razor -->
@using OperationalWorkspaceApplication.DTOs
@using Microsoft.FluentUI.AspNetCore.Components

@if (IsLoading)
{
    <FluentProgressRing />
}
else if (Data == null || !Data.Any())
{
    <div style="padding: 20px; text-align: center; color: #605e5c;">
        <p>No tasks available.</p>
    </div>
}
else
{
    <div style="border: 1px solid #edebe9; border-radius: 4px; overflow: hidden;">
        <table class="table" style="width: 100%; border-collapse: collapse; background: white;">
            <thead style="background-color: #f3f2f1; text-align: left;">
                <tr style="font-size: 0.75rem; color: #605e5c; text-transform: uppercase;">
                    <th style="padding: 12px 8px;">Title</th>
                    <th style="padding: 12px 8px;">Status</th>
                    <th style="padding: 12px 8px;">Assigned To</th>
                    <th style="padding: 12px 8px;">Due Date</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var task in Data)
                {
                    <tr @onclick="() => OnRowClick.InvokeAsync(task)"
                        style="cursor: pointer; border-top: 1px solid #edebe9; font-size: 0.85rem;"
                        class="sage-row-hover">
                        <td style="padding: 10px 8px;">@task.Title</td>
                        <td style="padding: 10px 8px;">
                            <FluentBadge Appearance="Appearance.Neutral">@task.Status</FluentBadge>
                        </td>
                        <td style="padding: 10px 8px;">@task.AssignedTo</td>
                        @* FIXED: Safe formatting for nullable DateTime *@
                        <td style="padding: 10px 8px;">
                            @(task.DueDate?.ToString("yyyy-MM-dd") ?? "-")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    [Parameter] public List<TaskDto>? Data { get; set; }
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public EventCallback<TaskDto> OnRowClick { get; set; }
}

<style>
    .sage-row-hover:hover {
        background-color: #f9f9f9;
    }
</style>
