@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider

@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceUI.Security
@using System.Net.Http.Json

<div class="sage-login-body">

    <!-- HEADER ICON -->
    <div class="login-icon-circle">
        <i class="ms-Icon ms-Icon--Lock"></i>
    </div>

    <h2 class="login-title">Sign In To Sage X3</h2>
    <p class="login-subtitle">Access your contextual operational workspace</p>

    <EditForm Model="loginModel" OnValidSubmit="HandleLogin">
        <DataAnnotationsValidator />

        <!-- USERNAME / EMAIL INPUT FIELD -->
        <div class="input-group-custom">
            <label>Username</label>
            <div class="input-wrapper">
                <i class="ms-Icon ms-Icon--Contact"></i>
                <InputText @bind-Value="loginModel.Username" placeholder="operator@test.com or admin@test.com" disabled="@isBusy" />
            </div>
            <ValidationMessage For="@(() => loginModel.Username)" />
        </div>

        <!-- SECURE PASSWORD INPUT FIELD -->
        <div class="input-group-custom">
            <label>Password</label>
            <div class="input-wrapper">
                <i class="ms-Icon ms-Icon--Lock"></i>
                <InputText @bind-Value="loginModel.Password" type="@PasswordInputType" placeholder="Enter password" disabled="@isBusy" />
                <button type="button" class="password-toggle-btn" @onclick="TogglePassword" disabled="@isBusy">
                    <i class="ms-Icon ms-Icon--RedEye"></i>
                </button>
            </div>
            <ValidationMessage For="@(() => loginModel.Password)" />
        </div>

        <!-- SESSION RETENTION REMEMBER TOGGLES -->
        <div class="login-options">
            <label class="remember-option">
                <input type="checkbox" @bind="RememberMe" disabled="@isBusy" />
                <span>Remember me</span>
            </label>
            <a href="#" class="forgot-link">Forgot Password?</a>
        </div>

        <!-- DYNAMIC ERROR ALERTS LAYER -->
        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="login-error">
                <i class="ms-Icon ms-Icon--ErrorBadge"></i> @ErrorMessage
            </div>
        }

        <!-- SECURE FORM ACTION DISPATCH TRIGGER -->
        <button type="submit" class="btn-login-submit" disabled="@isBusy">
            @if (isBusy && !isSsoLoading)
            {
                <span class="spinner-border submit-spinner"></span>
                <span>Authenticating...</span>
            }
            else
            {
                <span><i class="ms-Icon ms-Icon--Forward"></i> Sign In</span>
            }
        </button>

        <!-- HORIZONTAL ACCENT DIVIDER -->
        <div class="login-divider">
            <span>or</span>
        </div>

        <!-- IDENTITY PROVIDER SSO REDIRECT BRIDGE -->
        <button type="button" class="btn-sso-login @(isSsoLoading ? "sso-loading-active" : "")" @onclick="InitiateSSOAuthentication" disabled="@isBusy">
            @if (isSsoLoading)
            {
                <span class="spinner-border sso-spinner"></span>
                <span>Connecting to Identity Provider...</span>
            }
            else
            {
                <span><i class="ms-Icon ms-Icon--Shield"></i> Sign in with SSO</span>
            }
        </button>

    </EditForm>
</div>

@code {
    private LoginRequestDto loginModel = new();
    private bool isBusy;
    private bool isSsoLoading;
    private bool RememberMe = true;
    private bool ShowPassword;
    private string? ErrorMessage;

    private string PasswordInputType => ShowPassword ? "text" : "password";

    [Inject] private OperationalWorkspaceUI.UIServices.System.AuthService AuthService { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;
    [Inject] private OperationalWorkspaceUI.UIServices.System.ModalService ModalService { get; set; } = default!;
    [Inject] private Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env { get; set; } = default!;
    [Inject] private HttpClient Http { get; set; } = default!;
    [Inject] private OperationalWorkspaceUI.State.UIState UIState { get; set; } = default!;

    private void TogglePassword() => ShowPassword = !ShowPassword;

    private async Task HandleLogin()
    {
        if (isBusy) return;

        try
        {
            isBusy = true;
            ErrorMessage = null;
            StateHasChanged();

            await Task.Delay(400);

            // ✅ FIX 8: Dispatches login model directly to your dynamic AuthService container pipeline
            var success = await AuthService.LoginAsync(loginModel);

            if (!success)
            {
                ErrorMessage = "Authentication rejected by environment security settings.";
                return;
            }

            // ✅ FIX 8: Force clean synchronization from the newly registered Claims Principal target
            if (AuthStateProvider is CustomAuthenticationStateProvider authProvider)
            {
                var authState = await authProvider.GetAuthenticationStateAsync();
                UIState.SynchronizeUserSession(authState.User);
            }

            await ModalService.CloseModal();
            Nav.NavigateTo("/dashboard", forceLoad: false);
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Authentication failed: {ex.Message}";
        }
        finally
        {
            isBusy = false;
            StateHasChanged();
        }
    }

    private async Task InitiateSSOAuthentication()
    {
        if (isBusy) return;

        try
        {
            isBusy = true;
            isSsoLoading = true;
            ErrorMessage = null;
            StateHasChanged();

            if (Env.IsDevelopment())
            {
                await Task.Delay(1000);

                var ssoMockDto = new LoginRequestDto
                {
                    Username = "sso.operator@test.com",
                    Password = "sso_bypass_marker"
                };

                await AuthService.LoginAsync(ssoMockDto);

                if (AuthStateProvider is CustomAuthenticationStateProvider authProvider)
                {
                    var authState = await authProvider.GetAuthenticationStateAsync();
                    UIState.SynchronizeUserSession(authState.User);
                }

                await ModalService.CloseModal();
                Nav.NavigateTo("/dashboard", forceLoad: false);
            }
            else
            {
                var authResult = await Http.GetFromJsonAsync<LoginResponse>("/api/v1/auth/sso/challenge");
                if (authResult is null || string.IsNullOrWhiteSpace(authResult.Token))
                {
                    ErrorMessage = "Single Sign-On authentication handshake rejected or timed out.";
                    return;
                }

                var ssoProdDto = new LoginRequestDto
                {
                    Username = "sso_production_node",
                    Password = authResult.Token
                };

                await AuthService.LoginAsync(ssoProdDto);

                if (AuthStateProvider is CustomAuthenticationStateProvider authProvider)
                {
                    var authState = await authProvider.GetAuthenticationStateAsync();
                    UIState.SynchronizeUserSession(authState.User);
                }

                await ModalService.CloseModal();
                Nav.NavigateTo("/dashboard", forceLoad: false);
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Single Sign-On initialization failed: {ex.Message}";
        }
        finally
        {
            isBusy = false;
            isSsoLoading = false;
            StateHasChanged();
        }
    }

    public class LoginResponse
    {
        public string? Token { get; set; }
    }
}
