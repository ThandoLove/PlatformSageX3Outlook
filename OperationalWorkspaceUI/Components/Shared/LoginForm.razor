@using Microsoft.AspNetCore.Components.Authorization
@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceUI.Security
@using System.Net.Http.Json

@inject HttpClient Http
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@inject Majorsoft.Blazor.Extensions.BrowserStorage.ILocalStorageService LocalStorage
@inject OperationalWorkspaceUI.UIServices.System.ModalService ModalService

<div class="sage-login-body">

    <div class="login-icon-circle">
        <i class="ms-Icon ms-Icon--Shield"></i>
    </div>

    <h2 class="login-title">
        Sign In To Workspace
    </h2>

    <p class="login-subtitle">
        Authenticate with Sage X3 credentials
    </p>

    <EditForm Model="loginModel"
              OnValidSubmit="HandleLogin">

        <div class="input-group-custom">
            <label>Username</label>
            <div class="input-wrapper">
                <i class="ms-Icon ms-Icon--Contact"></i>
                <InputText @bind-Value="loginModel.Username" placeholder="Enter username" />
            </div>
        </div>

        <div class="input-group-custom">
            <label>Password</label>
            <div class="input-wrapper">
                <i class="ms-Icon ms-Icon--Lock"></i>
                <InputText @bind-Value="loginModel.Password" type="password" placeholder="Enter password" />
            </div>
        </div>

        <button type="submit" class="btn-login-submit" disabled="@isBusy">
            @if (isBusy)
            {
                <span>Authenticating...</span>
            }
            else
            {
                <span>Sign In</span>
            }
        </button>
    </EditForm>
</div>

@code {
    private LoginRequestDto loginModel = new();
    private bool isBusy = false;

    private async Task HandleLogin()
    {
        if (isBusy) return;

        try
        {
            isBusy = true;
            StateHasChanged();

            // Pointing to the distinct route requested by your initial form
            var response = await Http.PostAsJsonAsync("api/auth/login", loginModel);

            if (response.IsSuccessStatusCode)
            {
                // Custom routing destination for this specific administrative form file
                Nav.NavigateTo("/admin-dashboard");
            }
            else
            {
                await ModalService.ShowAlert("Login Failed", "Invalid administrative credentials.");
            }
        }
        catch (Exception)
        {
            await ModalService.ShowAlert("Connection Error", "Handshake failed.");
        }
        finally
        {
            isBusy = false;
            StateHasChanged();
        }
    }
}
