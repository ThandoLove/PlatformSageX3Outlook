@using Microsoft.AspNetCore.Components.Authorization
@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceUI.Security
@using System.Net.Http.Json

@inject HttpClient Http
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@inject Majorsoft.Blazor.Extensions.BrowserStorage.ILocalStorageService LocalStorage
@inject OperationalWorkspaceUI.UIServices.System.ModalService ModalService

<div class="sage-login-body">

    <!-- HEADER -->
    <div class="login-icon-circle">
        <i class="ms-Icon ms-Icon--Lock"></i>
    </div>

    <h2 class="login-title">
        Sign In To Sage X3
    </h2>

    <p class="login-subtitle">
        Access your contextual operational workspace
    </p>

    <EditForm Model="loginModel"
              OnValidSubmit="HandleLogin">

        <!-- USERNAME -->
        <div class="input-group-custom">

            <label>Username</label>

            <div class="input-wrapper">
                <i class="ms-Icon ms-Icon--Contact"></i>

                <InputText @bind-Value="loginModel.Username"
                           placeholder="Enter username" />
            </div>

        </div>

        <!-- PASSWORD -->
        <div class="input-group-custom">

            <label>Password</label>

            <div class="input-wrapper">

                <i class="ms-Icon ms-Icon--Lock"></i>

                <InputText @bind-Value="loginModel.Password"
                           type="@PasswordInputType"
                           placeholder="Enter password" />

                <button type="button"
                        class="password-toggle-btn"
                        @onclick="TogglePassword">

                    <i class="ms-Icon ms-Icon--RedEye"></i>

                </button>

            </div>

        </div>

        <!-- OPTIONS -->
        <div class="login-options">

            <label class="remember-option">
                <input type="checkbox" @bind="RememberMe" />
                <span>Remember me</span>
            </label>

            <a href="#" class="forgot-link">
                Forgot Password?
            </a>

        </div>

        <!-- ERROR -->
        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="login-error">
                @ErrorMessage
            </div>
        }

        <!-- SUBMIT -->
        <button type="submit"
                class="btn-login-submit"
                disabled="@isBusy">

            @if (isBusy)
            {
                <span>Authenticating...</span>
            }
            else
            {
                <span>
                    <i class="ms-Icon ms-Icon--Forward"></i>
                    Sign In
                </span>
            }

        </button>

        <!-- DIVIDER -->
        <div class="login-divider">
            <span>or</span>
        </div>

        <!-- SSO -->
        <button type="button"
                class="btn-sso-login">

            <i class="ms-Icon ms-Icon--Shield"></i>

            Sign in with SSO

        </button>

    </EditForm>

</div>

@code {

    private LoginRequestDto loginModel = new();

    private bool isBusy;

    private bool RememberMe = true;

    private bool ShowPassword;

    private string? ErrorMessage;

    private string PasswordInputType =>
        ShowPassword ? "text" : "password";

    private void TogglePassword()
    {
        ShowPassword = !ShowPassword;
    }

    private async Task HandleLogin()
    {
        if (isBusy)
            return;

        try
        {
            isBusy = true;
            ErrorMessage = null;

            StateHasChanged();

            var response =
                await Http.PostAsJsonAsync(
                    "api/v1/Auth/login",
                    loginModel);

            if (response.IsSuccessStatusCode)
            {
                var result =
                    await response.Content
                        .ReadFromJsonAsync<LoginResponse>();

                if (result is null ||
                    string.IsNullOrWhiteSpace(result.Token))
                {
                    ErrorMessage =
                        "Authentication token was not returned.";

                    return;
                }

                // STORE JWT
                await LocalStorage.SetItemAsync(
                    "authToken",
                    result.Token);

                // UPDATE AUTH STATE
                if (AuthStateProvider
                    is CustomAuthenticationStateProvider authProvider)
                {
                    authProvider.NotifyUserAuthentication(result.Token);
                }

                // CLOSE MODAL
                await ModalService.CloseModal();

                // ROUTE TO MAIN WORKSPACE
                Nav.NavigateTo("/dashboard", true);
            }
            else
            {
                ErrorMessage =
                    "Invalid username or password.";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage =
                $"Authentication failed: {ex.Message}";
        }
        finally
        {
            isBusy = false;
            StateHasChanged();
        }
    }

    public class LoginResponse
    {
        public string? Token { get; set; }
    }
}