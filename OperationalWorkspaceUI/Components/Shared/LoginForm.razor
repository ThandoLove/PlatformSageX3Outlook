@using Microsoft.AspNetCore.Components.Authorization
@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceUI.Security
@using System.Net.Http.Json

@inject HttpClient Http
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@inject Majorsoft.Blazor.Extensions.BrowserStorage.ILocalStorageService LocalStorage
@inject OperationalWorkspaceUI.UIServices.System.ModalService ModalService
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env

<div class="sage-login-body">

    <!-- HEADER -->
    <div class="login-icon-circle">
        <i class="ms-Icon ms-Icon--Lock"></i>
    </div>

    <h2 class="login-title">
        Sign In To Sage X3
    </h2>

    <p class="login-subtitle">
        Access your contextual operational workspace
    </p>

    <EditForm Model="loginModel"
              OnValidSubmit="HandleLogin">

        <!-- USERNAME -->
        <div class="input-group-custom">

            <label>Username</label>

            <div class="input-wrapper">
                <i class="ms-Icon ms-Icon--Contact"></i>

                <InputText @bind-Value="loginModel.Username"
                           placeholder="Enter username"
                           disabled="@isBusy" />
            </div>

        </div>

        <!-- PASSWORD -->
        <div class="input-group-custom">

            <label>Password</label>

            <div class="input-wrapper">

                <i class="ms-Icon ms-Icon--Lock"></i>

                <InputText @bind-Value="loginModel.Password"
                           type="@PasswordInputType"
                           placeholder="Enter password"
                           disabled="@isBusy" />

                <button type="button"
                        class="password-toggle-btn"
                        @onclick="TogglePassword"
                        disabled="@isBusy">

                    <i class="ms-Icon ms-Icon--RedEye"></i>

                </button>

            </div>

        </div>

        <!-- OPTIONS -->
        <div class="login-options">

            <label class="remember-option">
                <input type="checkbox" @bind="RememberMe" disabled="@isBusy" />
                <span>Remember me</span>
            </label>

            <a href="#" class="forgot-link">
                Forgot Password?
            </a>

        </div>

        <!-- ERROR -->
        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="login-error" style="color: #ef4444; font-size: 0.85rem; margin-top: 8px; font-weight: 500;">
                <i class="ms-Icon ms-Icon--ErrorBadge" style="margin-right: 4px;"></i> @ErrorMessage
            </div>
        }

        <!-- SUBMIT -->
        <button type="submit"
                class="btn-login-submit"
                disabled="@isBusy">

            @if (isBusy && !isSsoLoading)
            {
                <span class="spinner-border" style="display: inline-block; width: 1rem; height: 1rem; border: 2px solid currentColor; border-right-color: transparent; border-radius: 50%; animation: spinner-border .75s linear infinite; margin-right: 8px;"></span>
                <span>Authenticating...</span>
            }
            else
            {
                <span>
                    <i class="ms-Icon ms-Icon--Forward"></i>
                    Sign In
                </span>
            }

        </button>

        <!-- DIVIDER -->
        <div class="login-divider">
            <span>or</span>
        </div>

        <!-- SSO BUTTON: Leverages explicit conditional design tokens to render state changes cleanly -->
        <button type="button"
                class="btn-sso-login"
                @onclick="InitiateSSOAuthentication"
                disabled="@isBusy"
                style="@(isSsoLoading ? "background: rgba(255,255,255,0.1); color: #94a3b8; cursor: not-allowed;" : "")">

            @if (isSsoLoading)
            {
                <!-- Modern CSS Spinner Animation Blueprint -->
                <span class="spinner-border" style="display: inline-block; width: 1rem; height: 1rem; border: 2px solid #0ea5e9; border-right-color: transparent; border-radius: 50%; animation: spinner-border .75s linear infinite; margin-right: 8px;"></span>
                <span>Connecting to Identity Provider...</span>
            }
            else
            {
                <span>
                    <i class="ms-Icon ms-Icon--Shield"></i>
                    Sign in with SSO
                </span>
            }

        </button>

    </EditForm>

</div>

<!-- Inline layout animation runtime parameters to handle older rendering engine frames -->
<style>
    @@keyframes spinner-border {
        to {
            transform: rotate(360deg);
        }
    }
</style>
