@typeparam TItem
@using OperationalWorkspaceApplication.DTOs

@if (IsLoading)
{
    <LoadingSpinner />
}
else if (Items == null || !Items.Any())
{
    <EmptyState Message="No items found." />
}
else
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    @HeaderContent
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Items)
                {
                    @* This line fixes the 'object' conversion error by using the generic TItem *@
                    <tr @onclick="() => OnRowClick.InvokeAsync(item)" style="cursor: pointer;">
                        @RowTemplate(item)
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    [Parameter] public IEnumerable<TItem> Items { get; set; } = default!;
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public EventCallback<TItem> OnRowClick { get; set; }
    
    [Parameter] public RenderFragment HeaderContent { get; set; } = default!;
    [Parameter] public RenderFragment<TItem> RowTemplate { get; set; } = default!;
}
