<!-- CODE START: BpGrid.razor -->
@using OperationalWorkspaceApplication.DTOs

@if (IsLoading)
{
    <LoadingSpinner />
}
else if (Data == null || !Data.Any())
{
    <EmptyState Message="No clients found." />
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>City</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var client in Data)
            {
                <tr @onclick="() => OnRowClick.InvokeAsync(client)">
                    <td>@client.Name</td>
                    <td>@client.Email</td>
                    <td>@client.PhoneNumber</td>
                    <td>@client.City</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    [Parameter] public List<ClientDTO> Data { get; set; }
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public EventCallback<ClientDTO> OnRowClick { get; set; }
}
<!-- CODE END -->