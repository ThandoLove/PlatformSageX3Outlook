@using OperationalWorkspaceUI.State
@using Microsoft.FluentUI.AspNetCore.Components
@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons
@implements IDisposable
@inject UIState UIState
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="sage-topbar-master">

    @* ZONE 1: LEFT - Branding & Dynamic Title *@
    <div class="zone-left">
        <span class="sage-brand-text">SAGE X3 CONTEXTUAL WORKSPACE</span>
        <div class="topbar-divider"></div>
        <span class="page-dynamic-title">@PageTitle</span>
    </div>

    @* ZONE 2: MIDDLE - Search (Acting as Flexible Spacer) *@
    <div class="zone-middle">
        <div class="search-input-group">
            <FluentIcon Value="@(new Icons.Regular.Size16.Search())"
                        Color="@Microsoft.FluentUI.AspNetCore.Components.Color.Custom"
                        CustomColor="#ffffff" />
            <input type="text" placeholder="Search functions or data..." class="topbar-search-input" />
        </div>
    </div>

    @* ZONE 3: RIGHT - Status and Profile *@
    <div class="zone-right" style="display: flex; align-items: center; gap: 14px;">
        <div class="connection-status">
            <FluentIcon Value="@(new Icons.Filled.Size12.CheckmarkCircle())"
                        Color="@Microsoft.FluentUI.AspNetCore.Components.Color.Success" />
            <span class="conn-text">Connected to Sage X3</span>
        </div>

        @* 🚀 FIXED: Displays the real authenticated user parameters dynamically from UIState! [INDEX] *@
        <div class="user-profile-section" style="display: flex; align-items: center; gap: 8px;">
            <div style="display: flex; flex-direction: column; text-align: right; font-family: Inter, sans-serif;">
                <span style="font-size: 13px; font-weight: 600; color: white;">@DisplayName</span>
                <span style="font-size: 10px; color: #94a3b8;">@DisplayEmail</span>
            </div>
            <FluentPersona Name="@DisplayName" Status="@PresenceStatus.Available" AvatarSize="24" Brief="true" Class="topbar-persona" />
        </div>
    </div>
</div>
@code {
    private string PageTitle { get; set; } = "Dashboard";

    // 🚀 FIXED: Pulls directly from your UIState variables with smooth fallback text strings for initial boots [INDEX]
    private string DisplayName =>
    string.IsNullOrWhiteSpace(UIState.UserName)
    ? "Not Logged In"
    : UIState.UserName;

    private string DisplayEmail =>
        string.IsNullOrWhiteSpace(UIState.UserEmail)
        ? string.Empty
        : UIState.UserEmail;

    protected override void OnInitialized()
    {
        Nav.LocationChanged += HandleLocationChanged;
        UIState.OnChange += HandleStateChanged; // Listens to your NotifyStateChanged() call automatically! [INDEX]
        UpdatePageTitle();
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        UpdatePageTitle();
        InvokeAsync(StateHasChanged);
    }

    private void HandleStateChanged()
    {
        // Safe thread execution update when UIState changes asynchronously on login [INDEX]
        InvokeAsync(StateHasChanged);
    }

    private void UpdatePageTitle()
    {
        var relativePath = Nav.ToBaseRelativePath(Nav.Uri).ToLower();

        if (relativePath.Contains("?"))
            relativePath = relativePath.Split('?')[0];

        // Mapping Logic - Ensures sub-pages show correct parent title
        if (string.IsNullOrEmpty(relativePath) || relativePath.StartsWith("dashboard"))
            PageTitle = "Dashboard";
        else if (relativePath.StartsWith("tickets"))
            PageTitle = "Tickets";
        else if (relativePath.StartsWith("activities"))
            PageTitle = "Activities";
        else if (relativePath.StartsWith("kb") || relativePath.StartsWith("knowledge"))
            PageTitle = "Knowledge Base";
        else if (relativePath.StartsWith("tasks"))
            PageTitle = "My Tasks";
        else if (relativePath.Contains("attachments") || relativePath.Contains("documents"))
            PageTitle = "Documents";
        else if (relativePath.StartsWith("contacts"))
            PageTitle = "Contacts";
        else if (relativePath.StartsWith("admin-dashboard"))
            PageTitle = "Admin Dashboard";
        else if (relativePath.StartsWith("admin-tasks"))
            PageTitle = "Admin Tasks";
        else if (relativePath.StartsWith("admin/users"))
            PageTitle = "Users";
        else if (relativePath.StartsWith("admin/audit-logs"))
            PageTitle = "Audit Logs";
        else if (relativePath.StartsWith("admin/system-health"))
            PageTitle = "System Health";
        else if (relativePath.StartsWith("settings"))
            PageTitle = "Settings";
        else
            PageTitle = "Workspace";
    }

    public void Dispose()
    {
        Nav.LocationChanged -= HandleLocationChanged;
        UIState.OnChange -= HandleStateChanged; // Safe teardown to avoid memory footprint traps [INDEX]
    }
}
