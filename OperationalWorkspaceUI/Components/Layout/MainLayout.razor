@inherits LayoutComponentBase
@using OperationalWorkspaceUI.State
@using OperationalWorkspaceUI.Models.Email
@using OperationalWorkspaceUI.UIServices.System
@using OperationalWorkspaceUI.UIServices.Workspace
@using OperationalWorkspaceUI.Components.Pages.Forms
@using OperationalWorkspaceUI.Components.Shared
@using Microsoft.JSInterop
@implements IDisposable
@inject UIState UIState
@inject DashboardState DashboardState
@inject ActivityUIService ActivityService
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject ModalService ModalService
@inject OperationalWorkspaceUI.UIServices.ToastUIService.ToastService ToastService

<div class="main-layout @UIState.CurrentTheme @(UIState.IsGlassMode ? "glass-mode" : "")">

    @if (IsAppPage)
    {
        <!-- LEFT: FIXED SIDEBAR -->
        <Sidebar />

        <!-- CENTER: MAIN AREA -->
        <main class="main-content">
            <Topbar />

            <div class="content-body">
                @if (UIState.IsLoading)
                {
                    <LoadingSpinner />
                }
                else
                {
                    @Body
                }
            </div>

            @* 
               GLOBAL NOTIFICATIONS: 
               Replaced FluentToastProvider with your custom Sage-style container.
            *@
            <ToastContainer />
        </main>

        <!-- RIGHT: SAGE X3 CONTEXTUAL INSIGHTS -->
        <RightPanel />
    }
    else
    {
        <div class="landing-frame">
            @Body
        </div>
    }
</div>

@* --- MODAL OVERLAY --- *@
@if (_showModal && IsAppPage)
{
    <div class="modal-backdrop" @onclick="CloseModal">
        <div class="modal-container" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>@_modalTitle</h3>
                <button class="close-btn" @onclick="CloseModal">
                    @* FIX: Use fully qualified icon path *@
                    <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.Dismiss())" />
                </button>
            </div>
            <div class="modal-body">
                @_modalContent
            </div>
        </div>
    </div>
}

@code {
    private DotNetObjectReference<MainLayout>? _objRef;
    private bool _showModal;
    private string _modalTitle = "";
    private RenderFragment? _modalContent;

    private bool IsAppPage => !Nav.Uri.EndsWith("/login") && Nav.Uri.TrimEnd('/').Length > Nav.BaseUri.TrimEnd('/').Length;

    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += HandleLocationChanged;
        UIState.OnChange += StateHasChanged;
        DashboardState.OnChange += StateHasChanged;
        ModalService.OnShow += HandleShowModal;
        ModalService.OnClose += HandleCloseModal;

        await UIState.LoadThemeFromLocalStorage();
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e) => StateHasChanged();

    private async Task HandleShowModal(string title, RenderFragment content)
    {
        _modalTitle = title;
        _modalContent = content;
        _showModal = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleCloseModal()
    {
        _showModal = false;
        await InvokeAsync(StateHasChanged);
    }

    private void CloseModal() => ModalService.CloseModal();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && IsAppPage)
        {
            _objRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("officeBridge.initialize", _objRef);
        }
    }

    [JSInvokable]
    public async Task OnEmailReceived(EmailContextDTO emailData)
    {
        if (emailData == null || string.IsNullOrEmpty(emailData.SenderEmail)) return;

        await ActivityService.LogActivityAsync(
            title: $"Email from {emailData.SenderName}",
            action: "Email",
            createdBy: "System"
        );

        DashboardState.EmailContext = emailData;
        await DashboardState.LoadDashboardAsync();

        bool contactExists = await DashboardState.CheckContactExists(emailData.SenderEmail);

        if (!contactExists)
        {
            await ModalService.ShowModal($"New Sage X3 Contact: {emailData.SenderName}", builder =>
            {
                builder.OpenComponent<NewContactForm>(0);
                builder.AddAttribute(1, "Email", emailData.SenderEmail);
                builder.AddAttribute(2, "FullName", emailData.SenderName);
                builder.CloseComponent();
            });
        }

        StateHasChanged();
        
        // FIX: Replaced old JS toast with your new service logic
        ToastService.ShowInfo($"Workspace Synced: {emailData.SenderName}");
    }

    public void Dispose()
    {
        Nav.LocationChanged -= HandleLocationChanged;
        UIState.OnChange -= StateHasChanged;
        DashboardState.OnChange -= StateHasChanged;
        ModalService.OnShow -= HandleShowModal;
        ModalService.OnClose -= HandleCloseModal;
        _objRef?.Dispose();
    }
}
