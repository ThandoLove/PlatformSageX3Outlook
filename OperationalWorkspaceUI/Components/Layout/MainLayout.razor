@inherits LayoutComponentBase

@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.JSInterop

@using OperationalWorkspaceUI.State
@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceApplication.ApplicationState
@using OperationalWorkspaceUI.UIServices.System
@using OperationalWorkspaceUI.UIServices.Workspace
@using OperationalWorkspaceUI.UIServices.ToastUIService

@implements IDisposable

@inject UIState UIState
@inject DashboardState DashboardState
@inject ActivityUIService ActivityService
@inject AppStateContainer AppState
@inject EventBus EventBus
@inject AuthService AuthService
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IToastUIService ToastService
@inject HttpClient Http

<FluentLayout Class="app-container">

    @if (IsAppPage)
    {
        <header class="global-header">
            <Topbar />
        </header>

        <div class="main-wrapper">

            <div class="sidebar-wrapper">
                <Sidebar />
            </div>

            <main class="page-content">

                <div class="content-body">
                    @if (UIState.IsLoading || AppState.IsBusy)
                    {
                        <LoadingSpinner />
                    }
                    else
                    {
                        @Body
                    }
                </div>

                <ToastNotification />

            </main>

            <RightPanel />

        </div>
    }
    else
    {
        <div class="landing-frame">
            @Body
        </div>
    }

</FluentLayout>

@code {
    private DotNetObjectReference<MainLayout>? _objRef;
    private bool _initialized;
    private bool _disposed;
    private Action? _unsubscribeEmail;

    private bool IsAppPage =>
        !Nav.Uri.EndsWith("/login", StringComparison.OrdinalIgnoreCase);

    protected override void OnInitialized()
    {
        Nav.LocationChanged += HandleLocationChanged;

        UIState.OnChange += RefreshUI;
        DashboardState.OnChange += RefreshUI;
        AppState.OnChange += RefreshUI;

        _unsubscribeEmail = EventBus.Subscribe("EMAIL_RECEIVED", async data =>
        {
            if (_disposed) return;
            if (data is not EmailInsightDto email) return;

            try
            {
                UIState.IsLoading = true;
                await InvokeAsync(StateHasChanged);

                await Http.PostAsJsonAsync($"api/email/{email.Id}/enrich", email);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"EMAIL_RECEIVED processing failed: {ex.Message}");
            }
            finally
            {
                if (!_disposed)
                {
                    UIState.IsLoading = false;
                    await InvokeAsync(StateHasChanged);
                }
            }
        });
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _initialized || _disposed) return;
        _initialized = true;

        try
        {
            await AuthService.InitializeAsync();

            if (IsAppPage)
            {
                _objRef = DotNetObjectReference.Create(this);
                await JS.InvokeVoidAsync("officeBridge.initialize", _objRef);
            }
        }
        catch (JSDisconnectedException) { }
        catch (ObjectDisposedException) { }
        catch (Exception ex)
        {
            Console.WriteLine($"MainLayout initialization error: {ex.Message}");
        }
    }

    [JSInvokable]
    public async Task OnEmailReceived(EmailInsightDto emailData)
    {
        if (_disposed) return;
        if (emailData == null) return;

        try
        {
            EventBus.Publish("EMAIL_RECEIVED", emailData);
            await Task.CompletedTask;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"OnEmailReceived failed: {ex.Message}");
        }
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e) => RefreshUI();

    private void RefreshUI()
    {
        if (_disposed) return;
        _ = InvokeAsync(() => { if (!_disposed) StateHasChanged(); });
    }

    public void Dispose()
    {
        if (_disposed) return;
        _disposed = true;

        Nav.LocationChanged -= HandleLocationChanged;
        UIState.OnChange -= RefreshUI;
        DashboardState.OnChange -= RefreshUI;
        AppState.OnChange -= RefreshUI;

        _unsubscribeEmail?.Invoke();
        _unsubscribeEmail = null;
        _objRef?.Dispose();
        _objRef = null;
    }
}
