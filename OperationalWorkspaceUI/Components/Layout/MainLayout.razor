@inherits LayoutComponentBase
@using OperationalWorkspaceUI.State
@using OperationalWorkspaceUI.Models.Email
@using OperationalWorkspaceUI.UIServices.System
@using OperationalWorkspaceUI.UIServices.Workspace
@using OperationalWorkspaceUI.UIServices.ToastUIService
@using OperationalWorkspaceUI.Components.Pages.Forms
@using OperationalWorkspaceUI.Components.Shared
@using Microsoft.JSInterop
@implements IDisposable

@inject UIState UIState
@inject DashboardState DashboardState
@inject ActivityUIService ActivityService
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject ModalService ModalService
@inject IToastUIService ToastService

@* --- RESTORED TO SINGLE STABLE THEME (MATCHING IMAGE) --- *@
<div class="app-container">
    
    @if (IsAppPage)
    {
        @* --- TOPBAR: Spans full width of screen --- *@
        <header class="global-header">
            <Topbar />
        </header>

        @* --- WRAPPER: Flex layout for sidebar, content, and right panel --- *@
        <div class="main-wrapper">
            
            <Sidebar />

            <main class="page-content">
                <div class="content-body">
                    @if (UIState.IsLoading)
                    {
                        <LoadingSpinner />
                    }
                    else
                    {
                        @Body
                    }
                </div>
                
                <ToastNotification />
            </main>

            <RightPanel />
        </div>
    }
    else
    {
        <div class="landing-frame">
            @Body
        </div>
    }
</div>

<style>
    /* Absolute Structural Layout - No Variables used here to prevent ghosting */
    .app-container {
        display: flex;
        flex-direction: column;
        height: 100vh;
        width: 100vw;
        overflow: hidden;
        background-color: #f3f4f6; /* Hard-coded Light Grey Floor */
    }

    .global-header {
        width: 100%;
        height: 40px;
        flex-shrink: 0;
        z-index: 2000;
        background-color: #003366; /* Hard-coded Sage Navy */
    }

    .main-wrapper {
        display: flex;
        flex: 1;
        width: 100vw;
        overflow: hidden;
    }

    .page-content {
        flex: 1;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        background-color: transparent; /* Shows the Grey app-container floor */
    }

    .content-body {
        flex: 1;
        padding: 0;
    }
</style>

@code {
    private DotNetObjectReference<MainLayout>? _objRef;
    
    private bool IsAppPage => !Nav.Uri.EndsWith("/login") && Nav.Uri.TrimEnd('/').Length > Nav.BaseUri.TrimEnd('/').Length;

    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += HandleLocationChanged;
        UIState.OnChange += StateHasChanged;
        DashboardState.OnChange += StateHasChanged;
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e) => StateHasChanged();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && IsAppPage)
        {
            _objRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("officeBridge.initialize", _objRef);
        }
    }

    [JSInvokable]
    public async Task OnEmailReceived(EmailInsightDto emailData)
    {
        if (emailData == null) return;

        await ActivityService.LogActivityAsync(
            title: $"Email from {emailData.SenderName}",
            action: "Email",
            createdBy: "System"
        );

        DashboardState.EmailContext = emailData;
        await DashboardState.LoadDashboardAsync();
        
        StateHasChanged();
        ToastService.ShowInfo($"Workspace Synced: {emailData.SenderName}");
    }

    public void Dispose()
    {
        Nav.LocationChanged -= HandleLocationChanged;
        UIState.OnChange -= StateHasChanged;
        DashboardState.OnChange -= StateHasChanged;
        _objRef?.Dispose();
    }
}
