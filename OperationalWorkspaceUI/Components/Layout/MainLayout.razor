@inherits LayoutComponentBase

@using OperationalWorkspaceUI.State
@using OperationalWorkspaceUI.Models.Email
@using OperationalWorkspaceUI.UIServices.System
@using OperationalWorkspaceUI.UIServices.Workspace
@using OperationalWorkspaceUI.UIServices.ToastUIService
@using OperationalWorkspaceUI.Components.Pages.Forms
@using OperationalWorkspaceUI.Components.Shared
@using Microsoft.JSInterop

@implements IDisposable

@inject UIState UIState
@inject DashboardState DashboardState
@inject ActivityUIService ActivityService
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject ModalService ModalService
@inject IToastUIService ToastService
@inject AuthService AuthService

<div class="app-container">

    @if (IsAppPage)
    {
        <header class="global-header">
            <Topbar />
        </header>

        <div class="main-wrapper">

            <Sidebar />

            <main class="page-content">
                <div class="content-body">

                    @if (UIState.IsLoading)
                    {
                        <LoadingSpinner />
                    }
                    else
                    {
                        @Body
                    }

                </div>

                <ToastNotification />
            </main>

            <RightPanel />

        </div>
    }
    else
    {
        <div class="landing-frame">
            @Body
        </div>
    }

</div>



@code {

    private DotNetObjectReference<MainLayout>? _objRef;

    private bool IsAppPage =>
        !Nav.Uri.EndsWith("/login") &&
        Nav.Uri.TrimEnd('/').Length > Nav.BaseUri.TrimEnd('/').Length;

    protected override void OnInitialized()
    {
        Nav.LocationChanged += HandleLocationChanged;
        UIState.OnChange += StateHasChanged;
        DashboardState.OnChange += StateHasChanged;
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        if (!IsAppPage)
            return;

        try
        {
            // ======================================================
            // SAFE AUTH INIT (NOW CORRECT PLACE)
            // ======================================================
            await AuthService.InitializeAsync();

            // ======================================================
            // OFFICE JS INITIALIZATION
            // ======================================================
            _objRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("officeBridge.initialize", _objRef);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"MainLayout init error: {ex.Message}");
        }
    }

    [JSInvokable]
    public async Task OnEmailReceived(EmailInsightDto emailData)
    {
        if (emailData == null)
            return;

        await ActivityService.LogActivityAsync(
            title: $"Email from {emailData.SenderName}",
            action: "Email",
            createdBy: "System"
        );

        DashboardState.EmailContext = emailData;
        await DashboardState.LoadDashboardAsync();

        StateHasChanged();

        ToastService.ShowInfo($"Workspace Synced: {emailData.SenderName}");
    }

    public void Dispose()
    {
        Nav.LocationChanged -= HandleLocationChanged;
        UIState.OnChange -= StateHasChanged;
        DashboardState.OnChange -= StateHasChanged;

        _objRef?.Dispose();
    }
}