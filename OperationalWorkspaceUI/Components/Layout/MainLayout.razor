@inherits LayoutComponentBase
@inject OperationalWorkspaceUI.State.UIState UIState

<div class="main-layout @(UIState.CurrentTheme)">

    <!-- LEFT -->
    <Sidebar />

    <!-- CENTER -->
    <div class="main-content">
        <Topbar />

        <div class="page-container">
            @Body
        </div>
    </div>

    <!-- RIGHT -->
    <RightPanel />
</div>

<!-- GLOBAL COMPONENTS -->
<!-- GLOBAL COMPONENTS -->
<ErrorBanner Message="@UIState.ErrorMessage"
             IsVisible="@UIState.ShowError"
             @* FIX: Wrap the method in a lambda so it can be invoked correctly *@
             OnDismiss="@(() => UIState.ClearError())" />


<GlassModeToggle /> <!-- button-based theme switcher -->
<ToastNotification />
<Modal />
<LoadingSpinner />

@code {
    protected override async Task OnInitializedAsync()
    {
        // Load persisted theme from localStorage
        await UIState.LoadThemeFromLocalStorage();
    }
}