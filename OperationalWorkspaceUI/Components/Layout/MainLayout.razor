@inherits LayoutComponentBase

@using OperationalWorkspaceUI.State
@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceUI.UIServices.System
@using OperationalWorkspaceUI.UIServices.Workspace
@using OperationalWorkspaceUI.UIServices.ToastUIService
@using OperationalWorkspaceApplication.Services
@using Microsoft.JSInterop

@implements IDisposable

@inject UIState UIState
@inject DashboardState DashboardState
@inject ActivityUIService ActivityService
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IToastUIService ToastService
@inject AuthService AuthService

@inject AppStateContainer AppState
@inject EventBus EventBus
@inject EmailEnrichmentService EmailEnrichmentService

<div class="app-container">

    @if (IsAppPage)
    {
        <header class="global-header">
            <Topbar />
        </header>

        <div class="main-wrapper">

            <Sidebar />

            <main class="page-content">

                <div class="content-body">

                    @if (UIState.IsLoading || AppState.IsBusy)
                    {
                        <LoadingSpinner />
                    }
                    else
                    {
                        @Body
                    }

                </div>

                <ToastNotification />

            </main>

            <RightPanel />

        </div>
    }
    else
    {
        <div class="landing-frame">
            @Body
        </div>
    }

</div>

@code {

    private DotNetObjectReference<MainLayout>? _objRef;
    private bool _initialized;
    private Action? _unsubscribeEmail;

    private bool IsAppPage =>
        !Nav.Uri.EndsWith("/login");

    protected override void OnInitialized()
    {
        Nav.LocationChanged += HandleLocationChanged;

        UIState.OnChange += RefreshUI;
        DashboardState.OnChange += RefreshUI;
        AppState.OnChange += RefreshUI;

        _unsubscribeEmail =
            EventBus.Subscribe("EMAIL_RECEIVED", async data =>
            {
                if (data is EmailInsightDto email)
                {
                    await EmailEnrichmentService.EnrichAsync(email);
                }
            });
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _initialized) return;

        _initialized = true;

        await AuthService.InitializeAsync();

        if (IsAppPage)
        {
            _objRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("officeBridge.initialize", _objRef);
        }
    }

    [JSInvokable]
    public async Task OnEmailReceived(EmailInsightDto emailData)
    {
        if (emailData == null) return;

        EventBus.Publish("EMAIL_RECEIVED", emailData);
        await Task.CompletedTask;
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
        => InvokeAsync(StateHasChanged);

    private void RefreshUI()
        => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Nav.LocationChanged -= HandleLocationChanged;

        UIState.OnChange -= RefreshUI;
        DashboardState.OnChange -= RefreshUI;
        AppState.OnChange -= RefreshUI;

        _unsubscribeEmail?.Invoke();

        _objRef?.Dispose();
    }
}