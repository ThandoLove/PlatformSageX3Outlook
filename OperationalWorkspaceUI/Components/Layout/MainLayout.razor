@inherits LayoutComponentBase
@using OperationalWorkspaceUI.State
@using OperationalWorkspaceUI.Models.Email
@using OperationalWorkspaceUI.UIServices.System
@using OperationalWorkspaceUI.UIServices.Workspace
@using OperationalWorkspaceUI.UIServices.ToastUIService
@using OperationalWorkspaceUI.Components.Pages.Forms
@using OperationalWorkspaceUI.Components.Shared
@using Microsoft.JSInterop
@implements IDisposable

@inject UIState UIState
@inject DashboardState DashboardState
@inject ActivityUIService ActivityService
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject ModalService ModalService
@inject IToastUIService ToastService

<div class="main-layout @UIState.CurrentTheme @(UIState.IsGlassMode ? "glass-mode" : "") @(UIState.IsDarkMode ? "dark-mode" : "")">
    @if (IsAppPage)
    {
        <!-- LEFT: FIXED SIDEBAR -->
        <Sidebar />

        <!-- CENTER: MAIN AREA -->
        <main class="main-content">
            @* --- TOPBAR AREA WITH GLOBAL THEME TOGGLE --- *@
            <div class="top-row px-4" style="display: flex; justify-content: space-between; align-items: center; height: 50px; background: var(--topbar-bg); border-bottom: 1px solid var(--border-color);">
                <Topbar />
                
                <div class="header-actions" style="display: flex; align-items: center; gap: 15px; padding-right: 20px;">
                    @* GLOBAL THEME TOGGLE *@
                    <div class="theme-toggle-wrapper">
                        <FluentSwitch Value="@UIState.IsDarkMode"
                                      ValueChanged="@(async (bool val) => await ToggleTheme(val))"
                                      Label="@(UIState.IsDarkMode ? "Dark" : "Light")" />
                    </div>
                    <a href="https://sage.com" target="_blank" style="font-size: 0.8rem; text-decoration: none; color: var(--text-muted);">About Sage X3</a>
                </div>
            </div>

            <div class="content-body">
                @if (UIState.IsLoading)
                {
                    <LoadingSpinner />
                }
                else
                {
                    @Body
                }
            </div>

            @* GLOBAL NOTIFICATIONS *@
            <ToastNotification />
        </main>

        <!-- RIGHT: SAGE X3 CONTEXTUAL INSIGHTS -->
        <RightPanel />
    }
    else
    {
        <div class="landing-frame">
            @Body
        </div>
    }
</div>

@code {
    private DotNetObjectReference<MainLayout>? _objRef;
    
    private bool IsAppPage => !Nav.Uri.EndsWith("/login") && Nav.Uri.TrimEnd('/').Length > Nav.BaseUri.TrimEnd('/').Length;

    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += HandleLocationChanged;
        UIState.OnChange += StateHasChanged;
        DashboardState.OnChange += StateHasChanged;
        
        await UIState.LoadThemeFromLocalStorage();
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e) => StateHasChanged();

    private async Task ToggleTheme(bool isDark)
    {
        // 1. Update the Global State (this triggers the CSS class change in the top div)
        await UIState.SetTheme(isDark ? "dark-mode" : "light-mode");
        
        // 2. Trigger the JS for any specific component re-paints (FluentUI, etc)
        await JS.InvokeVoidAsync("applyTheme", isDark ? "dark-mode" : "light-mode");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && IsAppPage)
        {
            _objRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("officeBridge.initialize", _objRef);
        }
    }

    [JSInvokable]
    public async Task OnEmailReceived(EmailInsightDto emailData)
    {
        if (emailData == null) return;

        await ActivityService.LogActivityAsync(
            title: $"Email from {emailData.SenderName}",
            action: "Email",
            createdBy: "System"
        );

        DashboardState.EmailContext = emailData;
        await DashboardState.LoadDashboardAsync();
        
        StateHasChanged();
        ToastService.ShowInfo($"Workspace Synced: {emailData.SenderName}");
    }

    public void Dispose()
    {
        Nav.LocationChanged -= HandleLocationChanged;
        UIState.OnChange -= StateHasChanged;
        DashboardState.OnChange -= StateHasChanged;
        _objRef?.Dispose();
    }
}
