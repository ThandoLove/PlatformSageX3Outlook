@inherits LayoutComponentBase
@using OperationalWorkspaceUI.State
@using OperationalWorkspaceUI.Models.Email
@using OperationalWorkspaceUI.UIServices.System
@using OperationalWorkspaceUI.Components.Pages.Forms @* Ensure this matches your NewContactForm location *@
@using Microsoft.JSInterop
@implements IDisposable
@inject UIState UIState
@inject DashboardState DashboardState
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject ModalService ModalService

<div class="main-layout @UIState.CurrentTheme @(UIState.IsGlassMode ? "glass-mode" : "")">

    @if (IsAppPage)
    {
        <!-- LEFT: STATIC SIDEBAR (60px icon-only) -->
        <Sidebar />

        <!-- CENTER: MAIN AREA (Topbar + Dynamic Content) -->
        <div class="main-content">
            <Topbar />
            <div class="page-container">
                @if (UIState.IsLoading)
                {
                    <LoadingSpinner />
                }
                else
                {
                    @Body
                }
            </div>
        </div>

        <!-- RIGHT: SAGE X3 INSIGHTS (Static context panel) -->
        <RightPanel />
    }
    else
    {
        <!-- HOME/LOGIN: Clean view without navigation bars -->
        <div class="landing-frame">
            @Body
        </div>
    }
</div>

@if (IsAppPage)
{
    @* --- GLOBAL OVERLAYS --- *@
    
    <ErrorBanner Message="@UIState.ErrorMessage"
                 IsVisible="@UIState.ShowError"
                 OnDismiss="@(() => UIState.ClearError())" />

    <ToastNotification />

    @* --- BUSINESS ACTION MODAL (New Orders, Create Contact, etc.) --- *@
    <Modal />
}

@code {
    private DotNetObjectReference<MainLayout>? _objRef;

    // Logic: True if NOT on Home ("/") and NOT on Login ("/login")
    private bool IsAppPage => !Nav.Uri.EndsWith("/login") && Nav.Uri.TrimEnd('/').Length > Nav.BaseUri.TrimEnd('/').Length;

    protected override async Task OnInitializedAsync()
    {
        // 1. Subscribe to Global State changes
        Nav.LocationChanged += HandleLocationChanged;
        UIState.OnChange += StateHasChanged;
        DashboardState.OnChange += StateHasChanged;
        
        // 2. Load persistent settings
        await UIState.LoadThemeFromLocalStorage();
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e) => StateHasChanged();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && IsAppPage)
        {
            // 3. Initialize the Outlook "Nervous System" Bridge
            _objRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("officeBridge.initialize", _objRef);
        }
    }

    /// <summary>
    /// Triggered by officeBridge.js when an email is selected in Outlook.
    /// Drives the core "fucking logic" of the contextual workspace.
    /// </summary>
    [JSInvokable]
    public async Task OnEmailReceived(EmailContextDTO emailData)
    {
        // Ensure we have valid data before proceeding
        if (emailData == null || string.IsNullOrEmpty(emailData.SenderEmail)) return;

        // 1. Update Global Page Context
        UIState.CurrentPageTitle = $"Insights: {emailData.SenderName}";
        DashboardState.EmailContext = emailData;

        // 2. Auto-load Sage ERP data (Quotes, Orders, etc.)
        await DashboardState.LoadDashboardAsync();

        // 3. SECURE CONTEXT CHECK: Does this partner exist in Sage X3?
        bool contactExists = await DashboardState.CheckContactExists(emailData.SenderEmail);
        


        if (!contactExists)
        {
            // 4. TRIGGER POPUP: If unknown, pop the "New Contact" form immediately
            await ModalService.ShowModal($"Create Sage X3 Contact: {emailData.SenderName}", builder =>
            {
                builder.OpenComponent<NewContactForm>(0);
                builder.AddAttribute(1, "Email", emailData.SenderEmail);
                builder.AddAttribute(2, "FullName", emailData.SenderName);
                builder.CloseComponent();
            });
        }

        // 5. Finalize UI Refresh
        StateHasChanged();
        await JS.InvokeVoidAsync("showToast", $"Workspace Updated: {emailData.SenderName}");
    }

    public void Dispose()
    {
        Nav.LocationChanged -= HandleLocationChanged;
        UIState.OnChange -= StateHasChanged;
        DashboardState.OnChange -= StateHasChanged;
        _objRef?.Dispose();
    }
}
