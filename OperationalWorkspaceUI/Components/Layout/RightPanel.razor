@using Microsoft.JSInterop
@using OperationalWorkspaceUI.State
@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceApplication.Interfaces.IServices
@using Microsoft.FluentUI.AspNetCore.Components
@implements IAsyncDisposable
@implements IDisposable

@inject DashboardState DashboardState
@inject EmailContextState EmailState
@inject IBusinessPartnerService BPService

<div class="right-panel-container" style="padding: 16px; background-color: #f4f7f9; height: 100%; overflow-y: auto; border-left: 1px solid #e2e8f0;">
    @if (IsLoading)
    {
        <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 200px;">
            <FluentProgressRing />
            <p style="margin-top: 10px; color: #64748b;">Checking Sage X3...</p>
        </div>
    }
    else if (DashboardState.SelectedOrderId != null)
    {
        @* ORDER INSIGHT CARD *@
        <FluentCard Style="width: 100%; padding: 16px; margin-bottom: 20px; border-left: 4px solid #0078d4;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
                <h3 style="margin: 0; font-size: 1.1rem; font-weight: 600; color: #333;">Order Insight</h3>
                <div style="background-color: #eff6ff; color: #1d4ed8; padding: 2px 8px; border-radius: 4px; font-size: 0.7rem; font-weight: 700;">SAGE X3</div>
            </div>

            <div style="display: flex; flex-direction: column; gap: 12px;">
                <div style="display: flex; align-items: center; gap: 8px;">
                    <span style="color: #64748b; min-width: 80px;">Order #:</span>
                    <span style="font-weight: 600; color: #1e293b;">@DashboardState.SelectedOrderId</span>
                </div>
                <p style="font-size: 0.85rem; color: #475569; margin: 8px 0 0 0;">
                    Viewing live context for this order.
                </p>
            </div>
            
            <FluentButton Appearance="Appearance.Stealth"
                          Style="width: 100%; margin-top: 12px;"
                          OnClick="@(async () => await DashboardState.LoadOrderDetailsAsync(null))">
                Clear Context
            </FluentButton>
        </FluentCard>
    }
    else if (EmailState.CurrentEmail == null)
    {
        <FluentCard Style="padding: 20px; text-align: center;">
            <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size32.Mail())"
                        Color="@Microsoft.FluentUI.AspNetCore.Components.Color.Accent" />
            <p style="color: #64748b; margin-top: 10px;">Select an email or order record.</p>
        </FluentCard>
    }
    else
    {
        @* EMAIL INSIGHT CARD *@
        <FluentCard Style="width: 100%; padding: 16px; margin-bottom: 20px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
                <h3 style="margin: 0; font-size: 1.1rem; font-weight: 600; color: #333;">Email Insight</h3>
                <FluentIcon Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size16.ChevronDown())"
                            Color="@Microsoft.FluentUI.AspNetCore.Components.Color.Neutral" />
            </div>

            <div style="display: flex; flex-direction: column; gap: 12px;">
                <div style="display: flex; align-items: center; gap: 8px;">
                    <span style="color: #64748b; min-width: 70px;">Contact:</span>
                    <span style="font-weight: 500; color: #1e293b;">@EmailState.CurrentEmail.SenderName</span>
                </div>
                <div style="display: flex; align-items: center; gap: 8px;">
                    <span style="color: #64748b; min-width: 70px;">Company:</span>
                    <span style="font-weight: 500; color: #1e293b;">@(CurrentPartner?.Company ?? "Unknown")</span>
                </div>
            </div>
        </FluentCard>
    }
</div>

@code {
    [Inject] private IJSRuntime JS { get; set; } = default!;
    
    private BusinessPartnerSnapshotDto? CurrentPartner;
    private ContactCreateDto NewContact = new();
    private bool IsLoading = false;
    private DotNetObjectReference<RightPanel>? _dotRef;

    protected override void OnInitialized()
    {
        DashboardState.OnChange += HandleStateChange;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("officeBridge.initialize", _dotRef);
        }
    }

    private async void HandleStateChange()
    {
        if (DashboardState.SelectedOrderId != null)
        {
            EmailState.CurrentEmail = null;
        }
        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task HandleEmailSelection(EmailBridgeContext context)
    {
        IsLoading = true;
        // FIX: Added 'await' here to resolve the error in your image
        await DashboardState.LoadOrderDetailsAsync(null);
        await InvokeAsync(StateHasChanged);

        EmailState.CurrentEmail = new EmailInsightDto
        {
            SenderEmail = context.SenderEmail ?? string.Empty,
            SenderName = context.SenderName ?? string.Empty,
            Subject = context.Subject ?? string.Empty,
            ReceivedAt = DateTime.UtcNow
        };

        if (!string.IsNullOrWhiteSpace(context.SenderEmail))
        {
            CurrentPartner = await BPService.GetPartnerByEmailAsync(context.SenderEmail);
        }

        IsLoading = false;
        await InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        DashboardState.OnChange -= HandleStateChange;
        _dotRef?.Dispose();
        await Task.CompletedTask;
    }

    public void Dispose()
    {
        DashboardState.OnChange -= HandleStateChange;
    }

    public class EmailBridgeContext
    {
        public string SenderEmail { get; set; } = "";
        public string SenderName { get; set; } = "";
        public string Subject { get; set; } = "";
    }
}
