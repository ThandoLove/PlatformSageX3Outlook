@using Microsoft.JSInterop
@using OperationalWorkspaceUI.State
@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceApplication.Interfaces.IServices
@using Microsoft.FluentUI.AspNetCore.Components

@implements IAsyncDisposable
@implements IDisposable

@inject DashboardState DashboardState
@inject AppStateContainer AppState
@inject IBusinessPartnerService BPService

<div class="right-panel-wrapper" style="position: relative; height: 100%; display: flex; flex-direction: row;">

    <div style="position: absolute; left: -16px; top: 20px; z-index: 100;">
        <FluentButton Appearance="Appearance.Accent"
                      OnClick="TogglePanel"
                      Style="border-radius: 50%; min-width: 32px; height: 32px;">
            @(IsCollapsed ? ">" : "<")
        </FluentButton>
    </div>

    <div class="right-panel-container"
         style="width:@(IsCollapsed ? "0px" : "350px");
        padding:@(IsCollapsed ? "0" : "16px");">

        @if (!IsCollapsed)
        {
            @if (IsLoading)
            {
                <FluentProgressRing />
            }
            else if (DashboardState.SelectedOrderId != null)
            {
                <FluentCard>
                    <h3>Order Insight</h3>
                    <p>@DashboardState.SelectedOrderId</p>

                    <FluentButton OnClick="ClearOrder">
                        Clear Context
                    </FluentButton>
                </FluentCard>
            }
            else if (AppState.CurrentEmail == null)
            {
                <FluentCard>
                    <p>Select an email or order</p>
                </FluentCard>
            }
            else
            {
                <FluentCard>
                    <h3>Email Insight</h3>

                    <p>
                        @AppState.CurrentEmail.SenderName
                    </p>

                    <p>
                        @(CurrentPartner?.Company ?? "Unknown")
                    </p>
                </FluentCard>
            }
        }
    </div>
</div>

@code {

    private BusinessPartnerSnapshotDto? CurrentPartner;
    private bool IsLoading;
    private bool IsCollapsed;
    private DotNetObjectReference<RightPanel>? _objRef;

    protected override void OnInitialized()
    {
        DashboardState.OnChange += Refresh;
    }

    private void TogglePanel()
    {
        IsCollapsed = !IsCollapsed;
    }

    private void Refresh()
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task ClearOrder()
    {
        await DashboardState.LoadOrderDetailsAsync(null);
        AppState.ClearCurrentEmail();
    }

    [JSInvokable]
    public async Task HandleEmailSelection(EmailBridgeContext context)
    {
        IsLoading = true;
        IsCollapsed = false;

        await DashboardState.LoadOrderDetailsAsync(null);

        // ✅ FIXED (NO DIRECT PROPERTY ASSIGNMENT)
        AppState.SetCurrentEmail(new EmailInsightDto
        {
            SenderEmail = context.SenderEmail,
            SenderName = context.SenderName,
            Subject = context.Subject,
            ReceivedAt = DateTime.UtcNow
        });

        if (!string.IsNullOrWhiteSpace(context.SenderEmail))
        {
            CurrentPartner =
                await BPService.GetPartnerByEmailAsync(context.SenderEmail);
        }

        IsLoading = false;
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        DashboardState.OnChange -= Refresh;
    }

    public ValueTask DisposeAsync()
    {
        _objRef?.Dispose();
        return ValueTask.CompletedTask;
    }

    public class EmailBridgeContext
    {
        public string SenderEmail { get; set; } = "";
        public string SenderName { get; set; } = "";
        public string Subject { get; set; } = "";
    }
}