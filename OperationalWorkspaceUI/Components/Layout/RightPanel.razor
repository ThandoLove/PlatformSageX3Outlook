@using Microsoft.JSInterop
@using OperationalWorkspaceUI.State
@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceApplication.Interfaces.IServices
@implements IAsyncDisposable

<div class="right-panel">
    @if (IsLoading)
    {
        <div class="loading-container">
            <LoadingSpinner />
            <p>Checking Sage X3...</p>
        </div>
    }
    else if (EmailState.CurrentEmail == null)
    {
        <div class="empty-state">
            <i class="ms-Icon ms-Icon--Mail"></i>
            <p>Select an email to view Sage X3 insights.</p>
        </div>
    }
    else if (CurrentPartner != null && CurrentPartner.IsLinkedToSage)
    {
        <!-- UI: SAGE X3 LINKED VIEW -->
        <div class="panel-header">
            <div class="profile-section">
                <div class="avatar">@CurrentPartner.FullName[0]</div>
                <div class="header-text">
                    <h3>@CurrentPartner.FullName</h3>
                    <span class="status-badge linked">Linked to Sage X3</span>
                </div>
            </div>
        </div>

        <div class="details-list">
            <div class="detail-item"><strong>📧 Email:</strong> @EmailState.CurrentEmail.SenderEmail</div>
            <div class="detail-item"><strong>🏢 Company:</strong> @CurrentPartner.Company</div>
            <div class="detail-item"><strong>📍 Location:</strong> @CurrentPartner.Location</div>
            <div class="detail-item"><strong>👤 Rep:</strong> @CurrentPartner.AssignedRep</div>
        </div>

        <div class="action-links">
            <button class="btn-action">📎 Add Attachment</button>
            <button class="btn-action">📚 Add Knowledge Article</button>
        </div>

        <div class="timeline-container">
            <h4>Activity Timeline</h4>
            <ActivityGrid Data="@CurrentPartner.Timeline" />
        </div>
    }
    else
    {
        <!-- UI: CREATE CONTACT FORM -->
        <div class="panel-header">
            <h3>Create Contact</h3>
            <span class="info-tag">PRE-FILLED FROM OUTLOOK</span>
        </div>

        <EditForm Model="@NewContact" OnValidSubmit="HandleCreateContact">
            <DataAnnotationsValidator />
            
            <div class="form-group">
                <label>Full Name</label>
                <InputText @bind-Value="NewContact.FullName" class="form-control" />
            </div>

            <div class="form-group">
                <label>Email</label>
                <InputText @bind-Value="NewContact.Email" class="form-control" readonly />
            </div>

            <div class="form-group">
                <label>Company</label>
                <InputText @bind-Value="NewContact.Company" class="form-control" />
            </div>

            <div class="form-group">
                <label>Phone</label>
                <InputText @bind-Value="NewContact.Phone" class="form-control" />
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-create">Create Contact in Sage</button>
            </div>
        </EditForm>
    }
</div>

@code {
    [Inject] private IJSRuntime JS { get; set; } = default!;
    [Inject] private EmailContextState EmailState { get; set; } = default!;
    [Inject] private IBusinessPartnerService BPService { get; set; } = default!;

    private BusinessPartnerSnapshotDto? CurrentPartner;
    private ContactCreateDto NewContact = new();
    private bool IsLoading = false;
    private DotNetObjectReference<RightPanel>? _dotRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("officeBridge.initialize", _dotRef);
        }
    }

    [JSInvokable]
    public async Task HandleEmailSelection(EmailBridgeContext context)
    {
        IsLoading = true;
        StateHasChanged();

        // 1. Update basic email state (EmailContextState.CurrentEmail)
        EmailState.CurrentEmail = new EmailInsightDto
        {
            SenderEmail = context.SenderEmail ?? string.Empty,
            SenderName = context.SenderName ?? string.Empty,
            Subject = context.Subject ?? string.Empty,
            MessageId = Guid.NewGuid().ToString(),
            ReceivedAt = DateTime.UtcNow
        };

        // 2. Perform Sage X3 Lookup using your updated BusinessPartnerService
        if (string.IsNullOrWhiteSpace(context.SenderEmail))
        {
            CurrentPartner = null; // cannot lookup empty email
        }
        else
        {
            CurrentPartner = await BPService.GetPartnerByEmailAsync(context.SenderEmail);
        }

        // 3. If not found, prepare the "Create Contact" DTO
        if (CurrentPartner == null)
        {
            NewContact = new ContactCreateDto
            {
                FullName = context.SenderName ?? "",
                Email = context.SenderEmail ?? "",
                Company = "" // User fills this
            };
        }

        IsLoading = false;
        StateHasChanged();
    }

    private async Task HandleCreateContact()
    {
        // Logic to POST NewContact to your API
        await JS.InvokeVoidAsync("showToast", "Contact Created in Sage X3!");
        // Refresh lookup
        CurrentPartner = await BPService.GetPartnerByEmailAsync(NewContact.Email ?? string.Empty);
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        _dotRef?.Dispose();
        await Task.CompletedTask;
    }

    public class EmailBridgeContext
    {
        public string SenderEmail { get; set; } = "";
        public string SenderName { get; set; } = "";
        public string Subject { get; set; } = "";
    }
}
