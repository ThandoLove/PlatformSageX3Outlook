@using Microsoft.JSInterop
@using OperationalWorkspaceUI.State
@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceApplication.Interfaces.IServices
@using Microsoft.FluentUI.AspNetCore.Components
@using OperationalWorkspaceApplication.ApplicationState
@using System.Linq

@implements IDisposable

@inject DashboardState DashboardState
@inject AppStateContainer AppState
@inject IBusinessPartnerService BPService

<div class="right-panel-wrapper @(IsCollapsed ? "panel-collapsed" : "panel-expanded")">

    <div class="toggle-button-anchor">
        <FluentButton Appearance="Appearance.Accent"
                      OnClick="TogglePanel"
                      Style="border-radius: 50%; min-width: 32px; height: 32px; box-shadow: 0 2px 6px rgba(0,0,0,0.15);">
            @(IsCollapsed ? "◀" : "▶")
        </FluentButton>
    </div>

    <div class="right-panel-container">
        @if (!IsCollapsed)
        {
            @if (IsLoading)
            {
                <div class="panel-spinner-box">
                    <FluentProgressRing />
                </div>
            }
            else if (DashboardState.SelectedOrderId != null)
            {
                <FluentCard Class="insight-panel-card">
                    <h3>Order Insight</h3>
                    <p class="insight-main-value">@DashboardState.SelectedOrderId</p>

                    <FluentButton OnClick="ClearOrder" Appearance="Appearance.Neutral">
                        Clear Context
                    </FluentButton>
                </FluentCard>
            }
            else if (AppState.CurrentEmail == null)
            {
                <div class="panel-card-empty">
                    <p>Select an email or order</p>
                </div>
            }
            else
            {
                <!-- AI SUMMARY -->
                <FluentCard Class="insight-panel-card">

                    <h3>AI Summary</h3>

                    <p>
                        <b>Customer</b><br />
                        @(AppState.MatchedClient?.FullName ?? "Unknown")
                    </p>

                    <p>
                        <b>Outstanding</b><br />
                        @(AppState.MatchedClient?.TotalOutstanding ?? 0)
                    </p>

                    <p>
                        <b>Credit Limit</b><br />
                        @(AppState.MatchedClient?.CreditLimit ?? 0)
                    </p>

                    <p>
                        <b>Orders</b><br />
                        @AppState.LinkedOrders.Count
                    </p>

                    <p>
                        <b>Invoices</b><br />
                        @AppState.Invoices.Count
                    </p>

                    <p>
                        <b>Tasks</b><br />
                        @AppState.LinkedTasks.Count
                    </p>

                    <p>
                        <b>Activities</b><br />
                        @AppState.AutomationLog.Count
                    </p>

                </FluentCard>

                <br />

                <!-- AUTOMATION -->
                <FluentCard Class="insight-panel-card">

                    <h4>Automation Flow</h4>

                    @if (AppState.AutomationLog.Any())
                    {
                        @foreach (var log in AppState.AutomationLog)
                        {
                            <div style="font-size:12px;margin-bottom:4px;">
                                @log
                            </div>
                        }
                    }
                    else
                    {
                        <div>No automation yet.</div>
                    }

                </FluentCard>

                <br />

                <!-- ORDERS -->
                <FluentCard Class="insight-panel-card">

                    <h4>Open Orders</h4>

                    @foreach (var order in AppState.LinkedOrders)
                    {
                        <div style="margin-bottom:8px;">

                            <b>@order.OrderNumber</b>

                            <br />

                            @order.TotalAmount

                        </div>
                    }

                </FluentCard>

                <br />

                <!-- INVOICES -->
                <FluentCard Class="insight-panel-card">

                    <h4>Invoices</h4>

                    @foreach (var invoice in AppState.Invoices)
                    {
                        <div style="margin-bottom:8px;">

                            <b>@invoice.InvoiceNumber</b>

                            <br />

                            @invoice.OutstandingAmount

                        </div>
                    }

                </FluentCard>

                <br />

                <!-- TASKS -->
                <FluentCard Class="insight-panel-card">

                    <h4>Tasks</h4>

                    @foreach (var task in AppState.LinkedTasks)
                    {
                        <div style="margin-bottom:8px;">
                            @task.Title
                        </div>
                    }

                </FluentCard>

                <br />

                <!-- ACTIVITIES -->
                <FluentCard Class="insight-panel-card">

                    <h4>Activities</h4>

                    @foreach (var activity in AppState.AutomationLog)
                    {
                        <div style="font-size:12px;margin-bottom:4px;">
                            @activity
                        </div>
                    }

                </FluentCard>
            }
        }
    </div>
</div>

@code {
    private BusinessPartnerSnapshotDto? CurrentPartner;
    private bool IsLoading;
    private bool IsCollapsed;

    protected override void OnInitialized()
    {
        DashboardState.OnChange += Refresh;
        AppState.OnChange += Refresh; // Listen to global automation updates as well
    }

    private void TogglePanel()
    {
        IsCollapsed = !IsCollapsed;
    }

    private void Refresh()
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task ClearOrder()
    {
        await DashboardState.LoadOrderDetailsAsync(null);
        AppState.ClearCurrentEmail();
    }

    [JSInvokable]
    public async Task HandleEmailSelection(EmailBridgeContext context)
    {
        IsLoading = true;
        IsCollapsed = false;

        await DashboardState.LoadOrderDetailsAsync(null);

        AppState.SetCurrentEmail(new EmailInsightDto
        {
            SenderEmail = context.SenderEmail,
            SenderName = context.SenderName,
            Subject = context.Subject,
            ReceivedAt = DateTime.UtcNow
        });

        if (!string.IsNullOrWhiteSpace(context.SenderEmail))
        {
            CurrentPartner = await BPService.GetPartnerByEmailAsync(context.SenderEmail);
        }

        IsLoading = false;
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        DashboardState.OnChange -= Refresh;
        AppState.OnChange -= Refresh;
    }

    public class EmailBridgeContext
    {
        public string SenderEmail { get; set; } = "";
        public string SenderName { get; set; } = "";
        public string Subject { get; set; } = "";
    }
}
