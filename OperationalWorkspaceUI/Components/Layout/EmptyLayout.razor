@inherits LayoutComponentBase

<div class="empty-layout-container">
    @Body
</div>

<style>
    .empty-layout-container {
        width: 100%;
        min-height: 100vh;
        margin: 0;
        padding: 0;
        overflow-y: auto; /* ✅ ENABLE SCROLL */
        overflow-x: hidden;
     
    }

    /* 🔥 GLOBAL SAFETY NET */
    html, body {
        height: auto !important;
        overflow-y: auto !important;
    }
</style>
