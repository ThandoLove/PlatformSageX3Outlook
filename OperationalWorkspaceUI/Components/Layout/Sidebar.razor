@using OperationalWorkspaceUI.Models.Constant
@using OperationalWorkspaceUI.State
@using OperationalWorkspaceUI.UIServices.System

@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons

@implements IDisposable

@inject NavigationManager Nav
@inject NavigationService NavService
@inject DashboardState DashboardState
@inject UIState UIState
@inject OperationalWorkspaceUI.UIServices.System.AuthService AuthService

<div class="sage-sidebar @(DashboardState.IsSidebarCollapsed ? "is-collapsed" : "")">

    <!-- SIDEBAR HEADER WITH INTEGRATED COLLAPSE TOGGLE TRIGGER -->
    <div class="sidebar-header" @onclick="ToggleSidebarLayout" title="Toggle Navigation Panel">
        <FluentIcon Value="@(new Icons.Regular.Size16.LineHorizontal3())"
                    Color="@Color.Custom"
                    CustomColor="#94a3b8" />
    </div>

    <!-- NAVIGATION MENU LINKS REGISTRATION -->
    <nav class="nav-menu">

        <!-- SECTION: APPLICATION CORE -->
        <FluentNavLink Icon="@(new Icons.Regular.Size16.Board())"
                       Href="@AppRoutes.Dashboard"
                       Match="NavLinkMatch.All">
            <span class="nav-link-text">Dashboard</span>
        </FluentNavLink>

        <FluentNavLink Icon="@(new Icons.Regular.Size16.Person())"
                       Href="@AppRoutes.BusinessPartners">
            <span class="nav-link-text">Contacts</span>
        </FluentNavLink>

        <FluentNavLink Icon="@(new Icons.Regular.Size16.TicketDiagonal())"
                       Href="@AppRoutes.Tickets">
            <span class="nav-link-text">Tickets</span>
        </FluentNavLink>

        <FluentNavLink Icon="@(new Icons.Regular.Size16.DataUsage())"
                       Href="@AppRoutes.Activity">
            <span class="nav-link-text">Activities</span>
        </FluentNavLink>

        <div class="sidebar-divider"></div>

        <!-- SECTION: WORKSPACE REPOSITORIES -->
        <FluentNavLink Icon="@(new Icons.Regular.Size16.Library())"
                       Href="@AppRoutes.Knowledge">
            <span class="nav-link-text">Knowledge Base</span>
        </FluentNavLink>

        <FluentNavLink Icon="@(new Icons.Regular.Size16.CheckmarkCircle())"
                       Href="@AppRoutes.Tasks">
            <span class="nav-link-text">My Tasks</span>
        </FluentNavLink>

        <FluentNavLink Icon="@(new Icons.Regular.Size16.Book())"
                       Href="@AppRoutes.Attachments">
            <span class="nav-link-text">Documents</span>
        </FluentNavLink>

        <FluentNavLink Icon="@(new Icons.Regular.Size16.Settings())"
                       Href="@AppRoutes.Settings">
            <span class="nav-link-text">Settings</span>
        </FluentNavLink>

        <!-- DYNAMIC ADMINISTRATIVE VISIBILITY BLOCKS (CONDITIONAL SECURITY SHIELD) -->
        @if (UIState.IsAdminEnvironment)
        {
            <div class="sidebar-divider"></div>

            <div class="group-title">
                <span class="nav-link-text">Administration</span>
            </div>

            <FluentNavLink Icon="@(new Icons.Regular.Size16.ShieldSettings())"
                           Href="@AppRoutes.Administration">
                <span class="nav-link-text">Admin Dashboard</span>
            </FluentNavLink>

            <FluentNavLink Icon="@(new Icons.Regular.Size16.TaskListSquareLtr())"
                           Href="@AppRoutes.AdministrationTasks">
                <span class="nav-link-text">Admin Tasks</span>
            </FluentNavLink>

            <FluentNavLink Icon="@(new Icons.Regular.Size16.PeopleTeam())"
                           Href="/admin/users">
                <span class="nav-link-text">User Management</span>
            </FluentNavLink>

            <FluentNavLink Icon="@(new Icons.Regular.Size16.DocumentBulletList())"
                           Href="/admin/audit-logs">
                <span class="nav-link-text">Audit Logs</span>
            </FluentNavLink>

            <FluentNavLink Icon="@(new Icons.Regular.Size16.ShieldTask())"
                           Href="/admin/system-health">
                <span class="nav-link-text">System Health</span>
            </FluentNavLink>
        }

    </nav>

    <!-- FOOTER ACCESS SECTIONS: Modern horizontal action lines -->
    <div class="sidebar-footer">
        <div class="footer-actions">
            <button type="button" class="footer-action footer-menu-trigger" @onclick="ToggleFooterMenu" title="Open menu">
                <span class="footer-action-icon">☰</span>
                <span class="footer-action-label">Menu</span>
            </button>

            @if (_footerMenuOpen)
            {
                <div class="footer-menu-dropdown">
                    <FluentNavLink class="footer-menu-item" Icon="@(new Icons.Regular.Size16.Settings())" Href="@AppRoutes.Settings">
                        <span>Settings</span>
                    </FluentNavLink>

                    <button type="button" class="footer-menu-item" @onclick='() => Nav.NavigateTo("/help")'>
                        <span>Help</span>
                    </button>

                    <button type="button" class="footer-menu-item footer-signout" @onclick="PromptFooterLogoutConfirmation">
                        <span>Sign Out</span>
                    </button>
                </div>
            }

            @if (_showFooterLogoutConfirmation)
            {
                <div class="footer-logout-popover">
                    <span class="pop-text">Sign out of your workspace session?</span>
                    <div class="pop-actions">
                        <button type="button" class="pop-confirm" @onclick="ExecuteFooterLogoutPipeline">Yes, Exit</button>
                        <button type="button" class="pop-cancel" @onclick="CancelFooterLogout">Cancel</button>
                    </div>
                </div>
            }
        </div>
    </div>

</div>

@code {
    protected override void OnInitialized()
    {
        DashboardState.OnChange += Refresh;
        UIState.OnChange += Refresh;
    }

    private void ToggleSidebarLayout()
    {
        DashboardState.ToggleGlobalSidebar();
    }

    private void Refresh()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        DashboardState.OnChange -= Refresh;
        UIState.OnChange -= Refresh;
    }

    private bool _showFooterLogoutConfirmation = false;

    private bool _footerMenuOpen = false;

    private void ToggleFooterMenu()
    {
        _footerMenuOpen = !_footerMenuOpen;
        // close logout confirmation when opening menu
        if (_footerMenuOpen)
            _showFooterLogoutConfirmation = false;
    }

    private void PromptFooterLogoutConfirmation()
    {
        _showFooterLogoutConfirmation = !_showFooterLogoutConfirmation;
    }

    private void CancelFooterLogout()
    {
        _showFooterLogoutConfirmation = false;
    }

    private async Task ExecuteFooterLogoutPipeline()
    {
        _showFooterLogoutConfirmation = false;
        await AuthService.LogoutAsync();
        // Replace history entry so Back does not return to protected dashboard
        Nav.NavigateTo("/", forceLoad: false, replace: true);
    }
}
