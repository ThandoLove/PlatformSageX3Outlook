@using OperationalWorkspaceUI.State
@using OperationalWorkspaceUI.UIServices.System
@using static Microsoft.FluentUI.AspNetCore.Components.Icons.Filled.Size20
@implements IDisposable
@inject NavigationManager Nav
@inject NavigationService NavService
@inject DashboardState DashboardState

<div class="sage-sidebar">
    <div class="sidebar-header">
        <FluentIcon Value="@(new Icons.Regular.Size24.LineHorizontal3())" Color="Color.White" />
        <span class="brand-text">Sage X3 Contextual Workspace</span>
    </div>

    <nav class="nav-menu">
        <FluentNavLink Icon="@(new Icons.Regular.Size20.Board())" Title="Dashboard" Selected="true" />
        <FluentNavLink Icon="@(new Icons.Regular.Size20.Person())" Title="Contacts" />
        <FluentNavLink Icon="@(new Icons.Regular.Size20.Building())" Title="Accounts" />
        
        @* Replaced Items *@
        <FluentNavLink Icon="@(new Icons.Regular.Size20.Ticket())" Title="Tickets" />
        <FluentNavLink Icon="@(new Icons.Regular.Size20.Pulse())" Title="Activities" />
        
        <FluentNavLink Icon="@(new Icons.Regular.Size20.Cart())" Title="Sales Orders" />
        <FluentNavLink Icon="@(new Icons.Regular.Size20.DocumentQuote())" Title="Quotes" />
        <FluentNavLink Icon="@(new Icons.Regular.Size20.Receipt())" Title="Invoices" />
        <FluentNavLink Icon="@(new Icons.Regular.Size20.Briefcase())" Title="Cases" />
        
        <div class="sidebar-divider"></div>

        <FluentNavLink Icon="@(new Icons.Regular.Size20.Attach())" Title="Attach Documents" />
        <FluentNavLink Icon="@(new Icons.Regular.Size20.Library())" Title="Knowledge Base" />
        <FluentNavLink Icon="@(new Icons.Regular.Size20.AddSquare())" Title="Create Task (Admin)" />
        <FluentNavLink Icon="@(new Icons.Regular.Size20.CheckmarkCircle())" Title="My Tasks" />
        <FluentNavLink Icon="@(new Icons.Regular.Size20.Poll())" Title="Reports" />
        <FluentNavLink Icon="@(new Icons.Regular.Size20.Settings())" Title="Admin" />
    </nav>

    <div class="sidebar-footer">
        <FluentNavLink Icon="@(new Icons.Regular.Size20.Settings())" Title="Settings" />
    </div>
</div>

