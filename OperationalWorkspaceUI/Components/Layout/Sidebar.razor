@using OperationalWorkspaceUI.State
@using OperationalWorkspaceUI.UIServices.System
@implements IDisposable
@inject NavigationManager Nav
@inject NavigationService NavService
@inject DashboardState DashboardState

<div class="sage-sidebar">
    <div class="sidebar-header">
        <FluentIcon Value="@(new Icons.Regular.Size24.LineHorizontal3())" Color="@Color.Fill" />
        <span class="brand-text">Sage X3 Contextual Workspace</span>
    </div>

    <nav class="nav-menu">
        <FluentNavLink Icon="@(new Icons.Regular.Size20.Board())" Href="/dashboard" Match="NavLinkMatch.All">Dashboard</FluentNavLink>
        <FluentNavLink Icon="@(new Icons.Regular.Size20.Person())" Href="/contacts">Contacts</FluentNavLink>
        <FluentNavLink Icon="@(new Icons.Regular.Size20.Building())" Href="/accounts">Accounts</FluentNavLink>
        
        @* UPDATED: Tickets & Activities swapped in *@
        <FluentNavLink Icon="@(new Icons.Regular.Size20.TicketDiagonal())" Href="/tickets">Tickets</FluentNavLink>
        <FluentNavLink Icon="@(new Icons.Regular.Size20.Pulse())" Href="/activities">Activities</FluentNavLink>
        
        <div class="sidebar-divider"></div>

        <FluentNavLink Icon="@(new Icons.Regular.Size20.Cart())" Href="/sales-orders">Sales Orders</FluentNavLink>
        <FluentNavLink Icon="@(new Icons.Regular.Size20.Document())" Href="/quotes">Quotes</FluentNavLink>
        <FluentNavLink Icon="@(new Icons.Regular.Size20.Receipt())" Href="/invoices">Invoices</FluentNavLink>
        <FluentNavLink Icon="@(new Icons.Regular.Size20.Briefcase())" Href="/cases">Cases</FluentNavLink>
        
        <div class="sidebar-divider"></div>

        <FluentNavLink Icon="@(new Icons.Regular.Size20.Library())" Href="/kb">Knowledge Base</FluentNavLink>
        <FluentNavLink Icon="@(new Icons.Regular.Size20.CheckmarkCircle())" Href="/tasks">My Tasks</FluentNavLink>
        <FluentNavLink Icon="@(new Icons.Regular.Size20.Settings())" Href="/admin">Admin</FluentNavLink>
    </nav>

    <div class="sidebar-footer">
        <FluentNavLink Icon="@(new Icons.Regular.Size20.Settings())" Href="/settings">Settings</FluentNavLink>
    </div>
</div>

@code {
    protected override void OnInitialized() => DashboardState.OnChange += StateHasChanged;
    public void Dispose() => DashboardState.OnChange -= StateHasChanged;
}
