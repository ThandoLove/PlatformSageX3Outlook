@using OperationalWorkspaceUI.Models.Constant
@using OperationalWorkspaceUI.State
@using OperationalWorkspaceUI.UIServices.System
@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceApplication.Interfaces.IServices
@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons

@implements IDisposable

@inject NavigationManager Nav
@inject NavigationService NavService
@inject DashboardState DashboardState
@inject IUserContextService UserContextService

<div class="sage-sidebar @(DashboardState.IsSidebarCollapsed ? "is-collapsed" : "")">

    <!-- SIDEBAR HEADER -->
    <div class="sidebar-header" @onclick="ToggleSidebarLayout" style="cursor: pointer;">
        <FluentIcon Value="@(new Icons.Regular.Size16.LineHorizontal3())"
                    Color="@Color.Fill" />
        <span class="brand-text">Hub</span>
    </div>

    <!-- NAVIGATION -->
    <nav class="nav-menu">

        <!-- MAIN -->
        <FluentNavLink Icon="@(new Icons.Regular.Size16.Board())"
                       Href="@AppRoutes.Dashboard"
                       Match="NavLinkMatch.All">
            <span class="nav-link-text">Dashboard</span>
        </FluentNavLink>

        <FluentNavLink Icon="@(new Icons.Regular.Size16.Person())"
                       Href="@AppRoutes.BusinessPartners">
            <span class="nav-link-text">Contacts</span>
        </FluentNavLink>

        <FluentNavLink Icon="@(new Icons.Regular.Size16.TicketDiagonal())"
                       Href="@AppRoutes.Tickets">
            <span class="nav-link-text">Tickets</span>
        </FluentNavLink>

        <FluentNavLink Icon="@(new Icons.Regular.Size16.DataUsage())"
                       Href="@AppRoutes.Activity">
            <span class="nav-link-text">Activities</span>
        </FluentNavLink>

        <div class="sidebar-divider"></div>

        <!-- WORKSPACE -->
        <FluentNavLink Icon="@(new Icons.Regular.Size16.Library())"
                       Href="@AppRoutes.Knowledge">
            <span class="nav-link-text">Knowledge Base</span>
        </FluentNavLink>

        <FluentNavLink Icon="@(new Icons.Regular.Size16.CheckmarkCircle())"
                       Href="@AppRoutes.Tasks">
            <span class="nav-link-text">My Tasks</span>
        </FluentNavLink>

        <FluentNavLink Icon="@(new Icons.Regular.Size16.Book())"
                       Href="@AppRoutes.Attachments">
            <span class="nav-link-text">Documents</span>
        </FluentNavLink>

        <!-- ADMIN ONLY -->
        @if (IsAdmin)
        {
            <div class="sidebar-divider"></div>

            <div class="group-title">
                <span class="nav-link-text">Administration</span>
            </div>

            <FluentNavLink Icon="@(new Icons.Regular.Size16.ShieldSettings())"
                           Href="@AppRoutes.Administration">
                <span class="nav-link-text">Admin Dashboard</span>
            </FluentNavLink>

            <FluentNavLink Icon="@(new Icons.Regular.Size16.TaskListSquareLtr())"
                           Href="@AppRoutes.AdministrationTasks">
                <span class="nav-link-text">Admin Tasks</span>
            </FluentNavLink>

            <FluentNavLink Icon="@(new Icons.Regular.Size16.PeopleTeam())"
                           Href="/admin/users">
                <span class="nav-link-text">User Management</span>
            </FluentNavLink>

            <FluentNavLink Icon="@(new Icons.Regular.Size16.DocumentBulletList())"
                           Href="/admin/audit-logs">
                <span class="nav-link-text">Audit Logs</span>
            </FluentNavLink>

            <FluentNavLink Icon="@(new Icons.Regular.Size16.ShieldTask())"
                           Href="/admin/system-health">
                <span class="nav-link-text">System Health</span>
            </FluentNavLink>
        }

    </nav>

    <!-- FOOTER -->
    <div class="sidebar-footer">
        <FluentNavLink Icon="@(new Icons.Regular.Size16.Settings())"
                       Href="@AppRoutes.Settings">
            <span class="nav-link-text">Settings</span>
        </FluentNavLink>
    </div>

</div>

@code {
    private UserDto? CurrentUser;

    private bool IsAdmin =>
        CurrentUser?.Role?.Equals("Admin", StringComparison.OrdinalIgnoreCase) == true;

    protected override async Task OnInitializedAsync()
    {
        DashboardState.OnChange += Refresh;
        CurrentUser = await UserContextService.GetCurrentUserAsync();
    }

    private void ToggleSidebarLayout()
    {
        DashboardState.ToggleGlobalSidebar();
    }

    private void Refresh()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        DashboardState.OnChange -= Refresh;
    }
}
