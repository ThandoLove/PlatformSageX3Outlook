@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspaceApplication.Interfaces.IServices
@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration
@inject IAuditLogService AuditLogService
@inject IJSRuntime JS
@inject OperationalWorkspaceUI.UIServices.ToastUIService.ToastService CustomToastService

<div class="audit-shell-container">
    
    <!-- ENVIRONMENT DETECTION RIBBON -->
    <div class="environment-status-bar">
        <div class="status-left">
            <span class="pulse-indicator-dot @(Configuration.GetValue<bool>("SageX3:UseMockData") ? "offline-mode" : "online-mode")"></span>
            <span class="status-label-text">
                @(Configuration.GetValue<bool>("SageX3:UseMockData") ? "MOCK DEV SANDBOX ACTIVE" : "CONNECTED TO SAGE X3 RUNNING MODE")
            </span>
        </div>
        <span class="timestamp-stamp">Telemetry Sync Node: Live</span>
    </div>

    <!-- AUDIT HEADER CONTROLS TOOLBAR -->
    <div class="audit-toolbar-row">
        <div>
            <h1>Audit Logs</h1>
            <p class="toolbar-description">Monitor security events, user actions, integrations, and system activity.</p>
        </div>
        <div class="toolbar-actions-group">
            @* 🔍 FLUID SEARCH HOOK: Re-filters text metrics instantly on user input! *@
            <input type="text" placeholder="Search audit logs..." class="compact-search-box"
                   @bind="SearchQuery" @bind:event="oninput" />
            <button class="export-action-btn" @onclick="TriggerLogsExportBlob">Export Logs</button>
        </div>
    </div>

    <!-- FLUID METRIC CARD ROW -->
    <div class="metrics-cards-grid">
        <div class="mini-stats-card">
            <span class="stats-label">Total Events</span>
            <h2>@FilteredLogs.Count()</h2>
        </div>
        <div class="mini-stats-card">
            <span class="stats-label">Critical Events</span>
            <h2>@FilteredLogs.Count(x => x.Action.Contains("Delete", StringComparison.OrdinalIgnoreCase) || x.Action.Contains("Startup", StringComparison.OrdinalIgnoreCase))</h2>
        </div>
        <div class="mini-stats-card">
            <span class="stats-label">User Logins</span>
            <h2>@FilteredLogs.Count(x => x.Action.Contains("Login", StringComparison.OrdinalIgnoreCase))</h2>
        </div>
        <div class="mini-stats-card">
            <span class="stats-label">Today's Activity</span>
            <h2>@FilteredLogs.Count(x => x.Timestamp.Date == DateTime.Today)</h2>
        </div>
    </div>

    <!-- MAIN THREE-COLUMN WORKSPACE FRAME SYSTEM -->
    <div class="workspace-layout-grid">
        <!-- LEFT PANEL SIDEBAR: FILTERS -->
        <div class="sidebar-filters-pane">
            <h3>Filters</h3>
            <div class="filter-field-group">
                <label>Action Type</label>
                <select @bind="SelectedActionFilter" class="compact-select-input">
                    <option value="">All Actions</option>
                    <option value="System Startup">System Startup</option>
                    <option value="Login">Login</option>
                    <option value="Update">Update</option>
                    <option value="Create">Create</option>
                    <option value="Delete">Delete</option>
                </select>
            </div>
            <div class="filter-field-group">
                <label>Target Entity</label>
                <select @bind="SelectedEntityFilter" class="compact-select-input">
                    <option value="">All Entities</option>
                    <option value="Core">Core</option>
                    <option value="Ticket">Ticket</option>
                    <option value="Invoice">Invoice</option>
                    <option value="User">User</option>
                </select>
            </div>
            <div class="checkbox-row-field">
                <input type="checkbox" id="criticalOnlyCheck" @bind="ShowCriticalOnly" />
                <label for="criticalOnlyCheck">Critical Only</label>
            </div>
        </div>

        <!-- CENTER PANEL: RECTANGULAR USER GRIDS TABLE -->
        <div class="logs-list-table-wrapper">
            <table class="compact-audit-data-table">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Action</th>
                        <th>Entity</th>
                        <th>Timestamp</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in FilteredLogs)
                    {
                        <tr class="@(SelectedLog?.Id == log.Id ? "is-selected-data-row" : "")" @onclick="() => SetSelectedLog(log)">
                            <td>
                                <div class="profile-cell-wrapper">
                                    <div class="avatar-bubble-icon">@GetSafetyInitial(log.User)</div>
                                    <span class="user-fullname-text">@log.User</span>
                                </div>
                            </td>
                            <td>
                                <span class="badge-action-pill action-@log.Action.ToLower().Replace(" ", "-")">
                                    @log.Action
                                </span>
                            </td>
                            <td>
                                <span>@log.Entity</span>
                            </td>
                            <td><span class="timestamp-cell-text">@log.Timestamp.ToString("MMM dd yyyy HH:mm")</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- RIGHT PANEL SIDEBAR: DETAIL VIEW CONSOLE -->
        <div class="sidebar-details-pane">
            @if (SelectedLog != null)
            {
                <div class="details-avatar-hero">
                    <div class="hero-avatar-large">@GetSafetyInitial(SelectedLog.User)</div>
                    <h3>@SelectedLog.Action</h3>
                    <p>Triggered by: @SelectedLog.User</p>
                </div>
                <div class="meta-details-box">
                    <div class="meta-item-line"><label>Target Entity Element:</label><strong>@SelectedLog.Entity</strong></div>
                    <div class="meta-item-line"><label>System Timestamp:</label><strong>@SelectedLog.Timestamp.ToString("f")</strong></div>
                </div>

                <!-- DYNAMIC LIVE EVENT TIMELINE AUDIT FEED -->
                <div class="audit-timeline-card">
                    <h4>Event Timeline</h4>
                    <div class="timeline-scroll-viewport">
                        <div class="timeline-item-line">
                            <strong class="timeline-action">Session Context Handshake Authenticated</strong>
                            <span class="timeline-user-meta">User authenticated into system</span>
                        </div>
                        <div class="timeline-item-line">
                            <strong class="timeline-action">Schema Record Mutated Successfully</strong>
                            <span class="timeline-user-meta">Entity updated successfully</span>
                        </div>
                        <div class="timeline-item-line">
                            <strong class="timeline-action">Encrypted Audit Signature Logged</strong>
                            <span class="timeline-user-meta">Audit entry recorded cleanly at node checkpoint</span>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="empty-state-pane-msg">
                    <p>Select a specific operation row from the central database matrix log grid to expand security event payloads.</p>
                </div>
            }
        </div>
    </div>
</div>
@code {
    private string SearchQuery = "";
    private string SelectedActionFilter = "";
    private string SelectedEntityFilter = "";
    private bool ShowCriticalOnly = false;

    private List<AuditLogDto> MasterLogsCollection = new();
    private AuditLogDto? SelectedLog;

    private IEnumerable<AuditLogDto> FilteredLogs => MasterLogsCollection
        .Where(l => (string.IsNullOrWhiteSpace(SearchQuery) || l.User.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) || l.Action.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)) &&
                    (string.IsNullOrEmpty(SelectedActionFilter) || l.Action == SelectedActionFilter) &&
                    (string.IsNullOrEmpty(SelectedEntityFilter) || l.Entity == SelectedEntityFilter) &&
                    (!ShowCriticalOnly || l.Action.Contains("Delete", StringComparison.OrdinalIgnoreCase) || l.Action.Contains("Startup", StringComparison.OrdinalIgnoreCase)))
        .OrderByDescending(x => x.Timestamp);

    protected override async Task OnInitializedAsync()
    {
        bool useMockData = Configuration.GetValue<bool>("SageX3:UseMockData");

        if (!useMockData)
        {
            try
            {
                // DUAL SWAP LOGIC SAGE X3 RUNNING PIPELINE [INDEX: 3]
                var realLogs = await AuditLogService.GetAllAuditLogsAsync();
                if (realLogs != null && realLogs.Any())
                {
                    MasterLogsCollection = realLogs;
                    SelectedLog = MasterLogsCollection.FirstOrDefault();
                    return;
                }
            }
            catch (Exception ex)
            {
                global::System.Diagnostics.Debug.WriteLine($"Sage X3 remote audit stream parsing failure: {ex.Message}");
            }
        }

        // SANDBOX MODE RECONCILIATION RETRIEVAL ARCHITECTURE [INDEX: 3]
        MasterLogsCollection = new List<AuditLogDto>
        {
            new() { Id = Guid.NewGuid(), Action = "System Startup", User = "System", Entity = "Core", Timestamp = DateTime.Now.AddMinutes(-5) },
            new() { Id = Guid.NewGuid(), Action = "User Login", User = "admin@sagex3.com", Entity = "User", Timestamp = DateTime.Now.AddMinutes(-15) },
            new() { Id = Guid.NewGuid(), Action = "Update", User = "manager@sagex3.com", Entity = "Invoice", Timestamp = DateTime.Now.AddHours(-2) },
            new() { Id = Guid.NewGuid(), Action = "Create", User = "operator@test.com", Entity = "Ticket", Timestamp = DateTime.Now.AddHours(-4) },
            new() { Id = Guid.NewGuid(), Action = "Delete", User = "thando@test.com", Entity = "User", Timestamp = DateTime.Now.AddDays(-1) }
        };

        SelectedLog = MasterLogsCollection.FirstOrDefault();
    }

    private void SetSelectedLog(AuditLogDto log) => SelectedLog = log;

    private Task TriggerLogsExportBlob()
    {
        CustomToastService.ShowInfo(
            "Compiling audit log export..."
        );

        return Task.CompletedTask;
    }

    // FIXED CHARACTER INDEX WRAPPER ELIMINATES PARSING EXCEPTIONS [INDEX: 1]
    private string GetSafetyInitial(string? user)
    {
        if (string.IsNullOrWhiteSpace(user)) return "S";
        string cleanName = user.Trim();
        return cleanName.Length > 0 ? cleanName.Substring(0, 1).ToUpper() : "S";
    }
}
