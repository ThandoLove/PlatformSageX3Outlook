@using OperationalWorkspace.Domain.Enums
@using OperationalWorkspaceUI.State
@using OperationalWorkspaceApplication.DTOs

@inject DashboardState DashboardState

<div class="task-details-panel @(Task == null ? "hidden" : "")">

    @if (Task != null)
    {
        <!-- HEADER -->
        <div class="details-header">

            <div class="alert-icon">
                !
            </div>

            <div class="header-content">
                <h3>@Task.Title</h3>
                <p>@Task.CompanyName</p>
            </div>

            <button class="close-btn"
                    @onclick="() => DashboardState.SetSelectedTask(null)">
                &times;
            </button>

        </div>

        <!-- METADATA -->
        <div class="metadata-grid">

            <div class="meta-row">
                <label>Status</label>
                <span class="value-blue">@Task.Status</span>
            </div>

            <div class="meta-row">
                <label>Priority</label>
                <span class="value-red">@Task.Priority</span>
            </div>

            <div class="meta-row">
                <label>SLA Remaining</label>
                <span class="value-red">Overdue by 5h 20m</span>
            </div>

            <div class="meta-row">
                <label>Assigned To</label>

                <div class="assignee-wrap">
                    <span class="avatar-box">AP</span>
                    <span>@Task.AssignedTo</span>
                </div>
            </div>

            <div class="meta-row">
                <label>Created</label>
                <span>@Task.CreatedDate.ToString("MMM dd, yyyy hh:mm tt")</span>
            </div>

            <div class="meta-row">
                <label>Source</label>

                <div class="source-wrap">
                    <span>📧</span>
                    <span>Outlook Email</span>
                </div>
            </div>

        </div>

        <!-- TABS -->
        <div class="details-tabs">

            <button class="tab-btn @(activeTab == "overview" ? "active" : "")"
                    @onclick='() => activeTab = "overview"'>

                Overview

            </button>

            <button class="tab-btn @(activeTab == "links" ? "active" : "")"
                    @onclick='() => activeTab = "links"'>

                Sage Links

            </button>

            <button class="tab-btn @(activeTab == "actions" ? "active" : "")"
                    @onclick='() => activeTab = "actions"'>

                Actions

            </button>

        </div>

        <!-- OVERVIEW TAB -->
        @if (activeTab == "overview")
        {
            <div class="details-section">

                <label class="section-label">
                    CUSTOMER
                </label>

                <div class="customer-card">

                    <span class="customer-name">
                        @Task.CompanyName
                    </span>

                    <a href="javascript:void(0)"
                           class="sage-link">

                        Open in Sage X3

                    </a>

                </div>

            </div>
        }

        <!-- LINKS TAB -->
        @if (activeTab == "links")
        {
            <div class="details-section">

                <label class="section-label">
                    SAGE X3 LINKS
                </label>

                <div class="link-list">

                    <div class="link-item">
                        <span>Customer</span>
                        <span class="blue-link">@Task.CompanyName</span>
                    </div>

                    <div class="link-item">
                        <span>Invoice</span>
                        <span class="blue-link">INV-100123</span>
                    </div>

                    <div class="link-item">
                        <span>Sales Order</span>
                        <span class="blue-link">SO-10293</span>
                    </div>

                    <div class="link-item">
                        <span>Opportunity</span>
                        <span class="blue-link">OP-00921</span>
                    </div>

                </div>

            </div>
        }

        <!-- ACTIONS TAB -->
        @if (activeTab == "actions")
        {
            <div class="details-section">

                <label class="section-label">
                    ADMIN ACTIONS
                </label>

                <div class="admin-action-list">

                    <button class="action-btn">
                        Reassign Task
                    </button>

                    <button class="action-btn">
                        Change Priority
                    </button>

                    <button class="action-btn danger">
                        Escalate Task
                    </button>

                </div>

            </div>

            <AdminAssignmentControls Task="Task" />

            <AdminEscalationPanel Task="Task" />
        }

    }

</div>

@code {

    [Parameter]
    public TaskDto? Task { get; set; }

    private string activeTab = "overview";

}