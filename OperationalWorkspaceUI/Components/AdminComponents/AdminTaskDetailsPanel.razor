@using OperationalWorkspaceApplication.DTOs
@using OperationalWorkspace.Domain.Enums
@using OperationalWorkspaceUI.State
@inject DashboardState State

@if (CurrentTask != null)
{
    <div class="fidelity-details-panel">
        @* --- HEADER --- *@
        <div class="details-header">
            <div class="red-alert-icon">!</div>
            <div class="header-text">
                <h3>@CurrentTask.Title</h3>
                <p>@CurrentTask.CompanyName</p>
            </div>
            <button class="close-btn" @onclick="() => State.SetSelectedTask(null)">&times;</button>
        </div>

        @* --- METADATA GRID --- *@
        <div class="fidelity-table">
            <div class="f-row">
                <label>Status</label>
                <span class="v-blue">@CurrentTask.Status</span>
            </div>
            <div class="f-row">
                <label>Priority</label>
                <span class="v-red">@CurrentTask.Priority</span>
            </div>
            <div class="f-row">
                <label>SLA Remaining</label>
                <span class="v-red">Overdue by 5h 20m</span>
            </div>
            <div class="f-row">
                <label>Assigned To</label>
                <div class="assignee">
                    <span class="avatar">AP</span> @CurrentTask.AssignedTo
                </div>
            </div>
            <div class="f-row">
                <label>Created</label>
                <span>@CurrentTask.CreatedDate.ToString("MMM d, yyyy h:mm tt")</span>
            </div>
            <div class="f-row">
                <label>Source</label>
                <span>
                    <img src="https://wikimedia.org" width="14" style="margin-right: 4px; vertical-align: middle;" /> 
                    Outlook Email
                </span>
            </div>
        </div>

        @* --- CUSTOMER SNAPSHOT --- *@
        <div class="fidelity-section">
            <label class="sec-label">CUSTOMER</label>
            <div class="cust-card">
                <span class="bold">@CurrentTask.CompanyName</span>
                <a href="#" class="sage-link">Open in Sage X3 <i class="oi oi-external-link"></i></a>
            </div>
        </div>

        @* --- SAGE X3 LINKS (AS BLUE TEXT LINKS) --- *@
        <div class="fidelity-section">
            <label class="sec-label">SAGE X3 LINKS</label>
            <div class="sage-links-list">
                <a href="#"><i class="oi oi-person"></i> Customer: <span class="blue">@CurrentTask.CompanyName</span> <i class="oi oi-external-link"></i></a>
                <a href="#"><i class="oi oi-document"></i> Invoice: <span class="blue">INV-100123</span> <i class="oi oi-external-link"></i></a>
                <a href="#"><i class="oi oi-cart"></i> Sales Order: <span class="blue">SO-10293</span> <i class="oi oi-external-link"></i></a>
                <a href="#"><i class="oi oi-graph"></i> Opportunity: <span class="blue">OP-00921</span> <i class="oi oi-external-link"></i></a>
            </div>
        </div>

        @* --- ADMIN ACTIONS (AS TEXT LINKS) --- *@
        <div class="fidelity-section">
            <label class="sec-label">ADMIN ACTIONS</label>
            <div class="admin-links-list">
                <a href="#"><i class="oi oi-person"></i> Reassign Task</a>
                <a href="#"><i class="oi oi-arrow-top"></i> Change Priority</a>
                <a href="#" class="red-lnk"><i class="oi oi-shield"></i> Escalate Task</a>
                <a href="#"><i class="oi oi-briefcase"></i> Convert to Case</a>
                <a href="#"><i class="oi oi-cart"></i> Convert to Sales Order</a>
            </div>
        </div>
    </div>
}

@code {
    // FIX: Renamed from 'Task' to 'CurrentTask' to avoid System.Threading conflict
    [Parameter] public TaskDto? CurrentTask { get; set; }
}

