@using Microsoft.FluentUI.AspNetCore.Components

<div class="role-editor-card">

    <h4>Role Management</h4>

    <FluentSelect TOption="string"
                  Label="Role">

        <FluentOption TOption="string" Value="Admin">
            Admin
        </FluentOption>

        <FluentOption TOption="string" Value="Manager">
            Manager
        </FluentOption>

        <FluentOption TOption="string" Value="User">
            User
        </FluentOption>

    </FluentSelect>

    <FluentButton Appearance="Appearance.Accent">
        Save Role
    </FluentButton>

</div>

