@using Microsoft.FluentUI.AspNetCore.Components

<div class="filters-panel">

    <h3>Filters</h3>

    <!-- ROLE FILTER -->
    <FluentSelect TOption="string"
                  Label="Role">

        <FluentOption TOption="string" Value="">
            All Roles
        </FluentOption>

        <FluentOption TOption="string" Value="Admin">
            Admin
        </FluentOption>

        <FluentOption TOption="string" Value="Manager">
            Manager
        </FluentOption>

        <FluentOption TOption="string" Value="User">
            User
        </FluentOption>

    </FluentSelect>

    <!-- ENVIRONMENT FILTER -->
    <FluentSelect TOption="string"
                  Label="Environment">

        <FluentOption TOption="string" Value="">
            All Environments
        </FluentOption>

        <FluentOption TOption="string" Value="Production">
            Production
        </FluentOption>

        <FluentOption TOption="string" Value="Testing">
            Testing
        </FluentOption>

    </FluentSelect>

    <!-- DISABLED USERS -->
    <FluentCheckbox Label="Show Disabled Users" />

</div>