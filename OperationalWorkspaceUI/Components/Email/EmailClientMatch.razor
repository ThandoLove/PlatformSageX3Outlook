@using OperationalWorkspaceApplication.DTOs

<!-- CODE START: EmailClientMatch.razor -->
@if (IsLoading)
{
    <LoadingSpinner />
}
else if (Client == null)
{
    <div class="email-client-match">
        <EmptyState Message="No matching client found." />

        <button class="btn btn-primary" @onclick="CreateClient">
            Create New Client
        </button>
    </div>
}
else
{
    <div class="email-client-match">
        <h5>Matched Client</h5>

        <div class="client-card" @onclick="() => OnOpenClient.InvokeAsync(Client)">
            <p><b>@Client.Name</b></p>
            <p>@Client.Email</p>
            <p>@Client.PhoneNumber</p>
        </div>
    </div>
}

@code {
    [Parameter] public ClientDto? Client { get; set; }
    [Parameter] public bool IsLoading { get; set; }

    [Parameter] public EventCallback<ClientDto> OnOpenClient { get; set; }
    [Parameter] public EventCallback OnCreateClient { get; set; }

    private async Task CreateClient()
    {
        await OnCreateClient.InvokeAsync();
    }
}

<!-- CODE END -->
