{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=SageX3Test;Trusted_Connection=True;"
  },

  "Jwt": {
    "SecretKey": "YourSuperSecretTestKey123!ThisIsALongKeyToMeetLengthRequirements",
    "Issuer": "OperationalWorkspaceAPI",
    "Audience": "PlatformSageX3Outlook"
  },

  "ApiBaseUrl": "https://pstmn.io",

  "BlazorExecutionMode": "DevelopmentDemo",

  "SageX3": {
    "UseMockData": false,

    "BaseUrl": "https://pstmn.io",

    "Endpoint": "SEED",

    "RestBaseUrl": "https://pstmn.io"
  },

  "SageSecurityOptions": {
    "ClientId": "your-client-id",
    "ClientSecret": "your-client-secret",
    "BaseUrl": "https://pstmn.io"
  },

  "Outlook": {
    "EnableEmailPicker": true,
    "EnableAttachToOpenEmail": true
  },

  "Attachments": {
    "EnableMockDocuments": false,
    "MockDocumentsFolder": "mock-documents",
    "EnablePdfConversion": true
  }
}
