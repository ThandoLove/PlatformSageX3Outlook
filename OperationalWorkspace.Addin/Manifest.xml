<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
           xsi:type="MailApp">
  <Id>23F4B3A6-5E0D-4C67-988D-F6943082C49B</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>YourCompany</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="OperationalWorkspace ERP Add-In"/>
  <Description DefaultValue="ERP-first Sage X3 integration for Outlook"/>
  <IconUrl DefaultValue="https://yourcdn.com/icons/erpaddin-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://yourcdn.com/icons/erpaddin-64.png"/>
  <SupportUrl DefaultValue="https://yourcompany.com/support"/>
  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Set Name="Mailbox" MinVersion="1.8"/>
  </Requirements>

  <Permissions>ReadWriteMailbox</Permissions>

  <!-- VersionOverrides 1.1 adds command ribbon buttons and taskpane bindings for Mail add-ins -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1">
    <Requirements>
      <bt:Sets>
        <bt:Set Name="Mailbox" />
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host Name="Mailbox" />
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="icon16" DefaultValue="https://yourcdn.com/icons/erpaddin-16.png" />
        <bt:Image id="icon32" DefaultValue="https://yourcdn.com/icons/erpaddin-32.png" />
        <bt:Image id="icon80" DefaultValue="https://yourcdn.com/icons/erpaddin-80.png" />
      </bt:Images>
      <bt:Urls>
        <!-- These should point to pages in your Blazor app that bootstrap the app and provide the login/welcome UI -->
        <bt:Url id="messageReadPaneUrl" DefaultValue="https://localhost:7173/dashboard.html" />
        <bt:Url id="messageComposePaneUrl" DefaultValue="https://localhost:7173/compose.html" />
      </bt:Urls>
      <bt:Strings>
        <bt:String id="groupLabel" DefaultValue="OperationalWorkspace" />
        <bt:String id="openPaneLabel" DefaultValue="Open OperationalWorkspace" />
        <bt:String id="openPaneTitle" DefaultValue="Open OperationalWorkspace" />
        <bt:String id="openPaneDesc" DefaultValue="Open the OperationalWorkspace pane (login required)." />
      </bt:Strings>
    </Resources>

    <!-- Command surface for message read (ribbon) -->
    <ExtensionPoint xsi:type="MessageReadCommandSurface">
      <OfficeTab id="TabDefault">
        <Group id="OperationalWorkspaceGroup" label="OperationalWorkspace">
          <Control xsi:type="Button" id="OpenPaneReadButton">
            <Label resid="openPaneLabel" />
            <Supertip>
              <Title resid="openPaneTitle" />
              <Description resid="openPaneDesc" />
            </Supertip>
            <Icon>
              <bt:Image size="16" resid="icon16" />
              <bt:Image size="32" resid="icon32" />
              <bt:Image size="80" resid="icon80" />
            </Icon>
            <Action xsi:type="ShowTaskpane">
              <SourceLocation resid="messageReadPaneUrl" />
            </Action>
          </Control>
        </Group>
      </OfficeTab>
    </ExtensionPoint>

    <!-- Command surface for message compose (ribbon) -->
    <ExtensionPoint xsi:type="MessageComposeCommandSurface">
      <OfficeTab id="TabDefault">
        <Group id="OperationalWorkspaceComposeGroup" label="OperationalWorkspace">
          <Control xsi:type="Button" id="OpenPaneComposeButton">
            <Label resid="openPaneLabel" />
            <Supertip>
              <Title resid="openPaneTitle" />
              <Description resid="openPaneDesc" />
            </Supertip>
            <Icon>
              <bt:Image size="16" resid="icon16" />
              <bt:Image size="32" resid="icon32" />
              <bt:Image size="80" resid="icon80" />
            </Icon>
            <Action xsi:type="ShowTaskpane">
              <SourceLocation resid="messageComposePaneUrl" />
            </Action>
          </Control>
        </Group>
      </OfficeTab>
    </ExtensionPoint>

    <!-- Add rules for when the add-in is available in the message context -->
    <Permissions>ReadWriteMailbox</Permissions>
    <Rule xsi:type="RuleCollection" Mode="Or">
      <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read" />
      <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit" />
    </Rule>

  </VersionOverrides>

</OfficeApp>
